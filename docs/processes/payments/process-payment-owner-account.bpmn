          <dc:Bounds x="220" y="585" width="60" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_CheckAccounts_di" bpmnElement="Task_CheckAccounts">
        <dc:Bounds x="320" y="520" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_HasBalance_di" bpmnElement="Gateway_HasBalance" isMarkerVisible="true">
        <dc:Bounds x="470" y="535" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="454" y="595" width="82" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_GetDebts_di" bpmnElement="Task_GetDebts">
        <dc:Bounds x="570" y="520" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_HasDebts_di" bpmnElement="Gateway_HasDebts" isMarkerVisible="true">
        <dc:Bounds x="720" y="535" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="711" y="595" width="68" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_PayElectricity_di" bpmnElement="Task_PayElectricity">
        <dc:Bounds x="820" y="520" width="100" height="80" />
