        <dc:Bounds x="820" y="630" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Event_End_Cycle_di" bpmnElement="Event_End_Cycle">
        <dc:Bounds x="722" y="652" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="702" y="695" width="76" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Event_End_NoBalance_di" bpmnElement="Event_End_NoBalance">
        <dc:Bounds x="477" y="462" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="463" y="440" width="64" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Event_End_NoDebts_di" bpmnElement="Event_End_NoDebts">
        <dc:Bounds x="727" y="462" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="717" y="440" width="56" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_S1_di" bpmnElement="Flow_S1">
        <di:waypoint x="268" y="560" />
        <di:waypoint x="320" y="560" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_S2_di" bpmnElement="Flow_S2">
        <di:waypoint x="420" y="560" />
        <di:waypoint x="470" y="560" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_S3_No_di" bpmnElement="Flow_S3_No">
        <di:waypoint x="495" y="535" />
        <di:waypoint x="495" y="498" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="501" y="513" width="19" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_S3_Yes_di" bpmnElement="Flow_S3_Yes">
        <di:waypoint x="520" y="560" />
        <di:waypoint x="570" y="560" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="539" y="542" width="13" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_S4_di" bpmnElement="Flow_S4">
        <di:waypoint x="670" y="560" />
        <di:waypoint x="720" y="560" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_S5_No_di" bpmnElement="Flow_S5_No">
        <di:waypoint x="745" y="535" />
        <di:waypoint x="745" y="498" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="751" y="513" width="19" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_S5_Yes_di" bpmnElement="Flow_S5_Yes">
        <di:waypoint x="770" y="560" />
        <di:waypoint x="820" y="560" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="789" y="542" width="13" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_S6_di" bpmnElement="Flow_S6">
        <di:waypoint x="920" y="560" />
        <di:waypoint x="970" y="560" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_S7_di" bpmnElement="Flow_S7">
        <di:waypoint x="1070" y="560" />
        <di:waypoint x="1120" y="560" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_S8_di" bpmnElement="Flow_S8">
        <di:waypoint x="1170" y="600" />
        <di:waypoint x="1170" y="670" />
        <di:waypoint x="920" y="670" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_S9_di" bpmnElement="Flow_S9">
        <di:waypoint x="820" y="670" />
        <di:waypoint x="758" y="670" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_DepositTrigger_di" bpmnElement="Flow_DepositTrigger">
        <di:waypoint x="820" y="320" />
        <di:waypoint x="820" y="370" />
        <di:waypoint x="250" y="370" />
        <di:waypoint x="250" y="542" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="463" y="336" width="84" height="40" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
