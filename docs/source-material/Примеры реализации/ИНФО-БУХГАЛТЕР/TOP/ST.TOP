//-------------------------------------------------------------------------------------------------------------------------//
ОПЕРАЦИЯ СНТ : Закрытие долгов по взносам <st_closeDebt>
%1="ST_GSK\ST_GSK_SELECT"
   
  Дата задолженности : ~датаДолга

  Улицы    : *~улицы(%1,"STG_ВыборУлиц","пз"):250:50                 *#сбросУл(%1, "STG_КнопкаСбросФильтра"): "X"
  Участки  : *~участки(%1,"STG_ВыборУчастков","пз"):250:50           *#сбросУч(%1, "STG_КнопкаСбросФильтра"): "X"
  Взнос с  : *~взносС("ST_GSK\TOP\ST_GSK_CLOSE_DEBT","STG_ВыбВзносаТОЗакрДолг","пз"):250:50 
  Взнос на : *~взносНа("ST_GSK\TOP\ST_GSK_CLOSE_DEBT","STG_ВыбВзносаТОЗакрДолг","пз"):250:50

  Дата хоз. операции : ~датаОперации
  
ВЫЧИСЛИТЬ
  ИСПОЛЬЗОВАТЬ("ST\ST_CONST")
  ИСПОЛЬЗОВАТЬ("ST_GSK\TOP\ST_GSK_CLOSE_DEBT")
  
  УСТ_АТРИБУТ("&вызовМножВыбораПоОднойЗаписи", "ДА")
  
  профиль = к_СНТПрофДлгЗакрытиеДолгов
  IB_PROF_УстТекЛокПрофиль(профиль)
  STG_ОпределитьБлок
  STG_R_НастройкиСчетов
  STG_R_НастройкиБлока
  STG_ПодготовитьДанныеСтатей
  
  ЕСЛИ услугиКакАналитикаУчастков = "" И автоСписание = "" ТО
    СООБЩЕНИЕ("С текущими настройками счетов закрытие невозможно. Воспользуйтесь конвертацией ПС.")
    СТОП_ВСЕ
  КОНЕЦ_ЕСЛИ
  
  улицы = IB_PROF_СформироватьОтображение(профиль + к_СНТПрофСпрУлиц)
  участки = IB_PROF_СформироватьОтображение(профиль + к_СНТПрофСпрУчастков)
  взносС = IB_PROF_СформироватьОтображение(профиль + ".ВзносС" + к_СНТПрофСпрВзносов)
  взносНа = IB_PROF_СформироватьОтображение(профиль + ".ВзносНа" + к_СНТПрофСпрВзносов)
  
  IB_PROF_СчитатьПрофиль(профиль)
  IB_PROF_ЗаполнитьГрафуД("датаДолга", датаДолга)
  IB_PROF_ЗаполнитьГрафуД("датаОперации", датаОперации)
  
  ЦИКЛ ПОКА(ДА)
    IB_PROF_СчитатьПрофиль(профиль)
    IB_PROF_ДобавитьГрафу2("датаДолга", ТИП_ПЕРЕМ(датаДолга), СТР(датаДолга))
    IB_PROF_ДобавитьГрафу2("датаОперации", ТИП_ПЕРЕМ(датаОперации), СТР(датаОперации))
    IB_PROF_ЗаписатьПрофиль2(профиль)
    
    ЦИКЛ ПОКА(ДА)
      ВВЕСТИ
      
      ЕСЛИ взносС = "" ИЛИ взносНа = "" ТО
        СООБЩЕНИЕ("Необходимо выбрать оба взноса.")
      ИНАЧЕ
        СТОП  
      КОНЕЦ_ЕСЛИ
    КОНЕЦ_ЦИКЛА
    //
    путьПрофиляСпрУлиц = ""
    путьПрофиляСпрУчастков = ""
  
    колУлиц = 0
    ЕСЛИ улицы <> "" ТО
      ЕСЛИ IB_PROF_ФайлПрофиляМножВыб(профиль + к_СНТПрофСпрУлиц, путьПрофиляСпрУлиц) ТО
        колУлиц = IB_DBF_ВсегоЗап(путьПрофиляСпрУлиц)
      КОНЕЦ_ЕСЛИ
    КОНЕЦ_ЕСЛИ
    
    колУчастков = 0
    ЕСЛИ участки <> "" ТО
      ЕСЛИ IB_PROF_ФайлПрофиляМножВыб(профиль + к_СНТПрофСпрУчастков, путьПрофиляСпрУчастков) ТО
        колУчастков = IB_DBF_ВсегоЗап(путьПрофиляСпрУчастков)
      КОНЕЦ_ЕСЛИ
    КОНЕЦ_ЕСЛИ
    //
    ЕСЛИ колУлиц > 0 ИЛИ колУчастков > 0 ТО
      шаблоны!г_сервИнд = ""
      СОЗДАТЬ(сп, ТИП_СПИСОК)
      сп.ДОБАВИТЬ("SELECT DISTINCT " +
                  ?(услугиКакАналитикаУчастков <> "", 
                    ?(колУлиц > 0, "CODS", "") + 
                    ?(колУлиц > 0 И колУчастков > 0, ",", "") + 
                    ?(колУчастков > 0, "N_AREA", ""), 
                    "N_AREA") + 
                   " FROM")
      сп.ДОБАВИТЬ("'" + ф_СпрУчастковГаражей + "'")
      //
      ЕСЛИ колУлиц > 0 ТО
        сп.ДОБАВИТЬ("WHERE CODS IN (")
        сп.STG_ARH_СчитатьАрхив(к_АрхивСпрУлиц, путьПрофиляСпрУлиц)
        сп.ДОБАВИТЬ(")")
      КОНЕЦ_ЕСЛИ
      //
      ЕСЛИ колУчастков > 0 ТО
        word = ?(сп.ВСЕГО > 2, "AND", "WHERE")
        сп.ДОБАВИТЬ(word + " ID_AREA IN (")
        сп.STG_ARH_СчитатьАрхив(к_АрхивСпрУчастков, путьПрофиляСпрУчастков)
        сп.ДОБАВИТЬ(")")
      КОНЕЦ_ЕСЛИ
      
      sql = SQL_ЗАПРОС(сп)
      ЦИКЛ ДЛЯ(и = 1, sql.ВСЕГО)
        sql.ПЕРЕЙТИ(и)
        улица = "*"
        участок = "*"
        ЕСЛИ колУлиц > 0 ТО
          улица = sql.ПОЛЕ("CODS")
        КОНЕЦ_ЕСЛИ
        ЕСЛИ колУчастков > 0 ИЛИ услугиКакАналитикаУчастков = "" ТО
          участок = IB_STR_СтрСимвСлева(sql.ПОЛЕ("N_AREA"), "0", г_длинаКодаУчасткаПС)
        КОНЕЦ_ЕСЛИ
        ЕСЛИ услугиКакАналитикаУчастков <> "" ТО
          шаблоны!и = дебСчет + "/Участки/" + улица + "/" + участок + "/" + г_кодСтатьиПоНаим!взносС
        ИНАЧЕ
          шаблоны!и = кредСчет + "/" + г_кодСтатьиПоНаим!взносС + "/" + участок
        КОНЕЦ_ЕСЛИ
      КОНЕЦ_ЦИКЛА
      sql.ЗАКРЫТЬ
    ИНАЧЕ
      ЕСЛИ услугиКакАналитикаУчастков <> "" ТО
        шаблоны!1 = дебСчет + "/Участки/*/" + г_кодСтатьиПоНаим!взносС
      ИНАЧЕ
        шаблоны!1 = кредСчет + "/" + г_кодСтатьиПоНаим!взносС + "/*"
      КОНЕЦ_ЕСЛИ
    КОНЕЦ_ЕСЛИ
    
    ЕСЛИ услугиКакАналитикаУчастков = "" ТО
      ЕСЛИ НЕ СЧЕТ_СУЩ(кредСчет + "/" + г_кодСтатьиПоНаим!взносНа) ТО
        STG_СоздатьСчет(кредСчет + "/" + г_кодСтатьиПоНаим!взносНа, взносНа)
      КОНЕЦ_ЕСЛИ
    КОНЕЦ_ЕСЛИ
    //
    СОЗДАТЬ(оп, ТИП_ОПЕРАЦИЯ)
    СОЗДАТЬ(пров, ТИП_ПРОВОДКА)
    
    оп.название = "Перенос задолженности на " + СТР(датаДолга) + СИМВ(13) + "с "  + взносС + СИМВ(13) + "на " + взносНа
    оп.документ = "бух. справка"
    ЦИКЛ ИНДЕКС(шаблон = шаблоны!индШабл)
      ЕСЛИ индШабл = г_сервИнд ТО
        ПРОДОЛЖИТЬ
      КОНЕЦ_ЕСЛИ
      ЦИКЛ СЧЕТА(счет = шаблон)
        ЕСЛИ услугиКакАналитикаУчастков <> "" ИЛИ 
             (автоСписание <> "" И СЧЕТ_АКТ(счет)) ТО
          долг = ОСД(счет, датаДолга)
        ИНАЧЕ
          долг = ОСК(счет, датаДолга)
        КОНЕЦ_ЕСЛИ
        ЕСЛИ долг > 0 ТО
          ЕСЛИ услугиКакАналитикаУчастков <> "" ТО
            счетДеб = IB_SHP_ЗаменитьКодУровня(УРОВЕНЬ(счет), счет, г_кодСтатьиПоНаим!взносНа) 
          ИНАЧЕ
            счетДеб = IB_SHP_ЗаменитьКодУровня(УРОВЕНЬ(счет) - 1, счет, г_кодСтатьиПоНаим!взносНа) 
          КОНЕЦ_ЕСЛИ
          STG_СоздатьСчет(счетДеб, ?(услугиКакАналитикаУчастков <> "", взносНа, НАЗВ(счет)))
          пров.дебет = счетДеб
          пров.кредит = счет
          пров.сумма = долг
          оп.ЗАП_ПРОВ(пров)
          
          /*пров.дебет = кредАккСчет + "/" + г_кодСтатьиПоНаим!взносНа
          STG_СоздатьСчет(пров.дебет, взносНа)
          пров.кредит = кредАккСчет + "/" + г_кодСтатьиПоНаим!взносС
          STG_СоздатьСчет(пров.кредит, взносС)
          пров.сумма = долг
          оп.ЗАП_ПРОВ(пров)*/
        КОНЕЦ_ЕСЛИ
      КОНЕЦ_ЦИКЛА
    КОНЕЦ_ЦИКЛА
    
    ЕСЛИ оп.КОЛ_ПРОВ > 0 ТО
      оп.STG_РедактИЗаписатьОп
    ИНАЧЕ
      СООБЩЕНИЕ("Задолженности на указанную дату не обнаружены.")
    КОНЕЦ_ЕСЛИ
  КОНЕЦ_ЦИКЛА
  
  УСТ_АТРИБУТ("&вызовМножВыбораПоОднойЗаписи", "")
  УСТ_АТРИБУТ("&помнитьПредВыб", "")
КОНЕЦ