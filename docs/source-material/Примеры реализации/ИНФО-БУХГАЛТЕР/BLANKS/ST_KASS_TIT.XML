  <formulae>
    <line>ПерСтр=""</line>
    <line>Ош="Неверно задан период"</line>
    <line></line>
    <line>Предприят1 = ["IB_STR.ibl"].IB_STR_ЦЕНТРИРОВАТЬ(Предприят,65)</line>
    <line>ЕСЛИ Период="" ТО</line>
    <line>    СООБЩЕНИЕ(Ош); СТОП_ВСЕ</line>
    <line>КОНЕЦ_ЕСЛИ</line>
    <line>ЕСЛИ Период="год" ТО</line>
    <line>  ПерСтр="на "+СТР(год)+" год"</line>
    <line>КОНЕЦ_ЕСЛИ</line>
    <line>ЕСЛИ Период="месяц" ТО</line>
    <line>  ЕСЛИ (Номер&lt;1) ИЛИ (Номер&gt;12) ТО</line>
    <line>    СООБЩЕНИЕ(Ош); СТОП_ВСЕ</line>
    <line>  КОНЕЦ_ЕСЛИ</line>
    <line>  ПерСтр="на "+МЕСП(Номер)+" "+СТР(год)+" г."</line>
    <line>КОНЕЦ_ЕСЛИ</line>
    <line>ЕСЛИ Период="квартал" ТО</line>
    <line>  ЕСЛИ (Номер&lt;1) ИЛИ (Номер&gt;4) ТО</line>
    <line>    СООБЩЕНИЕ(Ош); СТОП_ВСЕ</line>
    <line>  КОНЕЦ_ЕСЛИ</line>
    <line>  ПерСтр="на "+СТР(Номер)+" квартал "+СТР(год)+" г."</line>
    <line>КОНЕЦ_ЕСЛИ</line>
    <line>ЕСЛИ Период="полугодие" ТО</line>
    <line>  ЕСЛИ (Номер&lt;1) ИЛИ (Номер&gt;2) ТО</line>
    <line>    СООБЩЕНИЕ(Ош); СТОП_ВСЕ</line>
    <line>  КОНЕЦ_ЕСЛИ</line>
    <line>  ПерСтр="на "+СТР(Номер)+" полугодие "+СТР(год)+" г."</line>
    <line>КОНЕЦ_ЕСЛИ</line>
    <line></line>
    <line>ВЫВЕСТИ(36, 18, ПерСтр, ДА)</line>
