  <formulae>
    <line>ИСПОЛЬЗОВАТЬ("ST\ST_CONST")</line>
    <line>ИСПОЛЬЗОВАТЬ("ST_GSK\BLW\ST_GSK_BLW")</line>
    <line></line>
    <line>  ЕСЛИ гр_Год &lt; 1980 ИЛИ гр_Год &gt; 2077 ТО</line>
    <line>    СООБЩЕНИЕ("Неверно указан год")</line>
    <line>    СТОП_ВСЕ</line>
    <line>  КОНЕЦ_ЕСЛИ</line>
    <line></line>
    <line>  STG_УстТекстБлока</line>
    <line>  STG_R_НастройкиСчетов</line>
    <line>  ТипСч = "ЗН"</line>
    <line>  г_КодСтатьиНачисления = ТипСч</line>
    <line>//</line>
    <line>  коэффПериода = ?(гр_КолМес = 0, 1, гр_КолМес/12)</line>
    <line></line>
    <line>  СОЗДАТЬ(СП,ТИП_СПИСОК)</line>
    <line>  ЕСЛИ гр_Детализация = "По улице" ТО</line>
    <line>    ЕСЛИ цл_КодУл = "" ТО</line>
    <line>      ЕСЛИ STG_ВыборУлицы(участок) ТО</line>
    <line>        sql_Где = "WHERE CODS='" + цл_КодУл + "' AND PRIV = FALSE"</line>
    <line>      ИНАЧЕ</line>
    <line>        СТОП_ВСЕ</line>
    <line>      КОНЕЦ_ЕСЛИ</line>
    <line>    ИНАЧЕ</line>
    <line>      sql_Где = "WHERE CODS='" + цл_КодУл + "' AND PRIV = FALSE"</line>
    <line>    КОНЕЦ_ЕСЛИ</line>
    <line>  ИНАЧЕ</line>
    <line>    ЕСЛИ гр_Детализация = "По " + текстЗагДП ТО</line>
    <line>      ЕСЛИ Id_Area = 0 ТО</line>
    <line>        ЕСЛИ STG_ВыборУлицы(г) ТО</line>
    <line>          ЕСЛИ STG_ВызовВыбУчГар(участок) ТО</line>
    <line>         sql_Где = "WHERE ID_AREA=" + СТР(Id_Area) + " AND CODS='" + цл_КодУл + "' AND PRIV = FALSE"</line>
    <line>          ИНАЧЕ</line>
    <line>            СТОП_ВСЕ</line>
    <line>          КОНЕЦ_ЕСЛИ</line>
    <line>        ИНАЧЕ</line>
    <line>          СТОП_ВСЕ</line>
    <line>        КОНЕЦ_ЕСЛИ</line>
    <line>      ИНАЧЕ</line>
    <line>        sql_Где = "WHERE ID_AREA=" + СТР(Id_Area) + " AND CODS='" + цл_КодУл + "' AND PRIV = FALSE"</line>
    <line>      КОНЕЦ_ЕСЛИ</line>
    <line>    ИНАЧЕ //по всем</line>
    <line>      sql_Где = "WHERE PRIV = FALSE"</line>
    <line>    КОНЕЦ_ЕСЛИ</line>
    <line>  КОНЕЦ_ЕСЛИ</line>
    <line></line>
    <line>  СП.ДОБАВИТЬ("SELECT * FROM")</line>
    <line>  СП.ДОБАВИТЬ("'" + ф_СпрУчастковГаражей + "'")</line>
    <line>  СП.ДОБАВИТЬ(sql_Где)</line>
    <line>  sql = SQL_ЗАПРОС(СП)</line>
    <line>  ЕСЛИ sql.ВСЕГО &gt; 0 ТО</line>
    <line>    STG_ПарамВыводаТаблиц</line>
    <line>    ЦИКЛ ДЛЯ(и = 1, sql.ВСЕГО)</line>
    <line>      sql.ПЕРЕЙТИ(и)</line>
    <line>      СуммаНалога = (гр_УдПокСт * sql.ПОЛЕ("SQUARE") - гр_ВычетЗН) * (гр_СтавкаЗН/100) * ?(гр_ПлВСотках, 100, 1)</line>
    <line>      ЕСЛИ  СуммаНалога&gt;0 ТО</line>
    <line>        ВсегоСтр++</line>
    <line>        Данные!ВсегоСтр!"A" = и</line>
    <line>        Данные!ВсегоСтр!"B" = sql.ПОЛЕ("N_AREA") + " / " + sql.ПОЛЕ("FIO")</line>
    <line>        Данные!ВсегоСтр!"C" = sql.ПОЛЕ("SQUARE")</line>
    <line>        Данные!ВсегоСтр!"D" = гр_УдПокСт * sql.ПОЛЕ("SQUARE") * ?(гр_ПлВСотках,100,1)</line>
    <line>        Данные!ВсегоСтр!"E" = гр_ВычетЗН</line>
    <line>        Данные!ВсегоСтр!"F" = гр_СтавкаЗН</line>
    <line>        Данные!ВсегоСтр!"G" = СуммаНалога * коэффПериода</line>
    <line>        цл_КодУл = sql.ПОЛЕ("CODS")</line>
    <line>        цл_КодУчГарПольз = sql.ПОЛЕ("N_AREA")</line>
    <line>        STG_ФПРОВ(Данные!ВсегоСтр!"G", СТР(гр_Год), sql.ПОЛЕ("FIO"))</line>
    <line>      КОНЕЦ_ЕСЛИ</line>
    <line>    КОНЕЦ_ЦИКЛА</line>
    <line>    ШирЯч!1=5;     ПредЯч!1=0;     НаимЯч!1="№"</line>
    <line>    ШирЯч!2=55;    ПредЯч!2=0;     НаимЯч!2=текстЗагИПЗагл + " / Ф.И.О."</line>
    <line>    ШирЯч!3=10;    ПредЯч!3=0;     НаимЯч!3="Площадь участка"</line>
    <line>    ШирЯч!4=16;    ПредЯч!4=0;     НаимЯч!4="Кадастровая стоимость, руб."</line>
    <line>    ШирЯч!5=15;    ПредЯч!5=0;     НаимЯч!5="Налоговый вычет, руб."</line>
    <line>    ШирЯч!6=10;    ПредЯч!6=0;     НаимЯч!6="Налоговая ставка, %"</line>
    <line>    ШирЯч!7=16;    ПредЯч!7=0;     НаимЯч!7="Сумма налога, руб."</line>
    <line>    КолЯч = 7</line>
    <line>    НачСтр = 10</line>
    <line>    Итоги!"G" = ДА</line>
    <line>    ЦИКЛ ДЛЯ(и=3,7)</line>
    <line>      Дроб!ЛИТЕР(и) = 2</line>
    <line>    КОНЕЦ_ЦИКЛА</line>
    <line>    ЕСЛИ ВсегоСтр &gt; 0 ТО</line>
    <line>      ПЕЧАТЬ_ШАПКИ</line>
    <line>      ПЕЧАТЬ_ТАБЛИЦЫ</line>
    <line>    КОНЕЦ_ЕСЛИ</line>
    <line>    СБРОС_ТАБЛИЦ(ДА)</line>
    <line>  КОНЕЦ_ЕСЛИ</line>
    <line></line>
  </formulae>
