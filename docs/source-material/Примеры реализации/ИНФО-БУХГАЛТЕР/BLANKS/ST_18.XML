  <formulae>
    <line>//Бланк импорта данных платежного поручения в формате клиент-банк/реестра платежей</line>
    <line></line>
    <line>  ИСПОЛЬЗОВАТЬ("IB_STR")</line>
    <line>  ИСПОЛЬЗОВАТЬ("IB_FILE")</line>
    <line>  ИСПОЛЬЗОВАТЬ("ORGANIZ")</line>
    <line>  ИСПОЛЬЗОВАТЬ("PL\PL_IMP")</line>
    <line></line>
    <line>  ИСПОЛЬЗОВАТЬ("ST\ST_CONST")</line>
    <line>  ИСПОЛЬЗОВАТЬ("ST_GSK\ST_GSK_PL_IMP")</line>
    <line></line>
    <line>  PL_IMP_ОпредПути</line>
    <line>  ЕСЛИ НЕ PL_IMP_БылПересчетБланка ТО</line>
    <line>   PL_IMP_СчитДанныеОрг</line>
    <line>   PL_IMP_ИнитДанные</line>
    <line>   ЕСЛИ НЕ IB_FILE_ЕстьНастр("Количество видов платежей") ТО</line>
    <line>    PL_IMP_ИнитНастрВидПлатПоУмолч</line>
    <line>    PL_IMP_ЗаписатьНастрВидПлат</line>
    <line>   КОНЕЦ_ЕСЛИ</line>
    <line>   PL_IMP_БылПересчетБланка = ДА</line>
    <line>   //СТОП_ВСЕ</line>
    <line>  КОНЕЦ_ЕСЛИ</line>
    <line>  STG_ИниИмпортКБ</line>
    <line></line>
    <line>  PL_IMP_ИнитДанные</line>
    <line>  КОМАНДА_БЛАНКА("REFRESH")</line>
    <line></line>
    <line>  PL_IMP_СчитатьНастрВидПлат</line>
    <line>  PL_IMP_СчитатьНастрСчетов</line>
    <line>  PL_IMP_СчитатьНастрРеквДатаХО</line>
    <line></line>
    <line>//Создаем временную таблицу для импорта платежных поручений</line>
    <line>  СОЗДАТЬ_ДИР(PL_IMP_Папка)</line>
    <line>  СОЗДАТЬ(СП,ТИП_СПИСОК)</line>
    <line>  НовыйИмпорт = ДА</line>
    <line>  ЕСЛИ СУЩ_ФАЙЛ(PL_IMP_ТабИмпорта) И PL_IMP_ПровСтруктТабИмп ТО</line>
    <line>   СП.ДОБАВИТЬ("SELECT S FROM")</line>
    <line>   СП.ДОБАВИТЬ("'"+PL_IMP_ТабИмпорта+"'")</line>
    <line>   СП.ДОБАВИТЬ("WHERE S = 'F'")</line>
    <line>   т = SQL_ЗАПРОС(СП)</line>
    <line>   ЕСЛИ т.ВСЕГО &gt; 0  ТО</line>
    <line>    НовыйИмпорт = ВОПРОС("Не все платежи предыдущего импорта данных были обработаны.Вы уверены,что хотите произвести новый импорт данных?")</line>
    <line>   КОНЕЦ_ЕСЛИ</line>
    <line>   т.ЗАКРЫТЬ</line>
    <line>  КОНЕЦ_ЕСЛИ</line>
    <line>  //ОТЛАДКА(НовыйИмпорт)</line>
    <line>  ЕСЛИ НовыйИмпорт ТО</line>
    <line>   IB_FILE_ФайлУдалить(PL_IMP_ТабИмпорта)</line>
    <line>   PL_IMP_СоздТабИмпПлат</line>
    <line>   ЦИКЛ ПОКА(ДА)</line>
    <line>    ИдФормат = PL_IMP_ИдентФормат(Графа0)</line>
    <line>    ЕСЛИ ИдФормат = 0 ТО</line>
    <line>     СообВопр = ?(Графа0 = "","Файл импорта не выбран.Выбрать файл?","Файл импорта " + Графа0 + " не существует.Выбрать другой файл?")</line>
    <line>     ЕСЛИ НЕ ВОПРОС(СообВопр) ТО</line>
    <line>      СТОП_ВСЕ</line>
    <line>     КОНЕЦ_ЕСЛИ</line>
    <line>     PL_IMP_ОбрВыбФайла(Графа0)</line>
    <line>    ИНАЧЕ</line>
    <line>     СТОП</line>
    <line>    КОНЕЦ_ЕСЛИ</line>
    <line>   КОНЕЦ_ЦИКЛА</line>
    <line>   ЕСЛИ ТипИмпорта = "Файл Клиент-Банка"  ТО</line>
    <line>    ЕСЛИ ИдФормат = 1 ТО //формат обмена Клиент-банка</line>
    <line>     PL_IMP_СчитатьДанныеИмпКБ(Графа0)</line>
    <line>    ИНАЧЕ</line>
    <line>     ЕСЛИ ВОПРОС("Файл не соответствует формату обмена системы Клиент-банка.Продолжить обработку файла?") ТО</line>
    <line>      PL_IMP_СчитатьДанныеИмпКБ(Графа0)</line>
    <line>     КОНЕЦ_ЕСЛИ</line>
    <line>    КОНЕЦ_ЕСЛИ</line>
    <line>    ЕСЛИ банкинн = "" ТО</line>
    <line>     ЕСЛИ PL_IMP_ИдОрг &gt; 0 И PL_IMP_ИдБнк &gt; 0 ТО</line>
    <line>      ЕСЛИ ВОПРОС("Графы ИНН и КПП банка не заполнены в справочнике банков. Внутренние платежи с банком могут быть не идентифицированы при импорте.Заполнить?") ТО</line>
    <line>       парамстр = ""</line>
    <line>       PL_IMP_ОбрВыбБнкОрг(парамстр)</line>
    <line>       КОМАНДА_БЛАНКА("REFRESH")</line>
    <line>      КОНЕЦ_ЕСЛИ</line>
    <line>     ИНАЧЕ</line>
    <line>      ЕСЛИ ВОПРОС("Графы ИНН и КПП банка не заполнены. Внутренние платежи с банком могут быть не идентифицированы при импорте.Заполнить?") ТО</line>
    <line>       ФОКУС("банкинн")</line>
    <line>       СТОП_ВСЕ</line>
    <line>      КОНЕЦ_ЕСЛИ</line>
    <line>     КОНЕЦ_ЕСЛИ</line>
    <line>    КОНЕЦ_ЕСЛИ</line>
    <line></line>
    <line>    ЕСЛИ налогинн = ""  ТО</line>
    <line>     ЕСЛИ ВОПРОС("Графа ИНН налоговой не заполнена. Платежи по страховым взносам или уплате налогов могут быть не идентфицированы при импорте.Заполнить?") ТО</line>
    <line>      ФОКУС("налогинн")</line>
    <line>      СТОП_ВСЕ</line>
    <line>     КОНЕЦ_ЕСЛИ</line>
    <line>    КОНЕЦ_ЕСЛИ</line>
    <line>   ИНАЧЕ</line>
    <line>    ЕСЛИ ИдФормат &lt;&gt; 1 ТО</line>
    <line>     PL_IMP_СчитатьДанныеИмпРП(Графа0)</line>
    <line>    ИНАЧЕ</line>
    <line>     ЕСЛИ ВОПРОС("Файл соответствует формату обмена системы Клиент-банка. Продолжить обработку файла в формате Клиент-Банка?") ТО</line>
    <line>      ТипИмпорта = "Файл Клиент-Банка"</line>
    <line>      КОМАНДА_БЛАНКА("REFRESH")</line>
    <line>      PL_IMP_СчитатьДанныеИмпКБ(Графа0)</line>
    <line>     КОНЕЦ_ЕСЛИ</line>
    <line>    КОНЕЦ_ЕСЛИ</line>
    <line>   КОНЕЦ_ЕСЛИ</line>
    <line>  КОНЕЦ_ЕСЛИ</line>
    <line>  ЕСЛИ ПровПлателПо = "" ТО</line>
    <line>   ПровПлателПо="ИНН и КПП"</line>
    <line>  КОНЕЦ_ЕСЛИ</line>
    <line>  //ОТЛАДКА(Графа0)</line>
    <line>  //ОТЛАДКА(СУЩ_ФАЙЛ(Графа0))</line>
    <line>  //СТОП_ВСЕ</line>
    <line>//---------------------------------------------------------------------------------------//</line>
    <line></line>
    <line>  PL_IMP_ОбработатьПлатежи</line>
    <line></line>
    <line>  PL_IMP_ПодготДанныеКонтраг</line>
    <line>  ЕСЛИ ОпцДобНовОрг ТО</line>
    <line>   PL_IMP_РедНовыхКонтраг</line>
    <line>   PL_IMP_ДобНовыхКонтрагВСпр</line>
    <line>  КОНЕЦ_ЕСЛИ</line>
    <line>  PL_IMP_ОбновДанныеКонтрТабИмп</line>
    <line></line>
    <line>  PL_IMP_ОпредСчетаКонтраг</line>
    <line>  ЕСЛИ АвтоСоздСчНовОрг ТО</line>
    <line>   PL_IMP_ПодгСписокНовыхСчКонтр</line>
    <line>   PL_IMP_РедНовСчетовКонтр</line>
    <line>   //СТОП_ВСЕ</line>
    <line>   PL_IMP_СоздатьНовСчетаКонтр</line>
    <line>   PL_IMP_ОбновСчКонтрТабИмпПлат</line>
    <line>  КОНЕЦ_ЕСЛИ</line>
    <line></line>
    <line>//---------------------------------------------------------------------------------------//</line>
    <line></line>
    <line> IB_FILE_ИнитФайлНастр(PL_IMP_ТабНастр)</line>
    <line> ПоляСорт = IB_FILE_СчитатьНастр("Поля сортировки")</line>
    <line></line>
    <line> ЕСЛИ оп_обработкаПлатежейЮрЛица ТО</line>
    <line>   PL_IMP_РедИмпПлат(ПоляСорт)</line>
    <line> ИНАЧЕ</line>
    <line>   STG_PL_IMP_РедИмпПлат(ПоляСорт, НовыйИмпорт)</line>
    <line> КОНЕЦ_ЕСЛИ</line>
    <line></line>
    <line> IB_FILE_ОбновитьНастр("Поля сортировки", АТРИБУТ("$PL_IMP_РедИмпПлат_ПоляСорт"))</line>
    <line></line>
    <line>//  //Редактор входящих платежей</line>
    <line>//  PL_IMP_РедВхПлат</line>
    <line>//</line>
    <line>//  //Редактор исходящих платежей</line>
    <line>//  PL_IMP_РедИсхПлат</line>
    <line>//</line>
    <line>//  //Редактор внутренних платежей с банком</line>
    <line>//  PL_IMP_РедВнутрПлатБнк</line>
    <line></line>
    <line>  //записываем данные по организации в таблицу настроек</line>
    <line>  PL_IMP_ЗапДанныеОрг</line>
  </formulae>
</blank>
