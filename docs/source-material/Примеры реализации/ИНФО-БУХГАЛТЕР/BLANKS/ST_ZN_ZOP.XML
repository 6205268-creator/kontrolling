  <events/>
  <formulae>
    <line>ИСПОЛЬЗОВАТЬ("ST\ST_CONST")</line>
    <line>ИСПОЛЬЗОВАТЬ("ST_GSK\BLW\ST_GSK_BLW")</line>
    <line></line>
    <line>  ЕСЛИ гр_Год &lt; 1980 ИЛИ гр_Год &gt; 2077 ТО</line>
    <line>    СООБЩЕНИЕ("Неверно указан год")</line>
    <line>    СТОП_ВСЕ</line>
    <line>  КОНЕЦ_ЕСЛИ</line>
    <line></line>
    <line>  STG_УстТекстБлока</line>
    <line>  STG_R_НастройкиСчетов</line>
    <line>  ТипСч = "ЗН"</line>
    <line>  г_КодСтатьиНачисления = ТипСч</line>
    <line>  ЕСЛИ гр_Метод = "" ТО</line>
    <line>    гр_Метод = "Равными долями между всеми участками"</line>
    <line>  КОНЕЦ_ЕСЛИ</line>
    <line></line>
    <line>  СОЗДАТЬ(СП,ТИП_СПИСОК)</line>
    <line>  СП.ДОБАВИТЬ("SELECT DISTINCT * FROM")</line>
    <line>  СП.ДОБАВИТЬ("'"+ф_СпрУчастковГаражей+"' ")</line>
    <line>  sql = SQL_ЗАПРОС(СП)</line>
    <line>  ЕСЛИ sql.ВСЕГО &gt; 0 ТО</line>
    <line>    ЕСЛИ гр_Метод = "Долями, пропорциональными площадям участков" ТО</line>
    <line>      Доля = гр_ПлощЗОП/гр_ПлощУч</line>
    <line>    ИНАЧЕ</line>
    <line>      Доля = гр_ПлощЗОП/sql.ВСЕГО</line>
    <line>    КОНЕЦ_ЕСЛИ</line>
    <line>    Ставка = гр_СтавкаЗН/100</line>
    <line>    КадСтЗОП = (гр_УдПокСт * гр_ПлощЗОП - гр_ВычетЗН) * ?(гр_ПлВСотках,100,1)</line>
    <line>    STG_ПарамВыводаТаблиц</line>
    <line>    ЦИКЛ ДЛЯ (и=1,sql.ВСЕГО)</line>
    <line>      sql.ПЕРЕЙТИ(и)</line>
    <line>      ЕСЛИ гр_Метод = "Долями, пропорциональными площадям участков" ТО</line>
    <line>        ПлощДляУч = Доля*sql.ПОЛЕ("SQUARE")</line>
    <line>      ИНАЧЕ</line>
    <line>        ПлощДляУч = Доля</line>
    <line>      КОНЕЦ_ЕСЛИ</line>
    <line>      ВсегоСтр++</line>
    <line>      Данные!ВсегоСтр!"A" = и</line>
    <line>      Данные!ВсегоСтр!"B" = sql.ПОЛЕ("N_AREA") + " / " + sql.ПОЛЕ("FIO")</line>
    <line>      Данные!ВсегоСтр!"C" = sql.ПОЛЕ("SQUARE")</line>
    <line>      Данные!ВсегоСтр!"D" = ПлощДляУч</line>
    <line>      Данные!ВсегоСтр!"E" = КадСтЗОП * ПлощДляУч * Ставка/гр_ПлощЗОП //?(гр_Метод = "Долями, пропорциональными площадям участков", гр_ПлощЗОП, 1)</line>
    <line>      цл_КодУл = sql.ПОЛЕ("CODS")</line>
    <line>      цл_КодУчГарПольз = sql.ПОЛЕ("N_AREA")</line>
    <line>      STG_ФПРОВ(Данные!ВсегоСтр!"E", СТР(гр_Год), sql.ПОЛЕ("FIO"))</line>
    <line>    КОНЕЦ_ЦИКЛА</line>
    <line>    ЗАП_ОПЕР</line>
    <line>    ШирЯч!1=5;     ПредЯч!1=0;     НаимЯч!1="№"</line>
    <line>    ШирЯч!2=55;    ПредЯч!2=0;     НаимЯч!2="Участок / Ф.И.О."</line>
    <line>    ШирЯч!3=10;    ПредЯч!3=0;     НаимЯч!3="Площадь участка"</line>
    <line>    ШирЯч!4=16;    ПредЯч!4=0;     НаимЯч!4="Площадь ЗОП для участка"</line>
    <line>    ШирЯч!5=16;    ПредЯч!5=0;     НаимЯч!5="Сумма налога, руб."</line>
    <line>    КолЯч = 5</line>
    <line>    НачСтр = 12</line>
    <line>    Итоги!"E" = ДА</line>
    <line>    ЦИКЛ ДЛЯ(и=3,5)</line>
    <line>      Дроб!ЛИТЕР(и) = 2</line>
    <line>    КОНЕЦ_ЦИКЛА</line>
    <line>    СтрЛист = 65</line>
    <line>    ЕСЛИ ВсегоСтр &gt; 0 ТО</line>
    <line>      ПЕЧАТЬ_ШАПКИ</line>
    <line>      ПЕЧАТЬ_ТАБЛИЦЫ</line>
    <line>    КОНЕЦ_ЕСЛИ</line>
    <line>    СБРОС_ТАБЛИЦ(ДА)</line>
    <line>  КОНЕЦ_ЕСЛИ</line>
    <line></line>
    <line>  КОНЕЦ_СТРАНИЦЫ(11)</line>
    <line></line>
  </formulae>
