ИСПОЛЬЗОВАТЬ_БИБЛ("ST_GSK\BLW\ST_GSK_BLW")
ИСПОЛЬЗОВАТЬ_БИБЛ("ST_GSK\BLW\ST_GSK_IMPORT_READINGS")

//-------------------------------------------------------------------------------------------------------------------------//
ПЕРЕМ stg_списокОпераций!
ПЕРЕМ ТИП_ЛОГИКА: гр_ОтдХОНаПотери

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ STG_ИниБланк02SPIS
  ЕСЛИ НЕ IB_ATR_СущАтрибут(к_атрибутБылаИни) ТО
    УСТ_АТРИБУТ(к_атрибутБылаИни, "ДА")
    IB_CONTEXT_УстановитьЛок("бланкДляАрхиваПД", "3.01")
    IB_CONTEXT_УстановитьЛок("бланкДляАрхиваРасч", "3.01")
    IB_CONTEXT_УстановитьЛок("неСбрасыватьИтоги", "ДА")
    
    STG_ОпределитьБлок
    STG_УстТекстБлока
    STG_R_НастройкиБлока
    STG_УстПрофилиМножВыбора
    STG_УстОтобрГрафМножВыбБланк
    
    гр_парамВывРеестраПД = ?(гр_парамВывРеестраПД = "", к_ВыводРеестраПДДоПД, гр_парамВывРеестраПД)
    гр_выводПД = ?(гр_выводПД = "", к_ВыгрузкаПДНаЭкран, гр_выводПД)
    гр_форматПД = ?(гр_выводПД = к_ВыгрузкаПДНаЭкран, "", ?(гр_форматПД = "", к_ФорматDOC, гр_форматПД))
    гр_выводРеестра = ?(гр_выводРеестра = "", к_ВыгрузкаПДВПрилУмолч, гр_выводРеестра)
    гр_форматРеестраПД = ?(гр_форматРеестраПД = "", к_ФорматXLS, гр_форматРеестраПД)
    гр_выводПДПочта = ?(гр_выводПДПочта = "", к_ВыгрузкаПДВПрилУмолч, гр_выводПДПочта)
    гр_форматПДПочта = ?(гр_форматПДПочта = "", к_ФорматDOC, гр_форматПДПочта)
    гр_ТипСч = ?(гр_ТипСч = "", к_СтатьиЭЭ, гр_ТипСч)
    ЕСЛИ НЕ СУЩ_ПЕРЕМ(гр_сортироватьПо) ТО
      гр_сортироватьПо = ""
    КОНЕЦ_ЕСЛИ
    гр_сортироватьПо = ?(гр_сортироватьПо = "", к_сортироватьПоФайлу, гр_сортироватьПо)
    
    ЕСЛИ гр_Месяц = "" ИЛИ гр_Год = "" ТО
      ЕСЛИ гр_Месяц = "" ТО
        гр_Месяц = ПРОП(МЕСП(МЕС(ДАТА_ТЕК)))
      КОНЕЦ_ЕСЛИ
      
      ЕСЛИ НЕ ЗНАЧ_ТЕСТ(гр_Год) ТО
        гр_Год = СТР_ЗНАЧ((ГОД(ДАТА_ТЕК)))
      КОНЕЦ_ЕСЛИ
      
      гр_ДатаС = ДАТА(1, IB_STR_МЕСЯЦ_В_ЧИСЛО(гр_Месяц), ЗНАЧ(гр_Год))
      гр_ДатаПо = ДАТА(1, IB_STR_МЕСЯЦ_В_ЧИСЛО(гр_Месяц) + 1, ЗНАЧ(гр_Год)) - 1
    КОНЕЦ_ЕСЛИ
    
    получениеПокССайта = IB_CONTEXT_Извлечь("получениеПокССайта")
    ЕСЛИ получениеПокССайта = "ДА" ТО
      IB_CONTEXT_УстановитьЛок("получениеПокССайта", "ДА")
    ИНАЧЕ
      СТОП_ВСЕ
    КОНЕЦ_ЕСЛИ
  КОНЕЦ_ЕСЛИ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ STG_РасчетНачисленийИПУ
  ИСПОЛЬЗОВАТЬ("ST_GSK\SPR\ST_GSK_VOLUME_RANGE.IBL")
  
  STG_ИниБланк02SPIS
  
  ЕСЛИ НЕ СУЩ_ПЕРЕМ(оп_импортИзФайла) ТО
    оп_импортИзФайла = НЕТ
  КОНЕЦ_ЕСЛИ
  
  ЕСЛИ оп_импортИзФайла ТО
    STG_ИмпортПоказанийИПУ
  КОНЕЦ_ЕСЛИ

  htmlTemplate.ОЧИСТИТЬ //сброс шаблона ПД для выгрузки в html

  УСТ_АТРИБУТ("$отправлятьНаПочту", "")
  г_датаВыгрузкиПД = ДАТА_ТЕК
  г_времяВыгрузкиПД = СТР(ВРЕМЯ_ТЕК)
  г_дирВыгрузкиПД = IB_FILE_ПутьСоед(г_дирВыгрузки, г_дирКвитанций) + "\" + СТР(г_датаВыгрузкиПД) + " - " + ЗАМ(":", г_времяВыгрузкиПД, "-")
  
  получениеПокССайта = (IB_CONTEXT_ИзвлечьЛок("получениеПокССайта") <> "")
  //
  ЕСЛИ оп_НачислениеБезТекПок ТО
    УСТ_АТРИБУТ("$использоватьШаблонНПБезВводаПок", "ДА")
    оп_Начисление = ДА
    оп_ФормироватьРеестр = НЕТ
  КОНЕЦ_ЕСЛИ
  
  СОЗДАТЬ(СП,ТИП_СПИСОК)
  
  STG_УстТекстБлока
  STG_R_НастройкиБлока
  STG_R_НастройкиСчетов
  STG_R_НастройкиПечатиПД
  STG_ПутиПрофилейМножВыбора
  STG_ПодготовитьДанныеСтатей
  STG_СчитатьДиапОбъемовЭЭ
  
  гр_линии = т_распЗагИПЗаглМнож
  гр_гаражи = текстЗагИПЗаглМнож
    
  //проверка настройки выгрузки реестра
  ЕСЛИ оп_ФормироватьРеестр ТО
    ЕСЛИ г_дирВыгрузки = "" ТО
      г_дирВыгрузки = г_времПапка
    КОНЕЦ_ЕСЛИ
  КОНЕЦ_ЕСЛИ
  
  //установка дат
  М = IB_STR_МЕСЯЦ_В_ЧИСЛО(гр_Месяц)
  ЕСЛИ г_способВводаПоказаний = к_СпособВводаПокРазВМес ТО
    гр_ДатаС = ДАТА(1, М, гр_Год)
    гр_ДатаПо = ДАТА(1, М + 1, гр_Год) - 1
  КОНЕЦ_ЕСЛИ
  
  //
  идентАрхива = АТРИБУТ("$пересчетПоАрхиву")
  ЕСЛИ идентАрхива <> "" ТО
    tmp_гр_ТипСч = гр_ТипСч
    tmp_оп_Начисление = оп_Начисление
    tmp_датаОперации = датаОперации
    tmp_гр_датаС = гр_ДатаС
    tmp_гр_датаПо = гр_ДатаПо
    STG_СчитатьПарамРасчета(датаОперации, гр_ДатаС, гр_ДатаПо, гр_ТипСч)
    г_текИдРасчета = ЗНАЧ(идентАрхива)
    оп_Начисление = ДА
  ИНАЧЕ 
    г_текИдРасчета = IB_DBF_МаксЗначПоля(ф_АрхивРасчетов, "ID_CALC") + 1 //ST_STD_SET_ID
  КОНЕЦ_ЕСЛИ

  //
  датаНачалоМесяца = гр_ДатаС
  датаКонецМесяца = гр_ДатаПо
  дн = ДАТА(1, М, гр_Год)
  дк = IB_DATE_КонецМесяца2(М, ЗНАЧ(гр_Год))
  началоСледМесяца = дк + 1
  
  //считываются различные настройки
  ПараметрПечатиПД!"Отправлять письма" = оп_ОтправлятьПочту //приоритет у настройки из бланка
  ПараметрПечатиПД!"Округлять" = оп_округлятьКопейки
  
  //
  строкаВзносовДляЗаг = ""
  г_создаватьСчета = ДА             //признак создания счетов в ПС
  минТарифность = 1                 //минимальная тарифность для цикла
  максТарифность = 1                //максимальная тарифность для цикла
  всегоКвит = 0                     //общее количество сформированных ПД
  начСтр = 32                       //начальная строка после разрыва печати
  текСтр = начСтр                   //строка начала вывода ПД
  //ини индексных перем
  парамИПУ!г_сервИнд = ДА           //параметры ИПУ
  г_суммаНачЭЭ!г_сервИнд = 0        //сумма начислений по ЭЭ - глобальная
  Тар!г_сервИнд = 0                 //тарифы - глобальные
  ТарСН!г_сервИнд = 0               //тарифы по соц. норме - глобальные
  randParam!г_сервИнд = ""          //различные дополнительные параметры
  логДобПоказаний!г_сервИнд = ДА    //признак добавления показаний в файл
  коррИспользована!г_сервИнд = ДА   //признак использования корректировки
  коррУчтена!г_сервИнд = ДА         //признак учета корректировки при добавлении в файл
  строкиРеестра!г_сервИнд = ""      //строки выгрузки реестра
  парамТаблРеестраПДНомУч!г_сервИнд = ""
  парамТаблРеестраПДФИО!г_сервИнд = ""
  г_randParam!"выводРазделовПД" = гр_разделыПД
  
  //различные переменные
  г_КодСтатьиНачисления = ?(гр_ТипСч = "Электроэнергия", к_СтатьиЭЭКод,
                            ?(гр_ТипСч = "Вода", к_СтатьиВКод, к_СтатьиГКод))
                            
  СПИСОК_АТРИБУТОВ("настройки печати", СП)
  стрНаЛист = 0
  ЕСЛИ СП.ВСЕГО <= 7 ТО
    ОКНО_СООБ("Текущий принтер недоступен: " + АТРИБУТ("cur_printer") + СИМВ(13) + "Рекомендуется перезапустить программу", "Ошибка текущего принтера", "OK, CANCEL", "ERROR")
  ИНАЧЕ
    стрНаЛист = ЗНАЧ(СТР_ФРАГ(СП.СТРОКА(9), "=", 2)) - 1
  КОНЕЦ_ЕСЛИ
  СП.ОЧИСТИТЬ
  
  //период
  периодКвит = гр_Месяц + " " + СТР(гр_Год) + " г."
  //определяется форма квитанции, которая будет использована при отправке по почте
  формаПД = ?(гр_ТипСч = "Электроэнергия",
              ?(ПараметрПечатиПД!"Форма ПД ИПУ" = к_ФормаПДСчСтд, к_ФормаПДМножЭЭСерв, к_ФормаПД4ЭЭСерв),
              ?(ПараметрПечатиПД!"Форма ПД ИПУ" = к_ФормаПДСчСтд, к_ФормаПДМножВГСерв, к_ФормаПД4ВГСерв))
  //тип ипу для вывода в ПД
  типСчетчика = ?(гр_ТипСч = "Электроэнергия", "электричество",
                  ?(гр_ТипСч = "Вода", "воду", "газ"))
  //определяется файл показаний по типу ИПУ
  файл = STG_ОпределитьТипИПУ(гр_ТипСч)
  //назначение платежа по умолчанию
  назнПлатУмолч = ?(ПараметрПечатиПД!"Членские взносы в назначении платежа",
                    "Плата за членские взносы", "Плата за " + типСчетчика)
  
  STG_ПодготовитьПарамТабл(г_КодСтатьиНачисления)
  //заменяют удаленные графы - расчет потерь ЭЭ
  STG_R_НастрРасчетПЭЭ
  гр_ВарУчПотерь = г_НастройкиРасчетаПЭЭ!к_ИмяНастрВарУчета
  гр_ЗначПотерьТ1 = г_НастройкиРасчетаПЭЭ!к_ИмяНастрЗначПЭЭТ1
  гр_ЗначПотерьТ2 = г_НастройкиРасчетаПЭЭ!к_ИмяНастрЗначПЭЭТ2
  гр_ЗначПотерьТ3 = г_НастройкиРасчетаПЭЭ!к_ИмяНастрЗначПЭЭТ3
  гр_ОтдХОНаПотери = г_НастройкиРасчетаПЭЭ!к_ИмяНастрОтдХО
  гр_ОтдПДНаПотери = г_НастройкиРасчетаПЭЭ!к_ИмяНастрОтдПД
  //
  STG_R_НастрПени
  STG_R_НастрСНЭЭ
  STG_C_tmpСписокВводаПоказаний
  ЕСЛИ оп_ПечатьПКО ТО
    STG_C_tmpПКО
    УСТ_АТРИБУТ("&группОперации", "ДА")
  КОНЕЦ_ЕСЛИ
  
  STG_СчитатьШаблоны(ПараметрПечатиПД!"Форма ПД ИПУ")
  STG_СчитатьШаблоны(к_ФормаПД4ЭЭ + ", " + к_ФормаПДСчСтд) //дщк
  STG_СчитатьШаблоны(к_содХОПоНачПоИПУ)
  STG_СчитатьШаблоны(к_ОбщиеРеквизиты) //дшк
  STG_СоздПолныйШаблонНП_ПД
  STG_СоздПолныйШаблонНП_ДШК
  STG_СоздПолныйШаблонСодОпер(к_содХОПоНачПоИПУКод)
  STG_ОпределитьРеквПолучателя
  //СТОП_ВСЕ
  //установка параметров формирования ДШК и рассылки
  IB_QR_ОчиститьВремПапкаДШК
  IB_MAIL_УстОписаниеРассылки(периодКвит + "; тип ИПУ: " + гр_ТипСч)
  //сброс жхо
  IB_FLT_СохранитьФильтр
  IB_FLT_СбросФильтраПрограммы
  
  //считываются e-mail владельцев
  ЕСЛИ ПараметрПечатиПД!"Отправлять письма" ТО
    СП.ОЧИСТИТЬ
    СП.ДОБАВИТЬ("SELECT A.ID, A.EMAIL FROM")
    СП.ДОБАВИТЬ("'" + ф_СпрВладельцев + "' A")
    СП.ДОБАВИТЬ("INNER JOIN")
    СП.ДОБАВИТЬ("'" + ф_СвязьВладУч + "' B")
    СП.ДОБАВИТЬ("ON A.ID = B.ID_OWNER WHERE A.EMAIL <> ''")
    //
    ЕСЛИ идентАрхива = "" ТО
      ЕСЛИ г_колУлиц > 0 ТО
        СП.ДОБАВИТЬ("AND B.ID_AREA IN (SELECT ID_AREA FROM")
        СП.ДОБАВИТЬ("'" + ф_СпрУчастковГаражей + "'")
        СП.ДОБАВИТЬ("WHERE CODS IN (")
        СП.STG_ARH_СчитатьАрхив(к_АрхивСпрУлиц, г_путьПрофиляСпрУлиц)
        СП.ДОБАВИТЬ("))")
      КОНЕЦ_ЕСЛИ
      //
      ЕСЛИ г_колУчастков > 0 ТО
        СП.ДОБАВИТЬ("AND B.ID_AREA IN (")
        СП.STG_ARH_СчитатьАрхив(к_АрхивСпрУчастков, г_путьПрофиляСпрУчастков)
        СП.ДОБАВИТЬ(")")
      КОНЕЦ_ЕСЛИ
    ИНАЧЕ
      СП.ДОБАВИТЬ("AND B.ID_AREA IN (SELECT ID_AREA FROM")
      СП.ДОБАВИТЬ("'" + ф_ЖурналРасчетов + "'")
      СП.ДОБАВИТЬ("WHERE ID_CALC = " + идентАрхива + ")")
    КОНЕЦ_ЕСЛИ
    sql = SQL_ЗАПРОС(СП)
    ЕСЛИ sql.ВСЕГО > 0 ТО
      ЦИКЛ ДЛЯ(и = 1, sql.ВСЕГО)
        sql.ПЕРЕЙТИ(и)
        идент = sql.ПОЛЕ("ID")
        eMail!идент = sql.ПОЛЕ("EMAIL")
      КОНЕЦ_ЦИКЛА
    ИНАЧЕ
      СООБЩЕНИЕ("Не обнаружены владельцы с указанным фильтром по E-mail.")
      ВЫХОД
    КОНЕЦ_ЕСЛИ
    sql.ЗАКРЫТЬ
  КОНЕЦ_ЕСЛИ
  
  //операции из журналов
  СП.ОЧИСТИТЬ
  СП.ДОБАВИТЬ("SELECT DISTINCT ID_AREA, TYPE, DOC, CONTENT FROM")
  СП.ДОБАВИТЬ("'" + ф_Журнал + "'")
  СП.ДОБАВИТЬ("WHERE DAT = '" + СТР(датаОперации) + "' AND REC_TYPE = " + СТР_ЗНАЧ(к_ТипЗаписиЖурналаНач))
  //
  ЕСЛИ идентАрхива = "" ТО
    ЕСЛИ г_колУлиц > 0 ТО
      СП.ДОБАВИТЬ("AND CODS IN (")
      СП.STG_ARH_СчитатьАрхив(к_АрхивСпрУлиц, г_путьПрофиляСпрУлиц)
      СП.ДОБАВИТЬ(")")
    КОНЕЦ_ЕСЛИ
    //
    ЕСЛИ г_колУчастков > 0 ТО 
      СП.ДОБАВИТЬ("AND ID_AREA IN (")
      СП.STG_ARH_СчитатьАрхив(к_АрхивСпрУчастков, г_путьПрофиляСпрУчастков)
      СП.ДОБАВИТЬ(")")
    КОНЕЦ_ЕСЛИ
  ИНАЧЕ
    СП.ДОБАВИТЬ("AND ID_AREA IN (SELECT ID_AREA FROM")
    СП.ДОБАВИТЬ("'" + ф_ЖурналРасчетов + "'")
    СП.ДОБАВИТЬ("WHERE ID_CALC = " + идентАрхива + ")")
  КОНЕЦ_ЕСЛИ
  //
  СП.ДОБАВИТЬ("AND TYPE IN ('" + ТипСч + "')")
  //
  sql = SQL_ЗАПРОС(СП)
  ЦИКЛ ДЛЯ(и = 1, sql.ВСЕГО)
    sql.ПЕРЕЙТИ(и)
    ид_уч = СТР_ЗНАЧ(sql.ПОЛЕ("ID_AREA"))
    ЕСЛИ ПОЗ("потер", ПРОП(sql.ПОЛЕ("CONTENT"))) > 0 ТО
      stg_списокОпераций[ид_уч + г_раздОб + к_СтатьиПотЭЭКодСерв] = sql.ПОЛЕ("DOC") + г_раздОб + sql.ПОЛЕ("CONTENT")
    ИНАЧЕ
      stg_списокОпераций[ид_уч + г_раздОб + sql.ПОЛЕ("TYPE")] = sql.ПОЛЕ("DOC") + г_раздОб + sql.ПОЛЕ("CONTENT")
    КОНЕЦ_ЕСЛИ
  КОНЕЦ_ЦИКЛА
  sql.ЗАКРЫТЬ
  
  //формирование, отправка ПД и ПО.
  ЕСЛИ НЕ оп_формПД И оп_ОтправлятьПочту ТО
    действие = "почта"
    УСТ_АТРИБУТ("$гр_выводПДПочта", гр_выводПДПочта)
    УСТ_АТРИБУТ("$гр_форматПДПочта", гр_форматПДПочта)
  ИНАЧЕ
     ЕСЛИ оп_формПД И НЕ оп_ОтправлятьПочту ТО
      действие = "печать" + г_раздОб + гр_выводПД
      УСТ_АТРИБУТ("$гр_выводПД", гр_выводПД)
      УСТ_АТРИБУТ("$гр_форматПД", гр_форматПД)
    ИНАЧЕ
      ЕСЛИ оп_формПД И оп_ОтправлятьПочту ТО
        действие = "1" + г_раздОб + гр_выводПД
        УСТ_АТРИБУТ("$гр_выводПД", гр_выводПД)
        УСТ_АТРИБУТ("$гр_форматПД", гр_форматПД)
        УСТ_АТРИБУТ("$гр_выводПДПочта", гр_выводПДПочта)
        УСТ_АТРИБУТ("$гр_форматПДПочта", гр_форматПДПочта)
      ИНАЧЕ
        действие = "НИЧЕГО НЕ ДЕЛАТЬ"
      КОНЕЦ_ЕСЛИ
    КОНЕЦ_ЕСЛИ
  КОНЕЦ_ЕСЛИ
  
  //выгружаются номера ФЛС - не очень надо, но пока пусть будет для квитков
  параметрыФЛС!г_сервИнд = ""
  СБРОС(параметрыФЛС)
  СП.ОЧИСТИТЬ
  СП.ДОБАВИТЬ("SELECT DISTINCT ID_AREA, FIO, ID_OWNER, FLS FROM")
  СП.ДОБАВИТЬ("'" + ф_СвязьВладУч + "'")
  sql = SQL_ЗАПРОС(СП)
  ЦИКЛ ДЛЯ(и = 1, sql.ВСЕГО)
    sql.ПЕРЕЙТИ(и)
    idArea = sql.ПОЛЕ("ID_AREA")
    idOwner = sql.ПОЛЕ("ID_OWNER")
    параметрыФЛС!"флс"!г_раздОб!idArea!г_раздОб!idOwner = sql.ПОЛЕ("FLS")
  КОНЕЦ_ЦИКЛА
  sql.ЗАКРЫТЬ
  
  //формирование файла редактирования показаний/сумм начислений
  СП.ОЧИСТИТЬ
  ЕСЛИ получениеПокССайта ТО
    ЕСЛИ КОЛ_ЭЛЕМ(stg_идИПУпоИДПок) > 0 ТО
      СП.ДОБАВИТЬ("SELECT A.ID, A.NOM, A.NPOK1, A.NPOK2, A.NPOK3, A.TYPE, A.COT, A.TOKEN, A.TOKEN_DATE, " + 
                  "B.ID_AREA, B.ID_OWNER, B.CODS, B.FIO, B.N_AREA, B.N_DOM, B.SRT, C.NUM1, C.NUM2, C.NUM3, C.T1_VOL, C.T2_VOL, C.T3_VOL, C.DAT, C.COMM FROM")   
      СП.ДОБАВИТЬ("'" + ф_СпрИндивСчетчики + "' A")
      СП.ДОБАВИТЬ("INNER JOIN")
      СП.ДОБАВИТЬ("'" + файл + "' C")
      СП.ДОБАВИТЬ("ON A.ID = C.ID_SCH")
      СП.ДОБАВИТЬ("INNER JOIN")
      СП.ДОБАВИТЬ("'" + ф_СпрУчастковГаражей + "' B")
      СП.ДОБАВИТЬ("ON B.ID_AREA = C.ID_AREA")
      
      начСтр = 1
      СБРОС(г_строкиЗапроса)
      начСтр = 1
      текСтрока = ""
      колЭлем = КОЛ_ЭЛЕМ(stg_идИПУпоИДПок)
      г_колИтер = 0
      г_колСтрокЗапроса = 0
      ЦИКЛ ИНДЕКС(знач = stg_идИПУпоИДПок!номЭл)
        СформироватьСтрокуЗапроса(текСтрока, номЭл, колЭлем)
      КОНЕЦ_ЦИКЛА
      
      СП.ДОБАВИТЬ("WHERE C.ID_RECSITE IN (")
      СП.ЗаполнитьСписокЭлементов(2500, 500, начСтр)
      СП.ДОБАВИТЬ(")")
    ИНАЧЕ
      получениеПокССайта = НЕТ
      СТОП_ВСЕ
    КОНЕЦ_ЕСЛИ
  ИНАЧЕ
    ЕСЛИ оп_НачислениеБезТекПок ТО
      СП.ДОБАВИТЬ("SELECT ID_AREA, ID_OWNER, CODS, FIO, N_AREA, N_DOM, SRT FROM ")
      СП.ДОБАВИТЬ("'" + ф_СпрУчастковГаражей + "'")
      ЕСЛИ идентАрхива = "" ТО
        ЕСЛИ г_колУлиц > 0 ТО
          СП.ДОБАВИТЬ("WHERE CODS IN (")
          СП.STG_ARH_СчитатьАрхив(к_АрхивСпрУлиц, г_путьПрофиляСпрУлиц)
          СП.ДОБАВИТЬ(")")
        КОНЕЦ_ЕСЛИ
        //
        ЕСЛИ г_колУчастков > 0 ТО
          СП.ДОБАВИТЬ(?(СП.ВСЕГО > 2, "AND", "WHERE") + " ID_AREA IN (")
          СП.STG_ARH_СчитатьАрхив(к_АрхивСпрУчастков, г_путьПрофиляСпрУчастков)
          СП.ДОБАВИТЬ(")")
        КОНЕЦ_ЕСЛИ
      ИНАЧЕ
        СП.ДОБАВИТЬ("WHERE ID_AREA IN (SELECT ID_AREA FROM")
        СП.ДОБАВИТЬ("'" + ф_ЖурналРасчетов + "'")
        СП.ДОБАВИТЬ("WHERE ID_CALC = " + идентАрхива + ")")
      КОНЕЦ_ЕСЛИ
      //
      //СП.ДОБАВИТЬ(?(СП.ВСЕГО > 2, "AND", "WHERE") + " TYPE = '" + ТипСч + "'")
      СП.ДОБАВИТЬ("ORDER BY SRT")
    ИНАЧЕ
      СП.ОЧИСТИТЬ
      СП.ДОБАВИТЬ("SELECT A.ID, A.NOM, A.NPOK1, A.NPOK2, A.NPOK3, A.TYPE, A.COT, A.TOKEN, A.TOKEN_DATE, " + 
                  "B.ID_AREA, B.ID_OWNER, B.CODS, B.FIO, B.N_AREA, B.N_DOM, B.SRT FROM ")
      СП.ДОБАВИТЬ("'" + ф_СпрИндивСчетчики + "' A")
      СП.ДОБАВИТЬ("INNER JOIN")
      СП.ДОБАВИТЬ("'" + ф_СпрУчастковГаражей + "' B")
      СП.ДОБАВИТЬ("ON A.ID_AREA = B.ID_AREA ")
      //
      ЕСЛИ идентАрхива = "" ТО
        ЕСЛИ г_колУлиц > 0 ТО
          СП.ДОБАВИТЬ("WHERE B.CODS IN (")
          СП.STG_ARH_СчитатьАрхив(к_АрхивСпрУлиц, г_путьПрофиляСпрУлиц)
          СП.ДОБАВИТЬ(")")
        КОНЕЦ_ЕСЛИ
        //
        ЕСЛИ г_колУчастков > 0 ТО
          СП.ДОБАВИТЬ(?(СП.ВСЕГО > 5, "AND", "WHERE") + " A.ID_AREA IN (")
          СП.STG_ARH_СчитатьАрхив(к_АрхивСпрУчастков, г_путьПрофиляСпрУчастков)
          СП.ДОБАВИТЬ(")")
        КОНЕЦ_ЕСЛИ
      ИНАЧЕ
        СП.ДОБАВИТЬ("WHERE ID_AREA IN (SELECT ID_AREA FROM")
        СП.ДОБАВИТЬ("'" + ф_ЖурналРасчетов + "'")
        СП.ДОБАВИТЬ("WHERE ID_CALC = " + идентАрхива + ")")
      КОНЕЦ_ЕСЛИ
      //
      СП.ДОБАВИТЬ(?(СП.ВСЕГО > 5, "AND", "WHERE") + " A.TYPE = '" + ТипСч + "'")
      ЕСЛИ НЕ оп_НачислениеБезТекПок ТО
        СП.ДОБАВИТЬ("AND A.DATEND >= '" + СТР(датаНачалоМесяца) + "'")
      КОНЕЦ_ЕСЛИ
      СП.ДОБАВИТЬ("ORDER BY B.SRT")
    КОНЕЦ_ЕСЛИ
  КОНЕЦ_ЕСЛИ
  //
  main = SQL_ЗАПРОС(СП)
  //БД_РЕДАКТОР(main)
  //ВЫХОД
  всегоMain = 0
  ЕСЛИ main.ВСЕГО > 0 ТО
    ОКНО_СТАТУСА("CREATE", "Идет подготовка таблицы редактора...")
    
    ЕСЛИ получениеПокССайта ТО
      оп_Начисление = ДА
      ЦИКЛ ДЛЯ(и = 1, main.ВСЕГО)
        main.ПЕРЕЙТИ(и)
        
        //Сбросим переменные
        //СБРОС(кодДиапазонаЭЭ)
        ЦИКЛ ДЛЯ(ж = 1, 3)
          ТекПок!ж = 0
          ПредПок!ж = 0
          Т!ж = 0
          Т_СН!ж = 0
          Потери!ж = 0
          г_идентВзноса!ж = 0
          кодДиапазонаЭЭ!ж = ""
          stg_тариф!ж = 0
          stg_тарифСН!ж = 0
        КОНЕЦ_ЦИКЛА
        УчетПотерь = ""
        
        idSch = main.ПОЛЕ("ID")
        idArea = main.ПОЛЕ("ID_AREA")
        idOwner = main.ПОЛЕ("ID_OWNER")
        Token = main.ПОЛЕ("TOKEN")
        TokenDate = main.ПОЛЕ("TOKEN_DATE")
        
        ЕСЛИ ПараметрПечатиПД!"Отправлять письма" ТО
          ЕСЛИ гр_email <> "" ТО
            ЕСЛИ НЕ СУЩ_ПЕРЕМ(eMail!idOwner) И гр_email = "Есть" ТО
              ПРОДОЛЖИТЬ
            КОНЕЦ_ЕСЛИ
            //
            ЕСЛИ СУЩ_ПЕРЕМ(eMail!idOwner) И гр_email = "Нет" ТО
              ПРОДОЛЖИТЬ
            КОНЕЦ_ЕСЛИ
          КОНЕЦ_ЕСЛИ
        КОНЕЦ_ЕСЛИ
        
        г_Тарифность = ?(main.ПОЛЕ("COT") = 0, 1, main.ПОЛЕ("COT")) //костыль
        
        минТарифность = ?(минТарифность > г_Тарифность, г_Тарифность, минТарифность)
        максТарифность = ?(максТарифность < г_Тарифность, г_Тарифность, максТарифность)
        
        флс = main.ПОЛЕ("N_AREA")
        ЕСЛИ СУЩ_ПЕРЕМ(параметрыФЛС!"флс"!г_раздОб!idArea!г_раздОб!idOwner) ТО
          ЕСЛИ параметрыФЛС!"флс"!г_раздОб!idArea!г_раздОб!idOwner <> "" ТО
            флс = параметрыФЛС!"флс"!г_раздОб!idArea!г_раздОб!idOwner
          КОНЕЦ_ЕСЛИ
        КОНЕЦ_ЕСЛИ
        
        //предыдущие
        СП.ОЧИСТИТЬ
        СП.ДОБАВИТЬ("SELECT * FROM")
        СП.ДОБАВИТЬ("'" + файл + "'")
        СП.ДОБАВИТЬ("WHERE ID_SCH = " + СТР_ЗНАЧ(main.ПОЛЕ("ID")) + " AND CORR = FALSE AND DAT < '" + СТР(main.ПОЛЕ("DAT")) + "'")
        СП.ДОБАВИТЬ("ORDER BY ID_SCH, DAT DESC")
        sql_ПредПоказания = SQL_ЗАПРОС(СП)
        
        //предыдущие или начальные
        /*найденнаяПоз = sql_ПредПоказания.НАЙТИ_ПОЗ("ID_SCH", idSch)
        логПоз = (найденнаяПоз > 0)*/
        ЕСЛИ sql_ПредПоказания.ВСЕГО > 0 ТО
          sql_ПредПоказания.ПЕРЕЙТИ(1)
          ЦИКЛ ДЛЯ(ж = 1, 3)
            ЕСЛИ г_КодСтатьиНачисления = к_СтатьиЭЭКод ИЛИ
                 ((г_КодСтатьиНачисления = к_СтатьиВКод ИЛИ г_КодСтатьиНачисления = к_СтатьиГКод) И ж = 1) ТО
              ПредПок!ж = sql_ПредПоказания.ПОЛЕ("NUM" + СТР_ЗНАЧ(ж))
              ЕСЛИ г_КодСтатьиНачисления = к_СтатьиЭЭКод ТО
                Потери!ж = sql_ПредПоказания.ПОЛЕ("P" + СТР_ЗНАЧ(ж))
              КОНЕЦ_ЕСЛИ
            КОНЕЦ_ЕСЛИ
          КОНЕЦ_ЦИКЛА
          ЕСЛИ г_КодСтатьиНачисления = к_СтатьиЭЭКод ТО
            УчетПотерь = sql_ПредПоказания.ПОЛЕ("P")
          КОНЕЦ_ЕСЛИ
          предДата = СТР(sql_ПредПоказания.ПОЛЕ("DAT"))
        ИНАЧЕ
          ЦИКЛ ДЛЯ (ж=1,3)
            ПредПок!ж = main.ПОЛЕ("NPOK" + СТР_ЗНАЧ(ж))
          КОНЕЦ_ЦИКЛА
          предДата = СТР(к_МинДата)
        КОНЕЦ_ЕСЛИ
        
        г_кодДиапазонаЭЭ = ""
        //СБРОС(кодДиапазонаЭЭ)
        ЕСЛИ г_испДиапОбъемовЭЭ ТО
          //суммарныйОбъем = 0
          ЦИКЛ ДЛЯ(в = 1, г_Тарифность)
            кодДиапазонаЭЭ!в = STG_КодДиапазонаПоОбъему(main.ПОЛЕ("NUM" + СТР(в)) - ПредПок!в)
          КОНЕЦ_ЦИКЛА
          
          //г_кодДиапазонаЭЭ = STG_КодДиапазонаПоОбъему(суммарныйОбъем)
        КОНЕЦ_ЕСЛИ
        
        //определяем необходимость использования сельского тарифа - КРАЙНЕ ХРЕНОВО, НО НАДО БУДЕТ ПЕРЕДЕЛАТЬ ПОТОМ НА НОРМ ВАРИАНТ
        //ind = СТР_ЗНАЧ(г_Тарифность) + "_" + СТР_ЗНАЧ(Token) + "_" + г_кодДиапазонаЭЭ + "_"
        //ЕСЛИ НЕ СУЩ_ПЕРЕМ(Тар!ind!1) ТО
          ЕСЛИ оп_Начисление ТО
            ЕСЛИ г_испДиапОбъемовЭЭ ТО
              ЦИКЛ ДЛЯ(в = 1, г_Тарифность)
                г_кодДиапазонаЭЭ = кодДиапазонаЭЭ!в
                //ind = СТР_ЗНАЧ(г_Тарифность) + "_" + СТР_ЗНАЧ(Token) + "_" + г_кодДиапазонаЭЭ + "_"
                ЕСЛИ НЕ STG_СчитатьТарифы(main.ПОЛЕ("DAT"), main.ПОЛЕ("DAT"), МЕС(main.ПОЛЕ("DAT"))) ТО
                  г_кодДиапазонаЭЭ = ""
                  //ind = СТР_ЗНАЧ(г_Тарифность) + "_" + СТР_ЗНАЧ(Token) + "_" + г_кодДиапазонаЭЭ + "_"
                  ib_protocol_кэшПротокола.ОЧИСТИТЬ
                  ib_protocol_кэшОшибок.ОЧИСТИТЬ
                  ЕСЛИ НЕ STG_СчитатьТарифы(main.ПОЛЕ("DAT"), main.ПОЛЕ("DAT"), МЕС(main.ПОЛЕ("DAT"))) ТО
                    IB_PROTOCOL_ОбработатьИВывестиОшибки
                    СТОП_ВСЕ
                  ИНАЧЕ
                    stg_тариф!в = Т!в
                    stg_тарифСН!в = Т_СН!в
                  КОНЕЦ_ЕСЛИ
                ИНАЧЕ
                  stg_тариф!в = Т!в
                  stg_тарифСН!в = Т_СН!в
                КОНЕЦ_ЕСЛИ
              КОНЕЦ_ЦИКЛА
            ИНАЧЕ
              ЕСЛИ НЕ STG_СчитатьТарифы(main.ПОЛЕ("DAT"), main.ПОЛЕ("DAT"), МЕС(main.ПОЛЕ("DAT"))) ТО
                IB_PROTOCOL_ОбработатьИВывестиОшибки
                СТОП_ВСЕ
              КОНЕЦ_ЕСЛИ
              ЦИКЛ ДЛЯ(ж = 1, 3)
                ЕСЛИ СУЩ_ПЕРЕМ(Т!ж) ТО
                  stg_тариф!в = Т!в
                  stg_тарифСН!в = Т_СН!в
                КОНЕЦ_ЕСЛИ
              КОНЕЦ_ЦИКЛА
            КОНЕЦ_ЕСЛИ
          КОНЕЦ_ЕСЛИ
        //КОНЕЦ_ЕСЛИ
        
        СП.ОЧИСТИТЬ
        СП.ДОБАВИТЬ("INSERT INTO")
        СП.ДОБАВИТЬ("'" + ф_tmp001 + "' ")
        СП.ДОБАВИТЬ("(CODS, ID_AREA, ID_OWNER, N_AREA, " + 
                    "FLS, FIO, SRT, ID_SCH, NOM, COT, " + 
                    "DAT, T_DAT, PNUM1, NUM1, PNUM2, NUM2, PNUM3, NUM3, " + 
                    "T1, T2, T3, T1SN, T2SN, T3SN, " + 
                    "P1, P2, P3, P, CORR, COMM, srv_slctd, ID_VZN, ROV1, ROV2, ROV3, TOKEN, TOKEN_DATE) VALUES ")
        СП.ДОБАВИТЬ("('" + main.ПОЛЕ("CODS") + "', " + СТР_ЗНАЧ(idArea) + ", " + СТР_ЗНАЧ(idOwner) + ", '" + main.ПОЛЕ("N_AREA"))
        СП.ДОБАВИТЬ("','" + флс + "', '" + main.ПОЛЕ("FIO") + "','" + main.ПОЛЕ("SRT") + "'," + СТР_ЗНАЧ(idSch))
        СП.ДОБАВИТЬ(",'" + main.ПОЛЕ("NOM") + "', " + СТР_ЗНАЧ(main.ПОЛЕ("COT")))
        СП.ДОБАВИТЬ(",'" + СТР(main.ПОЛЕ("DAT")) + "','" + СТР(main.ПОЛЕ("DAT")) + "'," + СТР_ЗНАЧ(ПредПок!1) + 
                    "," + СТР_ЗНАЧ(main.ПОЛЕ("NUM1")) + "," + СТР_ЗНАЧ(ПредПок!2) + "," + СТР_ЗНАЧ(main.ПОЛЕ("NUM2")))
        СП.ДОБАВИТЬ("," + СТР_ЗНАЧ(ПредПок!3) + "," + СТР_ЗНАЧ(main.ПОЛЕ("NUM3")) + ",")
        СП.ДОБАВИТЬ(СТР_ЗНАЧ(stg_тариф!1) + ", " + СТР_ЗНАЧ(stg_тариф!2) + ", " + СТР_ЗНАЧ(stg_тариф!3) + "," + 
                    СТР_ЗНАЧ(stg_тарифСН!1) + ", " + СТР_ЗНАЧ(stg_тарифСН!2) + ", " + СТР_ЗНАЧ(stg_тарифСН!3) + ",")
        СП.ДОБАВИТЬ(СТР_ЗНАЧ(Потери!1) + ", " + СТР_ЗНАЧ(Потери!2) + ", " + СТР_ЗНАЧ(Потери!3) + ", '" + УчетПотерь + "', FALSE, '', 'V', " + СТР_ЗНАЧ(г_идентВзноса!г_Тарифность)) 
        СП.ДОБАВИТЬ(", '" + кодДиапазонаЭЭ!1 + "', '" + кодДиапазонаЭЭ!2 + "', '" + кодДиапазонаЭЭ!3 + "', " + СТР(Token) + ", '" + СТР(TokenDate) + "')")
        SQL_ЗАПРОС(СП)
      КОНЕЦ_ЦИКЛА
    ИНАЧЕ
      ЕСЛИ оп_НачислениеБезТекПок ТО  //суммой без ввода показаний
        всегоMain = main.ВСЕГО
        ЦИКЛ ДЛЯ (и = 1, всегоMain)
          main.ПЕРЕЙТИ(и)
          //
          идУч = main.ПОЛЕ("ID_AREA")
          идВлад = main.ПОЛЕ("ID_OWNER")
          флс = main.ПОЛЕ("N_AREA")
          ЕСЛИ СУЩ_ПЕРЕМ(параметрыФЛС!"флс"!г_раздОб!idArea!г_раздОб!idOwner) ТО
            ЕСЛИ параметрыФЛС!"флс"!г_раздОб!idArea!г_раздОб!idOwner <> "" ТО
              флс = параметрыФЛС!"флс"!г_раздОб!idArea!г_раздОб!idOwner
            КОНЕЦ_ЕСЛИ
          КОНЕЦ_ЕСЛИ
          //
          ЕСЛИ ПараметрПечатиПД!"Отправлять письма" ТО
            ЕСЛИ гр_email <> "" ТО
              ЕСЛИ НЕ СУЩ_ПЕРЕМ(eMail!идВлад) И гр_email = "Есть" ТО
                ПРОДОЛЖИТЬ
              КОНЕЦ_ЕСЛИ
              //
              ЕСЛИ СУЩ_ПЕРЕМ(eMail!идВлад) И гр_email = "Нет" ТО
                ПРОДОЛЖИТЬ
              КОНЕЦ_ЕСЛИ
            КОНЕЦ_ЕСЛИ
          КОНЕЦ_ЕСЛИ
          //запишем во временный ф_tmp001 - надо заменить NUM1
          СП.ОЧИСТИТЬ
          СП.ДОБАВИТЬ("INSERT INTO")
          СП.ДОБАВИТЬ("'" + ф_tmp001 + "'")
          СП.ДОБАВИТЬ("(CODS, ID_AREA, ID_OWNER, FIO, N_AREA, N_DOM, FLS, NUM1, SRT, COT, T_DAT, NOM, srv_slctd) VALUES ")
          СП.ДОБАВИТЬ("('" + main.ПОЛЕ("CODS") + "', " + СТР_ЗНАЧ(идУч) + ", " + СТР_ЗНАЧ(идВлад) + "," + 
                       " '" + main.ПОЛЕ("FIO") + "', '" + main.ПОЛЕ("N_AREA") + "', '" + main.ПОЛЕ("N_DOM") + "',")
          СП.ДОБАВИТЬ("'" + флс + "', " + СТР_ЗНАЧ(гр_СуммаНач) + ", '" + main.ПОЛЕ("SRT")  + "', 1, '" + СТР(ДАТА_ТЕК) + 
                       "', '', 'V')")
          SQL_ЗАПРОС(СП)
          //
          проц = РУБ(100 *  и/ всегоMain)
          ОКНО_СТАТУСА("PROGRESS", "Обработано " + СТР_ЗНАЧ(и) + " из " + СТР_ЗНАЧ(всегоMain) + " (" + СТР_ЗНАЧ(проц) + "%)")
          ОКНО_СТАТУСА("PERCENT", СТР_ЗНАЧ(проц))
        КОНЕЦ_ЦИКЛА
      ИНАЧЕ
        //дата до начала периода
        СП.ОЧИСТИТЬ
        СП.ДОБАВИТЬ("SELECT DISTINCT DAT FROM")
        СП.ДОБАВИТЬ("'" + файл + "'")
        СП.ДОБАВИТЬ("WHERE DAT BETWEEN '" + СТР(датаНачалоМесяца) + "' AND '" + СТР(датаКонецМесяца) + "' AND CORR = FALSE")// + where1)
        //
        ЕСЛИ идентАрхива = "" ТО
          ЕСЛИ г_колУлиц > 0 ТО
            СП.ДОБАВИТЬ("AND CODS IN (")
            СП.STG_ARH_СчитатьАрхив(к_АрхивСпрУлиц, г_путьПрофиляСпрУлиц)
            СП.ДОБАВИТЬ(")")
          КОНЕЦ_ЕСЛИ
          //
          ЕСЛИ г_колУчастков > 0 ТО
            СП.ДОБАВИТЬ("AND ID_AREA IN (")
            СП.STG_ARH_СчитатьАрхив(к_АрхивСпрУчастков, г_путьПрофиляСпрУчастков)
            СП.ДОБАВИТЬ(")")
          КОНЕЦ_ЕСЛИ
        ИНАЧЕ
          СП.ДОБАВИТЬ("AND ID_AREA IN (SELECT ID_AREA FROM")
          СП.ДОБАВИТЬ("'" + ф_ЖурналРасчетов + "'")
          СП.ДОБАВИТЬ("WHERE ID_CALC = " + идентАрхива + ")")
        КОНЕЦ_ЕСЛИ
        СП.ДОБАВИТЬ("ORDER BY DAT")
        date = SQL_ЗАПРОС(СП)
        //ОТЛАДКА(СП)
        //БД_РЕДАКТОР(date)
        dateВсего = date.ВСЕГО
        колИтDate = ?(dateВсего = 0, 1, dateВсего)
        колЗап = main.ВСЕГО * колИтDate
        ЦИКЛ ДЛЯ(номДаты = 1, колИтDate)
          ЕСЛИ dateВсего > 0 ТО
            date.ПЕРЕЙТИ(номДаты)
            текДатаПок = date.ПОЛЕ("DAT")
          ИНАЧЕ
            текДатаПок = гр_ДатаПо
          КОНЕЦ_ЕСЛИ
          
          логВводаНовойСтроки = НЕТ
          ЕСЛИ г_способВводаПоказаний <> к_СпособВводаПокРазВМес ТО
            логВводаНовойСтроки = (номДаты = колИтDate)
          КОНЕЦ_ЕСЛИ
          
          ОКНО_СТАТУСА("MESSAGE", "Добавление показаний за " + СТР(текДатаПок))
          
          //предыдущие
          СП.ОЧИСТИТЬ
          СП.ДОБАВИТЬ("SELECT * FROM")
          СП.ДОБАВИТЬ("'" + файл + "'")
          СП.ДОБАВИТЬ("WHERE ID_SCH > 0 AND DAT < '" + СТР(текДатаПок) + "' AND CORR = FALSE") // + where1 + 
          //
          ЕСЛИ г_колУлиц > 0 ТО
            СП.ДОБАВИТЬ("AND CODS IN (")
            СП.STG_ARH_СчитатьАрхив(к_АрхивСпрУлиц, г_путьПрофиляСпрУлиц)
            СП.ДОБАВИТЬ(")")
          КОНЕЦ_ЕСЛИ
          //
          ЕСЛИ г_колУчастков > 0 ТО
            СП.ДОБАВИТЬ("AND ID_AREA IN (")
            СП.STG_ARH_СчитатьАрхив(к_АрхивСпрУчастков, г_путьПрофиляСпрУчастков)
            СП.ДОБАВИТЬ(")")
          КОНЕЦ_ЕСЛИ
          //
          СП.ДОБАВИТЬ("ORDER BY ID_SCH, DAT DESC")
          sql_ПредПоказания = SQL_ЗАПРОС(СП)
          //БД_РЕДАКТОР(sql_ПредПоказания)
          
          //корректировки
          СП.ОЧИСТИТЬ
          ЕСЛИ файл = ф_ПоказанияИСЭЭ ТО
            СП.ДОБАВИТЬ("SELECT ID_SCH, DAT, SUM(NUM1) AS NUM1, SUM(NUM2) AS NUM2, SUM(NUM3) AS NUM3, COMM FROM")
          ИНАЧЕ
            СП.ДОБАВИТЬ("SELECT ID_SCH, DAT, SUM(NUM1) AS NUM1, COMM FROM")
          КОНЕЦ_ЕСЛИ
          СП.ДОБАВИТЬ("'" + файл + "'")
          СП.ДОБАВИТЬ("WHERE ID_SCH > 0 AND CORR = TRUE AND DAT BETWEEN '" + СТР(гр_ДатаС) + "' AND '" + СТР(гр_ДатаПо) + "'")
          //
          ЕСЛИ идентАрхива = "" ТО
            ЕСЛИ г_колУлиц > 0 ТО
              СП.ДОБАВИТЬ("AND CODS IN (")
              СП.STG_ARH_СчитатьАрхив(к_АрхивСпрУлиц, г_путьПрофиляСпрУлиц)
              СП.ДОБАВИТЬ(")")
            КОНЕЦ_ЕСЛИ
            //
            ЕСЛИ г_колУчастков > 0 ТО
              СП.ДОБАВИТЬ("AND ID_AREA IN (")
              СП.STG_ARH_СчитатьАрхив(к_АрхивСпрУчастков, г_путьПрофиляСпрУчастков)
              СП.ДОБАВИТЬ(")")
            КОНЕЦ_ЕСЛИ
          ИНАЧЕ
            СП.ДОБАВИТЬ("AND ID_AREA IN (SELECT ID_AREA FROM")
            СП.ДОБАВИТЬ("'" + ф_ЖурналРасчетов + "'")
            СП.ДОБАВИТЬ("WHERE ID_CALC = " + идентАрхива + ")")
          КОНЕЦ_ЕСЛИ
          СП.ДОБАВИТЬ("GROUP BY ID_SCH, DAT, COMM")
          sql_Корр = SQL_ЗАПРОС(СП)
          всегоКорр = sql_Корр.ВСЕГО
          ЕСЛИ всегоКорр = 1 ТО
            sql_Корр.ПЕРЕЙТИ(1)
            ЕСЛИ sql_Корр.ПОЛЕ("ID_SCH") = 0 ТО
              всегоКорр = 0
            КОНЕЦ_ЕСЛИ
          КОНЕЦ_ЕСЛИ
          
          //текущие
          СП.ОЧИСТИТЬ
          СП.ДОБАВИТЬ("SELECT * FROM ")
          СП.ДОБАВИТЬ("'" + файл + "'")
          СП.ДОБАВИТЬ("WHERE ID_SCH > 0 AND DAT = '" + СТР(текДатаПок) + "' AND CORR = FALSE") // + where1 + 
          //
          ЕСЛИ идентАрхива = "" ТО
            ЕСЛИ г_колУлиц > 0 ТО
              СП.ДОБАВИТЬ("AND CODS IN (")
              СП.STG_ARH_СчитатьАрхив(к_АрхивСпрУлиц, г_путьПрофиляСпрУлиц)
              СП.ДОБАВИТЬ(")")
            КОНЕЦ_ЕСЛИ
            //
            ЕСЛИ г_колУчастков > 0 ТО
              СП.ДОБАВИТЬ("AND ID_AREA IN (")
              СП.STG_ARH_СчитатьАрхив(к_АрхивСпрУчастков, г_путьПрофиляСпрУчастков)
              СП.ДОБАВИТЬ(")")
            КОНЕЦ_ЕСЛИ
          ИНАЧЕ
            СП.ДОБАВИТЬ("AND ID_AREA IN (SELECT ID_AREA FROM")
            СП.ДОБАВИТЬ("'" + ф_ЖурналРасчетов + "'")
            СП.ДОБАВИТЬ("WHERE ID_CALC = " + идентАрхива + ")")
          КОНЕЦ_ЕСЛИ
          //
          СП.ДОБАВИТЬ("ORDER BY ID_SCH, DAT")
          sql_ТекПоказания = SQL_ЗАПРОС(СП)
          //БД_РЕДАКТОР(sql_ТекПоказания)
          
          ЦИКЛ ДЛЯ(и = 1, main.ВСЕГО)
            main.ПЕРЕЙТИ(и)
            //Сбросим переменные
            //СБРОС(кодДиапазонаЭЭ)
            ЦИКЛ ДЛЯ (ж=1,3)
              ТекПок!ж = 0
              ПредПок!ж = 0
              Т!ж = 0
              Т_СН!ж = 0
              Потери!ж = 0
              г_идентВзноса!ж = 0
              кодДиапазонаЭЭ!ж = ""
              stg_тариф!ж = 0
              stg_тарифСН!ж = 0
            КОНЕЦ_ЦИКЛА
            УчетПотерь = ""
            
            idSch = main.ПОЛЕ("ID")
            idArea = main.ПОЛЕ("ID_AREA")
            idOwner = main.ПОЛЕ("ID_OWNER")
            Token = main.ПОЛЕ("TOKEN")
            TokenDate = main.ПОЛЕ("TOKEN_DATE")
            
            ЕСЛИ ПараметрПечатиПД!"Отправлять письма" ТО
              ЕСЛИ гр_email <> "" ТО
                ЕСЛИ НЕ СУЩ_ПЕРЕМ(eMail!idOwner) И гр_email = "Есть" ТО
                  ПРОДОЛЖИТЬ
                КОНЕЦ_ЕСЛИ
                //
                ЕСЛИ СУЩ_ПЕРЕМ(eMail!idOwner) И гр_email = "Нет" ТО
                  ПРОДОЛЖИТЬ
                КОНЕЦ_ЕСЛИ
              КОНЕЦ_ЕСЛИ
            КОНЕЦ_ЕСЛИ
            
            г_Тарифность = ?(main.ПОЛЕ("COT") = 0, 1, main.ПОЛЕ("COT")) //костыль
            
            минТарифность = ?(минТарифность > г_Тарифность, г_Тарифность, минТарифность)
            максТарифность = ?(максТарифность < г_Тарифность, г_Тарифность, максТарифность)
            
            флс = main.ПОЛЕ("N_AREA")
            ЕСЛИ СУЩ_ПЕРЕМ(параметрыФЛС!"флс"!г_раздОб!idArea!г_раздОб!idOwner) ТО
              ЕСЛИ параметрыФЛС!"флс"!г_раздОб!idArea!г_раздОб!idOwner <> "" ТО
                флс = параметрыФЛС!"флс"!г_раздОб!idArea!г_раздОб!idOwner
              КОНЕЦ_ЕСЛИ
            КОНЕЦ_ЕСЛИ
            
            //предыдущие или начальные
            найденнаяПоз = sql_ПредПоказания.НАЙТИ_ПОЗ("ID_SCH", idSch)
            логПоз = (найденнаяПоз > 0)
            ЕСЛИ найденнаяПоз > 0 ТО
              sql_ПредПоказания.ПЕРЕЙТИ(найденнаяПоз)
              ЦИКЛ ДЛЯ (ж=1,3)
                ЕСЛИ г_КодСтатьиНачисления = к_СтатьиЭЭКод ИЛИ
                     ((г_КодСтатьиНачисления = к_СтатьиВКод ИЛИ г_КодСтатьиНачисления = к_СтатьиГКод) И ж = 1) ТО
                  ПредПок!ж = sql_ПредПоказания.ПОЛЕ("NUM" + СТР_ЗНАЧ(ж))
                  ЕСЛИ г_КодСтатьиНачисления = к_СтатьиЭЭКод ТО
                    Потери!ж = sql_ПредПоказания.ПОЛЕ("P" + СТР_ЗНАЧ(ж))
                  КОНЕЦ_ЕСЛИ
                КОНЕЦ_ЕСЛИ
              КОНЕЦ_ЦИКЛА
              ЕСЛИ г_КодСтатьиНачисления = к_СтатьиЭЭКод ТО
                УчетПотерь = sql_ПредПоказания.ПОЛЕ("P")
              КОНЕЦ_ЕСЛИ
              предДата = СТР(sql_ПредПоказания.ПОЛЕ("DAT"))
            ИНАЧЕ
              ЦИКЛ ДЛЯ (ж=1,3)
                ПредПок!ж = main.ПОЛЕ("NPOK" + СТР_ЗНАЧ(ж))
              КОНЕЦ_ЦИКЛА
              предДата = СТР(к_МинДата)
            КОНЕЦ_ЕСЛИ
            
            найденнаяПоз = sql_ТекПоказания.НАЙТИ_ПОЗ("ID_SCH", idSch)
            логПоз = логПоз ИЛИ (найденнаяПоз > 0)
            ЕСЛИ найденнаяПоз > 0 ТО
              sql_ТекПоказания.ПЕРЕЙТИ(найденнаяПоз)
              ЦИКЛ ДЛЯ(ж = 1, 3)
                ЕСЛИ г_КодСтатьиНачисления = к_СтатьиЭЭКод ИЛИ
                     ((г_КодСтатьиНачисления = к_СтатьиВКод ИЛИ г_КодСтатьиНачисления = к_СтатьиГКод) И ж = 1) ТО
                  ТекПок!ж = sql_ТекПоказания.ПОЛЕ("NUM" + СТР_ЗНАЧ(ж))
                  ЕСЛИ г_КодСтатьиНачисления = к_СтатьиЭЭКод ТО
                    Потери!ж = sql_ТекПоказания.ПОЛЕ("P" + СТР_ЗНАЧ(ж))
                  КОНЕЦ_ЕСЛИ
                КОНЕЦ_ЕСЛИ
              КОНЕЦ_ЦИКЛА
              ЕСЛИ г_КодСтатьиНачисления = к_СтатьиЭЭКод ТО
                УчетПотерь = sql_ТекПоказания.ПОЛЕ("P")
              КОНЕЦ_ЕСЛИ
              текДата = sql_ТекПоказания.ПОЛЕ("DAT")
              //
              ЕСЛИ логВводаНовойСтроки И и = main.ВСЕГО И sql_ТекПоказания.ПОЛЕ("DAT") = гр_ДатаПо ТО
                логВводаНовойСтроки = НЕТ
              КОНЕЦ_ЕСЛИ
            ИНАЧЕ
              ЦИКЛ ДЛЯ(ж = 1, 3)
                ТекПок!ж = 0
              КОНЕЦ_ЦИКЛА
              ЕСЛИ логВводаНовойСтроки ТО
                текДата = ?(оп_датаПокПоДатеОп, датаОперации, гр_ДатаПо)
              ИНАЧЕ
                //ПРОДОЛЖИТЬ
                ЕСЛИ г_способВводаПоказаний <> к_СпособВводаПокРазВМес ТО
                  ПРОДОЛЖИТЬ
                ИНАЧЕ
                  текДата = ?(оп_датаПокПоДатеОп, датаОперации, гр_ДатаПо) //ДАТА_ТЕК
                КОНЕЦ_ЕСЛИ
              КОНЕЦ_ЕСЛИ
            КОНЕЦ_ЕСЛИ
        
            
            г_кодДиапазонаЭЭ = ""
            //кодДиапазонаЭЭ!1 = ""
            ЕСЛИ г_испДиапОбъемовЭЭ ТО
              //суммарныйОбъем = 0
              ЦИКЛ ДЛЯ(в = 1, г_Тарифность)
                кодДиапазонаЭЭ!в = STG_КодДиапазонаПоОбъему(ТекПок!в - ПредПок!в)
              КОНЕЦ_ЦИКЛА
              
              //г_кодДиапазонаЭЭ = STG_КодДиапазонаПоОбъему(суммарныйОбъем)
            КОНЕЦ_ЕСЛИ
            
            //определяем необходимость использования сельского тарифа
            ЕСЛИ оп_Начисление ТО
              ЕСЛИ г_испДиапОбъемовЭЭ ТО
                ЦИКЛ ДЛЯ(в = 1, г_Тарифность)
                  г_кодДиапазонаЭЭ = кодДиапазонаЭЭ!в
                  //ind = СТР_ЗНАЧ(г_Тарифность) + "_" + СТР_ЗНАЧ(Token) + "_" + г_кодДиапазонаЭЭ + "_"
                  ЕСЛИ НЕ STG_СчитатьТарифы(дн, началоСледМесяца-1, М)  ТО
                    г_кодДиапазонаЭЭ = ""
                    //ind = СТР_ЗНАЧ(г_Тарифность) + "_" + СТР_ЗНАЧ(Token) + "_" + г_кодДиапазонаЭЭ + "_"
                    ib_protocol_кэшПротокола.ОЧИСТИТЬ
                    ib_protocol_кэшОшибок.ОЧИСТИТЬ
                    ЕСЛИ НЕ STG_СчитатьТарифы(дн, началоСледМесяца-1, М)  ТО
                      IB_PROTOCOL_ОбработатьИВывестиОшибки
                      СТОП_ВСЕ
                    ИНАЧЕ
                      stg_тариф!в = Т!в
                      stg_тарифСН!в = Т_СН!в
                    КОНЕЦ_ЕСЛИ
                  ИНАЧЕ
                    stg_тариф!в = Т!в
                    stg_тарифСН!в = Т_СН!в
                  КОНЕЦ_ЕСЛИ
                КОНЕЦ_ЦИКЛА
              ИНАЧЕ
                ЕСЛИ НЕ STG_СчитатьТарифы(дн, началоСледМесяца-1, М)  ТО
                  IB_PROTOCOL_ОбработатьИВывестиОшибки
                  СТОП_ВСЕ
                КОНЕЦ_ЕСЛИ
                ЦИКЛ ДЛЯ(ж = 1, 3)
                  ЕСЛИ СУЩ_ПЕРЕМ(Т!ж) ТО
                    stg_тариф!ж = Т!ж
                    stg_тарифСН!ж = Т_СН!ж
                  КОНЕЦ_ЕСЛИ
                КОНЕЦ_ЦИКЛА
              КОНЕЦ_ЕСЛИ
            КОНЕЦ_ЕСЛИ
            
            найденнаяПоз = sql_Корр.НАЙТИ_ПОЗ("ID_SCH", idSch)
            ЕСЛИ найденнаяПоз > 0 ТО
              ЦИКЛ ПОКА(ДА)
                
                ЕСЛИ найденнаяПоз > sql_Корр.ВСЕГО ТО
                  СТОП
                КОНЕЦ_ЕСЛИ
                sql_Корр.ПЕРЕЙТИ(найденнаяПоз)
                ЕСЛИ idSch <> sql_Корр.ПОЛЕ("ID_SCH") ТО
                  СТОП
                КОНЕЦ_ЕСЛИ
                
                ЕСЛИ СУЩ_ПЕРЕМ(коррИспользована!найденнаяПоз) ТО
                  найденнаяПоз++
                  ПРОДОЛЖИТЬ
                КОНЕЦ_ЕСЛИ
                
                корректировка!1 = 0
                корректировка!2 = 0
                корректировка!3 = 0
                ЦИКЛ ДЛЯ(ж = 1, 3)
                  ЕСЛИ г_КодСтатьиНачисления = к_СтатьиЭЭКод ИЛИ
                       ((г_КодСтатьиНачисления = к_СтатьиВКод ИЛИ г_КодСтатьиНачисления = к_СтатьиГКод) И ж = 1) ТО
                    корректировка!ж = sql_Корр.ПОЛЕ("NUM" + СТР_ЗНАЧ(ж))
                  КОНЕЦ_ЕСЛИ
                КОНЕЦ_ЦИКЛА
                
                СП.ОЧИСТИТЬ
                СП.ДОБАВИТЬ("INSERT INTO")
                СП.ДОБАВИТЬ("'" + ф_tmp001 + "' ")
                СП.ДОБАВИТЬ("(CORR, CODS, ID_AREA, ID_OWNER, N_AREA, " + 
                            "FLS, FIO, SRT, ID_SCH, NOM, COT, " + 
                            "DAT, T_DAT, NUM1, NUM2, NUM3, COMM, srv_slctd, ID_VZN, TOKEN, TOKEN_DATE) VALUES")
                СП.ДОБАВИТЬ("(TRUE,'" + main.ПОЛЕ("CODS") + "', " + СТР_ЗНАЧ(idArea) + ", " + СТР_ЗНАЧ(idOwner) + ", '" + main.ПОЛЕ("N_AREA"))
                СП.ДОБАВИТЬ("','" + флс + "', '" + main.ПОЛЕ("FIO") + "','" + main.ПОЛЕ("SRT") + "'," + СТР_ЗНАЧ(idSch))
                СП.ДОБАВИТЬ(",'" + main.ПОЛЕ("NOM") + "', " + СТР_ЗНАЧ(main.ПОЛЕ("COT")))
                СП.ДОБАВИТЬ(",'" + предДата + "','" + СТР(sql_Корр.ПОЛЕ("DAT")) + "'," + СТР_ЗНАЧ(корректировка!1) + ",")
                СП.ДОБАВИТЬ(СТР_ЗНАЧ(корректировка!2) + "," + СТР_ЗНАЧ(корректировка!3) + ",")
                СП.ДОБАВИТЬ("'" + sql_Корр.ПОЛЕ("COMM") + "', 'V', " + СТР_ЗНАЧ(г_идентВзноса!г_Тарифность) + ", " + СТР(Token) + ", '" + СТР(TokenDate) + "')")
                SQL_ЗАПРОС(СП)
                коррИспользована!найденнаяПоз = ДА
                найденнаяПоз++
              КОНЕЦ_ЦИКЛА
            КОНЕЦ_ЕСЛИ
            
            индЛогДобПок = СТР_ЗНАЧ(idSch) + "_" + СТР(текДата)
            ЕСЛИ НЕ СУЩ_ПЕРЕМ(логДобПоказаний!индЛогДобПок) ТО
              СП.ОЧИСТИТЬ
              СП.ДОБАВИТЬ("INSERT INTO")
              СП.ДОБАВИТЬ("'" + ф_tmp001 + "' ")
              СП.ДОБАВИТЬ("(CODS, ID_AREA, ID_OWNER, N_AREA, " + 
                          "FLS, FIO, SRT, ID_SCH, NOM, COT, " + 
                          "DAT, T_DAT, PNUM1, NUM1, PNUM2, NUM2, PNUM3, NUM3, " + 
                          "T1, T2, T3, T1SN, T2SN, T3SN, " + 
                          "P1, P2, P3, P, CORR, COMM, srv_slctd, ID_VZN, ROV1, ROV2, ROV3, TOKEN, TOKEN_DATE) VALUES ")
              СП.ДОБАВИТЬ("('" + main.ПОЛЕ("CODS") + "', " + СТР_ЗНАЧ(idArea) + ", " + СТР_ЗНАЧ(idOwner) + ", '" + main.ПОЛЕ("N_AREA"))
              СП.ДОБАВИТЬ("','" + флс + "', '" + main.ПОЛЕ("FIO") + "','" + main.ПОЛЕ("SRT") + "'," + СТР_ЗНАЧ(idSch))
              СП.ДОБАВИТЬ(",'" + main.ПОЛЕ("NOM") + "', " + СТР_ЗНАЧ(main.ПОЛЕ("COT")))
              СП.ДОБАВИТЬ(",'" + предДата + "','" + СТР(текДата) + "'," + СТР_ЗНАЧ(ПредПок!1) + "," + СТР_ЗНАЧ(ТекПок!1) + "," + СТР_ЗНАЧ(ПредПок!2) + ",")
              СП.ДОБАВИТЬ(СТР_ЗНАЧ(ТекПок!2) + "," + СТР_ЗНАЧ(ПредПок!3) + "," + СТР_ЗНАЧ(ТекПок!3) + ",")
              СП.ДОБАВИТЬ(СТР_ЗНАЧ(stg_тариф!1) + ", " + СТР_ЗНАЧ(stg_тариф!2) + ", " + СТР_ЗНАЧ(stg_тариф!3) + "," + 
                          СТР_ЗНАЧ(stg_тарифСН!1) + ", " + СТР_ЗНАЧ(stg_тарифСН!2) + ", " + СТР_ЗНАЧ(stg_тарифСН!3) + ",")
              СП.ДОБАВИТЬ(СТР_ЗНАЧ(Потери!1) + ", " + СТР_ЗНАЧ(Потери!2) + ", " + СТР_ЗНАЧ(Потери!3) + ", '" + УчетПотерь + "', FALSE, '', 'V', " + СТР_ЗНАЧ(г_идентВзноса!г_Тарифность)) 
              СП.ДОБАВИТЬ(", '" + кодДиапазонаЭЭ!1 + "', '" + кодДиапазонаЭЭ!2 + "', '" + кодДиапазонаЭЭ!3 + "', " + СТР(Token) + ", '" + СТР(TokenDate) + "')")
              SQL_ЗАПРОС(СП)
              логДобПоказаний!индЛогДобПок = ДА
            КОНЕЦ_ЕСЛИ
            
            ЕСЛИ г_способВводаПоказаний <> к_СпособВводаПокРазВМес И логВводаНовойСтроки И логПоз ТО
              ЕСЛИ (ТекПок!1 > 0 ИЛИ ТекПок!2 > 0 ИЛИ ТекПок!3 > 0) И текДата <> гр_ДатаПо ТО
                СП.ОЧИСТИТЬ
                СП.ДОБАВИТЬ("INSERT INTO")
                СП.ДОБАВИТЬ("'" + ф_tmp001 + "' ")
                СП.ДОБАВИТЬ("(CODS, ID_AREA, ID_OWNER, N_AREA, " + 
                            "FLS, FIO, SRT, ID_SCH, NOM, COT, " + 
                            "DAT, T_DAT, PNUM1, NUM1, PNUM2, NUM2, PNUM3, NUM3, " + 
                            "T1, T2, T3, T1SN, T2SN, T3SN, " + 
                            "P1, P2, P3, P, CORR, COMM, srv_slctd, ID_VZN, ROV1, ROV2, ROV3, TOKEN, TOKEN_DATE) VALUES ")
                СП.ДОБАВИТЬ("('" + main.ПОЛЕ("CODS") + "', " + СТР_ЗНАЧ(idArea) + ", " + СТР_ЗНАЧ(idOwner) + ", '" + main.ПОЛЕ("N_AREA"))
                СП.ДОБАВИТЬ("','" + флс + "', '" + main.ПОЛЕ("FIO") + "','" + main.ПОЛЕ("SRT") + "'," + СТР_ЗНАЧ(idSch))
                СП.ДОБАВИТЬ(",'" + main.ПОЛЕ("NOM") + "', " + СТР_ЗНАЧ(main.ПОЛЕ("COT")))
                СП.ДОБАВИТЬ(",'" + СТР(текДата) + "','" + СТР(гр_ДатаПо) + "'," + СТР_ЗНАЧ(ТекПок!1) + ",0," + СТР_ЗНАЧ(ТекПок!2) + ",0")
                СП.ДОБАВИТЬ("," + СТР_ЗНАЧ(ТекПок!3) + ",0,")
                СП.ДОБАВИТЬ(СТР_ЗНАЧ(stg_тариф!1) + ", " + СТР_ЗНАЧ(stg_тариф!2) + ", " + СТР_ЗНАЧ(stg_тариф!3) + "," + 
                            СТР_ЗНАЧ(stg_тарифСН!1) + ", " + СТР_ЗНАЧ(stg_тарифСН!2) + ", " + СТР_ЗНАЧ(stg_тарифСН!3) + ",")
                СП.ДОБАВИТЬ(СТР_ЗНАЧ(Потери!1) + ", " + СТР_ЗНАЧ(Потери!2) + ", " + СТР_ЗНАЧ(Потери!3) + ", '" + УчетПотерь + "', FALSE, '', 'V', " + СТР_ЗНАЧ(г_идентВзноса!г_Тарифность)) 
                СП.ДОБАВИТЬ(", '" + кодДиапазонаЭЭ!1 + "', '" + кодДиапазонаЭЭ!2 + "', '" + кодДиапазонаЭЭ!3 + "', " + СТР(Token) + ", '" + СТР(TokenDate) + "')")
                SQL_ЗАПРОС(СП)
                логДобПоказаний!индЛогДобПок = ДА
              КОНЕЦ_ЕСЛИ
            КОНЕЦ_ЕСЛИ
            
            всегоMain++
            проц = РУБ(100 * всегоMain / колЗап)
            ОКНО_СТАТУСА("PROGRESS", "Обработано " + СТР_ЗНАЧ(всегоMain) + " из " + СТР_ЗНАЧ(колЗап) + " (" + СТР_ЗНАЧ(проц) + "%)")
            ОКНО_СТАТУСА("PERCENT", СТР_ЗНАЧ(проц))
          КОНЕЦ_ЦИКЛА
          sql.ЗАКРЫТЬ
          sql_ПредПоказания.ЗАКРЫТЬ
          sql_ТекПоказания.ЗАКРЫТЬ
          sql_Корр.ЗАКРЫТЬ
        КОНЕЦ_ЦИКЛА
        date.ЗАКРЫТЬ
        СБРОС(логДобПоказаний)
        СБРОС(коррИспользована)
        
        //обновим расчет потерь для новых показаний, если он поддерживается
        ЕСЛИ г_КодСтатьиНачисления = к_СтатьиЭЭКод И гр_ВарУчПотерь <> "" И гр_ВарУчПотерь <> к_ВарУчПотерьНет ТО
          СП.ОЧИСТИТЬ
          СП.ДОБАВИТЬ("UPDATE '" + ф_tmp001 + "' ")
          СП.ДОБАВИТЬ("SET P1 = " + СТР_ЗНАЧ(гр_ЗначПотерьТ1) + ", P = '" + гр_ВарУчПотерь + "' " + 
                      "WHERE (NUM1 = 0 OR P = '' OR P1 = 0) AND COT = 1")
          SQL_ЗАПРОС(СП)
          
          СП.ОЧИСТИТЬ
          СП.ДОБАВИТЬ("UPDATE '" + ф_tmp001 + "' ")
          СП.ДОБАВИТЬ("SET P1 = " + СТР_ЗНАЧ(гр_ЗначПотерьТ1) + ", P2 = " + СТР_ЗНАЧ(гр_ЗначПотерьТ2) + ", P = '" + гр_ВарУчПотерь + "' " + 
                      "WHERE ((NUM1 = 0 AND NUM2 = 0) OR P = '' OR (P1 = 0 AND P2 = 0)) AND COT = 2")
          SQL_ЗАПРОС(СП)
          
          СП.ОЧИСТИТЬ
          СП.ДОБАВИТЬ("UPDATE '" + ф_tmp001 + "' ")
          СП.ДОБАВИТЬ("SET P1 = " + СТР_ЗНАЧ(гр_ЗначПотерьТ1) + ", P2 = " + СТР_ЗНАЧ(гр_ЗначПотерьТ2) + ", P3 = " + СТР_ЗНАЧ(гр_ЗначПотерьТ3) + ", P = '" + гр_ВарУчПотерь + "' " + 
                      "WHERE ((NUM1 = 0 AND NUM2 = 0 AND NUM3 = 0) OR P = '' OR (P1 = 0 AND P2 = 0 AND P3 = 0)) AND COT = 3")
          SQL_ЗАПРОС(СП)
        КОНЕЦ_ЕСЛИ
      КОНЕЦ_ЕСЛИ  // начисление без ввода показаний
    КОНЕЦ_ЕСЛИ
    ОКНО_СТАТУСА("CLOSE")
    
    //сортировка для верного отображения
    СП.ОЧИСТИТЬ
    СП.ДОБАВИТЬ("SELECT * FROM")
    СП.ДОБАВИТЬ("'" + ф_tmp001 + "'")
    СП.ДОБАВИТЬ("ORDER BY SRT, FIO, NOM, T_DAT, PNUM1, CORR")
    sql = SQL_ЗАПРОС(СП)
    sql1 = SQL_КЛОНИРОВАТЬ(sql)
    sql.ЗАКРЫТЬ
    IB_FILE_ФайлУдалить(ф_tmp001)
    sql1.ЗАПИСАТЬ(ф_tmp001)
    sql1.ЗАКРЫТЬ
    
    /*sql = SQL_ОТКРЫТЬ(ф_tmp001)
    sql.СОРТИРОВКА("SRT", "FIO", "NOM", "T_DAT", "PNUM1", "CORR")
    sql.ЗАКРЫТЬ*/
    
    //Вызовем файл на редактирование.
    СТРОКА_СТАТУСА("Редактирование " + ?(оп_НачислениеБезТекПок, "сумм", "показаний"))
    
    ЦИКЛ ДЛЯ(тар = минТарифность, максТарифность)
      логВып = НЕТ
      //
      ЕСЛИ НЕ оп_НачислениеБезТекПок ТО
        СП.ОЧИСТИТЬ
        СП.ДОБАВИТЬ("SELECT * FROM")
        СП.ДОБАВИТЬ("'" + ф_tmp001 + "'")
        СП.ДОБАВИТЬ("WHERE COT = " + СТР_ЗНАЧ(тар) + " AND P <> ''")
        sql = SQL_ЗАПРОС(СП)
        логВывБДРедПотерь = (sql.ВСЕГО > 0)
        sql.ЗАКРЫТЬ
      КОНЕЦ_ЕСЛИ
      //
      СП.ОЧИСТИТЬ
      СП.ДОБАВИТЬ("SELECT * FROM")
      СП.ДОБАВИТЬ("'" + ф_tmp001 + "'")
      СП.ДОБАВИТЬ("WHERE COT = " + СТР_ЗНАЧ(тар))
      sql = SQL_ЗАПРОС(СП)
      ЕСЛИ sql.IB_DBF_ЗаписатьSqlВФайл(ф_tmp024) ТО
        sql = SQL_ОТКРЫТЬ(ф_tmp024)
        ЕСЛИ оп_Начисление ТО
          набор = "набор"
          БД_СБРОС_СТОЛБЦОВ(набор)
          
          БД_ДОБАВИТЬ_СТОЛБЕЦ(набор, "srv_slctd", "", 1, "Ч")
          ЕСЛИ оп_НачислениеБезТекПок ТО
            БД_ДОБАВИТЬ_СТОЛБЕЦ(набор, "N_AREA", текстЗагИПЗагл, 10, "%")
            БД_ДОБАВИТЬ_СТОЛБЕЦ(набор, "FIO", "Ф.И.О.", 35, "%")
            //БД_ДОБАВИТЬ_СТОЛБЕЦ(набор, "NOM", "№ счётчика", 15, "%")
            БД_ДОБАВИТЬ_СТОЛБЕЦ(набор, "NUM1", "Сумма", 15)
          ИНАЧЕ
            ЕСЛИ всегоКорр > 0 ТО
              БД_ДОБАВИТЬ_СТОЛБЕЦ(набор, "CORR", "Корр.", 5, "%")
            КОНЕЦ_ЕСЛИ
            
            БД_ДОБАВИТЬ_СТОЛБЕЦ(набор, "N_AREA", текстЗагИПЗагл, 10, "%")
            БД_ДОБАВИТЬ_СТОЛБЕЦ(набор, "FIO", "Ф.И.О.", 35, "%")
            БД_ДОБАВИТЬ_СТОЛБЕЦ(набор, "NOM", "№ счётчика", 15, "%")
            БД_ДОБАВИТЬ_СТОЛБЕЦ(набор, "DAT", "Дата " + СИМВ(13) + "пред. пок.", 11, "%")
            ЕСЛИ г_способВводаПоказаний <> к_СпособВводаПокРазВМес ТО
              БД_ДОБАВИТЬ_СТОЛБЕЦ(набор, "T_DAT", "Дата ввода" + СИМВ(13) + "тек. пок.", 11)
            КОНЕЦ_ЕСЛИ
            ЕСЛИ г_КодСтатьиНачисления = к_СтатьиЭЭКод ТО
              лог1 = логВывБДРедПотерь ИЛИ (НЕ логВывБДРедПотерь И гр_ВарУчПотерь <> "" И гр_ВарУчПотерь <> к_ВарУчПотерьНет)
              ЦИКЛ ДЛЯ(и = 1, тар)
                БД_ДОБАВИТЬ_СТОЛБЕЦ(набор, "PNUM" + СТР_ЗНАЧ(и), "Пред. пок. Т" + СТР_ЗНАЧ(и), 15, "%")
                БД_ДОБАВИТЬ_СТОЛБЕЦ(набор, "NUM" + СТР_ЗНАЧ(и), "Тек. пок. Т" + СТР_ЗНАЧ(и), 15)
                ЕСЛИ лог1 ТО
                  БД_ДОБАВИТЬ_СТОЛБЕЦ(набор, "P" + СТР_ЗНАЧ(и), "Потери Т" + СТР_ЗНАЧ(и), 15)
                КОНЕЦ_ЕСЛИ
              КОНЕЦ_ЦИКЛА
              ЕСЛИ лог1 ТО
                БД_ДОБАВИТЬ_СТОЛБЕЦ(набор, "P", "Вариант учета потерь", 20, "", "обрВарУчПотерь")
              КОНЕЦ_ЕСЛИ
            ИНАЧЕ
              БД_ДОБАВИТЬ_СТОЛБЕЦ(набор, "NUM1", "Тек. пок.", 15)
            КОНЕЦ_ЕСЛИ
          КОНЕЦ_ЕСЛИ
          
          т = 0
          ЕСЛИ sql.ВСЕГО > 0 ТО
            т = БД_РЕДАКТОР(sql, "Редактор показаний ИПУ (F4 - изменить; двойной клик - вкл/выкл)",
                            [
                             СТОЛБЦЫ(набор),
                             "обрВарУчПотерь": ("ST_GSK\TOP\ST_GSK_METERS", "STG_ВариантУчПотерь"(ТИП_СТРОКА))
                            ], ДА, НЕТ, НЕТ, ДА,
                            [
                              //В: ("IB_DLG.IBL", "IB_DLG_ПереклПоляВыбора"),
                              Ж: ("IB_DLG.IBL", "IB_DLG_МножУстПоляВыбора"),
                              М: ("ST_GSK\BLW\ST_GSK_02SPIS", "STG_ПереключательВыбора")
                            ];
                            перекл_выбора = ДА;
                            @путь_файла = ф_tmp024;
                            @поле_выбора = "srv_slctd";
                            яч_курсор = ДА)
          КОНЕЦ_ЕСЛИ
          логВып = т > 0
          изменена = sql.ИЗМЕНЕНА
        ИНАЧЕ
          изменена = НЕТ
          логВып = ДА
        КОНЕЦ_ЕСЛИ
      КОНЕЦ_ЕСЛИ
      
      //Теперь переходим к формированию платежек, проводок и т.д.
      ЕСЛИ логВып ТО
        //
        ЕСЛИ оп_учетОплат ТО
          г_колВзносов = 1
          stg_текВзносыФильтра!г_КодСтатьиНачисления = ДА
          СБРОС(stg_суммаОплатНаДату)
          STG_ОплатыНаДату(датаОперации, НЕТ)
          //ОТЛАДКА(&stg_суммаОплатНаДату)
          //СТОП_ВСЕ
        КОНЕЦ_ЕСЛИ
        
        //не очень хорошее решение, но пока сделаю так. если через один цикл, то слишком запутано
        //номера строк каждого пд в файле по ФЛС
        начСтрокаПД!г_сервИнд = 0
        конСтрокаПД!г_сервИнд = 0
        ЦИКЛ ДЛЯ(и = 1, sql.ВСЕГО)
          sql.ПЕРЕЙТИ(и)
          индекс = sql.ПОЛЕ("SRT") + г_раздОб + СТР_ЗНАЧ(sql.ПОЛЕ("ID_AREA"))
          ЕСЛИ НЕ СУЩ_ПЕРЕМ(начСтрокаПД!индекс) ТО
            начСтрокаПД!индекс = и
          КОНЕЦ_ЕСЛИ
          конСтрокаПД!индекс = и
        КОНЕЦ_ЦИКЛА
        //
        текПД = 0
        всегоПД = КОЛ_ЭЛЕМ(начСтрокаПД) - 1
        ОКНО_СТАТУСА("CREATE", "Идет формирование ПД...")
        //
        ЦИКЛ ИНДЕКС(начНом = начСтрокаПД!инд)
          ЕСЛИ инд = г_сервИнд ТО
            ПРОДОЛЖИТЬ
          КОНЕЦ_ЕСЛИ
          конНом = конСтрокаПД!инд
          //
          ЕСЛИ НЕ оп_НачислениеБезТекПок ТО
            СБРОС(парамИПУ)
            парамИПУ!г_сервИнд = ДА
            ЦИКЛ ДЛЯ (и = начНом, конНом)
              sql.ПЕРЕЙТИ(и)
              ЕСЛИ sql.ПОЛЕ("CORR") ТО
                //параметры ИПУ
                Id_Sch = sql.ПОЛЕ("ID_SCH")
                датаКорр = СТР(sql.ПОЛЕ("T_DAT"))
                
                парамИПУ!"1_"!Id_Sch!"_"!датаКорр = sql.ПОЛЕ("NUM1")
                парамИПУ!"2_"!Id_Sch!"_"!датаКорр = sql.ПОЛЕ("NUM2")
                парамИПУ!"3_"!Id_Sch!"_"!датаКорр = sql.ПОЛЕ("NUM3")
              КОНЕЦ_ЕСЛИ
            КОНЕЦ_ЦИКЛА
          КОНЕЦ_ЕСЛИ
          //сброс
          графаАдрес = ""
          графаФИО = ""
          должок = 0
          долгПотери = 0
          суммаНачисления = 0
          суммаПотериИтого = 0
          текПоз = 0
          н_п = назнПлатУмолч
          //
          СОЗДАТЬ(оп, ТИП_ОПЕРАЦИЯ)
          СОЗДАТЬ(опПотери, ТИП_ОПЕРАЦИЯ)
          ЦИКЛ ДЛЯ(и = начНом, конНом)
            sql.ПЕРЕЙТИ(и)
            ЕСЛИ sql.ПОЛЕ("srv_slctd") = "" ТО
              ПРОДОЛЖИТЬ
            КОНЕЦ_ЕСЛИ
            суммаПотери = 0 //потери для каждого показания свои и суммируются в суммаПотериИтого
            //если корректировка, то пропускаем
            ЕСЛИ sql.ПОЛЕ("CORR") ТО
              ПРОДОЛЖИТЬ
            КОНЕЦ_ЕСЛИ
            //параметры участка
            цл_КодУл = sql.ПОЛЕ("CODS")
            цл_КодУчГарПольз = sql.ПОЛЕ("N_AREA")
            флс = sql.ПОЛЕ("FLS")
            г_ФЛС = флс
            цл_ФИО = sql.ПОЛЕ("FIO")
            номерДома = sql.ПОЛЕ("N_DOM")
            Id_Area = sql.ПОЛЕ("ID_AREA")
            идентВладельца = sql.ПОЛЕ("ID_OWNER")
            г_идентСтатьи = sql.ПОЛЕ("ID_VZN")
            улица = ""
            
            ЕСЛИ STG_ДобУлицу ТО
              улица = УлНазв!цл_КодУл
            КОНЕЦ_ЕСЛИ
            //для отправки на почту
            email = ""
            ЕСЛИ СУЩ_ПЕРЕМ(eMail!идентВладельца) ТО
              email = eMail!идентВладельца
            КОНЕЦ_ЕСЛИ
            //
            счетУчастка = дебСчетПлаты + "/" + цл_КодУл + "/" + IB_STR_СтрСимвСлева(цл_КодУчГарПольз, "0", г_длинаКодаУчасткаПС)
            имяФайла = текстЗагИП + " " + цл_КодУчГарПольз + ", " + цл_ФИО
            //
            номсч = sql.ПОЛЕ("NOM")
            Id_Sch = sql.ПОЛЕ("ID_SCH")
            
            //тут блок для корректного вывода данных в квиток
            СуммаИтого = 0
            ЕСЛИ оп_НачислениеБезТекПок ТО
              СуммаИтого = sql.ПОЛЕ("NUM1")
            ИНАЧЕ
              ЦИКЛ ДЛЯ (ж = 1, 3)
                ПредПок!ж = sql.ПОЛЕ("PNUM" + СТР_ЗНАЧ(ж))
                //
                Показание!ж = sql.ПОЛЕ("NUM" + СТР_ЗНАЧ(ж))
                Т!ж = sql.ПОЛЕ("T" + СТР_ЗНАЧ(ж))
                Т_СН!ж = sql.ПОЛЕ("T" + СТР_ЗНАЧ(ж) + "SN")
                Потери!ж = sql.ПОЛЕ("P" + СТР_ЗНАЧ(ж))
                СуммаПотерь!ж = 0
              КОНЕЦ_ЦИКЛА
              текПоз++
              //параметры ИПУ
              предДата = ?(sql.ПОЛЕ("DAT") = к_МинДата, "нач. пок.", СТР(sql.ПОЛЕ("DAT")))
              ВарУчПотерь = sql.ПОЛЕ("P")
              г_КолТарифов = sql.ПОЛЕ("COT")
              датаПоказания = СТР(sql.ПОЛЕ("T_DAT"))
              ЕСЛИ получениеПокССайта ТО
                текстПериод = МЕСП(МЕС(sql.ПОЛЕ("DAT"))) + " " + СТР(ГОД(sql.ПОЛЕ("DAT")))
              ИНАЧЕ
                текстПериод = гр_Месяц + " " + СТР(гр_Год) + " г."
              КОНЕЦ_ЕСЛИ
              //
              г_коррПокИПУ!1 = 0
              г_коррПокИПУ!2 = 0
              г_коррПокИПУ!3 = 0
              коррУчтена!г_сервИнд = ДА
              ЦИКЛ ИНДЕКС(значКорр = парамИПУ!индКорр)
                ЕСЛИ индКорр = г_сервИнд ТО
                  ПРОДОЛЖИТЬ
                КОНЕЦ_ЕСЛИ
                //
                ЕСЛИ НЕ СУЩ_ПЕРЕМ(коррУчтена!индКорр) ТО
                  коррУчтена!индКорр = НЕТ
                ИНАЧЕ
                  ЕСЛИ коррУчтена!индКорр ТО
                    ПРОДОЛЖИТЬ
                  КОНЕЦ_ЕСЛИ
                КОНЕЦ_ЕСЛИ
                //
                идИПУ = СТР_ФРАГ(индКорр, "_", 2)
                ЕСЛИ идИПУ = СТР_ЗНАЧ(Id_Sch) ТО
                  ЕСЛИ IB_DATE_СтрокаДата(СТР_ФРАГ(индКорр, "_", 3), датаКоррД) ТО
                    ЕСЛИ датаКоррД >= sql.ПОЛЕ("DAT") И
                         датаКоррД <= sql.ПОЛЕ("T_DAT") ТО
                      кодТарЗоны = СТР_ФРАГ(индКорр, "_", 1)
                      г_коррПокИПУ!кодТарЗоны = г_коррПокИПУ!кодТарЗоны + значКорр
                      коррУчтена!индКорр = ДА
                    КОНЕЦ_ЕСЛИ
                  КОНЕЦ_ЕСЛИ
                КОНЕЦ_ЕСЛИ
              КОНЕЦ_ЦИКЛА
              //
              Показание!1 = Показание!1 + г_коррПокИПУ!1
              Показание!2 = Показание!2 + г_коррПокИПУ!2
              Показание!3 = Показание!3 + г_коррПокИПУ!3
              
              //подсчет возможности сохранение показаний в базу. если ДА, то будет расчет суммы.
              Сохранено = (ПредПок!1 <= Показание!1 ИЛИ ПредПок!2 <= Показание!2 ИЛИ ПредПок!3 <= Показание!3) И
                          (Показание!1 > 0 ИЛИ Показание!2 > 0 ИЛИ Показание!3 > 0)
              
              //подсчет сумм начисления
              ЕСЛИ оп_Начисление И Сохранено ТО
                ЕСЛИ г_КодСтатьиНачисления = к_СтатьиЭЭКод ТО
                  STG_СуммаНачислЭЭ(СуммаИтого)
                ИНАЧЕ
                  STG_СуммаНачислВГ(СуммаИтого)
                КОНЕЦ_ЕСЛИ
                //
                ЦИКЛ ДЛЯ(тз = 1, ?(г_КодСтатьиНачисления = к_СтатьиЭЭКод, 3, 1))
                  ЕСЛИ г_НастройкиРасчетаСНЭЭ!"Расчет" И ТипСч = "ЭЭ" ТО
                    sql.ЗАП_ПОЛЕ("SUM_T" + СТР_ЗНАЧ(тз), г_суммаНачЭЭ!"поСН_"!тз)
                    sql.ЗАП_ПОЛЕ("T" + СТР_ЗНАЧ(тз) + "_VOL", г_объемЭЭ!"поСН_"!тз)
                    sql.ЗАП_ПОЛЕ("SUM_SNT" + СТР_ЗНАЧ(тз), г_суммаНачЭЭ!"сверхСН_"!тз)
                    sql.ЗАП_ПОЛЕ("T" + СТР_ЗНАЧ(тз) + "SN_VOL", г_объемЭЭ!"сверхСН_"!тз)
                  ИНАЧЕ
                    sql.ЗАП_ПОЛЕ("SUM_T" + СТР_ЗНАЧ(тз), СуммаНач!тз)
                    sql.ЗАП_ПОЛЕ("T" + СТР_ЗНАЧ(тз) + "_VOL", Показание!тз - ПредПок!тз)
                  КОНЕЦ_ЕСЛИ  
                  ЕСЛИ ТипСч = "ЭЭ" ТО
                    sql.ЗАП_ПОЛЕ("SUM_PT" + СТР_ЗНАЧ(тз), СуммаПотерь!тз)
                  КОНЕЦ_ЕСЛИ
                  sql.ЗАМЕНИТЬ
                КОНЕЦ_ЦИКЛА
              КОНЕЦ_ЕСЛИ
              
              //определим суммы потерь и начисления
              ЕСЛИ гр_ТипСч = "Электроэнергия" ТО
                ЦИКЛ ДЛЯ(тарЗонаПотерь = 1, г_КолТарифов)
                  ЕСЛИ СУЩ_ПЕРЕМ(СуммаПотерь!тарЗонаПотерь) ТО
                    суммаПотери = суммаПотери + СуммаПотерь!тарЗонаПотерь
                    суммаПотериИтого = суммаПотериИтого + СуммаПотерь!тарЗонаПотерь
                  ИНАЧЕ
                    СуммаПотерь!тарЗонаПотерь = 0
                    СуммаНач!тарЗонаПотерь = 0
                  КОНЕЦ_ЕСЛИ
                КОНЕЦ_ЦИКЛА
                суммаПотери = ОКРУГЛЕНИЕ(суммаПотери, ?(ПараметрПечатиПД!"Округлять", 0, 2))
                суммаПотериИтого = ОКРУГЛЕНИЕ(суммаПотериИтого, ?(ПараметрПечатиПД!"Округлять", 0, 2))
              КОНЕЦ_ЕСЛИ
            КОНЕЦ_ЕСЛИ
            
            //адрес
            ЕСЛИ графаАдрес = "" ТО
              STG_ДобавитьЗначениеПарам(к_ШаблонАдресПлательщика, к_ШаблонПредприят, Предприят)
              STG_ДобавитьЗначениеПарам(к_ШаблонАдресПлательщика, к_ШаблонПредприятПолн, ПредприятПолн)
              STG_ДобавитьЗначениеПарам(к_ШаблонАдресПлательщика, к_ШаблонФИО, цл_ФИО)
              STG_ДобавитьЗначениеПарам(к_ШаблонАдресПлательщика, к_ШаблонЛС, флс)
              STG_ДобавитьЗначениеПарам(к_ШаблонАдресПлательщика, ?(г_блокГСК, к_ШаблонНомерГар, к_ШаблонНомерУч), цл_КодУчГарПольз)
              STG_ДобавитьЗначениеПарам(к_ШаблонАдресПлательщика, к_ШаблонНомерДома, номерДома)
              STG_ДобавитьЗначениеПарам(к_ШаблонАдресПлательщика, ?(г_блокГСК, к_ШаблонЛиния, к_ШаблонУлица), улица)
              графаАдрес = STG_ЗаполнитьАдрес("ПД")
            КОНЕЦ_ЕСЛИ
            //фио
            ЕСЛИ графаФИО = "" ТО
              STG_ДобавитьЗначениеПарам(к_ШаблонФИОПлательщика, к_ШаблонПредприят, Предприят)
              STG_ДобавитьЗначениеПарам(к_ШаблонФИОПлательщика, к_ШаблонПредприятПолн, ПредприятПолн)
              STG_ДобавитьЗначениеПарам(к_ШаблонФИОПлательщика, к_ШаблонФИО, цл_ФИО)
              STG_ДобавитьЗначениеПарам(к_ШаблонФИОПлательщика, к_ШаблонЛС, флс)
              STG_ДобавитьЗначениеПарам(к_ШаблонФИОПлательщика, ?(г_блокГСК, к_ШаблонНомерГар, к_ШаблонНомерУч), цл_КодУчГарПольз)
              STG_ДобавитьЗначениеПарам(к_ШаблонФИОПлательщика, к_ШаблонНомерДома, номерДома)
              STG_ДобавитьЗначениеПарам(к_ШаблонФИОПлательщика, ?(г_блокГСК, к_ШаблонЛиния, к_ШаблонУлица), улица)
              графаФИО = STG_ЗаполнитьФИО
            КОНЕЦ_ЕСЛИ
            
            //формирование реестра для выгрузки в банк
            ЕСЛИ оп_ФормироватьРеестр ТО
              срт = sql.ПОЛЕ("SRT")
              ЕСЛИ НЕ СУЩ_ПЕРЕМ(строкиРеестра!срт!г_раздОб!Id_Area) ТО
                строкиРеестра!срт!г_раздОб!Id_Area = флс + ";" + цл_ФИО + ";" + 
                                                     Предприят + ", " + текстЗагИП + " " + цл_КодУчГарПольз
              КОНЕЦ_ЕСЛИ 
              ЦИКЛ ДЛЯ(пок = 1, г_КолТарифов)
                ЕСЛИ ПредПок!пок > 0 ТО
                  строкиРеестра!срт!г_раздОб!Id_Area = строкиРеестра!срт!г_раздОб!Id_Area + ";;0.00;" + 
                                                       гр_ТипСч + ";" + ЗАМ(".", STG_ЧислоВСтрОтч(ПредПок!пок), ",")
                  // + ЗАМ(".",STG_ЧислоВСтрОтч(СуммаИтого),",") + ";" + /*Ф.ПОЛЕ("NOM") + */
                КОНЕЦ_ЕСЛИ
              КОНЕЦ_ЦИКЛА
            КОНЕЦ_ЕСЛИ
            
            суммаПоТекПок = ОКРУГЛЕНИЕ(СуммаИтого, ?(ПараметрПечатиПД!"Округлять", 0, 2))
            суммаНачисления = суммаНачисления + суммаПоТекПок
            
            //Проводки
            ЕСЛИ делатьПроводки ТО
              логНоваяДата = оп_датаОпПоДатеПок И (оп.дата <> sql.ПОЛЕ("T_DAT"))
              //
              ЕСЛИ логНоваяДата И оп.КОЛ_ПРОВ > 0 ТО
                оп.STG_ЗаписатьХозОп(суммаПотери, НЕТ)
                опПотери.STG_ЗаписатьХозОпПотери(суммаПотери, НЕТ)
                СОЗДАТЬ(оп, ТИП_ОПЕРАЦИЯ)
                СОЗДАТЬ(опПотери, ТИП_ОПЕРАЦИЯ)
              КОНЕЦ_ЕСЛИ
              
              ЕСЛИ и = начНом ИЛИ оп.название = "" ТО
                STG_ДобавитьЗначениеПарам(к_ШаблонСодержаниеХозОп, к_ШаблонПериод, текстПериод)
                STG_ДобавитьЗначениеПарам(к_ШаблонСодержаниеХозОп, к_ШаблонФИО, цл_ФИО)
                STG_ДобавитьЗначениеПарам(к_ШаблонСодержаниеХозОп, ?(г_блокГСК, к_ШаблонНомерГар, к_ШаблонНомерУч), цл_КодУчГарПольз)
                STG_ДобавитьЗначениеПарам(к_ШаблонСодержаниеХозОп, к_ШаблонТипИПУ, ?(гр_ТипСч = к_СтатьиЭЭ, "электроэнергию", 
                                                                                     ?(гр_ТипСч = к_СтатьиВ, "воду", "газ")))
                STG_ДобавитьЗначениеПарам(к_ШаблонСодержаниеХозОп, к_ШаблонИПУ, номсч)
                ЦИКЛ ДЛЯ(т = 1, г_КолТарифов)
                  ЕСЛИ оп_НачислениеБезТекПок ТО
                    STG_ДобавитьЗначениеПарам(к_ШаблонСодержаниеХозОп, к_ШаблонППок, "")
                    STG_ДобавитьЗначениеПарам(к_ШаблонСодержаниеХозОп, к_ШаблонТПок, "")
                  ИНАЧЕ
                    STG_ДобавитьЗначениеПарам(к_ШаблонСодержаниеХозОп, к_ШаблонППок, "Т" + СТР_ЗНАЧ(т) + ": " + СТР_ЗНАЧ(ПредПок!т))
                    STG_ДобавитьЗначениеПарам(к_ШаблонСодержаниеХозОп, к_ШаблонТПок, "Т" + СТР_ЗНАЧ(т) + ": " + СТР_ЗНАЧ(Показание!т))
                  КОНЕЦ_ЕСЛИ
                  STG_ЗаполнитьСодержаниеХО(к_содХОПоНачПоИПУКод)
                КОНЕЦ_ЦИКЛА
                //
                оп.STG_ЗаполнитьПарамОп(гр_Месяц + " " + СТР(гр_Год) + " г.", ТипСч)
                ЕСЛИ оп_датаОпПоДатеПок ТО
                  оп.дата = sql.ПОЛЕ("T_DAT")
                  оп.STG_ДобПроводкуПоНач(суммаПоТекПок + ?(гр_ОтдХОНаПотери, 0, суммаПотери), деб, кред)
                КОНЕЦ_ЕСЛИ
                //
                ЕСЛИ гр_ОтдХОНаПотери И НЕ оп_НачислениеБезТекПок ТО
                  опПотери.STG_ЗаполнитьПарамОп(гр_Месяц + " " + СТР(гр_Год) + " г.", к_СтатьиПотЭЭКодСерв)
                  опПотери.документ = ?(г_блокГСК, "начГСК", "начСНТ") + СТР_ЗНАЧ(г_последнийНомерОп)
                  ЕСЛИ оп_датаОпПоДатеПок ТО
                    опПотери.дата = sql.ПОЛЕ("T_DAT")
                    опПотери.STG_ДобПроводкуПоНач(суммаПотери, деб, кред)
                  КОНЕЦ_ЕСЛИ
                КОНЕЦ_ЕСЛИ
              ИНАЧЕ
                ЕСЛИ оп_датаОпПоДатеПок ТО
                  ЕСЛИ и = конНом И (оп.дата = sql.ПОЛЕ("T_DAT")) ТО //спорно, но работает
                    оп.дата = sql.ПОЛЕ("T_DAT")
                    оп.STG_ДобПроводкуПоНач(суммаПоТекПок + ?(гр_ОтдХОНаПотери, 0, суммаПотери), деб, кред)
                    ЕСЛИ гр_ОтдХОНаПотери И НЕ оп_НачислениеБезТекПок ТО
                      опПотери.STG_ДобПроводкуПоНач(суммаПотери, деб, кред)
                    КОНЕЦ_ЕСЛИ
                  ИНАЧЕ
                    ЕСЛИ и <> конНом ТО
                      оп.STG_ДобПроводкуПоНач(суммаПоТекПок + ?(гр_ОтдХОНаПотери, 0, суммаПотери), деб, кред)
                      ЕСЛИ гр_ОтдХОНаПотери И НЕ оп_НачислениеБезТекПок ТО
                        опПотери.STG_ДобПроводкуПоНач(суммаПотери, деб, кред)
                      КОНЕЦ_ЕСЛИ
                    КОНЕЦ_ЕСЛИ
                  КОНЕЦ_ЕСЛИ
                КОНЕЦ_ЕСЛИ
              КОНЕЦ_ЕСЛИ
              
              ЕСЛИ и = конНом ТО
                ЕСЛИ оп_датаОпПоДатеПок ТО
                  оп.STG_ЗаписатьХозОп(суммаПотери, НЕТ)
                  опПотери.STG_ЗаписатьХозОпПотери(суммаПотери, НЕТ)
                ИНАЧЕ
                  оп.STG_ДобПроводкуПоНач(суммаНачисления, деб, кред)
                  оп.STG_ЗаписатьХозОп(суммаПотериИтого, ДА)
                  опПотери.STG_ЗаписатьХозОпПотери(суммаПотериИтого, ДА)
                КОНЕЦ_ЕСЛИ
              КОНЕЦ_ЕСЛИ
            КОНЕЦ_ЕСЛИ
            //конец проводки
            
            //печать извещений
            текПокСтр = ""
            предПокСтр = ""
            расходСтр = ""
            ЕСЛИ действие <> "НИЧЕГО НЕ ДЕЛАТЬ" ТО
              ЕСЛИ оп_Начисление ТО
                ЕСЛИ оп_НачислениеБезТекПок ТО
                  ЕСЛИ гр_ТипСч = "Электроэнергия" ТО
                    STG_ДобавитьСтрокуПДЭЭ(номсч, 0, 0, 0, 0, 0, СуммаИтого)
                  ИНАЧЕ
                    STG_ДобавитьСтрокуПДВГ(номсч, 0, 0, 0, СуммаИтого)
                  КОНЕЦ_ЕСЛИ
                ИНАЧЕ
                  ЕСЛИ НЕ (Показание!1 = 0 И Показание!2 = 0 И Показание!3 = 0) ТО
                    /*ЕСЛИ гр_ТипСч = "Электроэнергия" ТО
                      STG_ДобавитьПустуюСтроку(номсч)
                    ИНАЧЕ
                      STG_ДобавитьПустуюСтроку(номсч)
                    КОНЕЦ_ЕСЛИ*/
                    ЦИКЛ ДЛЯ(тарЗона = 1, г_КолТарифов)
                      ЕСЛИ гр_ТипСч = "Электроэнергия" ТО
                        ЕСЛИ г_НастройкиРасчетаСНЭЭ!"Расчет" ТО
                          ЕСЛИ СУЩ_ПЕРЕМ(г_суммаНачЭЭ!"сверхСН_"!тарЗона) ТО
                            ЕСЛИ г_суммаНачЭЭ!"сверхСН_"!тарЗона = 0 ТО
                              ЕСЛИ г_суммаНачЭЭ!"поСН_"!тарЗона = 0 ТО
                                STG_ДобавитьСтрокуПДЭЭ("Т" + СТР_ЗНАЧ(тарЗона), ПредПок!тарЗона, Показание!тарЗона,  0,
                                                       Т!тарЗона, 0, 0)
                              ИНАЧЕ
                                STG_ДобавитьСтрокуПДЭЭ("Т" + СТР_ЗНАЧ(тарЗона) + " по", ПредПок!тарЗона, Показание!тарЗона,  г_объемЭЭ!"поСН_"!тарЗона,
                                                       Т_СН!тарЗона, ?(НЕ гр_ОтдПДНаПотери, СуммаПотерь!тарЗона, 0), г_суммаНачЭЭ!"поСН_"!тарЗона)
                              КОНЕЦ_ЕСЛИ
                            ИНАЧЕ
                              STG_ДобавитьСтрокуПДЭЭ("Т" + СТР_ЗНАЧ(тарЗона) + " св", ПредПок!тарЗона, Показание!тарЗона, г_объемЭЭ!"сверхСН_"!тарЗона,
                                                     Т!тарЗона, ?(НЕ гр_ОтдПДНаПотери, СуммаПотерь!тарЗона, 0), г_суммаНачЭЭ!"сверхСН_"!тарЗона)
                              ЕСЛИ г_суммаНачЭЭ!"поСН_"!тарЗона > 0 ТО
                                STG_ДобавитьСтрокуПДЭЭ("Т" + СТР_ЗНАЧ(тарЗона) + " по", 0, 0,  г_объемЭЭ!"поСН_"!тарЗона, Т_СН!тарЗона, 0,
                                                       г_суммаНачЭЭ!"поСН_"!тарЗона)
                              КОНЕЦ_ЕСЛИ
                            КОНЕЦ_ЕСЛИ
                          КОНЕЦ_ЕСЛИ
                        ИНАЧЕ
                          STG_ДобавитьСтрокуПДЭЭ("Т" + СТР_ЗНАЧ(тарЗона), ПредПок!тарЗона, Показание!тарЗона, Показание!тарЗона - ПредПок!тарЗона,
                                                 Т!тарЗона, ?(НЕ гр_ОтдПДНаПотери, СуммаПотерь!тарЗона, 0), СуммаНач!тарЗона)
                        КОНЕЦ_ЕСЛИ
                      ИНАЧЕ
                        STG_ДобавитьСтрокуПДВГ(гр_ТипСч, ПредПок!тарЗона, Показание!тарЗона, Т!тарЗона, СуммаНач!тарЗона)
                      КОНЕЦ_ЕСЛИ
                      
                      ЕСЛИ НЕ ПараметрПечатиПД!"Членские взносы в назначении платежа" ТО
                        колТарЗонСтр = ?(г_КолТарифов = 1, "", "Т" + СТР_ЗНАЧ(тарЗона) + "- ")
                        н_п = н_п + "(" + ?(гр_ТипСч = "Электроэнергия", колТарЗонСтр, "") + СТР_ЗНАЧ(Показание!тарЗона) + 
                              " (расход " + СТР_ЗНАЧ(?(Показание!тарЗона > ПредПок!тарЗона, Показание!тарЗона - ПредПок!тарЗона, 0)) + ")" + 
                              ?(тарЗона = г_КолТарифов, "", ", ")
                      КОНЕЦ_ЕСЛИ
                      
                      колТарЗонСтр = ?(г_КолТарифов = 1, "", "Т" + СТР_ЗНАЧ(тарЗона) + "- ")
                      предПокСтр = предПокСтр + ?(гр_ТипСч = "Электроэнергия", колТарЗонСтр, "") + СТР_ЗНАЧ(ПредПок!тарЗона) + ?(тарЗона = г_КолТарифов, "", ",")
                      текПокСтр = текПокСтр + ?(гр_ТипСч = "Электроэнергия", колТарЗонСтр, "") + СТР_ЗНАЧ(Показание!тарЗона) + ?(тарЗона = г_КолТарифов, "", ",")
                      расходСтр = расходСтр + ?(гр_ТипСч = "Электроэнергия", колТарЗонСтр, "") + 
                                  СТР_ЗНАЧ(?(Показание!тарЗона > ПредПок!тарЗона, Показание!тарЗона - ПредПок!тарЗона, 0)) + ?(тарЗона = г_КолТарифов, "", ",")
                    КОНЕЦ_ЦИКЛА
                  ИНАЧЕ
                    ЕСЛИ оп_ФормироватьПустые ТО
                      /*ЕСЛИ гр_ТипСч = "Электроэнергия" ТО
                        STG_ДобавитьПустуюСтроку(номсч)
                      ИНАЧЕ
                        STG_ДобавитьПустуюСтроку(номсч)
                      КОНЕЦ_ЕСЛИ*/
                      ЦИКЛ ДЛЯ(тарЗона = 1, г_КолТарифов)
                        ЕСЛИ гр_ТипСч = "Электроэнергия" ТО
                          STG_ДобавитьСтрокуПДЭЭ("Т" + СТР_ЗНАЧ(тарЗона), ПредПок!тарЗона, 0, 0, Т!тарЗона, 0, 0)
                        ИНАЧЕ
                          STG_ДобавитьСтрокуПДВГ(гр_ТипСч, ПредПок!тарЗона, Показание!тарЗона, Т!тарЗона, 0)
                        КОНЕЦ_ЕСЛИ
                      
                        ЕСЛИ НЕ ПараметрПечатиПД!"Членские взносы в назначении платежа" ТО
                          колТарЗонСтр = ?(г_КолТарифов = 1, "", "Т" + СТР_ЗНАЧ(тарЗона) + "- ")
                          н_п = н_п + "(" + ?(гр_ТипСч = "Электроэнергия", колТарЗонСтр, "") + "0 (расход 0)" + 
                                ?(тарЗона = г_КолТарифов, "", ", ")
                        КОНЕЦ_ЕСЛИ
                        
                        колТарЗонСтр = ?(г_КолТарифов = 1, "", "Т" + СТР_ЗНАЧ(тарЗона) + ": ")
                        предПокСтр = предПокСтр + ?(гр_ТипСч = "Электроэнергия", колТарЗонСтр, "") + СТР_ЗНАЧ(ПредПок!тарЗона) + ?(тарЗона = г_КолТарифов, "", ",")
                      КОНЕЦ_ЦИКЛА
                    КОНЕЦ_ЕСЛИ
                    текПокСтр = "0"
                    расходСтр = "0"
                  КОНЕЦ_ЕСЛИ
                КОНЕЦ_ЕСЛИ
                
                //для формы ПД4
                ЕСЛИ ПараметрПечатиПД!"Форма ПД ИПУ" = к_ФормаПД4ЭЭ ТО
                  STG_ДобавитьЗначениеПарам(к_ШаблонНазначениеПлатежа, к_ШаблонИПУ, номсч)
                  STG_ДобавитьЗначениеПарам(к_ШаблонНазначениеПлатежа, к_ШаблонТипИПУ, типСчетчика)
                  ЕСЛИ НЕ оп_НачислениеБезТекПок ТО
                    STG_ДобавитьЗначениеПарам(к_ШаблонНазначениеПлатежа, к_ШаблонТПок, текПокСтр)
                    STG_ДобавитьЗначениеПарам(к_ШаблонНазначениеПлатежа, к_ШаблонППок, предПокСтр)
                    STG_ДобавитьЗначениеПарам(к_ШаблонНазначениеПлатежа, к_ШаблонРасход, расходСтр)
                  КОНЕЦ_ЕСЛИ
                  STG_ДобавитьЗначениеПарам(к_ШаблонНазначениеПлатежа, к_ШаблонПериод, текстПериод)
                  STG_ЗаполнитьНП_ПД
                КОНЕЦ_ЕСЛИ
              КОНЕЦ_ЕСЛИ
              
              //для дшк
              ЕСЛИ ПараметрПечатиПД!"Формировать ДШК" ТО
                STG_ДобавитьЗначениеПарам(к_ШаблонНазначениеПлатежа, к_ШаблонИПУ, номсч)
                STG_ДобавитьЗначениеПарам(к_ШаблонНазначениеПлатежа, к_ШаблонТипИПУ, типСчетчика)
                ЕСЛИ НЕ оп_НачислениеБезТекПок ТО
                  STG_ДобавитьЗначениеПарам(к_ШаблонНазначениеПлатежа, к_ШаблонТПок, текПокСтр)
                  STG_ДобавитьЗначениеПарам(к_ШаблонНазначениеПлатежа, к_ШаблонППок, предПокСтр)
                  STG_ДобавитьЗначениеПарам(к_ШаблонНазначениеПлатежа, к_ШаблонРасход, расходСтр)
                КОНЕЦ_ЕСЛИ
                STG_ДобавитьЗначениеПарам(к_ШаблонНазначениеПлатежа, к_ШаблонПериод, текстПериод)
                STG_ДобавитьЗначениеПарам(к_ШаблонНазначениеПлатежа, к_ШаблонПредприят, Предприят)
                STG_ДобавитьЗначениеПарам(к_ШаблонНазначениеПлатежа, к_ШаблонПредприятПолн, ПредприятПолн)
                STG_ДобавитьЗначениеПарам(к_ШаблонНазначениеПлатежа, к_ШаблонФИО, цл_ФИО)
                STG_ДобавитьЗначениеПарам(к_ШаблонНазначениеПлатежа, к_ШаблонЛС, флс)
                STG_ДобавитьЗначениеПарам(к_ШаблонНазначениеПлатежа, ?(г_блокГСК, к_ШаблонНомерГар, к_ШаблонНомерУч), цл_КодУчГарПольз)
                STG_ДобавитьЗначениеПарам(к_ШаблонНазначениеПлатежа, к_ШаблонНомерДома, номерДома)
                STG_ДобавитьЗначениеПарам(к_ШаблонНазначениеПлатежа, ?(г_блокГСК, к_ШаблонЛиния, к_ШаблонУлица), улица)
                STG_ЗаполнитьНП_ДШК
              КОНЕЦ_ЕСЛИ
              
              //расчет 
              ЕСЛИ (оп_Аванс ИЛИ оп_Долг ИЛИ оп_учетОплат) И и = конНом ТО
                ЕСЛИ оп_Аванс ИЛИ оп_Долг ТО
                  полныйРасчет = ?(оп_Долг И НЕ оп_Аванс, НЕТ, ДА)
                  должок = STG_РасчетСальдоПоСтатье(г_КодСтатьиНачисления,
                                                    г_счетСтатьиПоКоду!г_КодСтатьиНачисления, счетУчастка,
                                                    ?(аккСубСчета = "", "", "/" + IB_STR_СтрСимвСлева(цл_КодУчГарПольз, "0", г_длинаКодаУчасткаПС)),
                                                    датаОперации, полныйРасчет, НЕТ)
                  ЕСЛИ (оп_Аванс И НЕ оп_Долг) И должок > 0 ТО
                    должок = 0
                  КОНЕЦ_ЕСЛИ
                  //
                  долгПотери = 0
                  ЕСЛИ ВарУчПотерь <> "" И гр_ТипСч = "Электроэнергия" И НЕ гр_ОтдПДНаПотери ТО
                    долгПотери = STG_РасчетСальдоПоСтатье(к_СтатьиПотЭЭКодСерв,
                                                          г_счетСтатьиПоКоду!к_СтатьиПотЭЭКодСерв, счетУчастка,
                                                          ?(аккСубСчета = "", "",
                                                          "/" + IB_STR_СтрСимвСлева(цл_КодУчГарПольз, "0", г_длинаКодаУчасткаПС)),
                                                          датаОперации, полныйРасчет, НЕТ)
                    ЕСЛИ (оп_Аванс И НЕ оп_Долг) И долгПотери > 0 ТО
                      долгПотери = 0
                    КОНЕЦ_ЕСЛИ
                  КОНЕЦ_ЕСЛИ
                КОНЕЦ_ЕСЛИ
                ЕСЛИ оп_учетОплат ТО
                  должок = должок - STG_СуммаОплатНаДатуПоВзносуУч(цл_КодУчГарПольз, г_КодСтатьиНачисления, датаОперации)
                КОНЕЦ_ЕСЛИ
                //
                ЕСЛИ должок <> 0 ИЛИ долгПотери <> 0 ТО
                  ЕСЛИ гр_ТипСч = "Электроэнергия" ТО
                    STG_ДобавитьСтрокуПДЭЭ("Сальдо", 0, 0, 0, 0, долгПотери, должок)
                  ИНАЧЕ
                    STG_ДобавитьСтрокуПДВГ("Сальдо", 0, 0, 0, должок)
                  КОНЕЦ_ЕСЛИ
                КОНЕЦ_ЕСЛИ
              КОНЕЦ_ЕСЛИ
              //
              ЕСЛИ и = конНом ТО
                СБРОС(Итого)
                СчитатьИтоги = НЕТ
                ЦИКЛ ДЛЯ(ж = 1, ВсегоСтр)
                  ЦИКЛ ИНДЕКС(лог = Итоги!литера)
                    ЕСЛИ лог ТО
                      ЕСЛИ НЕ СУЩ_ПЕРЕМ(Итого!литера) ТО
                        Итого!литера = 0
                      КОНЕЦ_ЕСЛИ
                      ЕСЛИ ТИП_ПЕРЕМ(Данные!ж!литера) = "Ч" ТО
                        Итого!литера = Итого!литера + Данные!ж!литера
                      КОНЕЦ_ЕСЛИ
                    КОНЕЦ_ЕСЛИ
                  КОНЕЦ_ЦИКЛА
                КОНЕЦ_ЦИКЛА
                //Итого!"G" = суммаПотериИтого
                ЕСЛИ НЕ СУЩ_ПЕРЕМ(Итого!литера) ТО
                  ПРОДОЛЖИТЬ
                КОНЕЦ_ЕСЛИ
                //
                Итого!литера = ?(Итого!литера > 0, Итого!литера, 0)
                г_итогоКОплате = Итого!литера
                
                ЕСЛИ оп_строкаИтогоПоСтлб И 
                     гр_ТипСч = "Электроэнергия" ТО
                  Итоги!"F" = ДА
                  Итоги!"G" = ДА
                  Итоги!"H" = НЕТ
                
                  STG_ДобавитьСтрИтоговПоСтлб
                
                  Итоги!"F" = НЕТ
                  Итоги!"G" = НЕТ
                  Итоги!"H" = ДА
                КОНЕЦ_ЕСЛИ
                
                н_п = STG_СобратьНазнПлатежаПД(н_п)
                
                STG_ДобавитьЗначениеПарам(к_ШаблонАдресПлательщика, к_ШаблонПредприят, Предприят)
                STG_ДобавитьЗначениеПарам(к_ШаблонАдресПлательщика, к_ШаблонПредприятПолн, ПредприятПолн)
                STG_ДобавитьЗначениеПарам(к_ШаблонАдресПлательщика, к_ШаблонФИО, цл_ФИО)
                STG_ДобавитьЗначениеПарам(к_ШаблонАдресПлательщика, к_ШаблонЛС, флс)
                STG_ДобавитьЗначениеПарам(к_ШаблонАдресПлательщика, ?(г_блокГСК, к_ШаблонНомерГар, к_ШаблонНомерУч), цл_КодУчГарПольз)
                STG_ДобавитьЗначениеПарам(к_ШаблонАдресПлательщика, к_ШаблонНомерДома, номерДома)
                STG_ДобавитьЗначениеПарам(к_ШаблонАдресПлательщика, ?(г_блокГСК, к_ШаблонЛиния, к_ШаблонУлица), улица)
                г_randParam!"адресДШК" = STG_ЗаполнитьАдрес("ДШК")
          
                г_randParam!"назначениеПлатежаДШК" = STG_СобратьНазнПлатежаДШК(н_п + ", " + текстЗагИП + " № " + цл_КодУчГарПольз  + ", без НДС")
                
                строкаДо = текСтр
                
                текСтр = STG_ПечатьКвитанций(текСтр + 1,
                                             суммаНачисления + должок + долгПотери + 
                                             ?(гр_ОтдПДНаПотери И гр_ТипСч = "Электроэнергия", 0, суммаПотериИтого), 0,
                                             графаАдрес, графаФИО, флс,
                                             "", н_п, email, формаПД, текстПериод, имяФайла + ", " + ПРОП(гр_ТипСч), действие)
                СчитатьИтоги = ДА
                
                ЕСЛИ текСтр <> строкаДо ИЛИ (оп_формПД И гр_выводПД <> к_ВыгрузкаПДНаЭкран) ТО
                  всегоКвит++
                  конецДокумента!всегоКвит = текСтр
                  //
                  парамТаблРеестраПДНомУч!всегоКвит = sql.ПОЛЕ("N_AREA")
                  парамТаблРеестраПДФИО!всегоКвит = sql.ПОЛЕ("FIO")
                КОНЕЦ_ЕСЛИ
                
                //квитанция по потерям, если получается
                //переделать
                ЕСЛИ гр_ОтдПДНаПотери И гр_ТипСч = "Электроэнергия" И суммаПотериИтого <> 0 ТО
                  //определяется тариф для потерь и добавляется строка квитанции                 
                  ЦИКЛ ДЛЯ(пот = начНом, конНом)
                    sql.ПЕРЕЙТИ(пот)
                    ЦИКЛ ДЛЯ(тарЗона = 1, г_КолТарифов)
                      //определим тариф для потерь
                      тарифП = 0
                      ЕСЛИ ВарУчПотерь = "Процент" ТО
                        тарифП = sql.ПОЛЕ("T" + СТР_ЗНАЧ(тарЗона)) * (sql.ПОЛЕ("P" + СТР_ЗНАЧ(тарЗона))/100)
                      КОНЕЦ_ЕСЛИ
                      ЕСЛИ ВарУчПотерь = "Сумма к тарифу" ТО
                        тарифП = sql.ПОЛЕ("P" + СТР_ЗНАЧ(тарЗона))
                      КОНЕЦ_ЕСЛИ
                      //
                      суммаНач!тарЗона = 0
                      ЕСЛИ sql.ПОЛЕ("NUM" + СТР_ЗНАЧ(тарЗона)) > sql.ПОЛЕ("PNUM" + СТР_ЗНАЧ(тарЗона)) ТО
                        суммаНач!тарЗона = ОКРУГЛЕНИЕ((sql.ПОЛЕ("NUM" + СТР_ЗНАЧ(тарЗона)) - sql.ПОЛЕ("PNUM" + СТР_ЗНАЧ(тарЗона))) * sql.ПОЛЕ("T" + СТР_ЗНАЧ(тарЗона)), ?(ПараметрПечатиПД!"Округлять", 0, 2));
                      КОНЕЦ_ЕСЛИ
                      //
                      ВЫБОР(ВарУчПотерь)
                        # "Сумма" : суммаПотерь!тарЗона = ОКРУГЛЕНИЕ(sql.ПОЛЕ("P" + СТР_ЗНАЧ(тарЗона)), ?(ПараметрПечатиПД!"Округлять", 0, 2));
                        # "Процент" : суммаПотерь!тарЗона = ОКРУГЛЕНИЕ(суммаНач!тарЗона * sql.ПОЛЕ("P" + СТР_ЗНАЧ(тарЗона))/100, ?(ПараметрПечатиПД!"Округлять", 0, 2));
                        # "Сумма к тарифу" : суммаПотерь!тарЗона = ОКРУГЛЕНИЕ((sql.ПОЛЕ("NUM" + СТР_ЗНАЧ(тарЗона)) - sql.ПОЛЕ("PNUM" + СТР_ЗНАЧ(тарЗона))) * тарифП, ?(ПараметрПечатиПД!"Округлять", 0, 2));
                      ИНАЧЕ
                        СуммаПотерь!и = 0
                      КОНЕЦ_ВЫБОРА
                      //
                      STG_ДобавитьСтрокуПДЭЭ("Т" + СТР_ЗНАЧ(тарЗона), sql.ПОЛЕ("PNUM" + СТР_ЗНАЧ(тарЗона)), sql.ПОЛЕ("NUM" + СТР_ЗНАЧ(тарЗона)), 0, тарифП, 0, суммаПотерь!тарЗона)
                    КОНЕЦ_ЦИКЛА
                  КОНЕЦ_ЦИКЛА
                  sql.ПЕРЕЙТИ(и)
                  //назначение платежа для потерь
                  н_пП = ?(ПараметрПечатиПД!"Членские взносы в назначении платежа",
                           "Плата за членские взносы", "Плата за потери ЭЭ")
                  //вывод квитанции
                  ЕСЛИ и = конНом ТО
                    ЕСЛИ оп_Долг ИЛИ оп_Аванс ТО
                      долгПотери = 0
                      ЕСЛИ ВарУчПотерь <> "" ТО
                        долгПотери = STG_РасчетСальдоПоСтатье(к_СтатьиПотЭЭКодСерв,
                                                              г_счетСтатьиПоКоду!к_СтатьиПотЭЭКодСерв, счетУчастка,
                                                              ?(аккСубСчета = "", "", "/" + IB_STR_СтрСимвСлева(цл_КодУчГарПольз, "0", г_длинаКодаУчасткаПС)),
                                                              датаОперации, полныйРасчет, НЕТ)
                        ЕСЛИ (оп_Аванс И НЕ оп_Долг) И
                             долгПотери > 0 ТО
                          долгПотери = 0
                        КОНЕЦ_ЕСЛИ
                      КОНЕЦ_ЕСЛИ
                      //
                      ЕСЛИ долгПотери <> 0 ТО
                        STG_ДобавитьСтрокуПДЭЭ("Сальдо", 0, 0, 0, 0, долгПотери, 0)
                      КОНЕЦ_ЕСЛИ
                    КОНЕЦ_ЕСЛИ
                    
                    строкаДо = текСтр
                    г_randParam!"назначениеПлатежаДШК" = н_пП + ", " + текстЗагИП + " № " + цл_КодУчГарПольз + ", без НДС"
                    текСтр = STG_ПечатьКвитанций(текСтр + 1, суммаПотери + долгПотери, 0,
                                                 графаАдрес, графаФИО, флс,
                                                 "", н_пП + " " + периодКвит, email, формаПД,
                                                 периодКвит, имяФайла + ", потери ЭЭ", действие)
                    //добавление разрыва страницы
                    //разбиваем на страницы для удобства печати
                    ЕСЛИ текСтр <> строкаДо ИЛИ (оп_формПД И гр_выводПД <> к_ВыгрузкаПДНаЭкран) ТО
                      всегоКвит++
                      конецДокумента!всегоКвит = текСтр
                      //
                      парамТаблРеестраПДНомУч!всегоКвит = sql.ПОЛЕ("N_AREA")
                      парамТаблРеестраПДФИО!всегоКвит = sql.ПОЛЕ("FIO")
                    КОНЕЦ_ЕСЛИ
                  КОНЕЦ_ЕСЛИ
                КОНЕЦ_ЕСЛИ //квитанция по потерям
                
                //формирование ПКО
                ЕСЛИ оп_ПечатьПКО ТО
                  типВзноса = ?(г_КодСтатьиНачисления = к_СтатьиЭЭКод, взносЭлектичество,
                               ?(г_КодСтатьиНачисления = к_СтатьиВКод, взносВода, взносГаз))
                  дебСчетПотерь = ""
                  STG_I_tmpПКО(датаОперации, суммаНачисления, типВзноса, ТипСч)
                  ЕСЛИ суммаПотериИтого > 0 ТО
                    дебСчетПотерь = г_СчетПотерьЭЭ
                    STG_I_tmpПКО(датаОперации, суммаПотериИтого, взносПотери, к_СтатьиПотЭЭКодСерв)
                    дебСчетПотерь = ""
                  КОНЕЦ_ЕСЛИ
                КОНЕЦ_ЕСЛИ //формирование ПКО
              КОНЕЦ_ЕСЛИ
            КОНЕЦ_ЕСЛИ //печать квитанций
          КОНЕЦ_ЦИКЛА //по sql
          СБРОС(г_парамСохраненияВБД)
          //прокачка статуса
          текПД++
          ок = ОКНО_СТАТУСА("MESSAGE", "Текущий ПД №" + СТР_ЗНАЧ(текПД))
          проц = РУБ(100 * текПД / всегоПД)
          ок = ОКНО_СТАТУСА("PROGRESS", "Сформировано " + СТР_ЗНАЧ(текПД) + " из " + СТР_ЗНАЧ(всегоПД) + " (" + СТР_ЗНАЧ(проц) + "%)")
          ок = ОКНО_СТАТУСА("PERCENT", СТР_ЗНАЧ(проц))
        КОНЕЦ_ЦИКЛА //по начСтрока
        ОКНО_СТАТУСА("CLOSE")
        //сохранение показаний после вывода на печать
        ЕСЛИ изменена И НЕ оп_НачислениеБезТекПок ТО
          STG_СохранитьПоказания(датаНачалоМесяца, датаКонецМесяца)
        КОНЕЦ_ЕСЛИ
      КОНЕЦ_ЕСЛИ //логВып
      sql.ЗАКРЫТЬ
      
      //сохраним файл в tmp000 - можно реализовать иначе, так просто проще.
      ЕСЛИ логВып ТО
        СП.ОЧИСТИТЬ
        СП.ДОБАВИТЬ("DELETE FROM")
        СП.ДОБАВИТЬ("'" + ф_tmp001 + "'")
        СП.ДОБАВИТЬ("WHERE ID_SCH IN (SELECT ID_SCH FROM")
        СП.ДОБАВИТЬ("'" + ф_tmp024 + "')")
        SQL_ЗАПРОС(СП)
        //
        СП.ОЧИСТИТЬ
        СП.ДОБАВИТЬ("INSERT INTO")
        СП.ДОБАВИТЬ("'" + ф_tmp001 + "'")
        СП.ДОБАВИТЬ("SELECT * FROM")
        СП.ДОБАВИТЬ("'" + ф_tmp024 + "'")
        SQL_ЗАПРОС(СП)
      КОНЕЦ_ЕСЛИ
      
      СБРОС(начСтрокаПД, конСтрокаПД)
    КОНЕЦ_ЦИКЛА //по тарифностям
    
    ЕСЛИ всегоКвит > 0 ТО
      //пока отключено
      ЕСЛИ идентАрхива = "" И оп_Начисление И делатьПроводки ТО //сохранять только при сохранении в ЖХО?
        STG_СохранитьРасчет("3.01",
                            ?(гр_улицы = "", "по всем", гр_улицы), 
                            ?(гр_участки = "", "по всем", гр_участки),
                            гр_ТипСч,
                            дн, дк, датаОперации)
        //
        СП.ОЧИСТИТЬ
        СП.ДОБАВИТЬ("INSERT INTO")
        СП.ДОБАВИТЬ("'" + ф_ЖурналРасчетов + "'")
        СП.ДОБАВИТЬ("(CODS, ID_AREA, FLS, ID_IPU, T1_VOL, T2_VOL, T3_VOL," + 
                    " T1SN_VOL, T2SN_VOL, T3SN_VOL, SUM_T1, SUM_T2, SUM_T3," + 
                    " SUM_SNT1, SUM_SNT2, SUM_SNT3, SUM_PT1, SUM_PT2, SUM_PT3, ID_TYPE, ROV1, ROV2, ROV3) ")
        СП.ДОБАВИТЬ("SELECT CODS, ID_AREA, FLS, ID_SCH, T1_VOL, T2_VOL, T3_VOL," + 
                    " T1SN_VOL, T2SN_VOL, T3SN_VOL, SUM_T1, SUM_T2, SUM_T3," + 
                    " SUM_SNT1, SUM_SNT2, SUM_SNT3, SUM_PT1, SUM_PT2, SUM_PT3, ID_VZN, ROV1, ROV2, ROV3 FROM")
        СП.ДОБАВИТЬ("'" + ф_tmp001 + "'")
        СП.ДОБАВИТЬ("WHERE SUM_T1 <> 0")
        SQL_ЗАПРОС(СП)
        //
        СП.ОЧИСТИТЬ
        СП.ДОБАВИТЬ("UPDATE")
        СП.ДОБАВИТЬ("'" + ф_ЖурналРасчетов + "'")
        СП.ДОБАВИТЬ("SET ID_CALC = " + СТР_ЗНАЧ(г_текИдРасчета) + ", TYPE = '" + г_КодСтатьиНачисления + 
                    "', ID_RECSITE = -1, IS_SYNCED = FALSE WHERE ID_CALC = 0")
        SQL_ЗАПРОС(СП)
        //
        STG_ДобавитьПарамСинхр(к_спрСайтаРасчеты, -1, "д", "добавление расчетов")
      КОНЕЦ_ЕСЛИ
      //
      УСТ_АТРИБУТ("$отправлятьНаПочту", "ДА")
      ЕСЛИ гр_выводПД <> к_ВыгрузкаПДНаЭкран ТО
        описаниеВыгрузки = "Выгрузка ПД от " + СТР(датаОперации) + " за период с " + СТР(гр_ДатаС) + 
                           " по " + СТР(гр_ДатаПо) + " по " + ?(гр_ТипСч = "Электроэнергия", "электроэнергии", 
                                                                ?(гр_ТипСч = "Вода", "воде", 
                                                                  ?(гр_ТипСч = "Газ", "газу", "отоплению")))
        STG_ДобВыгрузкуПД(описаниеВыгрузки, "3.01")
        г_идТекВыгрузкиПД = 0
      КОНЕЦ_ЕСЛИ
      
      начВыводаДок = 32
      строкВывели = 0
      ЦИКЛ ДЛЯ(и = 1, всегоКвит - 1)
        ЕСЛИ оп_разрывПослеКаждогоПД ТО
          ЕСЛИ и <= всегоКвит - 1 ТО
            КОНЕЦ_СТРАНИЦЫ(конецДокумента[и])
          КОНЕЦ_ЕСЛИ
        ИНАЧЕ
          строкНаПД = конецДокумента[и] - начВыводаДок
          
          ЕСЛИ строкВывели + строкНаПД <= стрНаЛист ТО
            строкВывели = строкВывели + строкНаПД
          ИНАЧЕ
            КОНЕЦ_СТРАНИЦЫ(конецДокумента[и-1])
            строкВывели = строкНаПД 
          КОНЕЦ_ЕСЛИ
          
          начВыводаДок = конецДокумента[и] + 1
        КОНЕЦ_ЕСЛИ
      КОНЕЦ_ЦИКЛА
      
      ЕСЛИ оп_вывестиРеестрПД ТО
        СБРОС_ТАБЛИЦ(ДА)
        КолЯч = 0
        ВсегоСтр = 0
        ВерхСтр = 0
        НизСтр = 0
        Верх=0    // Верхний колонтитул
        Низ=0     // Нижний колонтитул
        ВыводИт = НЕТ
        СПИСОК_АТРИБУТОВ("настройки печати", СП)
        СтрЛист = 0
        ЕСЛИ СП.ВСЕГО <= 7 ТО
          ОКНО_СООБ("Текущий принтер недоступен: " + АТРИБУТ("cur_printer") + СИМВ(13) + "Рекомендуется перезапустить программу", "Ошибка текущего принтера", "OK, CANCEL", "ERROR")
        ИНАЧЕ
          СтрЛист = ЗНАЧ(СТР_ФРАГ(СП.СТРОКА(9), "=", 2)) - 1
        КОНЕЦ_ЕСЛИ
        РазбСтр = ДА
        учитывать_шапку = ДА
        
        логВыводаДо = (гр_парамВывРеестраПД = "до квитанций")
        
        стрЗаг = ?(логВыводаДо, начСтр, конецДокумента[всегоКвит])
        ЕСЛИ стрЗаг = 0 ТО
          стрЗаг = начСтр + 1
        КОНЕЦ_ЕСЛИ
        ВСТАВИТЬ_СТРОКУ(стрЗаг)
        
        заголовокТаблДо = "Реестр ПД от " + СТР(датаОперации) + " за период с " + СТР(гр_ДатаС) + 
                          " по " + СТР(гр_ДатаПо) + " по " + ?(гр_ТипСч = "Электроэнергия", "электроэнергии", 
                                                               ?(гр_ТипСч = "Вода", "воде", 
                                                                 ?(гр_ТипСч = "Газ", "газу", "отоплению")))
        заголовокТабл = СТР_РАЗБИТЬ(заголовокТаблДо, 76, колСтр)
        
        ЕСЛИ логВыводаДо ТО
          КОНЕЦ_СТРАНИЦЫ(стрЗаг)
          ВСТАВИТЬ_СТРОКУ(стрЗаг + 1, 1 + колСтр)
        ИНАЧЕ
          ЕСЛИ конецДокумента!всегоКвит > 0 ТО
            КОНЕЦ_СТРАНИЦЫ(конецДокумента!всегоКвит)
          КОНЕЦ_ЕСЛИ
        КОНЕЦ_ЕСЛИ
        
        ВЫВЕСТИ(5, стрЗаг, заголовокТабл, 76, колСтр, ДА)
        НачСтр = стрЗаг + 1 + колСтр
        НачСтлб = 2
        
        TBLPRINT_ДобавитьСтолбец(6, "№ п/п", 0)
        TBLPRINT_ДобавитьСтолбец(15, "Участок", 0)
        TBLPRINT_ДобавитьСтолбец(40, "Ф.И.О.", 0)
        TBLPRINT_ДобавитьСтолбец(15, "Подпись", 0)
        
        ЦИКЛ ДЛЯ(и = 1, всегоКвит)
          ВсегоСтр++
          Данные!ВсегоСтр!"A" = и
          Данные!ВсегоСтр!"B" = текстЗагИП + " №" + парамТаблРеестраПДНомУч!и
          Данные!ВсегоСтр!"C" = парамТаблРеестраПДФИО!и
          Данные!ВсегоСтр!"D" = ""
        КОНЕЦ_ЦИКЛА
        tblpr_отнПозНачСтр = 3
        ПЕЧАТЬ_ШАПКИ
        
        ЕСЛИ оп_выгрузитьРеестрПД ТО
          стр = СТР_РАЗБИТЬ(заголовокТабл, 57, кол)
          ЦИКЛ ДЛЯ(и = 1, кол)
            IB_TBLEXP_ДобавитьСтрокуЗаголовка(СТР_ФРАГ(стр, СИМВ(13), и), "", 12, ДА, НЕТ, "", "")  
          КОНЕЦ_ЦИКЛА
          IB_TBLEXP_ДобавитьСтрокуЗаголовка("", "", 0, НЕТ, НЕТ, "", "")
          
          резВыгр = STG_ВыгрузитьТаблицуНаМН(гр_выводРеестра,
                                                ЗАМ(":", заголовокТаблДо, " - "), 
                                                гр_форматРеестраПД, НЕТ, НЕТ, НЕТ, файл)
      
          ЕСЛИ резВыгр ТО
            ЕСЛИ ВОПРОС("Показать выгруженный файл в проводнике?") ТО
              IB_FILE_ПоказатьФайлВПроводнике(файл)
            КОНЕЦ_ЕСЛИ
          КОНЕЦ_ЕСЛИ
        КОНЕЦ_ЕСЛИ
              
        нач_НачСтр = Высота
        ПЕЧАТЬ_ТАБЛИЦЫ
        СБРОС_ТАБЛИЦ(ДА)
      КОНЕЦ_ЕСЛИ
    КОНЕЦ_ЕСЛИ
    
    //запись реестра в файл
    ЕСЛИ оп_ФормироватьРеестр ТО
      ЦИКЛ ИНДЕКС(строка = строкиРеестра!индекс)
        ЕСЛИ строкиРеестра!индекс <> "" ТО
          STG_ДобавитьСтрРеестра(строка)
        КОНЕЦ_ЕСЛИ
      КОНЕЦ_ЦИКЛА
    КОНЕЦ_ЕСЛИ
  КОНЕЦ_ЕСЛИ
  main.ЗАКРЫТЬ
  
  //отправка почты
  ЕСЛИ оп_ОтправлятьПочту ТО
    IB_FILE_ДирСоздать(IB_MAIL_ДирТекРассылки + "\qrCode")
    IB_FILE_ФайлКопировать(ТЕК_ДИР + "\Pics\BMP\plug.bmp", IB_MAIL_ДирТекРассылки + "\qrCode\plug.bmp", НЕТ)
    ЕСЛИ ПараметрПечатиПД!"Формировать ДШК" ТО
      IB_FILE_ДирКопировать(ib_qr_времПапкаДШК, IB_MAIL_ДирТекРассылки + "\qrCode")
    КОНЕЦ_ЕСЛИ
    СООБЩЕНИЕ("Для отправки писем на электронную почту нажмите на кнопку ""Отправить"".")
  КОНЕЦ_ЕСЛИ
    
  ЕСЛИ гр_email <> "Нет" ТО
    IB_PROTOCOL_ОбработатьИВывестиОшибки
  КОНЕЦ_ЕСЛИ
  
  //печать приходников
  ЕСЛИ оп_ПечатьПКО И IB_DBF_ВсегоЗап(ф_tmp005) > 0 ТО
    ЕСЛИ ВОПРОС("Сформировать приходные ордера?") ТО
      sql = SQL_ОТКРЫТЬ(ф_tmp005)
      ЕСЛИ sql.ВСЕГО > 0 ТО
        БЛАНК("ST_SERV02.BLW",ДА)
      КОНЕЦ_ЕСЛИ
    КОНЕЦ_ЕСЛИ
  КОНЕЦ_ЕСЛИ
  
  //выгрузка реестров
  ЕСЛИ оп_ФормироватьРеестр ТО
    STG_ВыгрузитьРеестр
    ЕСЛИ STG_ВыгруженыРеестры ТО
      ЕСЛИ ВОПРОС("Показать выгруженный файл в проводнике?") ТО
        IB_FILE_ПоказатьФайлВПроводнике(г_путьПослРеестра)
      КОНЕЦ_ЕСЛИ
    КОНЕЦ_ЕСЛИ
  КОНЕЦ_ЕСЛИ
  
  ЕСЛИ идентАрхива <> "" ТО
    оп_Начисление = tmp_оп_Начисление
    датаОперации = tmp_датаОперации
    гр_ДатаС = tmp_гр_датаС
    гр_ДатаПо = tmp_гр_датаПо
    гр_ТипСч = tmp_гр_ТипСч
  КОНЕЦ_ЕСЛИ
  
  ЕСЛИ всегоКвит > 0 ТО
    STG_КнВыгрузитьНаСайт("", "", "")
  КОНЕЦ_ЕСЛИ
  
  //вернем как было
  IB_FLT_ЗагрузитьФильтр
  STG_СбросРеестров
  IB_CONTEXT_УстановитьЛок("получениеПокССайта", "")
  
  УСТ_АТРИБУТ("&группОперации", "")
  УСТ_АТРИБУТ("$использоватьШаблонНПБезВводаПок", "")
  УСТ_АТРИБУТ("$гр_выводПД", "")
  УСТ_АТРИБУТ("$гр_форматПД", "")
  УСТ_АТРИБУТ("$гр_выводПДПочта", "")
  УСТ_АТРИБУТ("$гр_форматПДПочта", "")
  УСТ_АТРИБУТ("$пересчетПоАрхиву", "")
  
  СБРОС(строкиРеестра, eMail, парамИПУ, Т, Тар, ТарСН, ПредПок, ТекПок, Потери, randParam)
  СБРОС(stg_путиДШК, коррУчтена, коррИспользована, логДобПоказаний, г_суммаНачЭЭ)
  СБРОС(парамТаблРеестраПДНомУч, парамТаблРеестраПДФИО, stg_списокОпераций)
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
//сохранение показаний в базу
ФУНКЦИЯ ТИП_ЛОГИКА: STG_СохранитьПоказания(ТИП_ДАТА: датаНачалоМесяца,
                                                     датаКонецМесяца)
  СОЗДАТЬ(сп, ТИП_СПИСОК)
  //определяется файл
  файл = ?(ТипСч = "ЭЭ", ф_ПоказанияИСЭЭ, ф_ПоказанияИСВГ)
  //поля файла
  поляФайла = ""
  sql = SQL_ОТКРЫТЬ(файл)
  колПолей = sql.КОЛ_ПОЛЕЙ
  ЦИКЛ ДЛЯ(и = 1, колПолей)
    поляФайла = поляФайла + sql.НАЗВ_ПОЛЯ(и) + ?(и = колПолей, "", ",")
  КОНЕЦ_ЦИКЛА
  sql.ЗАКРЫТЬ
  //надо обновить текущие показания у многотарифных ИПУ по ЭЭ
  ЕСЛИ ТипСч = "ЭЭ" ТО
    сп.ОЧИСТИТЬ
    сп.ДОБАВИТЬ("UPDATE")
    сп.ДОБАВИТЬ("'" + ф_tmp024 + "'")
    сп.ДОБАВИТЬ("SET NUM1 = PNUM1 WHERE NUM1 = 0 AND (NUM2 > 0 OR NUM3 > 0)")
    SQL_ЗАПРОС(сп)
    //
    сп.ОЧИСТИТЬ
    сп.ДОБАВИТЬ("UPDATE")
    сп.ДОБАВИТЬ("'" + ф_tmp024 + "'")
    сп.ДОБАВИТЬ("SET NUM2 = PNUM2 WHERE NUM2 = 0 AND (NUM1 > 0 OR NUM3 > 0)")
    SQL_ЗАПРОС(сп)
    //
    сп.ОЧИСТИТЬ
    сп.ДОБАВИТЬ("UPDATE")
    сп.ДОБАВИТЬ("'" + ф_tmp024 + "'")
    сп.ДОБАВИТЬ("SET NUM3 = PNUM3 WHERE NUM3 = 0 AND (NUM1 > 0 OR NUM2 > 0)")
    SQL_ЗАПРОС(сп)
  КОНЕЦ_ЕСЛИ
  //
  сп.ОЧИСТИТЬ
  сп.ДОБАВИТЬ("UPDATE")
  сп.ДОБАВИТЬ("'" + ф_tmp024 + "'")
  сп.ДОБАВИТЬ("SET T1_VOL = NUM1 - PNUM1 WHERE NUM1 > 0")
  SQL_ЗАПРОС(сп)
  //
  сп.ОЧИСТИТЬ
  сп.ДОБАВИТЬ("UPDATE")
  сп.ДОБАВИТЬ("'" + ф_tmp024 + "'")
  сп.ДОБАВИТЬ("SET T2_VOL = NUM2 - PNUM2 WHERE NUM2 > 0")
  SQL_ЗАПРОС(сп)
  //
  сп.ОЧИСТИТЬ
  сп.ДОБАВИТЬ("UPDATE")
  сп.ДОБАВИТЬ("'" + ф_tmp024 + "'")
  сп.ДОБАВИТЬ("SET T3_VOL = NUM3 - PNUM3 WHERE NUM3 > 0")
  SQL_ЗАПРОС(сп)
  //очистка файла от старых показаний
  сп.ОЧИСТИТЬ
  сп.ДОБАВИТЬ("DELETE FROM")
  сп.ДОБАВИТЬ("'" + файл + "'")
  сп.ДОБАВИТЬ("WHERE DAT BETWEEN '" + СТР(датаНачалоМесяца) + "' AND '" + СТР(датаКонецМесяца) + "'")
  сп.ДОБАВИТЬ("AND ID_SCH IN (SELECT ID_SCH FROM")
  сп.ДОБАВИТЬ("'" + ф_tmp024 + "')")
  SQL_ЗАПРОС(сп)
  //запись новых показаний в файл. текущая дата лежит в поле T_DAT
  сп.ОЧИСТИТЬ
  сп.ДОБАВИТЬ("INSERT INTO")
  сп.ДОБАВИТЬ("'" + файл + "'")
  сп.ДОБАВИТЬ("(" + поляФайла + ") SELECT " + ЗАМ("DAT", поляФайла, "T_DAT") + " FROM")
  сп.ДОБАВИТЬ("'" + ф_tmp024 + "'")
  сп.ДОБАВИТЬ("WHERE NUM1 > 0 OR NUM2 > 0 OR NUM3 > 0")
  SQL_ЗАПРОС(сп)
  //
  IB_DBF_ДобавитьНаУпаковку(файл)
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ ТИП_ОПЕРАЦИЯ STG_ЗаписатьХозОп(ТИП_ЧИСЛО: суммаПотериИтого; ТИП_ЛОГИКА: учетПотерь)
  ЕСЛИ учетПотерь ТО
    ЕСЛИ г_КодСтатьиНачисления = к_СтатьиЭЭКод И ВарУчПотерь <> "" ТО
      ЕСЛИ суммаПотериИтого <> 0 И НЕ гр_ОтдХОНаПотери ТО
        STG_ДобПроводкуПотЭЭ(суммаПотериИтого, г_СчетПотерьЭЭ)
      КОНЕЦ_ЕСЛИ
    КОНЕЦ_ЕСЛИ
  КОНЕЦ_ЕСЛИ
  
  STG_ПроверкаИЗаписьХозОп(ТипСч)
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ ТИП_ОПЕРАЦИЯ STG_ЗаписатьХозОпПотери(ТИП_ЧИСЛО: суммаПотериИтого; ТИП_ЛОГИКА: учетПотерь)
  ЕСЛИ учетПотерь ТО
    ЕСЛИ г_КодСтатьиНачисления = к_СтатьиЭЭКод И ВарУчПотерь <> "" ТО
      ЕСЛИ суммаПотериИтого <> 0 И гр_ОтдХОНаПотери ТО
        tmp_г_КодСтатьиНачисления = г_КодСтатьиНачисления
        ЕСЛИ г_блокГСК ТО
          г_КодСтатьиНачисления = к_СтатьиПотЭЭКодСерв
        КОНЕЦ_ЕСЛИ
        STG_ДобПроводкуПотЭЭ(суммаПотериИтого, г_СчетПотерьЭЭ)
        г_КодСтатьиНачисления = tmp_г_КодСтатьиНачисления
      КОНЕЦ_ЕСЛИ
    КОНЕЦ_ЕСЛИ
  КОНЕЦ_ЕСЛИ
  
  STG_ПроверкаИЗаписьХозОп(к_СтатьиПотЭЭКодСерв)
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ ТИП_ОПЕРАЦИЯ STG_ПроверкаИЗаписьХозОп(ТИП_СТРОКА: кодСтатьи)
  ЕСЛИ STG_РедактОп ТО
    инд1 = СТР_ЗНАЧ(Id_Area) + г_раздОб + кодСтатьи
    ЕСЛИ СУЩ_ПЕРЕМ(stg_списокОпераций!инд1) ТО
      //ищем операцию в журнале
      СОЗДАТЬ(фильтр, ТИП_ФИЛЬТР)
      фильтр.дата = СТР(дата)
      фильтр.документ = СТР_ФРАГ(stg_списокОпераций!инд1, г_раздОб, 1)
      фильтр.содержание = СТР_ФРАГ(stg_списокОпераций!инд1, г_раздОб, 2)
      фильтр.разл_регистр = НЕТ
      фильтр.действ_отч = ДА
      фильтр.ПРИМЕНИТЬ
      ВКЛ_ФИЛЬТР
      ЕСЛИ ОПЕР_ВСЕГО > 0 ТО 
        //пока предположим, что операция всегда одна
        ЕСЛИ ВОПРОС("В ЖХО обнаружена ранее созданная операция. Перезаписать её?", НЕТ) ТО
          документ = СТР_ФРАГ(stg_списокОпераций!инд1, г_раздОб, 1)
          название = СТР_ФРАГ(stg_списокОпераций!инд1, г_раздОб, 2)
          //
          УДАЛ_ОПЕР(1)
        КОНЕЦ_ЕСЛИ
      КОНЕЦ_ЕСЛИ
      ВЫКЛ_ФИЛЬТР
    КОНЕЦ_ЕСЛИ
    //
    STG_ЗаписатьОп(СТР_ЗНАЧ(к_ТипЗаписиЖурналаНач), НЕТ)
  КОНЕЦ_ЕСЛИ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ ТИП_ЛОГИКА: STG_ПереключательВыбора(ПЕРЕМ ТИП_СТРОКА: стр)
  РЕЗУЛЬТАТ = ДА
  полеВыб = РЕД_ПОЛЕ("поле_выбора")
  ЕСЛИ ПРОП(РЕД_ПОЛЕ("#ТЕК_СТОЛБЕЦ")) = ПРОП(полеВыб) ТО
    УСТ_РЕД_ПОЛЕ(полеВыб, ?(РЕД_ПОЛЕ(полеВыб) <> "", "", "V"))
  ИНАЧЕ
    текСтолбец = РЕД_ПОЛЕ("#ТЕК_СТОЛБЕЦ")
    ЕСЛИ НЕ (ПОЗ("NUM", текСтолбец) = 1 ИЛИ 
             текСтолбец = "P1" ИЛИ
             текСтолбец = "P2" ИЛИ
             текСтолбец = "P3" ИЛИ
             текСтолбец = "P") ТО
      текСтолбец = "NUM1"
    КОНЕЦ_ЕСЛИ
      
    значение = РЕД_ПОЛЕ(текСтолбец)
    значение = ВВОД_ЗНАЧЕНИЯ("Введите значение", значение)
    РЕЗУЛЬТАТ = (АТРИБУТ("результат_диалога") = "ДА")
    
    ЕСЛИ РЕЗУЛЬТАТ ТО
      ЕСЛИ г_работаССайтом ТО
        ЕСЛИ РЕД_ПОЛЕ(текСтолбец) = 0 И значение > 0 ТО
          ЕСЛИ РЕД_ПОЛЕ("ID_RECSITE") <= 0 ТО
            STG_ДобавитьПарамСинхр(к_спрСайтаПоказания, -1, "д", "добавление показаний")
          ИНАЧЕ
            STG_ДобавитьПарамСинхр(к_спрСайтаПоказания, РЕД_ПОЛЕ("ID_RECSITE"), "и", "изменение показаний")
          КОНЕЦ_ЕСЛИ
        ИНАЧЕ
          ЕСЛИ РЕД_ПОЛЕ(текСтолбец) > 0 И значение > 0 ТО
            ЕСЛИ РЕД_ПОЛЕ("ID_RECSITE") <= 0 ТО
              STG_ДобавитьПарамСинхр(к_спрСайтаПоказания, -1, "д", "добавление показаний")
            ИНАЧЕ
              STG_ДобавитьПарамСинхр(к_спрСайтаПоказания, РЕД_ПОЛЕ("ID_RECSITE"), "и", "изменение показаний")
            КОНЕЦ_ЕСЛИ
          ИНАЧЕ
            ЕСЛИ РЕД_ПОЛЕ(текСтолбец) = 0 И значение > 0 ТО            
              ЕСЛИ РЕД_ПОЛЕ("ID_RECSITE") > 0 ТО
                ЕСЛИ ВОПРОС("Это показание будет удалено?") ТО
                  STG_ДобавитьПарамСинхр(к_спрСайтаПоказания, РЕД_ПОЛЕ("ID_RECSITE"), "у", "удаление показаний")
                КОНЕЦ_ЕСЛИ
              КОНЕЦ_ЕСЛИ
            КОНЕЦ_ЕСЛИ
          КОНЕЦ_ЕСЛИ
        КОНЕЦ_ЕСЛИ
      КОНЕЦ_ЕСЛИ
      
      УСТ_РЕД_ПОЛЕ(текСтолбец, значение)
      
      ЕСЛИ г_испДиапОбъемовЭЭ И ПОЗ("NUM", текСтолбец) = 1 ТО //только для столбцов NUM!
      
        Token = РЕД_ПОЛЕ("TOKEN")
        TokenDate = РЕД_ПОЛЕ("TOKEN_DATE")
            
        объем = РЕД_ПОЛЕ(текСтолбец) - РЕД_ПОЛЕ("P" + текСтолбец)
        г_кодДиапазонаЭЭ = STG_КодДиапазонаПоОбъему(объем)
        М = IB_STR_МЕСЯЦ_В_ЧИСЛО(гр_Месяц)
        дн = ДАТА(1, М, гр_Год)
        началоСледМесяца = IB_DATE_КонецМесяца2(М, ЗНАЧ(гр_Год)) + 1
        
        ЕСЛИ НЕ STG_СчитатьТарифы(дн, началоСледМесяца-1, М)  ТО
          г_кодДиапазонаЭЭ = ""
          //ind = СТР_ЗНАЧ(г_Тарифность) + "_" + СТР_ЗНАЧ(Token) + "_" + г_кодДиапазонаЭЭ + "_"
          ib_protocol_кэшПротокола.ОЧИСТИТЬ
          ib_protocol_кэшОшибок.ОЧИСТИТЬ
          ЕСЛИ STG_СчитатьТарифы(дн, началоСледМесяца-1, М)  ТО
            ВЫБОР(текСтолбец)
             #"NUM1": УСТ_РЕД_ПОЛЕ("T1", Т!1)
                      УСТ_РЕД_ПОЛЕ("ROV1", г_кодДиапазонаЭЭ)
             #"NUM2": УСТ_РЕД_ПОЛЕ("T2", Т!2)
                      УСТ_РЕД_ПОЛЕ("ROV2", г_кодДиапазонаЭЭ)
             #"NUM3": УСТ_РЕД_ПОЛЕ("T3", Т!3)
                      УСТ_РЕД_ПОЛЕ("ROV3", г_кодДиапазонаЭЭ)
            КОНЕЦ_ВЫБОРА
          КОНЕЦ_ЕСЛИ
        ИНАЧЕ
          ВЫБОР(текСтолбец)
            #"NUM1": УСТ_РЕД_ПОЛЕ("T1", Т!1)
                     УСТ_РЕД_ПОЛЕ("ROV1", г_кодДиапазонаЭЭ)
            #"NUM2": УСТ_РЕД_ПОЛЕ("T2", Т!2)
                     УСТ_РЕД_ПОЛЕ("ROV2", г_кодДиапазонаЭЭ)
            #"NUM3": УСТ_РЕД_ПОЛЕ("T3", Т!3)
                     УСТ_РЕД_ПОЛЕ("ROV3", г_кодДиапазонаЭЭ)
          КОНЕЦ_ВЫБОРА
        КОНЕЦ_ЕСЛИ
      КОНЕЦ_ЕСЛИ
    КОНЕЦ_ЕСЛИ
  КОНЕЦ_ЕСЛИ
  STG_ПереключательВыбора = РЕЗУЛЬТАТ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ STG_КнПолучитьПокССайта(ТИП_СТРОКА: соб, имя, текст)
  ЕСЛИ г_работаССайтом ТО
    ЕСЛИ ВОПРОС(текст + "?", НЕТ) ТО
      STG_УпаковатьПарамСинхр
      //STG_СинхронизацияСайта
      ЕСЛИ НЕ г_блокСНТ ТО
        IB_FILE_СТАРТ_ПРОГ("__GSK_SITE_GET_R.IBX")
      ИНАЧЕ
        IB_FILE_СТАРТ_ПРОГ("__ST_SITE_GET_R.IBX")
      КОНЕЦ_ЕСЛИ
        
      /*STG_R_НастройкиБлока
        
      оп_подзапрДобавление = г_использоватьПоздапросы
      гр_датаОпераций = к_МинДата
      гр_датаОперацийПо = к_МаксДата
      гр_датаРасчетов = к_МинДата
      гр_датаРасчетовПо = к_МаксДата
      
      STG_ПолучитьССайта
      REST_Logout
      УСТ_АТРИБУТ("&REST_адрес", "")*/
      IB_CONTEXT_УстановитьЛок("получениеПокССайта", "ДА")
      КОМАНДА_БЛАНКА("RECALC")
    КОНЕЦ_ЕСЛИ
  КОНЕЦ_ЕСЛИ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ STG_КнВыгрузитьНаСайт(ТИП_СТРОКА: соб, имя, текст)
  ЕСЛИ г_работаССайтом ТО
    STG_ЗаписатьПарамСинхр
    ЕСЛИ ВОПРОС("Синхронизировать изменения с сайтом?") ТО
      //STG_СбросИндексов(к_спрСайтаПоказания)
      stg_списокСпрДляСинхр!1 = к_спрСайтаИПУ
      stg_списокСпрДляСинхр!2 = к_спрСайтаПоказания
      stg_списокСпрДляСинхр!3 = к_спрСайтаЖурнал
      stg_списокСпрДляСинхр!4 = к_спрСайтаРасчеты
      STG_УпаковатьПарамСинхр
      //STG_СинхронизацияСайта
      ЕСЛИ НЕ г_блокСНТ ТО
        IB_FILE_СТАРТ_ПРОГ("__GSK_SITE_SYNC.IBX")
      ИНАЧЕ
        IB_FILE_СТАРТ_ПРОГ("__ST_SITE_SYNC.IBX")
      КОНЕЦ_ЕСЛИ
    КОНЕЦ_ЕСЛИ
  КОНЕЦ_ЕСЛИ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ПЕРЕМ stg_предПоказания!
ПЕРЕМ stg_следПоказания!
ФУНКЦИЯ STG_ПоказатьПоказания(ТИП_СТРОКА: соб, имя, текст)
  ИСПОЛЬЗОВАТЬ("ST_gsk\TOP\ST_GSK_METERS.IBL")
  
  STG_ПутиПрофилейМножВыбора
  IB_CONTEXT_УстановитьЛок(к_выборИПУ, "ДА")
  
  СБРОС(stg_предПоказания, stg_следПоказания)
  СБРОС(stg_парамСайтаДоб, stg_парамПоказанийИзм, stg_парамПоказанийИзмЗнач, stg_парамСайтаИзм, stg_парамСайтаУд, stg_показанияНаУдаление)
  
  файл = STG_ОпределитьТипИПУ(гр_ТипСч)

  СОЗДАТЬ(сп, ТИП_СПИСОК)
  //
  сп.ОЧИСТИТЬ
  сп.ДОБАВИТЬ("SELECT A.cods, A.id_area, A.n_area, a.n_dom, A.fio, A.srt, B.id, B.nom, B.model, B.cot, C.dat, C.uuid, C.id_recsite,")
  сп.ДОБАВИТЬ("C.num1,")
  ЕСЛИ гр_ТипСч = к_СтатьиЭЭ ТО
    сп.ДОБАВИТЬ("C.num2, C.num3, C.p, C.p1, C.p2, C.p3,")
  КОНЕЦ_ЕСЛИ
  сп.ДОБАВИТЬ("C.dat AS p_dat, C.num1 AS p_num1,")
  ЕСЛИ гр_ТипСч = к_СтатьиЭЭ ТО
    сп.ДОБАВИТЬ("C.num2 AS p_num2, C.num3 AS p_num3,")
  КОНЕЦ_ЕСЛИ
  сп.ДОБАВИТЬ("C.dat AS pr_dat, C.num1 AS pr_num1,")
  ЕСЛИ гр_ТипСч = к_СтатьиЭЭ ТО
    сп.ДОБАВИТЬ("C.num2 AS pr_num2, C.num3 AS pr_num3,")
  КОНЕЦ_ЕСЛИ
  сп.ДОБАВИТЬ("C.dat AS n_dat, C.num1 AS n_num1,")
  ЕСЛИ гр_ТипСч = к_СтатьиЭЭ ТО
    сп.ДОБАВИТЬ("C.num2 AS n_num2, C.num3 AS n_num3,")
  КОНЕЦ_ЕСЛИ
  сп.ДОБАВИТЬ("CAST(FALSE AS BOOLEAN) AS added, CAST(FALSE AS BOOLEAN) AS edited FROM")
  сп.ДОБАВИТЬ("'" + ф_СпрУчастковГаражей + "' A")
  сп.ДОБАВИТЬ("INNER JOIN")
  сп.ДОБАВИТЬ("'" + ф_СпрИндивСчетчики + "' B")
  сп.ДОБАВИТЬ("ON A.ID_AREA = B.ID_AREA INNER JOIN")
  сп.ДОБАВИТЬ("'" + файл + "' C")
  сп.ДОБАВИТЬ("ON B.ID = C.ID_SCH WHERE C.DAT BETWEEN '" + СТР(гр_ДатаС) + "' AND '" + СТР(гр_ДатаПо) + "'")
  
  ЕСЛИ г_колУлиц > 0 ТО
    сп.ДОБАВИТЬ("AND A.ID_AREA IN (SELECT ID_AREA FROM")
    сп.ДОБАВИТЬ("'" + ф_СпрУчастковГаражей + "'")
    сп.ДОБАВИТЬ("WHERE CODS IN (")
    сп.STG_ARH_СчитатьАрхив(к_АрхивСпрУлиц, г_путьПрофиляСпрУлиц)
    сп.ДОБАВИТЬ("))")
  КОНЕЦ_ЕСЛИ
  
  ЕСЛИ г_колУчастков > 0 ТО
    сп.ДОБАВИТЬ("AND A.ID_AREA IN (")
    сп.STG_ARH_СчитатьАрхив(к_АрхивСпрУчастков, г_путьПрофиляСпрУчастков)
    сп.ДОБАВИТЬ(")")
  КОНЕЦ_ЕСЛИ
  
  сп.ДОБАВИТЬ("ORDER BY A.srt, B.NOM, C.DAT")
  
  IB_FILE_ФайлУдалить(ф_tmp027)
  
  sql = SQL_ЗАПРОС(сп)
  sql.ЗАПИСАТЬ(ф_tmp027)
  
  набор = "редакторПокИПУ"
  БД_СБРОС_СТОЛБЦОВ(набор)
  БД_ДОБАВИТЬ_СТОЛБЕЦ(набор, "n_area", текстЗагИПЗагл, 10, "%")
  БД_ДОБАВИТЬ_СТОЛБЕЦ(набор, "fio", "Ф.И.О.", 35, "%")
  БД_ДОБАВИТЬ_СТОЛБЕЦ(набор, "nom", "Номер ИПУ", 15, "%")
  БД_ДОБАВИТЬ_СТОЛБЕЦ(набор, "dat", "Дата", 11)
  ЕСЛИ гр_ТипСч = к_СтатьиЭЭ ТО
    БД_ДОБАВИТЬ_СТОЛБЕЦ(набор, "num1", "Пок. Т1", 13)
    БД_ДОБАВИТЬ_СТОЛБЕЦ(набор, "num2", "Пок. Т2", 13)
    БД_ДОБАВИТЬ_СТОЛБЕЦ(набор, "num3", "Пок. Т3", 13)
    
    ЕСЛИ sql.НАЙТИ_ПОЗ("p!", "") <> 0 ТО
      БД_ДОБАВИТЬ_СТОЛБЕЦ(набор, "p", "Потери", 13)
      БД_ДОБАВИТЬ_СТОЛБЕЦ(набор, "p1", "Потери Т1", 13)
      БД_ДОБАВИТЬ_СТОЛБЕЦ(набор, "p2", "Потери Т2", 13)
      БД_ДОБАВИТЬ_СТОЛБЕЦ(набор, "p3", "Потери Т3", 13)
    КОНЕЦ_ЕСЛИ
  ИНАЧЕ
    БД_ДОБАВИТЬ_СТОЛБЕЦ(набор, "num1", "Показание", 13)
  КОНЕЦ_ЕСЛИ
  
  всегоДо = sql.ВСЕГО
  
  т = БД_РЕДАКТОР(sql, "Список показаний",
                   [
                    СТОЛБЦЫ(набор)
                   ],
                   ДА, ДА, ДА, ДА,
                   [АНач: ("ST_GSK\BLW\ST_GSK_02SPIS.IBL", "STG_ОбрПДобавлениемПоказаний"),
                    Уд:  ("ST_GSK\BLW\ST_GSK_02SPIS.IBL", "STG_ОбрУдалениеПоказаний"),
                    Мод: ("ST_GSK\BLW\ST_GSK_02SPIS.IBL", "STG_ОбрМодВнесениеПоказаний")
                   ];
                   яч_курсор = ДА)
  всегоПосле = sql.ВСЕГО
  sql.ЗАКРЫТЬ
  
  ЕСЛИ т > 0 ИЛИ (всегоДо > 0 И всегоПосле = 0) ТО
    путьФ = ""
    //добавление
    сп.ОЧИСТИТЬ
    сп.ДОБАВИТЬ("INSERT INTO")
    сп.ДОБАВИТЬ("'" + файл + "'")
    сп.ДОБАВИТЬ("(cods, id_area, id_sch, dat, num1")
    ЕСЛИ гр_ТипСч = к_СтатьиЭЭ ТО
      сп.ДОБАВИТЬ(", num2, num3, p, p1, p2, p3")
    КОНЕЦ_ЕСЛИ
    сп.ДОБАВИТЬ(", corr, is_synced)")
    сп.ДОБАВИТЬ("SELECT cods, id_area, id, dat, num1")
    ЕСЛИ гр_ТипСч = к_СтатьиЭЭ ТО
      сп.ДОБАВИТЬ(", num2, num3, p, p1, p2, p3")
    КОНЕЦ_ЕСЛИ
    сп.ДОБАВИТЬ(", CAST(FALSE AS BOOLEAN) AS corr, CAST(FALSE AS BOOLEAN) AS is_synced FROM")
    сп.ДОБАВИТЬ("'" + ф_tmp027 + "'")
    сп.ДОБАВИТЬ("WHERE added = TRUE")
    SQL_ЗАПРОС(сп)
    
    ЦИКЛ ИНДЕКС(ном = stg_парамСайтаДоб!ид)
      STG_ДобавитьЗаписьИзмСайт(к_спрСайтаПоказания, 0, "д", STG_ОписаниеИПУ(ном, гр_ТипСч))
    КОНЕЦ_ЦИКЛА
    
    //изменение
    колЭлем = КОЛ_ЭЛЕМ(stg_парамПоказанийИзм)
    ЕСЛИ колЭлем > 0 ТО
      СтатусСоздать("Изменение показаний")
      СтатусСтартПрогресс(колЭлем)
      ЦИКЛ ИНДЕКС(лог = stg_парамПоказанийИзм!индекс)
        СтатусОбновитьПрогресс("")
          
        id_a = СТР_ФРАГ(индекс, "@", 1)
        id_c = СТР_ФРАГ(индекс, "@", 2)
        dat = СТР_ФРАГ(индекс, "@", 3)
        
        сп.ОЧИСТИТЬ
        сп.ДОБАВИТЬ("UPDATE")
        сп.ДОБАВИТЬ("'" + ф_ПоказанияИСЭЭ + "'")
        сп.ДОБАВИТЬ("SET num1 = " + СТР_ЗНАЧ(stg_парамПоказанийИзмЗнач!индекс!"@t1"))
        ЕСЛИ гр_ТипСч = к_СтатьиЭЭ ТО
          сп.ДОБАВИТЬ(", num2 = " + СТР_ЗНАЧ(stg_парамПоказанийИзмЗнач!индекс!"@t2") + 
                      ", num3 = " + СТР_ЗНАЧ(stg_парамПоказанийИзмЗнач!индекс!"@t3"))
          сп.ДОБАВИТЬ(", p = '" + stg_парамПоказанийИзмЗнач!индекс!"@p" + "'" +
                      ", p1 = " + СТР_ЗНАЧ(stg_парамПоказанийИзмЗнач!индекс!"@p1") + 
                      ", p2 = " + СТР_ЗНАЧ(stg_парамПоказанийИзмЗнач!индекс!"@p1") + 
                      ", p3 = " + СТР_ЗНАЧ(stg_парамПоказанийИзмЗнач!индекс!"@p3"))
        КОНЕЦ_ЕСЛИ
        сп.ДОБАВИТЬ(", dat = '" + СТР(stg_парамПоказанийИзмЗнач!индекс!"@dat") + "'" + 
                    ", is_synced = FALSE")
        сп.ДОБАВИТЬ("WHERE id_area = " + id_a + " AND id_sch = " + id_c + " AND dat = '" + dat + "'")
        SQL_ЗАПРОС(сп)
      КОНЕЦ_ЦИКЛА
      СтатусЗакрыть
      
      ЦИКЛ ИНДЕКС(ном = stg_парамСайтаИзм!ид)
        STG_ДобавитьЗаписьИзмСайт(к_спрСайтаПоказания, ЗНАЧ(ид), "и", STG_ОписаниеИПУ(ном, гр_ТипСч))
      КОНЕЦ_ЦИКЛА
    КОНЕЦ_ЕСЛИ
    
    //удаление
    колЭлем = КОЛ_ЭЛЕМ(stg_показанияНаУдаление)
    ЕСЛИ колЭлем > 0 ТО
      СтатусСоздать("Удаление показаний")
      СтатусСтартПрогресс(колЭлем)
      ЦИКЛ ИНДЕКС(лог = stg_показанияНаУдаление!индекс)
        СтатусОбновитьПрогресс("")
        
        id_a = СТР_ФРАГ(индекс, "@", 1)
        id_c = СТР_ФРАГ(индекс, "@", 2)
        dat = СТР_ФРАГ(индекс, "@", 3)
        
        сп.ОЧИСТИТЬ
        сп.ДОБАВИТЬ("DELETE FROM")
        сп.ДОБАВИТЬ("'" + файл + "'")
        сп.ДОБАВИТЬ("WHERE id_area = " + id_a + " AND id_sch = " + id_c + " AND dat = '" + dat + "'")
        SQL_ЗАПРОС(сп)
      КОНЕЦ_ЦИКЛА
      СтатусЗакрыть
    
      ЦИКЛ ИНДЕКС(ном = stg_парамСайтаУд!ид)
        STG_ДобавитьЗаписьИзмСайт(к_спрСайтаПоказания, ЗНАЧ(ид), "у", STG_ОписаниеИПУ(ном, гр_ТипСч))
      КОНЕЦ_ЦИКЛА
    КОНЕЦ_ЕСЛИ
    
    //грубый пересчет объемов
    СтатусСоздать("Считывание начальных показаний")
    сп.ОЧИСТИТЬ
    сп.ДОБАВИТЬ("SELECT ID, NPOK1, NPOK2, NPOK3, TYPE, CODS FROM")
    сп.ДОБАВИТЬ("'" + ф_СпрИндивСчетчики + "'")
    сп.ДОБАВИТЬ("WHERE ID IN (")
    сп.ДОБАВИТЬ("SELECT ID FROM '" + ф_tmp027 + "'")
    сп.ДОБАВИТЬ(")")
    sql = SQL_ЗАПРОС(сп)
    СтатусСтартПрогресс(sql.ВСЕГО)
    ЦИКЛ ДЛЯ(и = 1, sql.ВСЕГО)
      sql.ПЕРЕЙТИ(и)
      СтатусОбновитьПрогресс("")
      
      идИПУ = sql.ПОЛЕ("ID")
      г_парамИПУ!идИПУ!"//тип" = sql.ПОЛЕ("TYPE")
      г_парамИПУ!идИПУ!"//кодУл" = sql.ПОЛЕ("CODS")
      г_начПоказания!идИПУ!"//Т1" = sql.ПОЛЕ("NPOK1")
      г_начПоказания!идИПУ!"//Т2" = sql.ПОЛЕ("NPOK2")
      г_начПоказания!идИПУ!"//Т3" = sql.ПОЛЕ("NPOK3")
    КОНЕЦ_ЦИКЛА
    sql.ЗАКРЫТЬ
    СтатусЗакрыть
    
    контекст = IB_CONTEXT_УстановитьЛок("контекстОбновленияОбъмов", "редакторПоказаний")
    STG_ОбновитьОбъемыИПУ(файл)
    контекст = IB_CONTEXT_УстановитьЛок("контекстОбновленияОбъмов", "")
  КОНЕЦ_ЕСЛИ
  
  IB_CONTEXT_ИзвлечьЛок(к_выборИПУ)
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ПЕРЕМ stg_парамСайтаДоб!
ФУНКЦИЯ ТИП_ЛОГИКА: STG_ОбрПДобавлениемПоказаний(ПЕРЕМ ТИП_СТРОКА: стр)
  ЕСЛИ STG_ВыборИПУизСпр(стр) ТО
    УСТ_РЕД_ПОЛЕ("cods", цл_КодУл)
    УСТ_РЕД_ПОЛЕ("id_area", Id_Area)
    УСТ_РЕД_ПОЛЕ("n_area", цл_КодУчГарПольз)
    УСТ_РЕД_ПОЛЕ("fio", цл_ФИО)
    УСТ_РЕД_ПОЛЕ("id", г_парамИПУ!"ид")
    УСТ_РЕД_ПОЛЕ("nom", г_парамИПУ!"номер")
    УСТ_РЕД_ПОЛЕ("model", г_парамИПУ!"модель")
    УСТ_РЕД_ПОЛЕ("cot", г_парамИПУ!"тарифность")
    УСТ_РЕД_ПОЛЕ("dat", датаОперации)
    УСТ_РЕД_ПОЛЕ("added", ДА)
    УСТ_РЕД_ПОЛЕ("edited", НЕТ)
    УСТ_РЕД_ПОЛЕ("srt", цл_ЗначениеСорт)
    
    ЦИКЛ ПОКА(ДА)
      STG_ВвестиДату(РЕД_ПОЛЕ("dat"), "dat")
      УСТ_РЕД_ПОЛЕ("p_dat", РЕД_ПОЛЕ("p_dat"))
      
      РЕЗУЛЬТАТ = STG_ПроверитьПарамДобПок(стр)
      ЕСЛИ РЕЗУЛЬТАТ ТО
        STG_НайтиПоказанияТекРед
        STG_НайтиПредПоказания
        STG_НайтиСледПоказания
        
        cot = 1
        ЕСЛИ гр_ТипСч = к_СтатьиЭЭ ТО
          cot = РЕД_ПОЛЕ("cot")
        КОНЕЦ_ЕСЛИ
        
        ЦИКЛ ДЛЯ(и = 1, cot)
          поле = "num" + СТР_ЗНАЧ(и)
          STG_ВвестиПоказание(РЕД_ПОЛЕ(поле), поле)
        КОНЕЦ_ЦИКЛА
        
        STG_ЗаполнитьПоказанияДоб
        
        stg_парамСайтаДоб[РЕД_ПОЛЕ("nom") + "@" + СТР(РЕД_ПОЛЕ("dat"))] = РЕД_ПОЛЕ("nom")
        
        СТОП
      КОНЕЦ_ЕСЛИ
    КОНЕЦ_ЦИКЛА
    
    STG_ОбрПДобавлениемПоказаний = РЕЗУЛЬТАТ
  КОНЕЦ_ЕСЛИ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ ТИП_ЛОГИКА: STG_ПроверитьПарамДобПок(ПЕРЕМ ТИП_СТРОКА: стр)
  РЕЗУЛЬТАТ = ДА
  
  sql = SQL_ТЕК_РЕД_КЛОН
  ЕСЛИ sql.НАЙТИ_ПОЗ("id", РЕД_ПОЛЕ("id"),
                     "dat", РЕД_ПОЛЕ("dat")) > 0 ТО
    СООБЩЕНИЕ("Нельзя вносить несколько показаний на одну дату для одного ИПУ. Измените дату или существующие показания.")
    РЕЗУЛЬТАТ = НЕТ
  КОНЕЦ_ЕСЛИ
  
  ЕСЛИ РЕД_ПОЛЕ("dat") > гр_ДатаПо ИЛИ РЕД_ПОЛЕ("dat") < гр_ДатаС ТО
    СООБЩЕНИЕ("Показания вносятся за период с " + СТР(гр_ДатаС) + " по " + СТР(гр_ДатаПо) + " включительно. Измените дату.")
    РЕЗУЛЬТАТ = НЕТ
  КОНЕЦ_ЕСЛИ
  
  STG_ПроверитьПарамДобПок = РЕЗУЛЬТАТ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ STG_НайтиПредПоказания
  РЕЗУЛЬТАТ = НЕТ
  
  id_ipu = РЕД_ПОЛЕ("id")
  
  stg_предПоказания!"t1" = 0
  stg_предПоказания!"t2" = 0
  stg_предПоказания!"t3" = 0
  
  ЕСЛИ СУЩ_ПЕРЕМ(stg_текРедПоказания!id_ipu) ТО
    ЦИКЛ ДЛЯ(и = 1, stg_текРедПоказания!id_ipu)
      индекс = СТР0(и, 6) + "@" + СТР_ЗНАЧ(id_ipu)
      ЕСЛИ и = 1 ТО
        максМинДата = stg_текРедПоказанияЗнач!индекс!"@dat"
      КОНЕЦ_ЕСЛИ
      ЕСЛИ stg_текРедПоказанияЗнач!индекс!"@dat" < РЕД_ПОЛЕ("dat") ТО
        ЕСЛИ максМинДата > stg_текРедПоказанияЗнач!индекс!"@dat" ТО
          УСТ_РЕД_ПОЛЕ("pr_dat", stg_текРедПоказанияЗнач!индекс!"@dat")
          stg_предПоказания!"t1" = stg_текРедПоказанияЗнач!индекс!"@num1"
          stg_предПоказания!"t2" = stg_текРедПоказанияЗнач!индекс!"@num2"
          stg_предПоказания!"t3" = stg_текРедПоказанияЗнач!индекс!"@num3"
          РЕЗУЛЬТАТ = ДА
        КОНЕЦ_ЕСЛИ
      КОНЕЦ_ЕСЛИ
    КОНЕЦ_ЦИКЛА
  КОНЕЦ_ЕСЛИ
  
  ЕСЛИ НЕ РЕЗУЛЬТАТ ТО
    СОЗДАТЬ(сп, ТИП_СПИСОК)
    сп.ДОБАВИТЬ("SELECT * FROM")
    сп.ДОБАВИТЬ("'" + ф_ПоказанияИСЭЭ + "'")
    сп.ДОБАВИТЬ("WHERE dat < '" + СТР(РЕД_ПОЛЕ("dat")) + "' AND id_sch = " + СТР_ЗНАЧ(id_ipu))
    сп.ДОБАВИТЬ("ORDER BY dat DESC")
  
    sql = SQL_ЗАПРОС(сп)
    //БД_РЕДАКТОР(sql)
    ЕСЛИ sql.ВСЕГО > 0 ТО
      sql.ПЕРЕЙТИ(1)
      
      УСТ_РЕД_ПОЛЕ("pr_dat", sql.ПОЛЕ("dat"))
      stg_предПоказания!"t1" = sql.ПОЛЕ("num1")
      ЕСЛИ гр_ТипСч = к_СтатьиЭЭ ТО
        stg_предПоказания!"t2" = sql.ПОЛЕ("num2")
        stg_предПоказания!"t3" = sql.ПОЛЕ("num3")
      КОНЕЦ_ЕСЛИ
    ИНАЧЕ
      УСТ_РЕД_ПОЛЕ("pr_dat", к_МинДата)
      stg_предПоказания!"t1" = г_парамИПУ!"НачПокТ1"
      ЕСЛИ гр_ТипСч = к_СтатьиЭЭ ТО
        stg_предПоказания!"t2" = г_парамИПУ!"НачПокТ2"
        stg_предПоказания!"t3" = г_парамИПУ!"НачПокТ3"
      КОНЕЦ_ЕСЛИ
    КОНЕЦ_ЕСЛИ
    sql.ЗАКРЫТЬ
  КОНЕЦ_ЕСЛИ
  
  УСТ_РЕД_ПОЛЕ("pr_num1", stg_предПоказания!"t1")
  ЕСЛИ гр_ТипСч = к_СтатьиЭЭ ТО
    УСТ_РЕД_ПОЛЕ("pr_num2", stg_предПоказания!"t2")
    УСТ_РЕД_ПОЛЕ("pr_num3", stg_предПоказания!"t3")
  КОНЕЦ_ЕСЛИ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ STG_НайтиСледПоказания
  РЕЗУЛЬТАТ = НЕТ
  
  id_ipu = РЕД_ПОЛЕ("id")
  
  stg_следПоказания!"t1" = 0
  stg_следПоказания!"t2" = 0
  stg_следПоказания!"t3" = 0
  
  ЕСЛИ СУЩ_ПЕРЕМ(stg_текРедПоказания!id_ipu) ТО
    ЦИКЛ ДЛЯ(и = 1, stg_текРедПоказания!id_ipu)
      индекс = СТР0(и, 6) + "@" + СТР_ЗНАЧ(id_ipu)
      ЕСЛИ и = 1 ТО
        максМинДата = stg_текРедПоказанияЗнач!индекс!"@dat"
      КОНЕЦ_ЕСЛИ
      ЕСЛИ stg_текРедПоказанияЗнач!индекс!"@dat" > РЕД_ПОЛЕ("dat") ТО
        ЕСЛИ максМинДата < stg_текРедПоказанияЗнач!индекс!"@dat" ТО
          УСТ_РЕД_ПОЛЕ("n_dat", stg_текРедПоказанияЗнач!индекс!"@dat")
          stg_следПоказания!"t1" = stg_текРедПоказанияЗнач!индекс!"@num1"
          stg_следПоказания!"t2" = stg_текРедПоказанияЗнач!индекс!"@num2"
          stg_следПоказания!"t3" = stg_текРедПоказанияЗнач!индекс!"@num3"
          РЕЗУЛЬТАТ = ДА
        КОНЕЦ_ЕСЛИ
      КОНЕЦ_ЕСЛИ
    КОНЕЦ_ЦИКЛА
  КОНЕЦ_ЕСЛИ
  
  ЕСЛИ НЕ РЕЗУЛЬТАТ ТО
    СОЗДАТЬ(сп, ТИП_СПИСОК)
    сп.ДОБАВИТЬ("SELECT * FROM")
    сп.ДОБАВИТЬ("'" + ф_ПоказанияИСЭЭ + "'")
    сп.ДОБАВИТЬ("WHERE dat > '" + СТР(РЕД_ПОЛЕ("dat")) + "' AND id_sch = " + СТР_ЗНАЧ(id_ipu))
    сп.ДОБАВИТЬ("ORDER BY dat ASC")
  
    sql = SQL_ЗАПРОС(сп)
    //БД_РЕДАКТОР(sql)
    ЕСЛИ sql.ВСЕГО > 0 ТО
      sql.ПЕРЕЙТИ(1)
      
      УСТ_РЕД_ПОЛЕ("n_dat", sql.ПОЛЕ("dat"))
      stg_следПоказания!"t1" = sql.ПОЛЕ("num1")
      ЕСЛИ гр_ТипСч = к_СтатьиЭЭ ТО
        stg_следПоказания!"t2" = sql.ПОЛЕ("num2")
        stg_следПоказания!"t3" = sql.ПОЛЕ("num3")
      КОНЕЦ_ЕСЛИ
    КОНЕЦ_ЕСЛИ
    sql.ЗАКРЫТЬ
  КОНЕЦ_ЕСЛИ
    
   УСТ_РЕД_ПОЛЕ("n_num1", stg_следПоказания!"t1")
   ЕСЛИ гр_ТипСч = к_СтатьиЭЭ ТО
     УСТ_РЕД_ПОЛЕ("n_num2", stg_следПоказания!"t2")
     УСТ_РЕД_ПОЛЕ("n_num3", stg_следПоказания!"t3")
   КОНЕЦ_ЕСЛИ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ПЕРЕМ stg_текРедПоказания!
ПЕРЕМ stg_текРедПоказанияЗнач!
ФУНКЦИЯ STG_НайтиПоказанияТекРед
  ЕСЛИ НЕ СУЩ_ПЕРЕМ(stg_текРедПоказания[РЕД_ПОЛЕ("id")]) ТО
    колЭлем = 1
    sql = SQL_ТЕК_РЕД_КЛОН
    текПоз = sql.НАЙТИ_ПОЗ("id", РЕД_ПОЛЕ("id"))
    ЕСЛИ текПоз > 0 ТО
      ЦИКЛ ПОКА(sql.ПОЛЕ("id") = РЕД_ПОЛЕ("id"))
        индекс = СТР0(колЭлем, 6) + "@" + СТР_ЗНАЧ(РЕД_ПОЛЕ("id"))
        
        stg_текРедПоказания[РЕД_ПОЛЕ("id")] = колЭлем
        stg_текРедПоказанияЗнач!индекс!"@dat" = sql.ПОЛЕ("dat")
        stg_текРедПоказанияЗнач!индекс!"@num1" = sql.ПОЛЕ("num1")
        ЕСЛИ гр_ТипСч = к_СтатьиЭЭ ТО
          stg_текРедПоказанияЗнач!индекс!"@num2" = sql.ПОЛЕ("num2")
          stg_текРедПоказанияЗнач!индекс!"@num3" = sql.ПОЛЕ("num3")
        КОНЕЦ_ЕСЛИ
        
        текПоз++
        колЭлем++
        ЕСЛИ текПоз > sql.ВСЕГО ТО
          СТОП
        КОНЕЦ_ЕСЛИ
        sql.ПЕРЕЙТИ(текПоз)
      КОНЕЦ_ЦИКЛА
    КОНЕЦ_ЕСЛИ
    sql.ЗАКРЫТЬ
  КОНЕЦ_ЕСЛИ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ STG_ЗаполнитьПоказанияДоб
  id_ipu = РЕД_ПОЛЕ("id")
  
  ЕСЛИ НЕ СУЩ_ПЕРЕМ(stg_текРедПоказания!id_ipu) ТО
    stg_текРедПоказания!id_ipu = 0
  КОНЕЦ_ЕСЛИ
  stg_текРедПоказания!id_ipu++
    
  индекс = СТР0(stg_текРедПоказания!id_ipu, 6) + "@" + СТР_ЗНАЧ(id_ipu)
  
  stg_текРедПоказанияЗнач!индекс!"@dat" = РЕД_ПОЛЕ("dat")
  stg_текРедПоказанияЗнач!индекс!"@num1" = РЕД_ПОЛЕ("num1")
  ЕСЛИ гр_ТипСч = к_СтатьиЭЭ ТО
    stg_текРедПоказанияЗнач!индекс!"@num2" = РЕД_ПОЛЕ("num2")
    stg_текРедПоказанияЗнач!индекс!"@num3" = РЕД_ПОЛЕ("num3")
  КОНЕЦ_ЕСЛИ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
//-------------------------------------------------------------------------------------------------------------------------//
ПЕРЕМ stg_парамПоказанийИзм!
ПЕРЕМ stg_парамПоказанийИзмЗнач!
ПЕРЕМ stg_парамСайтаИзм!
ФУНКЦИЯ ТИП_ЛОГИКА: STG_ОбрИзменениеПоказаний(ПЕРЕМ ТИП_СТРОКА: стр)
  ЕСЛИ НЕ РЕД_ПОЛЕ("added") ТО //уже существующая ранее запись
    УСТ_РЕД_ПОЛЕ("edited", ДА)
    
    инд = СТР_ЗНАЧ(РЕД_ПОЛЕ("id_area")) + "@" + СТР_ЗНАЧ(РЕД_ПОЛЕ("id")) + "@" + СТР(РЕД_ПОЛЕ("p_dat"))
    
    stg_парамПоказанийИзм!инд = ДА
    stg_парамПоказанийИзмЗнач!инд!"@dat" = РЕД_ПОЛЕ("dat")
    stg_парамПоказанийИзмЗнач!инд!"@t1" = РЕД_ПОЛЕ("num1")
    ЕСЛИ гр_ТипСч = к_СтатьиЭЭ ТО
      stg_парамПоказанийИзмЗнач!инд!"@t2" = РЕД_ПОЛЕ("num2")
      stg_парамПоказанийИзмЗнач!инд!"@t3" = РЕД_ПОЛЕ("num3")
      stg_парамПоказанийИзмЗнач!инд!"@p" = РЕД_ПОЛЕ("p")
      stg_парамПоказанийИзмЗнач!инд!"@p1" = РЕД_ПОЛЕ("p1")
      stg_парамПоказанийИзмЗнач!инд!"@p2" = РЕД_ПОЛЕ("p2")
      stg_парамПоказанийИзмЗнач!инд!"@p3" = РЕД_ПОЛЕ("p3")
    КОНЕЦ_ЕСЛИ
    
    ЕСЛИ РЕД_ПОЛЕ("id_recsite") > 0 ТО
      stg_парамСайтаИзм[РЕД_ПОЛЕ("id_recsite")] = РЕД_ПОЛЕ("nom")
    КОНЕЦ_ЕСЛИ
  КОНЕЦ_ЕСЛИ
  STG_ОбрИзменениеПоказаний = ДА
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
//-------------------------------------------------------------------------------------------------------------------------//
ПЕРЕМ stg_показанияНаУдаление!
ПЕРЕМ stg_парамСайтаУд!
ФУНКЦИЯ ТИП_ЛОГИКА: STG_ОбрУдалениеПоказаний(ПЕРЕМ ТИП_СТРОКА: стр)
  РЕЗУЛЬТАТ = ВОПРОС("Удалить показание?", НЕТ)
  ЕСЛИ РЕЗУЛЬТАТ ТО
    ЕСЛИ НЕ РЕД_ПОЛЕ("added") ТО
      инд = СТР_ЗНАЧ(РЕД_ПОЛЕ("id_area")) + "@" + СТР_ЗНАЧ(РЕД_ПОЛЕ("id")) + "@" + СТР(РЕД_ПОЛЕ("dat"))
      stg_показанияНаУдаление!инд = ДА
    
      ЕСЛИ РЕД_ПОЛЕ("id_recsite") > 0 ТО
        stg_парамСайтаУд[РЕД_ПОЛЕ("id_recsite")] = РЕД_ПОЛЕ("nom")
      КОНЕЦ_ЕСЛИ
    КОНЕЦ_ЕСЛИ
  КОНЕЦ_ЕСЛИ
  STG_ОбрУдалениеПоказаний = РЕЗУЛЬТАТ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ ТИП_ЛОГИКА: STG_ОбрМодВнесениеПоказаний(ПЕРЕМ ТИП_СТРОКА: стр)
  РЕЗУЛЬТАТ = НЕТ
  
  текСтолбец = РЕД_ПОЛЕ("#ТЕК_СТОЛБЕЦ")
  ЕСЛИ текСтолбец = "" ТО
    ВЫХОД
  КОНЕЦ_ЕСЛИ
  
  знач = РЕД_ПОЛЕ(текСтолбец)
  ВЫБОР(ЗАГЛ(текСтолбец))
   #"NUM1", "NUM2", "NUM3":
    текТЗ = 3
    ЕСЛИ IB_STR_ВыделитьЧисло(текСтолбец, текТЗ) ТО
      ЕСЛИ текТЗ <= РЕД_ПОЛЕ("cot") ТО
        STG_НайтиПоказанияТекРед
        STG_НайтиПредПоказания
        STG_НайтиСледПоказания
        ЕСЛИ STG_ВвестиПоказание(РЕД_ПОЛЕ(текСтолбец), текСтолбец) ТО
          РЕЗУЛЬТАТ = STG_ОбрИзменениеПоказаний(стр)
        КОНЕЦ_ЕСЛИ
      КОНЕЦ_ЕСЛИ
    КОНЕЦ_ЕСЛИ
   #"DAT":
     ЕСЛИ STG_ВвестиДату(РЕД_ПОЛЕ(текСтолбец), текСтолбец) ТО
       STG_НайтиПоказанияТекРед
       STG_НайтиПредПоказания
       STG_НайтиСледПоказания
       ЕСЛИ STG_ПроверитьПарамДобПок(стр) ТО
        РЕЗУЛЬТАТ = STG_ОбрИзменениеПоказаний(стр)
       КОНЕЦ_ЕСЛИ
     КОНЕЦ_ЕСЛИ
   #"P":
    знач = РЕД_ПОЛЕ(текСтолбец)
    РЕЗУЛЬТАТ = STG_ВариантУчПотерь(знач)
    ЕСЛИ РЕЗУЛЬТАТ ТО
      УСТ_РЕД_ПОЛЕ(текСтолбец, знач)
    КОНЕЦ_ЕСЛИ
   #"P1", "P2", "P3":
    знач = РЕД_ПОЛЕ(текСтолбец)
    РЕЗУЛЬТАТ = STG_ВвестиЧисло(знач)
    ЕСЛИ РЕЗУЛЬТАТ ТО
      УСТ_РЕД_ПОЛЕ(текСтолбец, знач)
    КОНЕЦ_ЕСЛИ
  КОНЕЦ_ВЫБОРА
  
  STG_ОбрМодВнесениеПоказаний = РЕЗУЛЬТАТ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ ТИП_ЛОГИКА: STG_ВвестиПоказание(ТИП_ЧИСЛО: знач; ТИП_СТРОКА: столбец)
  текТЗ = 3
  IB_STR_ВыделитьЧисло(столбец, текТЗ)
  ЦИКЛ ПОКА(ДА)
    значВвода = ВВОД_ЗНАЧЕНИЯ("Введите показание Т" + СТР_ЗНАЧ(текТЗ) + ":", знач)
    РЕЗУЛЬТАТ = (АТРИБУТ("результат_диалога") = "ДА") И знач <> значВвода
    ЕСЛИ РЕЗУЛЬТАТ ТО
      ЕСЛИ STG_ПроверитьПоказание(значВвода, текТЗ) ТО
        УСТ_РЕД_ПОЛЕ(столбец, значВвода)
        СТОП
      КОНЕЦ_ЕСЛИ
    ИНАЧЕ
      ЕСЛИ АТРИБУТ("результат_диалога") = "НЕТ" ТО
        СТОП
      КОНЕЦ_ЕСЛИ
    КОНЕЦ_ЕСЛИ
  КОНЕЦ_ЦИКЛА
  STG_ВвестиПоказание = РЕЗУЛЬТАТ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ ТИП_ЛОГИКА: STG_ВвестиЧисло(ПЕРЕМ ТИП_ЧИСЛО: знач)
  значВвода = ВВОД_ЗНАЧЕНИЯ("Введите значение:", знач)
  РЕЗУЛЬТАТ = (АТРИБУТ("результат_диалога") = "ДА") И знач <> значВвода
  ЕСЛИ РЕЗУЛЬТАТ ТО
    знач = значВвода
  КОНЕЦ_ЕСЛИ
  STG_ВвестиЧисло = РЕЗУЛЬТАТ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ ТИП_ЛОГИКА: STG_ПроверитьПоказание(ТИП_ЧИСЛО: значВвода, текТЗ)
  РЕЗУЛЬТАТ = ДА
  
  поле = "pr_num" + СТР_ЗНАЧ(текТЗ)
  ЕСЛИ значВвода < РЕД_ПОЛЕ(поле) ТО
    СООБЩЕНИЕ("Текущее показание не может быть меньше предыдущего(" + СТР(РЕД_ПОЛЕ(поле)) + ").")
    РЕЗУЛЬТАТ = НЕТ
  КОНЕЦ_ЕСЛИ
  
  поле = "n_num" + СТР_ЗНАЧ(текТЗ)
  ЕСЛИ значВвода > РЕД_ПОЛЕ(поле) И РЕД_ПОЛЕ(поле) > 0 ТО
    СООБЩЕНИЕ("Текущее показание не может быть больше следующего(" + СТР(РЕД_ПОЛЕ(поле)) + ").")
    РЕЗУЛЬТАТ = НЕТ
  КОНЕЦ_ЕСЛИ
    
  STG_ПроверитьПоказание = РЕЗУЛЬТАТ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ ТИП_ЛОГИКА: STG_ВвестиДату(ТИП_ДАТА: знач; ТИП_СТРОКА: столбец)
  значВвода = ВВОД_ЗНАЧЕНИЯ("Введите дату:", знач)
  РЕЗУЛЬТАТ = (АТРИБУТ("результат_диалога") = "ДА") И знач <> значВвода
  ЕСЛИ РЕЗУЛЬТАТ ТО
    УСТ_РЕД_ПОЛЕ(столбец, значВвода)
  КОНЕЦ_ЕСЛИ
  STG_ВвестиДату = РЕЗУЛЬТАТ
КОНЕЦ_ФУНКЦИИ