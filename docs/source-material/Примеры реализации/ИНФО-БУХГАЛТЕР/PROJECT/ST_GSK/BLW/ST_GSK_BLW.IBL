//-------------------------------------------------------------------------------------------------------------------------//
//Источник данных для отчетов
ФУНКЦИЯ ТИП_ЛОГИКА: STG_ВыборТипОтчОплат(ПЕРЕМ ТИП_СТРОКА: стр)
  СОЗДАТЬ(сп, ТИП_СПИСОК)
  сп.ДОБАВИТЬ(к_РеестрОплатРазвернуто)
  сп.ДОБАВИТЬ(к_РеестрОплатСвернуто)
  сп.ДОБАВИТЬ(к_РеестрОплатПомесячно)
  
  IB_DLG_ЗаголовкиВыбИзСписка("Выбор типа отчёта", "Тип отчёта")
  STG_ВыборТипОтчОплат = сп.IB_DLG_ВыборИзСписка(стр)

  ЕСЛИ стр = к_РеестрОплатРазвернуто ТО
    IB_TBLSET_УстановитьПрофиль(?(г_блокГСК, к_ГСКПрофТблРеестрОплРазв, к_СНТПрофТблРеестрОплРазв))
  ИНАЧЕ
    IB_TBLSET_УстановитьПрофиль("")
  КОНЕЦ_ЕСЛИ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
//Источник данных для отчетов
ФУНКЦИЯ ТИП_ЛОГИКА: STG_ВыборТипОтчНачисления(ПЕРЕМ ТИП_СТРОКА: стр)
  СОЗДАТЬ(сп, ТИП_СПИСОК)
  сп.ДОБАВИТЬ(к_РеестрНачисленийРазвернуто)
  сп.ДОБАВИТЬ(к_РеестрНачисленийСвернуто)
  сп.ДОБАВИТЬ(к_РеестрНачисленийПомесячно)
  
  IB_DLG_ЗаголовкиВыбИзСписка("Выбор типа отчёта", "Тип отчёта")
  STG_ВыборТипОтчНачисления = сп.IB_DLG_ВыборИзСписка(стр)

  ЕСЛИ стр = к_РеестрНачисленийРазвернуто ТО
    IB_TBLSET_УстановитьПрофиль(?(г_блокГСК, к_ГСКПрофТблРеестрНачРазв, к_СНТПрофТблРеестрНачРазв))
  ИНАЧЕ
    IB_TBLSET_УстановитьПрофиль("")
  КОНЕЦ_ЕСЛИ
КОНЕЦ_ФУНКЦИИ

