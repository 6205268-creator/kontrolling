//-------------------------------------------------------------------------------------------------------------------------//
//Пути к файлам профилей граф множ выбора
ФУНКЦИЯ STG_ПутиПрофилейМножВыбора
  г_путьПрофиляСпрУлиц = ""
  г_путьПрофиляСпрУчастков = ""
  г_путьПрофиляСпрВзносов = ""
  г_колУлиц = 0
  г_колУчастков = 0
  г_колВзносов = 0
  ЕСЛИ НЕ СУЩ_ПЕРЕМ(гр_улицы) ТО
    гр_улицы = ""
  КОНЕЦ_ЕСЛИ
  ЕСЛИ НЕ СУЩ_ПЕРЕМ(гр_участки) ТО
    гр_участки = ""
  КОНЕЦ_ЕСЛИ
  ЕСЛИ НЕ СУЩ_ПЕРЕМ(гр_взносы) ТО
    гр_взносы = ""
  КОНЕЦ_ЕСЛИ
  
  ЕСЛИ гр_улицы <> "" ТО
    ЕСЛИ IB_PROF_ФайлПрофиляМножВыб(г_идПрофСпрУлиц, г_путьПрофиляСпрУлиц) ТО
      sql = SQL_ОТКРЫТЬ(г_путьПрофиляСпрУлиц)
      г_колУлиц = sql.ВСЕГО
      ЕСЛИ г_колУлиц > 0 ТО
        ЦИКЛ ДЛЯ(и = 1, г_колУлиц)
          sql.ПЕРЕЙТИ(и)
          stg_текУлицыФильтра[sql.ПОЛЕ("CODS")] = ДА
        КОНЕЦ_ЦИКЛА
      КОНЕЦ_ЕСЛИ
      sql.ЗАКРЫТЬ
    КОНЕЦ_ЕСЛИ
  КОНЕЦ_ЕСЛИ

  ЕСЛИ гр_участки <> "" ТО
    ЕСЛИ IB_PROF_ФайлПрофиляМножВыб(г_идПрофСпрУчастков, г_путьПрофиляСпрУчастков) ТО
      sql = SQL_ОТКРЫТЬ(г_путьПрофиляСпрУчастков)
      г_колУчастков = sql.ВСЕГО
      ЕСЛИ г_колУчастков > 0 ТО
        ЦИКЛ ДЛЯ(и = 1, г_колУчастков)
          sql.ПЕРЕЙТИ(и)
          stg_текУчасткиФильтра[sql.ПОЛЕ("ID_AREA")] = ДА
        КОНЕЦ_ЦИКЛА
      КОНЕЦ_ЕСЛИ
      sql.ЗАКРЫТЬ
    КОНЕЦ_ЕСЛИ
  КОНЕЦ_ЕСЛИ

  ЕСЛИ гр_взносы <> "" ТО
    ЕСЛИ IB_PROF_ФайлПрофиляМножВыб(г_идПрофСпрВзносов, г_путьПрофиляСпрВзносов) ТО
      sql = SQL_ОТКРЫТЬ(г_путьПрофиляСпрВзносов)
      г_колВзносов = sql.ВСЕГО
      ЕСЛИ г_колВзносов > 0 ТО
        ЦИКЛ ДЛЯ(и = 1, г_колВзносов)
          sql.ПЕРЕЙТИ(и)
          stg_текВзносыФильтра[sql.ПОЛЕ("CODP")] = ДА
        КОНЕЦ_ЦИКЛА
      КОНЕЦ_ЕСЛИ
      sql.ЗАКРЫТЬ
    КОНЕЦ_ЕСЛИ
  КОНЕЦ_ЕСЛИ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ STG_УстОтобрГрафМножВыбБланк
  ЕСЛИ СУЩ_ПЕРЕМ(гр_улицы) ТО
    гр_улицы = IB_PROF_СформироватьОтображение(г_идПрофСпрУлиц)
  КОНЕЦ_ЕСЛИ
  ЕСЛИ СУЩ_ПЕРЕМ(гр_участки) ТО
    гр_участки = IB_PROF_СформироватьОтображение(г_идПрофСпрУчастков)
  КОНЕЦ_ЕСЛИ
  ЕСЛИ СУЩ_ПЕРЕМ(гр_взносы) ТО
   гр_взносы = IB_PROF_СформироватьОтображение(г_идПрофСпрВзносов)
  КОНЕЦ_ЕСЛИ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ STG_УстОтобрГрафМножВыбТО
  ЕСЛИ СУЩ_ПЕРЕМ(гр_улицы) ТО
    гр_улицы = IB_PROF_СформироватьОтображение(г_идПрофСпрУлиц)
  КОНЕЦ_ЕСЛИ
  ЕСЛИ СУЩ_ПЕРЕМ(гр_участки) ТО
    гр_участки = IB_PROF_СформироватьОтображение(г_идПрофСпрУчастков)
  КОНЕЦ_ЕСЛИ
  ЕСЛИ СУЩ_ПЕРЕМ(гр_взносы) ТО
   гр_взносы = IB_PROF_СформироватьОтображение(г_идПрофСпрВзносов)
  КОНЕЦ_ЕСЛИ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
//Функция выбора детализации расширенная
ПЕРЕМ ТИП_ЧИСЛО: г_типДетализации
ФУНКЦИЯ ТИП_ЛОГИКА: STG_ДетализацияОтчета(ПЕРЕМ ТИП_СТРОКА: стр) //STG_ДЕТАЛИЗАЦИЯ
  STG_УстТекстБлока
  СОЗДАТЬ(сп, ТИП_СПИСОК)
  сп.STG_ЗаполнитьДетализацию
  ВЫБОР(г_типДетализации)
   #к_ТипДетализации1:
    сп.ДОБАВИТЬ("По членам")
    сп.ДОБАВИТЬ("По не членам")
   #к_ТипДетализации2:
    сп.ДОБАВИТЬ(к_ДетализацияВыводПустойТбл)
  КОНЕЦ_ВЫБОРА

  STG_ДетализацияОтчета = сп.IB_DLG_ВыборИзСписка(стр)
  Id_Area = 0  цл_КодУл = ""  цл_КодУчГарПольз = ""
КОНЕЦ_ФУНКЦИИ

//Cтандартная детализация
ФУНКЦИЯ ТИП_СПИСОК STG_ЗаполнитьДетализацию
  ДОБАВИТЬ("По всем")
  ДОБАВИТЬ("По " + т_распЗагДП)
  ДОБАВИТЬ("По " + текстЗагДП)
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ ТИП_ЛОГИКА: STG_ВыборНаличияEMail(ПЕРЕМ ТИП_СТРОКА: стр)
  СОЗДАТЬ(сп, ТИП_СПИСОК)
  сп.ДОБАВИТЬ("")
  сп.ДОБАВИТЬ("Есть")
  сп.ДОБАВИТЬ("Нет")
  STG_ВыборНаличияEMail = сп.IB_DLG_ВыборИзСписка(стр)
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
//Бланки 2.01 и 3.01
//Выбор способа распределения затрат ОПУ ЭЭ
ФУНКЦИЯ ТИП_ЛОГИКА: STG_ВыбРазделовПД(ПЕРЕМ ТИП_СТРОКА: стр)
  СОЗДАТЬ(сп, ТИП_СПИСОК)
  сп.ДОБАВИТЬ(к_разделПДВсе)
  сп.ДОБАВИТЬ(к_разделПДИзвещение)
  сп.ДОБАВИТЬ(к_разделПДКвитанция)
  
  IB_DLG_ЗаголовкиВыбИзСписка("Выбор разделов ПД", "Раздел ПД")
  рез = сп.IB_DLG_ВыборИзСписка(стр)
  
  STG_ВыбРазделовПД = рез
КОНЕЦ_ФУНКЦИИ

//Бланк 7.01
//-------------------------------------------------------------------------------------------------------------------------//
//Выбор детализации владельцев
ФУНКЦИЯ ТИП_ЛОГИКА: STG_ДетВладелец (ПЕРЕМ ТИП_СТРОКА: С)
  С1 = к_ВсеВладельцы
  С2 = к_ТекВладелецНаДату
  С = ?(С = С1, С2, С1)
  STG_ДетВладелец = ДА
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
//Выбор, по какому счету фильтровать
ФУНКЦИЯ ТИП_ЛОГИКА: STG_ВыборТаблКарточкиОб(ПЕРЕМ ТИП_СТРОКА: стр)
  СОЗДАТЬ(сп, ТИП_СПИСОК)
  сп.ДОБАВИТЬ("Начисления и оплаты")
  сп.ДОБАВИТЬ("Только начисления")
  сп.ДОБАВИТЬ("Только оплаты")
  сп.ДОБАВИТЬ("Не выводить")
  STG_ВыборТаблКарточкиОб = сп.IB_DLG_ВыборИзСписка(стр)
КОНЕЦ_ФУНКЦИИ

