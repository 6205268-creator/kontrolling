//-------------------------------------------------------------------------------------------------------------------------//
//выбор формата ПД
ФУНКЦИЯ ТИП_ЛОГИКА: STG_ВыбФорматаПД(ПЕРЕМ ТИП_СТРОКА: стр)
  СОЗДАТЬ(сп, ТИП_СПИСОК)
  сп.ДОБАВИТЬ(к_ФорматDOC)
  сп.ДОБАВИТЬ(к_ФорматDOCX)
  сп.ДОБАВИТЬ(к_ФорматODT)
  сп.ДОБАВИТЬ(к_ФорматPDF)
  ЕСЛИ ИМЯ_ГРАФЫ = "гр_форматПДПочта" ТО
    сп.ДОБАВИТЬ(к_форматHTML)
  КОНЕЦ_ЕСЛИ
  STG_ВыбФорматаПД = сп.IB_DLG_ВыборИзСписка(стр)
КОНЕЦ_ФУНКЦИИ

