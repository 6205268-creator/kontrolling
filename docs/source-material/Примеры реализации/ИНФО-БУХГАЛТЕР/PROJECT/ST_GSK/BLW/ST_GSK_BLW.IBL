//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ ТИП_ЛОГИКА: STG_МЕТОД_3(ПЕРЕМ ТИП_СТРОКА: С) //_МЕТОД_3
  С1 = к_ОдиночнОперПо1Стат
  С2 = к_ОдиночнОперПоНескСтат
  С = ?(С = С1, С2, С1)
  STG_МЕТОД_3 = ДА
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ ТИП_ЛОГИКА: STG_ВыбДействиеРазноска(ПЕРЕМ ТИП_СТРОКА: С)
  С1 = к_ДействиеРазноскаЦлВзДоб
  С2 = к_ДействиеРазноскаЦлВзУд
  С = ?(С = С1, С2, С1)
  STG_ВыбДействиеРазноска = ДА
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
//Выбор типа отчета в бланке реестр участков/гаражей
ФУНКЦИЯ ТИП_ЛОГИКА: STG_ВыборТипаРеестраБл13(ПЕРЕМ ТИП_СТРОКА: С)
  STG_УстТекстБлока
  С = ?(С = "По " + текстЗагДПМнож, "По собственникам", "По " + текстЗагДПМнож)  
  ЕСЛИ С = "По собственникам" ТО
    IB_TBLSET_УстановитьПрофиль(?(г_блокГСК, к_ГСКПрофТблРеестрСобств, к_СНТПрофТблРеестрСобств))
  ИНАЧЕ
    IB_TBLSET_УстановитьПрофиль(?(г_блокГСК, к_ГСКПрофТблРеестрУчасток, к_СНТПрофТблРеестрУчасток))
  КОНЕЦ_ЕСЛИ
  STG_ВыборТипаРеестраБл13 = ДА
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
//Выбор, по какому счету фильтровать
ФУНКЦИЯ ТИП_ЛОГИКА: STG_ВыборСчетаОплат(ПЕРЕМ ТИП_СТРОКА: стр)
  СОЗДАТЬ(сп, ТИП_СПИСОК)
  сп.ДОБАВИТЬ(к_СчетаКассаИРС)
  сп.ДОБАВИТЬ(к_СчетаКасса)
  сп.ДОБАВИТЬ(к_СчетаРС)
  STG_ВыборСчетаОплат = сп.IB_DLG_ВыборИзСписка(стр)
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
//Определяет тип счетчика
ФУНКЦИЯ ТИП_СТРОКА: STG_ОпределитьТипИПУ(ПЕРЕМ ТИП_СТРОКА: С)
  ВЫБОР(С)
    #к_СтатьиЭЭ : STG_ОпределитьТипИПУ = ф_ПоказанияИСЭЭ; ТипСч = к_СтатьиЭЭКод
    #к_СтатьиВ  : STG_ОпределитьТипИПУ = ф_ПоказанияИСВГ; ТипСч = к_СтатьиВКод
    #к_СтатьиГ  : STG_ОпределитьТипИПУ = ф_ПоказанияИСВГ; ТипСч = к_СтатьиГКод
    #к_СтатьиОТ : STG_ОпределитьТипИПУ = ф_ПоказанияИСВГ; ТипСч = к_СтатьиОТКод
  ИНАЧЕ
    СТОП_ВСЕ
  КОНЕЦ_ВЫБОРА
  г_КодСтатьиНачисления = ТипСч
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ STG_ВыгрузитьОтчет(ТИП_СТРОКА: заголовок1, заголовок2, заголовокПолн; 
                           ТИП_ЛОГИКА: ширинаСтолбцовАвто,
                                       узкиеПоля)
  ЕСЛИ оп_выгрузитьРеестр ТО
    IB_TBLEXP_ДобавитьСтрокуЗаголовка(заголовок1, "", 14, ДА, НЕТ, "", "")
    ЕСЛИ заголовок2 <> "" ТО
      IB_TBLEXP_ДобавитьСтрокуЗаголовка(заголовок2, "", 10, НЕТ, НЕТ, "", "")
    КОНЕЦ_ЕСЛИ
    IB_TBLEXP_ДобавитьСтрокуЗаголовка("", "", 0, НЕТ, НЕТ, "", "")
    
    резВыгр = STG_ВыгрузитьТаблицуНаМН(гр_прогВывода,
                                       заголовокПолн, 
                                       гр_формат, ширинаСтолбцовАвто, г_альбом, узкиеПоля, файл)

    ЕСЛИ резВыгр ТО
      ЕСЛИ ВОПРОС("Показать выгруженный файл в проводнике?") ТО
        IB_FILE_ПоказатьФайлВПроводнике(файл)
      КОНЕЦ_ЕСЛИ
    КОНЕЦ_ЕСЛИ
  КОНЕЦ_ЕСЛИ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ ТИП_ЛОГИКА: STG_ПроверитьМесяц(ТИП_СТРОКА: Месяц; ПЕРЕМ ТИП_ЧИСЛО: М) //_ПРОВЕРКА_МЕСЯЦ
  М = IB_STR_МЕСЯЦ_В_ЧИСЛО(Месяц)
  ЕСЛИ (М < 1) ИЛИ (М > 12) ТО
    СООБЩЕНИЕ("Неверно указан месяц.")
    СТОП_ВСЕ
  КОНЕЦ_ЕСЛИ
  STG_ПроверитьМесяц = ДА
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ ТИП_ЛОГИКА: STG_ПроверитьМесяцЧ(ПЕРЕМ ТИП_ЧИСЛО: М) //_ПРОВЕРКА_МЕСЯЦ_Ч
  ЕСЛИ (М < 1) ИЛИ (М > 12) ТО
    СООБЩЕНИЕ("Неверно указан месяц.")
    СТОП_ВСЕ
  КОНЕЦ_ЕСЛИ
  STG_ПроверитьМесяцЧ = ДА
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ ТИП_ЛОГИКА: STG_ПроверкаПериода(ТИП_ДАТА: датаНач, датаКон)
  ЕСЛИ датаНач > датаКон ТО
    СООБЩЕНИЕ("Дата начала периода не может быть позже даты конца.")
    СТОП_ВСЕ
  КОНЕЦ_ЕСЛИ
  STG_ПроверкаПериода = ДА
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ ТИП_ЛОГИКА: STG_ПроверитьГод(ТИП_ЧИСЛО: Год) //_ПРОВЕРКА_ГОД
  ЕСЛИ Год < 1980 ИЛИ Год > 2077 ТО
    СООБЩЕНИЕ("Неверно указан год")
    СТОП_ВСЕ
  КОНЕЦ_ЕСЛИ
  STG_ПроверитьГод = ДА
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
//Кнопка показа настроек ПД
ФУНКЦИЯ STG_НастрПечатиПДКноп(ТИП_СТРОКА: событие, кнопка, текст)
   ТИП_ОПЕР(?(г_блокГСК, "ГСК", "СНТ") + " : Настройки ПД <" + ?(г_блокГСК, "GSK", "ST") + ".TOP>")
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
//кнопка отправки на почту
ФУНКЦИЯ STG_ОтправкаПДНаПочтуКноп(ТИП_СТРОКА: событие, кнопка, текст)
  ЕСЛИ оп_ОтправлятьПочту И 
       АТРИБУТ("$отправлятьНаПочту") <> "" ТО
    STG_R_НастройкиПечатиПД
    //
    ЕСЛИ ПараметрПечатиПД!"Отправлять в фоне" ТО
      ЕСЛИ IB_MAIL_ВклФоновуюОтправку ТО
        IB_MAIL_УстановитьТаймаут(ПараметрПечатиПД!"Таймаут отправки")
      ИНАЧЕ
        ВЫХОД
      КОНЕЦ_ЕСЛИ
    КОНЕЦ_ЕСЛИ
    //
    IB_MAIL_ОтправитьПочту
    //
    IB_PROTOCOL_ОбработатьИВывестиОшибки
  ИНАЧЕ
    СООБЩЕНИЕ("Пересчитайте бланк и включите опцию ""Отправлять на почту"".")
  КОНЕЦ_ЕСЛИ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
//Кнопка Настройки расчета и вывода потерь ЭЭ
ФУНКЦИЯ STG_НастрРасчетаПЭЭ(ТИП_СТРОКА: событие, кнопка, текст)
   ТИП_ОПЕР(?(г_блокГСК, "ГСК", "СНТ") + " : Настройки расчета и вывода потерь ЭЭ <" + ?(г_блокГСК, "GSK", "ST") + ".TOP>")
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
//Обработчик опции
ФУНКЦИЯ STG_ОбрабОпцииПени(ТИП_СТРОКА: событие, кнопка, текст)
  оп_Долг = ?(НЕ оп_Долг, ДА, оп_Долг)
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ ТИП_ЛОГИКА: STG_ВыборМесяца(ПЕРЕМ ТИП_СТРОКА: знач) //ВЫБОР_МЕС
   СОЗДАТЬ(сп, ТИП_СПИСОК)
   ЦИКЛ ДЛЯ(м = 1, 12)
      сп.ДОБАВИТЬ(ПРОП(МЕСП(м)))
   КОНЕЦ_ЦИКЛА
   STG_ВыборМесяца = сп.IB_DLG_ВыборИзСписка(знач)
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ ТИП_ЛОГИКА: STG_УстановкаПериода(ПЕРЕМ ТИП_СТРОКА: стр)
  РЕЗУЛЬТАТ = ДА
  мес = гр_Месяц
  год = ЗАМ(" ", СТР(гр_Год), "")
  
  ВЫБОР(ИМЯ_ГРАФЫ)
    #"гр_Месяц": РЕЗУЛЬТАТ = STG_ВыборМесяца(стр)
                 //
                 ЕСЛИ РЕЗУЛЬТАТ ТО
                   датаСтр = "01." + СТР0(IB_STR_МЕСЯЦ_В_ЧИСЛО(стр),2) + "." + год
                   ЕСЛИ ДАТА_ТЕСТ(датаСтр) ТО
                     гр_ДатаС = ДАТА(1, IB_STR_МЕСЯЦ_В_ЧИСЛО(стр), год)
                     гр_ДатаПо = ДАТА(1, IB_STR_МЕСЯЦ_В_ЧИСЛО(стр) + 1, год) - 1
                   КОНЕЦ_ЕСЛИ
                 КОНЕЦ_ЕСЛИ
                 
    #"гр_Год": ЕСЛИ ЗНАЧ_ТЕСТ(стр) ТО
                 начЗнач = ЗНАЧ(стр)
               ИНАЧЕ
                 начЗнач = ГОД(ДАТА_ТЕК)
               КОНЕЦ_ЕСЛИ
               стр = СТР_ЗНАЧ(ВВЕСТИ_ЗНАЧЕНИЕ("Введите год: ", начЗнач, 1900, 2078))
               гр_ДатаС = ДАТА(ЧИСЛО(гр_ДатаС), МЕС(гр_ДатаС), стр)
               гр_ДатаПо = ДАТА(ЧИСЛО(гр_ДатаПо), МЕС(гр_ДатаПо), стр)
  КОНЕЦ_ВЫБОРА
  датаОперации = гр_ДатаПо
  г_randParam!"датаОперации" = гр_ДатаПо
  STG_УстановкаПериода = РЕЗУЛЬТАТ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ STG_КнопкаВывестиОтчет(ТИП_СТРОКА: стр1, стр2, стр3)
  ЕСЛИ СУЩ_ФАЙЛ(ф_tmp000) ТО
    ЕСЛИ IB_DBF_ВсегоЗап(ф_tmp000) > 0 ТО
      УСТ_АТРИБУТ("&ДАТА_НАЧАЛА_РАСЧЕТА_НАЧИСЛЕНИЙ", СТР(гр_датаС))
      УСТ_АТРИБУТ("&ДАТА_КОНЦА_РАСЧЕТА_НАЧИСЛЕНИЙ", СТР(гр_датаПо))
      IB_PROF_УстТекГлобПрофиль(IB_PROF_ТекЛокПрофиль)
      БЛАНК(?(г_блокГСК, "GSK", "ST") + "_SERV03", ДА)
    ИНАЧЕ
      СООБЩЕНИЕ("Нет данных для формирования отчёта.")
    КОНЕЦ_ЕСЛИ
  ИНАЧЕ
    СООБЩЕНИЕ("Пересчитайте бланк.")
  КОНЕЦ_ЕСЛИ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
//Выбор даты и перегон её в строку
ФУНКЦИЯ ТИП_ЛОГИКА: STG_УстДатуСНТ(ПЕРЕМ ТИП_СТРОКА: строка) //_ДАТА_УСТ
  ЕСЛИ строка <> "" ТО
    пред_дата = строка
  ИНАЧЕ
    пред_дата = ""
  КОНЕЦ_ЕСЛИ
  строка = СТР(ВВОД_ЗНАЧЕНИЯ("Введите дату:", ДАТА_ТЕК))
  ЕСЛИ строка = "01.01.1980" ТО
    строка = пред_дата
  КОНЕЦ_ЕСЛИ
  STG_УстДатуСНТ = ДА
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
//Выбор текстового файла
ФУНКЦИЯ ТИП_ЛОГИКА: STG_ВыбTXTФайла(ПЕРЕМ ТИП_СТРОКА: кат)
  STG_ВыбTXTФайла = НЕТ

  ЕСЛИ СУЩ_ФАЙЛ(г_дирВыгрузки) ТО
    Графа=ЗАМ("\", г_дирВыгрузки, "/")
    стр=ПОДСЧ(Графа, УРОВЕНЬ(Графа))
    стр=ЗАМ(стр, Графа, "")
    стр=ЗАМ("/", стр + "*.txt", "\")
  ИНАЧЕ
    стр = ТЕК_ДИР + "\*.txt"
  КОНЕЦ_ЕСЛИ

  кат = ВЫБОР_ФАЙЛА(стр,"Выбор импортируемого файла","Текстовые файлы","")
  ЕСЛИ кат <> "" ТО
    STG_ВыбTXTФайла = ДА
  КОНЕЦ_ЕСЛИ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
//Выбор метода распределения суммы налога по учатскам (расчет ЗН ЗОП)
ФУНКЦИЯ ТИП_ЛОГИКА: STG_ВыбМетодаРаспрЗН(ПЕРЕМ ТИП_СТРОКА: С)
  С1 = "Равными долями между всеми участками"
  С2 = "Долями, пропорциональными площадям участков"
  С = ?(С = С1, С2, С1)
  STG_ВыбМетодаРаспрЗН = ДА
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ ТИП_ЛОГИКА: STG_ВыборТипаРасчетаПени(ПЕРЕМ ТИП_СТРОКА: стр)
  СОЗДАТЬ(сп, ТИП_СПИСОК)
  сп.ДОБАВИТЬ(к_ТипРасчетаПениПоДатам)
  сп.ДОБАВИТЬ(к_ТипРасчетаПениПоГодам)
  STG_ВыборТипаРасчетаПени = сп.IB_DLG_ВыборИзСписка(стр)
КОНЕЦ_ФУНКЦИИ