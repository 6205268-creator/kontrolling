//-------------------------------------------------------------------------------------------------------------------------//
//куда выводить ПД при пересчете бланка
ФУНКЦИЯ ТИП_ЛОГИКА: STG_ВыбВыводаПД(ПЕРЕМ ТИП_СТРОКА: стр)
  СОЗДАТЬ(сп, ТИП_СПИСОК)
  сп.ДОБАВИТЬ(к_ВыгрузкаПДНаЭкран)
  сп.ДОБАВИТЬ(к_ВыгрузкаПДВПрилУмолч)
  сп.ДОБАВИТЬ(к_ВыгрузкаПДВWord)
  сп.ДОБАВИТЬ(к_ВыгрузкаПДВOOWriter)
  STG_ВыбВыводаПД = сп.IB_DLG_ВыборИзСписка(стр)
  ЕСЛИ стр = к_ВыгрузкаПДНаЭкран ИЛИ стр = "" ТО
    гр_форматПД = ""
  ИНАЧЕ
    гр_форматПД = к_ФорматDOC
  КОНЕЦ_ЕСЛИ
КОНЕЦ_ФУНКЦИИ

