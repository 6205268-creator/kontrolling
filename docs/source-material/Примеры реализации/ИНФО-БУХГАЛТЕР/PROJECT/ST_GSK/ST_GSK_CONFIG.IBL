ФУНКЦИЯ STG_ИниПеремБД
  г_папкаБлока = ДИР_DBF + "\" + к_дирБлока

  г_папкаСпр = г_папкаБлока +"\SPR"
  г_папкаАрх = г_папкаБлока +"\ARHIV"
  г_папкаВрем = г_папкаБлока +"\TMP"
  г_папкаИмпорт = г_папкаБлока +"\PL"
  г_папкаШаблонов = STG_ПроверитьПуть("\DOC\Shabl\" + к_дирБлока)
  ЕСЛИ НЕ СУЩ_ДИР(г_папкаШаблонов) ТО
    г_папкаШаблонов = IB_FILE_ПутьСоед(ДИР_DBF, "\DOC\Shabl\" + к_дирБлока)
  КОНЕЦ_ЕСЛИ
  г_времПапка = ТЕК_ДИР + "\Temp"
  г_времПапкаКвитанций = г_времПапка + "\Kvit" + к_дирБлока

  г_дирРеестров = "\" + к_дирБлока + "Reestr"
  г_дирОтчетов = "\" + к_дирБлока + "Otchet"
  г_дирКвитанций = "\" + к_дирБлока + "Kvit"

  шаблонФормаПД4Новая = г_папкаШаблонов + "\PD4_NEW.dot"
  шаблонФормаПД4Старая = г_папкаШаблонов + "\PD4_OLD.dot"
  шаблонФормаПД4ЭЭ = г_папкаШаблонов + "\PD4_MEE.dot"
  шаблонФормаПД4ВГ = г_папкаШаблонов + "\PD4_MVG.dot"
  шаблонФормаПДСписок = г_папкаШаблонов + "\PD_LIST.dot"
  шаблонФормаПДСписокЭЭ = г_папкаШаблонов + "\PD_LIST_EE.dot"
  шаблонФормаПДСписокВГ = г_папкаШаблонов + "\PD_LIST_VG.dot"

  ф_СпрУлиц = г_папкаБлока + "\streats.dbf"
  ф_СпрУчастковГаражей = г_папкаБлока + "\dachniki.dbf"
  ф_СпрЦелевыхВзносов = г_папкаБлока + "\vznosi.dbf"
  ф_СпрСвязьЦВиУч = г_папкаБлока + "\Vznos-Dach.dbf"
  ф_СпрОбщиеСчетчики = г_папкаСпр + "\SPR_SCHOBEE.DBF"
  ф_ПоказанияОСЭЭ = г_папкаБлока + "\POK_SCHOBEE.DBF"
  ф_СпрИндивСчетчики = г_папкаСпр + "\SPR_SCHIND.DBF"
  ф_ПоказанияИСВГ = г_папкаБлока + "\POK_SCHIVG.DBF"
  ф_ПоказанияИСЭЭ = г_папкаБлока + "\POK_SCHIEE.DBF"
  ф_ВерсияБДСТ = г_папкаБлока + "\VERBD.DBF"
