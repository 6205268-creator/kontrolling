ФУНКЦИЯ STG_ДобПарамАвторизации
  IB_DBF_ДОБАВИТЬ_ПОЛЕ(ф_СпрВладельцев, "С", "LOGIN", 100, 0)
  IB_DBF_ДОБАВИТЬ_ПОЛЕ(ф_СпрВладельцев, "С", "PASSW", 50, 0)
