                " DATEIN DATE," + 
                " NOM_PROT CHAR(50)," + 
                " DATEOUT DATE," + 
                " EMAIL CHAR(250)," + 
                " COMM CHAR(250)," + 
                " ID_RECSITE NUMERIC(10)," +  
                " UUID CHAR(40)," +
                " IS_SYNCED BOOLEAN)")
