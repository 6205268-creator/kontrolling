  ф_tmp_СпрУчастковГаражей = г_папкаВрем + "\tmp_dachniki.dbf"
  ф_tmp_СпрВладельцев = г_папкаВрем + "\tmp_owners.dbf"
  
  //устаревшие и удаленные - из блока СНТ
  ф_архивСпрУлиц = г_папкаАрх + "\" + к_дирБлока + "_arh_street.dbf"
  ф_архивСпрУчастков = г_папкаАрх + "\" + к_дирБлока + "_arh_area.dbf"
  ф_архивСпрВзносов = г_папкаАрх + "\" + к_дирБлока + "_arh_due.dbf"

  ф_архив001 = г_папкаАрх + "\" + к_дирБлока + "_arh_001.dbf"
  ф_архив002 = г_папкаАрх + "\" + к_дирБлока + "_arh_002.dbf"
  ф_архив003 = г_папкаАрх + "\" + к_дирБлока + "_arh_003.dbf"
  ф_архив004 = г_папкаАрх + "\" + к_дирБлока + "_arh_004.dbf"
  ф_ССС = г_папкаСпр + "\SPR_STATEY_SMET.DBF"

  файлСчетчик = г_папкаБлока + "\poksch.dbf"
  файлСчетчик2 = г_папкаБлока + "\poksch2.dbf"
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ ТИП_СТРОКА: STG_ПроверитьПуть(ТИП_СТРОКА: путь)
  РЕЗУЛЬТАТ = IB_FILE_ПутьСоед(ТЕК_ДИР, путь)
  ЕСЛИ НЕ СУЩ_ДИР(РЕЗУЛЬТАТ) ТО
    общ_дир = АТРИБУТ("common_path")
    РЕЗУЛЬТАТ = IB_FILE_ПутьСоед(общ_дир, путь)
  КОНЕЦ_ЕСЛИ
  STG_ПроверитьПуть =  РЕЗУЛЬТАТ
КОНЕЦ_ФУНКЦИИ

