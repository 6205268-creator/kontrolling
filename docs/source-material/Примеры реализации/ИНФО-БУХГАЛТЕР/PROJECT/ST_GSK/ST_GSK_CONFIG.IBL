    SQL_СОЗДАТЬ(ф_СпрУлиц, 
                [ "CODS"   : ТИП_СТРОКА  :  50,
                  "STREAT" : ТИП_СТРОКА  :  50
                 ]
                )
  КОНЕЦ_ЕСЛИ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
