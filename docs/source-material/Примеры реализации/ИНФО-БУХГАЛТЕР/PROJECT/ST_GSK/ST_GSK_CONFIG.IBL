//-------------------------------------------------------------------------------------------------------------------------//
//для создания постоянных и временных файлов журналов
ФУНКЦИЯ STG_C_ЖурналОборотов(ТИП_СТРОКА: путьФайла)
  ЕСЛИ НЕ СУЩ_ФАЙЛ(путьФайла) ТО
    СОЗДАТЬ(сп, ТИП_СПИСОК)
    сп.ДОБАВИТЬ("CREATE TABLE")
    сп.ДОБАВИТЬ("'" + путьФайла + "'")
    сп.ДОБАВИТЬ("(CODS CHAR(50)," +         //код улицы
                " N_AREA CHAR(30)," +       //номер участка
                " ID_AREA NUMERIC(5,0)," +  //код участка
                " FLS CHAR(20)," +          //номер флс
                " TYPE CHAR(30)," +         //тип(код) услуги - длина по спр. цл. вз.
                " ID_VZN NUMERIC(10)," +    //id взноса
                " ID_CALC NUMERIC(10,0)," +   //id расчета
                " ADD_SUM NUMERIC(15,2)," + //начисление
                " PAY_SUM NUMERIC(15,2)," + //оплата PERIOD1
                " REC_TYPE NUMERIC(2,0)," + //тип записи: 0 - начисление, 1 - касса, 2 - расч. сч., 3 - пени
                " DAT DATE," +              //дата операции
                " DOC CHAR(20),")           //документ операции
    сп.ДОБАВИТЬ(" CONTENT CHAR(250)," +     //содержимое операции
                " ID_RECSITE NUMERIC(10)," +  
                " UUID CHAR(40)," +
                " IS_SYNCED BOOLEAN)")      
    SQL_ЗАПРОС(сп)
  КОНЕЦ_ЕСЛИ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
//Справочник тарифов
ФУНКЦИЯ STG_C_СправочникТарифов
  ЕСЛИ НЕ СУЩ_ФАЙЛ(ф_СпрТарифов) ТО
    СОЗДАТЬ(сп, ТИП_СПИСОК)
    сп.ДОБАВИТЬ("CREATE TABLE")
    сп.ДОБАВИТЬ("'" + ф_СпрТарифов + "'")
    сп.ДОБАВИТЬ("(ID NUMERIC(10)," + 
                " TOKEN NUMERIC(2)," + 
                " PERIOD CHAR(10)," + 
                " TYPE CHAR(30),")
    сп.ДОБАВИТЬ(" COT NUMERIC(2,0)," + 
                " T1 NUMERIC(15,6)," + 
                " T2 NUMERIC(15,6)," + 
                " T3 NUMERIC(15,6),")
    сп.ДОБАВИТЬ(" T1SN NUMERIC(15,6)," + 
                " T2SN NUMERIC(15,6)," + 
                " T3SN NUMERIC(15,6)," + 
                " D1 DATE," + 
                " D2 DATE," + 
                " ROV CHAR(10)," +  //диапазон объема для ЭЭ - range of volume
                " FIX NUMERIC(15,6)," + 
                " ID_RECSITE NUMERIC(10)," +  
                " UUID CHAR(40)," +
                " IS_SYNCED BOOLEAN)")
    SQL_ЗАПРОС(сп)
  КОНЕЦ_ЕСЛИ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
