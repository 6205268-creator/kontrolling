//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ STG_C_ДиректорииБД
  ЕСЛИ НЕ СУЩ_ДИР(г_папкаБлока) ТО
    СОЗДАТЬ_ДИР(г_папкаБлока)
  КОНЕЦ_ЕСЛИ

  ЕСЛИ НЕ СУЩ_ДИР(г_папкаСпр) ТО
    СОЗДАТЬ_ДИР(г_папкаСпр)
  КОНЕЦ_ЕСЛИ

  ЕСЛИ НЕ СУЩ_ДИР(г_папкаВрем) ТО
    СОЗДАТЬ_ДИР(г_папкаВрем)
  КОНЕЦ_ЕСЛИ

  ЕСЛИ НЕ СУЩ_ДИР(г_папкаИмпорт) ТО
    СОЗДАТЬ_ДИР(г_папкаИмпорт)
  КОНЕЦ_ЕСЛИ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
//справочник взносов и тарифов
ФУНКЦИЯ STG_C_СправочникВзносов
  ЕСЛИ НЕ СУЩ_ФАЙЛ(ф_СпрЦелевыхВзносов) ТО
    SQL_СОЗДАТЬ(ф_СпрЦелевыхВзносов, ["CODP"       : ТИП_СТРОКА : 30 ,
                                      "CAP"        : ТИП_СТРОКА : 100 ,
                                      "REC_NAME"   : ТИП_СТРОКА : 50,
                                      "TYPE"       : ТИП_СТРОКА : 30,
                                      "METHOD"     : ТИП_ЧИСЛО  : 5;0,
                                      "COT"        : ТИП_ЧИСЛО  : 5; 0,
                                      "ORDER_BY"   : ТИП_ЧИСЛО  : 5; 0,
                                      "ID"         : ТИП_ЧИСЛО  : 10; 0,
                                      "SRCH"       : ТИП_СТРОКА : 50,
                                      "ID_RECSITE" : ТИП_ЧИСЛО  : 10,
                                      "UUID"       : ТИП_СТРОКА : 40,
                                      "IS_SYNCED"  : ТИП_ЛОГИКА])
  КОНЕЦ_ЕСЛИ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
//справочник участков или гаражей - для гск потом ужать?
ФУНКЦИЯ STG_C_СправочникОбъектов
  ЕСЛИ НЕ СУЩ_ФАЙЛ(ф_СпрУчастковГаражей) ТО
    SQL_СОЗДАТЬ(ф_СпрУчастковГаражей, ["ID_AREA"    : ТИП_ЧИСЛО  : 5;0,
                                       "CODS"       : ТИП_СТРОКА : 50,
                                       "N_DOM"      : ТИП_СТРОКА : 9,
                                       "N_AREA"     : ТИП_СТРОКА : 30,
                                       "SQUARE"     : ТИП_ЧИСЛО  : 10;2,
                                       "FIO"        : ТИП_СТРОКА : 100,
                                       "KADN"       : ТИП_СТРОКА : 30,
                                       "PRIV"       : ТИП_ЛОГИКА,
                                       "USE"        : ТИП_ЛОГИКА,
                                       "METHOD_RAS" : ТИП_СТРОКА : 50,
                                       "SRT"        : ТИП_СТРОКА : 30,
                                       "ID_OWNER"   : ТИП_ЧИСЛО  : 5;0,
                                       "KB_FLT"     : ТИП_СТРОКА : 250,
                                       "ID_RECSITE" : ТИП_ЧИСЛО  : 10,
                                       "UUID"       : ТИП_СТРОКА : 40,
                                       "IS_SYNCED"  : ТИП_ЛОГИКА])
  КОНЕЦ_ЕСЛИ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
//справочник улиц или линий
ФУНКЦИЯ STG_C_СправочникРасположений
