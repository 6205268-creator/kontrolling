//-------------------------------------------------------------------------------------------------------------------------//
//настройки расчета пени
ФУНКЦИЯ STG_C_НастройкиПени 
  ЕСЛИ НЕ СУЩ_ФАЙЛ(ф_НастройкиПени) ТО
    СОЗДАТЬ(сп, ТИП_СПИСОК)
    сп.ДОБАВИТЬ("CREATE TABLE")
    сп.ДОБАВИТЬ("'" + ф_НастройкиПени + "'")
    сп.ДОБАВИТЬ("(CALC BOOLEAN," +           //вкл/выкл расчет пени
                " PERCENT NUMERIC(6, 4)," +  //процент пени для расчета
                " START_DATE DATE," +        //дата начала расчета пени
                " PERC_IPU NUMERIC(6, 4)," +  //процент пени для расчета
                " MIN_D_IPU NUMERIC(5, 0)," +  //минимальное количество дней просрочки, с которого начнем считать
                " TYPE CHAR(50))")  //тип расчета пени
    SQL_ЗАПРОС(сп)
  КОНЕЦ_ЕСЛИ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
//настройки соц. нормы ЭЭ
ФУНКЦИЯ STG_C_НастройкиСНЭЭ
  ЕСЛИ НЕ СУЩ_ФАЙЛ(ф_НастройкиСНЭЭ) ТО
    СОЗДАТЬ(сп, ТИП_СПИСОК)
    сп.ДОБАВИТЬ("CREATE TABLE")
    сп.ДОБАВИТЬ("'" + ф_НастройкиСНЭЭ + "'")
    сп.ДОБАВИТЬ("(CALC BOOLEAN," +       //вкл/выкл расчет
                " SNEE NUMERIC(10, 2))") //размер соц. нормы на участок
    SQL_ЗАПРОС(сп)
  КОНЕЦ_ЕСЛИ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
//настройки расчета потерь ЭЭ
ФУНКЦИЯ STG_C_НастройкиПЭЭ
  ЕСЛИ НЕ СУЩ_ФАЙЛ(ф_НастройкиПЭЭ) ТО
    СОЗДАТЬ(сп, ТИП_СПИСОК)
    сп.ДОБАВИТЬ("CREATE TABLE")
    сп.ДОБАВИТЬ("'" + ф_НастройкиПЭЭ + "'")
    сп.ДОБАВИТЬ("(VAL1 CHAR(15)," +       //вариант учета
                " VAL2 NUMERIC(10, 2)," + //значение потерь Т1
                " VAL3 NUMERIC(10, 2)," + //значение потерь Т2
                " VAL4 NUMERIC(10, 2)," + //значение потерь Т3
                " VAL5 BOOLEAN," +        //отдельная хоз. оп.
                " VAL6 BOOLEAN)")         //отдельный ПД
    SQL_ЗАПРОС(сп)
    //
    сп.ОЧИСТИТЬ
    сп.ДОБАВИТЬ("INSERT INTO")
    сп.ДОБАВИТЬ("'" + ф_НастройкиПЭЭ + "'")
    сп.ДОБАВИТЬ("(VAL1, VAL2, VAL3, VAL4, VAL5, VAL6) VALUES ('Не учитывать', 0, 0, 0, FALSE, FALSE)")
    SQL_ЗАПРОС(сп)
  КОНЕЦ_ЕСЛИ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
//настройки блока
ФУНКЦИЯ STG_C_НастройкиБлока
  ЕСЛИ НЕ СУЩ_ФАЙЛ(ф_НастройкиБлока) ТО
    блокГСК = ПОЗ("GSK", ЗАГЛ(ф_НастройкиБлока)) > 0
    СОЗДАТЬ(сп, ТИП_СПИСОК)
    сп.ДОБАВИТЬ("CREATE TABLE")
    сп.ДОБАВИТЬ("'" + ф_НастройкиБлока + "'")
    сп.ДОБАВИТЬ("(VAL1 CHAR(15)," +  //источник данных
                " VAL2 CHAR(15)," +  //группировка участков при выборе
                " VAL3 CHAR(20)," +  //сортировка участков по
                " VAL4 CHAR(3)," +   //выводить улицу в отчетах
                " VAL5 CHAR(25)," +  //способ ввода показаний
                " VAL6 CHAR(250)," + //директория выгрузки всего
                " VAL7 BOOLEAN," +   //запоминать пред. выбор в диалогах множ. выбора
                " VAL8 BOOLEAN,")     //связь граф выбора улиц и участков
    ЕСЛИ блокГСК ТО
      сп.ДОБАВИТЬ(" VAL9 CHAR(20),")  //текст для расположений объектов владения
      сп.ДОБАВИТЬ(" VAL10 CHAR(20),") //текст для объектов владения
    КОНЕЦ_ЕСЛИ
    сп.ДОБАВИТЬ(" VAL11 BOOLEAN," +   //выгружать на сайт
                " VAL12 CHAR(50)," +  //имя профиля для выгрузки на сайт
                " VAL13 BOOLEAN," +   //использовать подзаросы
                " VAL14 BOOLEAN")     //использовать диапазоны объемов ЭЭ
    сп.ДОБАВИТЬ(")")
    sql = SQL_ЗАПРОС(сп)
    //
    сп.ОЧИСТИТЬ
    сп.ДОБАВИТЬ("INSERT INTO")
    сп.ДОБАВИТЬ("'" + ф_НастройкиБлока + "'")
    сп.ДОБАВИТЬ("(VAL1, VAL2, VAL3, VAL4, VAL5, VAL6, VAL7, VAL8" + ?(блокГСК, ", VAL9, VAL10", "") + ", VAL11, VAL12, VAL13, VAL14) VALUES ('" + к_ИсточникЖХО +
                "', '" + к_ГруппировкаУчастковПоУлицам + "', '" + к_СортПоНомеруУчастка +
                "', 'Да', '" + к_СпособВводаПокРазВМес + "', '" + г_времПапка + "', FALSE, TRUE" + ?(блокГСК, ",'линия', 'гараж'", "") + ", FALSE, '', TRUE, FALSE)")
    SQL_ЗАПРОС(сп)
  КОНЕЦ_ЕСЛИ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
//Функция создания архива выгрузок
ФУНКЦИЯ STG_C_АрхивВыгрузок
  ЕСЛИ НЕ СУЩ_ФАЙЛ(ф_АрхивВыгрузокКвит) ТО
    СОЗДАТЬ(сп, ТИП_СПИСОК)
    сп.ДОБАВИТЬ("CREATE TABLE")
    сп.ДОБАВИТЬ("'" + ф_АрхивВыгрузокКвит + "'")
    сп.ДОБАВИТЬ("(ID NUMERIC(10,0)," + //идентификатор рассылки
                " DATE_D DATE," +      //дата рассылки
                " TIME_D TIME," +      //время начала рассылки
                " DESCR CHAR(250)," +  //описание
                " BLANK CHAR(10))")    //бланк
    SQL_ЗАПРОС(сп)
  КОНЕЦ_ЕСЛИ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
//Функция создания архива выгруженных квитанций
ФУНКЦИЯ STG_C_АрхивКвитанций
  СОЗДАТЬ(сп, ТИП_СПИСОК)
  ЕСЛИ НЕ СУЩ_ФАЙЛ(ф_АрхивКвитанций) ТО
    сп.ДОБАВИТЬ("CREATE TABLE")
    сп.ДОБАВИТЬ("'" + ф_АрхивКвитанций + "'")
    сп.ДОБАВИТЬ("(ID NUMERIC(10,0)," +      //идентификатор рассылки
                " RECIPIENT CHAR(250)," +   //получатель
                " ATTACHMENT CHAR(250))")   //вложение
    SQL_ЗАПРОС(сп)
  КОНЕЦ_ЕСЛИ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
//архив расчетов
ФУНКЦИЯ STG_C_АрхивРасчетов
  ЕСЛИ НЕ СУЩ_ФАЙЛ(ф_АрхивРасчетов) ТО
    СОЗДАТЬ(сп, ТИП_СПИСОК)
    сп.ДОБАВИТЬ("CREATE TABLE")
    сп.ДОБАВИТЬ("'" + ф_АрхивРасчетов + "'")
    сп.ДОБАВИТЬ("(ID_CALC NUMERIC(10,0)," + //идентификатор расчета
                " BLW CHAR(50)," +      //бланк
                " DESCR_1 CHAR(250)," + //описание расчета
                " DESCR_2 CHAR(250)," + //описание расчета
                " DESCR_3 CHAR(250)," + //описание расчета
                " DATE_S DATE," +       //дата начала периода
                " DATE_E DATE," +       //дата конца периода
                " DAT DATE)")           //дата операции
    SQL_ЗАПРОС(сп)
  КОНЕЦ_ЕСЛИ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
//журнал расчетов
ФУНКЦИЯ STG_C_ЖурналРасчетов
  ЕСЛИ НЕ СУЩ_ФАЙЛ(ф_ЖурналРасчетов) ТО
    СОЗДАТЬ(сп, ТИП_СПИСОК)
    сп.ДОБАВИТЬ("CREATE TABLE")
    сп.ДОБАВИТЬ("'" + ф_ЖурналРасчетов + "'")
    сп.ДОБАВИТЬ("(ID_CALC NUMERIC(10,0)," +  //идентификатор расчета
                " ID_TYPE NUMERIC(10,0)," +  //id взноса
                " CODS CHAR(50)," +          //код улицы
                " ID_AREA NUMERIC(5,0)," +   //id участка
                " FLS CHAR(20)," +           //номер флс
                " TYPE CHAR(30),")           //код взноса
    сп.ДОБАВИТЬ(" ID_IPU NUMERIC(5,0)," +    //id ИПУ
                " SQUARE NUMERIC(10,2)," +   //площадь
                " T1_VOL NUMERIC(15,4)," +   //объем Т1
                " T2_VOL NUMERIC(15,4)," +   //объем Т2
                " T3_VOL NUMERIC(15,4)," +   //объем Т3
                " T1SN_VOL NUMERIC(15,4)," + //объем сверх нормы Т1 или площадь
                " T2SN_VOL NUMERIC(15,4)," + //объем сверх нормы Т2
                " T3SN_VOL NUMERIC(15,4),")  //объем сверх нормы Т3
    сп.ДОБАВИТЬ(" SUM_FIX NUMERIC(15,2)," +  //сумма по фикс части взноса
                " SUM_T1 NUMERIC(15,6)," +   //сумма т1 или по площади
                " SUM_T2 NUMERIC(15,2)," +   //сумма т2
                " SUM_T3 NUMERIC(15,2)," +   //сумма т3
                " SUM_SNT1 NUMERIC(15,2)," + //сумма сверх нормы т1
                " SUM_SNT2 NUMERIC(15,2)," + //сумма сверх нормы т2
                " SUM_SNT3 NUMERIC(15,2)," + //сумма сверх нормы т3
                " SUM_PT1 NUMERIC(15,2)," +  //сумма потерь т1
                " SUM_PT2 NUMERIC(15,2)," +  //сумма потерь т2
                " SUM_PT3 NUMERIC(15,2),")   //сумма потерь т3
    сп.ДОБАВИТЬ(" ROV1 CHAR(10)," +          //код диап объемов т1
                " ROV2 CHAR(10)," +          //код диап объемов т2
                " ROV3 CHAR(10),")           //код диап объемов т3
    сп.ДОБАВИТЬ(" ID_RECSITE NUMERIC(10)," + 
                " UUID CHAR(40)," +
                " IS_SYNCED BOOLEAN)")
    SQL_ЗАПРОС(сп)
  КОНЕЦ_ЕСЛИ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ STG_C_ЖурналУдаленияНаСайте
  ЕСЛИ НЕ СУЩ_ФАЙЛ(ф_ЖурналИзмененияНаСайте) ТО
    СОЗДАТЬ(сп, ТИП_СПИСОК)
    сп.ДОБАВИТЬ("CREATE TABLE")
    сп.ДОБАВИТЬ("'" + ф_ЖурналИзмененияНаСайте + "'")
    сп.ДОБАВИТЬ("( SLCTR CHAR(1)," +     //селектор
                " ID NUMERIC(10)," +    //ид на сайте или в базе
                " CAT CHAR(20)," +      //ид справочник
                " CAT_NAME CHAR(50)," + //имя справочника для показа
                " DESCR CHAR(250)," +   //описание объекта для показа
                " ACT_NAME CHAR(10)," +  //действие имя для показа
                " ACT CHAR(2))")        //действие удалить/изменить
    SQL_ЗАПРОС(сп)
  КОНЕЦ_ЕСЛИ
