//-------------------------------------------------------------------------------------------------------------------------//
//Справочник общих счетчиков ЭЭ
ФУНКЦИЯ STG_C_СправочникОПУЭЭ
  ЕСЛИ НЕ СУЩ_ФАЙЛ(ф_СпрОбщиеСчетчики) ТО
    СОЗДАТЬ(сп, ТИП_СПИСОК)
    сп.ДОБАВИТЬ("CREATE TABLE")
    сп.ДОБАВИТЬ("'" + ф_СпрОбщиеСчетчики + "' ")
    сп.ДОБАВИТЬ("(ID NUMERIC(5,0)," + 
                " NOM CHAR(50)," + 
                " MODEL CHAR(50)," + 
                " NPOK1 NUMERIC(15,4)," + 
                " NPOK2 NUMERIC(15,4),")
    сп.ДОБАВИТЬ(" NPOK3 NUMERIC(15,4)," + 
                " COT NUMERIC(2,0)," + 
                " DATUST DATE," + 
                " KTT NUMERIC(15,4)," + 
                " PPVLT NUMERIC(15,4),")
    сп.ДОБАВИТЬ(" PHHTT1 NUMERIC(15,4)," + 
                " PHHTT2 NUMERIC(15,4)," + 
                " PHHTT3 NUMERIC(15,4)," + 
                " KOMMENT CHAR(100)," + 
                " DATEND DATE)")
    SQL_ЗАПРОС(сп)
  КОНЕЦ_ЕСЛИ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
//Файл показаний общего счетчика ЭЭ
ФУНКЦИЯ STG_C_ЖурналПоказанийОПУЭЭ
  ЕСЛИ НЕ СУЩ_ФАЙЛ(ф_ПоказанияОСЭЭ) ТО
    СОЗДАТЬ(сп,ТИП_СПИСОК)
    сп.ДОБАВИТЬ("CREATE TABLE")
    сп.ДОБАВИТЬ("'" + ф_ПоказанияОСЭЭ + "' ")
    сп.ДОБАВИТЬ("(ID NUMERIC(5,0)," + 
                " POK1 NUMERIC(15,4)," + 
                " POK2 NUMERIC(15,4)," + 
                " POK3 NUMERIC(15,4)," +
                " T1_VOL NUMERIC(15,4)," + 
                " T2_VOL NUMERIC(15,4)," + 
                " T3_VOL NUMERIC(15,4)," + 
                " PPVLT NUMERIC(15,4), " + 
                " DAT DATE)")
    SQL_ЗАПРОС(сп)
  КОНЕЦ_ЕСЛИ
  STG_C_ФПОСЭЭ = ДА
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
//Справочник индивидуальных счетчиков (общий)
ФУНКЦИЯ STG_C_СправочникИПУ
  ЕСЛИ НЕ СУЩ_ФАЙЛ(ф_СпрИндивСчетчики) ТО
    СОЗДАТЬ(сп, ТИП_СПИСОК)
    сп.ДОБАВИТЬ("CREATE TABLE")
    сп.ДОБАВИТЬ("'" + ф_СпрИндивСчетчики + "'")
    сп.ДОБАВИТЬ("(CODS CHAR(50)," + 
                " ID_AREA NUMERIC(5,0)," + 
                " ID NUMERIC(5,0)," + 
                " COT NUMERIC(2,0)," + 
                " NOM CHAR(50)," + 
                " MODEL CHAR(50)," + 
                " NPOK1 NUMERIC(15,4),")
    сп.ДОБАВИТЬ(" NPOK2 NUMERIC(15,4)," + 
                " NPOK3 NUMERIC(15,4)," + 
                " DATUST DATE," + 
                " DATEND DATE," + 
                " TYPE CHAR(2)," + 
                " OBSCH NUMERIC(5,0)," + 
                " KOMMENT CHAR(100)," + 
                " SCH CHAR(50),")
    сп.ДОБАВИТЬ(" TOKEN NUMERIC(2,0)," + 
                " TOKEN_DATE DATE," + 
                " ID_RECSITE NUMERIC(10)," + 
                " UUID CHAR(40)," +
                " IS_SYNCED BOOLEAN)")
    SQL_ЗАПРОС(сп)
  КОНЕЦ_ЕСЛИ
КОНЕЦ_ФУНКЦИИ

