//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ STG_C_ВремФЖурнала
  ЕСЛИ IB_FILE_ФайлУдалить(ф_tmp_Журнал) ТО
    STG_C_ЖурналОборотов(ф_tmp_Журнал)
  КОНЕЦ_ЕСЛИ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
//Предупреждения о задолженности
ФУНКЦИЯ ТИП_ЛОГИКА: STG_C_tmpПредупреждения
  РЕЗУЛЬТАТ = IB_FILE_ФайлУдалить(ф_tmp005)
  ЕСЛИ РЕЗУЛЬТАТ ТО
    СОЗДАТЬ(сп, ТИП_СПИСОК)
    сп.ДОБАВИТЬ("CREATE TABLE")
    сп.ДОБАВИТЬ("'" + ф_tmp005 + "'")
    сп.ДОБАВИТЬ("(N_AREA CHAR(50)," + 
                " FIO CHAR(100)," + 
                " DAT DATE," + 
                " DATOP DATE," + 
                " PRICE NUMERIC(15,4)," + 
                " TYPE CHAR(50)," + 
                " FW CHAR(50))")
    SQL_ЗАПРОС(сп)
  КОНЕЦ_ЕСЛИ
  STG_C_ВФПоЗ = РЕЗУЛЬТАТ И СУЩ_ФАЙЛ(ф_tmp005)
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
//Insert в ф_tmp005 для предупреждения о задолженности
ФУНКЦИЯ ТИП_ЛОГИКА: STG_I_tmpПредупреждения(ТИП_ДАТА: дата, датаОп;
                                            ТИП_ЧИСЛО: сумма;
                                            ТИП_СТРОКА: типВзноса, наименование)
  ЕСЛИ СУЩ_ФАЙЛ(ф_tmp005) ТО
    СОЗДАТЬ(сп, ТИП_СПИСОК)
    сп.ДОБАВИТЬ("INSERT INTO")
    сп.ДОБАВИТЬ("'" + ф_tmp005 + "' ")
    сп.ДОБАВИТЬ("(N_AREA, FIO, DAT, DATOP, PRICE, TYPE, FW) VALUES")
    сп.ДОБАВИТЬ("('" + цл_КодУчГарПольз + "', '" + цл_ФИО + "', '" + СТР(дата) + "', ")
    сп.ДОБАВИТЬ("'" + СТР(датаОп) + "', " + СТР_ЗНАЧ(сумма) + ", '" + типВзноса + "', '" + наименование + "')")
    SQL_ЗАПРОС(сп)
    STG_I_ВФПоЗ = ДА
  КОНЕЦ_ЕСЛИ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
//-------------------------------------------------------------------------------------------------------------------------//
//4. ф_tmp007 и ф_tmp008 - разбивка суммы оплаты по статьям
ФУНКЦИЯ ТИП_ЛОГИКА: STG_C_ф_tmp0078(ТИП_СТРОКА: путьФайла)
  STG_C_ф_tmp0078 = НЕТ
  СОЗДАТЬ(СП,ТИП_СПИСОК)
  /*ЕСЛИ СУЩ_ФАЙЛ(путьФайла) ТО
    удалять = НЕТ
    ЕСЛИ г_Вопросы ТО
      sql = SQL_ОТКРЫТЬ(путьФайла)
      колПолей = sql.КОЛ_ПОЛЕЙ
      ЕСЛИ sql.ВСЕГО > 0 И колПолей = 15 ТО
        удалять = ВОПРОС("Существует заполненный список статей. Очистить его?")
      ИНАЧЕ
        удалять = ДА //неизвестная структура файла
      КОНЕЦ_ЕСЛИ
      sql.ЗАКРЫТЬ
    КОНЕЦ_ЕСЛИ
    ЕСЛИ удалять ТО
      IB_FILE_ФайлУдалить(путьФайла)
    КОНЕЦ_ЕСЛИ
  КОНЕЦ_ЕСЛИ*/
  ЕСЛИ IB_FILE_ФайлУдалить(путьФайла) ТО
    СП.ОЧИСТИТЬ
    СП.ДОБАВИТЬ("CREATE TABLE")
    СП.ДОБАВИТЬ("'" + путьФайла + "'")
    СП.ДОБАВИТЬ("(ID NUMERIC(10,0)," +    //идентификатор услуги
                " FW CHAR(250)," +        //название услуги
                " DEBT NUMERIC(15,4)," +  //сумма долга по взносу на дату оплаты
                " SUMMA NUMERIC(15,4)," + //сумма к оплате
                " CODE CHAR(30)," +       //код услуги
                " METOD CHAR(100)," +     //метод расчета
                " PERIOD BOOLEAN," +      //учет периода для тарифа
                " PERIOD_FIX BOOLEAN," +  //учета периода для фикс. взноса
                " FIX NUMERIC(10,2)," +   //учета периода для фикс. взноса
                " C_TYPE CHAR(20)," +     //тип расчета
                " PENI BOOLEAN,")         //имя для квитка
    СП.ДОБАВИТЬ(" ID_AREA NUMERIC(5,0)," + //идентификатор участка
                " N_AREA CHAR(30)," +      //номер участка
                " CODS CHAR(50)," +        //номер участка
                " FLS CHAR(20)," +         //номер флс
                " FIO CHAR(100)," +        //фио
                " NOMKB CHAR(100)," +      //номер из клиент банка
                " POK_EE CHAR(3),")        //служебное поле для вывода редактора показаний ЭЭ
    СП.ДОБАВИТЬ(" DAT DATE," +             //дата док
                " N NUMERIC(15,0))")       //номер док
    SQL_ЗАПРОС(СП)
    
    STG_C_ф_tmp0078 = ДА
  ИНАЧЕ
    STG_ОбновитьПоля_ф_tmp007(путьФайла)
  КОНЕЦ_ЕСЛИ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ STG_ОбновитьПоля_ф_tmp007(ТИП_СТРОКА: путьФайла)
  ИСПОЛЬЗОВАТЬ("IB_DBF")
  ЕСЛИ IB_DBF_УДАЛИТЬ_ПОЛЕ(путьФайла, "REC_NAME") ТО
    IB_DBF_ДОБАВИТЬ_ПОЛЕ(путьФайла, "Л", "PENI", 0, 0)
    IB_DBF_ДОБАВИТЬ_ПОЛЕ(путьФайла, "Ч", "ID_AREA", 5, 0)
    IB_DBF_ДОБАВИТЬ_ПОЛЕ(путьФайла, "С", "N_AREA", 30, 0)
    IB_DBF_ДОБАВИТЬ_ПОЛЕ(путьФайла, "С", "CODS", 50, 0)
    IB_DBF_ДОБАВИТЬ_ПОЛЕ(путьФайла, "С", "FIO", 100, 0)
    IB_DBF_ДОБАВИТЬ_ПОЛЕ(путьФайла, "С", "C_TYPE", 20, 0)
  КОНЕЦ_ЕСЛИ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
//временный файл списка показаний для бланка 3.01
ФУНКЦИЯ ТИП_ЛОГИКА: STG_C_tmpСписокВводаПоказаний //_СОЗДАТЬ_ВФПССпис
  ЕСЛИ IB_FILE_ФайлУдалить(ф_tmp001) ТО
    СОЗДАТЬ(СП,ТИП_СПИСОК)
    СП.ДОБАВИТЬ("CREATE TABLE")
    СП.ДОБАВИТЬ("'" + ф_tmp001 + "'")
    СП.ДОБАВИТЬ("(CODS CHAR(50), ID_AREA NUMERIC(5,0), ID_OWNER NUMERIC(5,0), ID_SCH NUMERIC(5,0), DAT DATE, T_DAT DATE, NOM CHAR(50), PNUM1 NUMERIC(15,4)," +
                " NUM1 NUMERIC(15,4), PNUM2 NUMERIC(15,4), NUM2 NUMERIC(15,4), PNUM3 NUMERIC(15,4), NUM3 NUMERIC(15,4),")
    СП.ДОБАВИТЬ(" T1_VOL NUMERIC(15,4), T2_VOL NUMERIC(15,4), T3_VOL NUMERIC(15,4),")
    СП.ДОБАВИТЬ(" T1SN_VOL NUMERIC(15,4), T2SN_VOL NUMERIC(15,4), T3SN_VOL NUMERIC(15,4),")
    СП.ДОБАВИТЬ(" SUM_T1 NUMERIC(15,6), SUM_T2 NUMERIC(15,2), SUM_T3 NUMERIC(15,2),")
    СП.ДОБАВИТЬ(" SUM_SNT1 NUMERIC(15,2), SUM_SNT2 NUMERIC(15,2), SUM_SNT3 NUMERIC(15,2),")
    СП.ДОБАВИТЬ(" SUM_PT1 NUMERIC(15,2), SUM_PT2 NUMERIC(15,2), SUM_PT3 NUMERIC(15,2),")
    СП.ДОБАВИТЬ(" T1 NUMERIC(15,6), T2 NUMERIC(15,6), T3 NUMERIC(15,6),  T1SN NUMERIC(15,6), T2SN NUMERIC(15,6), T3SN NUMERIC(15,6)," +
                " P1 NUMERIC(5,2), P2 NUMERIC(5,2), P3 NUMERIC(5,2), P CHAR(20), FIO CHAR(100)," +
                " N_AREA CHAR(30), COT NUMERIC (5), FLS CHAR(20), SRT CHAR(30)")
    СП.ДОБАВИТЬ(", N_DOM CHAR(9), CORR BOOLEAN, COMM CHAR(250), srv_slctd CHAR(1), ID_RECSITE NUMERIC(10)," +
                " UUID CHAR(40), IS_SYNCED BOOLEAN, ID_VZN NUMERIC(10), ROV1 CHAR(10), ROV2 CHAR(10), ROV3 CHAR(10)")
    СП.ДОБАВИТЬ(", TOKEN NUMERIC(2), TOKEN_DATE DATE)")
    SQL_ЗАПРОС(СП)
  КОНЕЦ_ЕСЛИ
  STG_C_tmpСписокВводаПоказаний = СУЩ_ФАЙЛ(ф_tmp001)
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
//3. ф_tmp005 - приходник
ФУНКЦИЯ ТИП_ЛОГИКА: STG_C_tmpПКО //_СОЗДАТЬ_ВФПО
  IB_FILE_ФайлУдалить(ф_tmp005)
  СОЗДАТЬ(СП, ТИП_СПИСОК)
  ЕСЛИ IB_FILE_ФайлУдалить(ф_tmp005) ТО
    СП.ДОБАВИТЬ("CREATE TABLE")
    СП.ДОБАВИТЬ("'" + ф_tmp005 + "'")
    СП.ДОБАВИТЬ("(CODS CHAR(50)," +
                " N_AREA CHAR(30)," +
                " FIO CHAR(100)," +
                " CODE CHAR(30)," +
                " ID_VZN NUMERIC(10)," +
                " ID_AREA NUMERIC(5)," +
                " FORWHAT CHAR(250)," +
                " DAT DATE," +
                " PRICE NUMERIC(15,4)," +
                " POTERI CHAR(250))")
    SQL_ЗАПРОС(СП)
  ИНАЧЕ
    SQL_ЗАПРОС("DELETE FROM '" + ф_tmp005 + "'")
  КОНЕЦ_ЕСЛИ
  STG_C_tmpПКО = СУЩ_ФАЙЛ(ф_tmp005)
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
//Insert в ф_tmp005 для приходника
ФУНКЦИЯ ТИП_ЛОГИКА: STG_I_tmpПКО(ТИП_ДАТА: Дата; ТИП_ЧИСЛО: Сумма; ТИП_СТРОКА: ЗаЧто, кодСтатьи) //_ВФПО
  ЕСЛИ СУЩ_ФАЙЛ(ф_tmp005) ТО
    СОЗДАТЬ(СП,ТИП_СПИСОК)
    СП.ДОБАВИТЬ("INSERT INTO")
    СП.ДОБАВИТЬ("'" + ф_tmp005 + "'")
    СП.ДОБАВИТЬ("(CODS, N_AREA, DAT, PRICE, FORWHAT, FIO, POTERI, CODE, ID_VZN, ID_AREA) VALUES ")
    СП.ДОБАВИТЬ("('" + цл_КодУл + "', '" + цл_КодУчГарПольз + "', '" + СТР(Дата) + "', " + СТР_ЗНАЧ(Сумма) + ",")
    СП.ДОБАВИТЬ("'" + ЗаЧто + "', '" + цл_ФИО + "', '" + дебСчетПотерь + "', '"  +  кодСтатьи  +  "', " + СТР_ЗНАЧ(г_идентСтатьи) + ", " + СТР_ЗНАЧ(Id_Area) + ")")
    SQL_ЗАПРОС(СП)
    STG_I_tmpПКО = ДА
  КОНЕЦ_ЕСЛИ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
//Чтение из ф_tmp005 для приходника
ФУНКЦИЯ ТИП_ЛОГИКА: STG_R_tmpПКО(ПЕРЕМ ТИП_ДАТА: Дата; ПЕРЕМ ТИП_ЧИСЛО: Сумма; ПЕРЕМ ТИП_СТРОКА: ЗаЧто) //_R_ВФПО
  ЕСЛИ СУЩ_ФАЙЛ(ф_tmp005) ТО
    sql = БД_ОТКРЫТЬ(ф_tmp005)
    ЕСЛИ sql.ВСЕГО > 0 ТО
      sql.ПЕРЕЙТИ(1)
      цл_КодУл = sql.ПОЛЕ("CODS")
      цл_КодУчГарПольз = sql.ПОЛЕ("N_AREA")
      Дата = sql.ПОЛЕ("DAT")
      Сумма = sql.ПОЛЕ("PRICE")
      ЗаЧто = sql.ПОЛЕ("FORWHAT")
      цл_ФИО = sql.ПОЛЕ("FIO")
      дебСчетПотерь = sql.ПОЛЕ("POTERI")
      г_идентСтатьи = sql.ПОЛЕ("ID_VZN")
      Id_Area = sql.ПОЛЕ("ID_AREA")
      STG_R_tmpПКО = ДА
    КОНЕЦ_ЕСЛИ
    sql.ЗАКРЫТЬ
    IB_FILE_ФайлУдалить(ф_tmp005)
  КОНЕЦ_ЕСЛИ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
//список ПКО
ФУНКЦИЯ ТИП_ЛОГИКА: STG_C_tmpСписокПКО //_СОЗДАТЬ_ВФОплСпис
  ЕСЛИ IB_FILE_ФайлУдалить(ф_tmp002) ТО
    СОЗДАТЬ(СП,ТИП_СПИСОК)
    СП.ДОБАВИТЬ("CREATE TABLE")
    СП.ДОБАВИТЬ("'" + ф_tmp002 + "'")
    СП.ДОБАВИТЬ("(N NUMERIC(5,0)," +       //номер док
                " DAT DATE," +             //дата док
                " FIO CHAR(100)," +        //владелец
                " PRICE NUMERIC(15,4)," +  //сумма
                " CAP CHAR(100)," +        //имя взноса
                " ID_VZN NUMERIC(10)," +   //ид взноса
                " FLS CHAR(20)," +         //флс
                " ID_AREA NUMERIC(10)," +  //ид участка
                " CODS CHAR(50)," +        //код улицы
                " N_AREA CHAR(30))")       //номер участка
    SQL_ЗАПРОС(СП)
    STG_C_tmpСписокПКО = ДА
  КОНЕЦ_ЕСЛИ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
//-------------------------------------------------------------------------------------------------------------------------//
//-------------------------------------------------------------------------------------------------------------------------//
ПЕРЕМ г_значНастрПоУмолч!
ПЕРЕМ г_настройкаБланка!
ПЕРЕМ г_новоеЗначНастр!     //новое значение настройки. используется для смены имени значения настройки

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ STG_ОбновитьНастрБланка(ТИП_СТРОКА: Документ)
  Раздел = ?(НЕ г_блокГСК, "ST", "GSK")
  СБРОС(г_значНастрПоУмолч, г_настройкаБланка, ЗначениеПараметра)
  
  //Сносим все старые, если удалось их считать
  ЕСЛИ ib_f4_СЧИТАТЬ_ЗНАЧЕНИЯ(Раздел,Документ) ТО
    ЦИКЛ ИНДЕКС(значНастр = ЗначениеПараметра!инд)
      назвНастр = инд + "=" //убираем предупреждение
      IB_F4_УДАЛИТЬ_НАСТРОЙКУ(Раздел, Документ, назвНастр) 
    КОНЕЦ_ЦИКЛА
  КОНЕЦ_ЕСЛИ
    
  //определяем текущие
  STG_ИниНастройки(Документ)
    
  //Затем сохраняем обновленные
  ЦИКЛ ИНДЕКС(настройка = г_настройкаБланка!индекс)
    назвНастр = СТР_ФРАГ(индекс, "_", 2) //ПОДСТР(индекс, 5)
    ЕСЛИ СУЩ_ПЕРЕМ(ЗначениеПараметра!назвНастр) ТО
      значПарам = ЗначениеПараметра!назвНастр
    ИНАЧЕ
      значПарам = г_значНастрПоУмолч!индекс
    КОНЕЦ_ЕСЛИ
    
    ЕСЛИ СУЩ_ПЕРЕМ(г_новоеЗначНастр!индекс!"_"!значПарам) ТО
      значПарам = г_новоеЗначНастр!индекс!"_"!значПарам
    КОНЕЦ_ЕСЛИ
    
    настр = назвНастр + "=" + значПарам + "_" + настройка
    IB_F4_ДОБАВИТЬ_НАСТРОЙКУ(Раздел, Документ, настр)
  КОНЕЦ_ЦИКЛА
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ STG_ИниНастройки(ТИП_СТРОКА: документ)
  ЕСЛИ документ = "Реестр собственников" ИЛИ 
       документ = "Карточка " + текстЗагРП ТО
    ЕСЛИ документ = "Реестр собственников" ТО
      г_значНастрПоУмолч!"000_Адрес" = "Да"
      г_значНастрПоУмолч!"001_Участок" = "Нет"
      
      г_настройкаБланка!"000_Адрес" = "Да/Нет"
      г_настройкаБланка!"001_Участок" = "Да/Нет"
    КОНЕЦ_ЕСЛИ
    г_значНастрПоУмолч!"002_Дата рождения" = "Да"
    г_значНастрПоУмолч!"003_Место рождения" = "Да"
    г_значНастрПоУмолч!"004_Адрес прописки" = "Да"
    г_значНастрПоУмолч!"005_Паспортные данные" = "Да"
    ЕСЛИ документ = "Реестр собственников" ТО 
      г_значНастрПоУмолч!"006_Телефоны" = "Да"
      г_значНастрПоУмолч!"007_E-mail" = "Да"
      г_значНастрПоУмолч!"010_Статус" = "Да"
    ИНАЧЕ
      г_значНастрПоУмолч!"006_Телефон" = "Да"
      г_значНастрПоУмолч!"007_Моб. тел. 1" = "Да"
      г_значНастрПоУмолч!"008_Моб. тел. 2" = "Да"
      г_значНастрПоУмолч!"009_E-mail" = "Да"
      
      г_значНастрПоУмолч!"010_Дата принятия" = "Да"
      г_значНастрПоУмолч!"011_№ протокола" = "Да"
      г_значНастрПоУмолч!"012_Дата выбытия" = "Да"
    КОНЕЦ_ЕСЛИ
    
    г_настройкаБланка!"002_Дата рождения" = "Да/Нет"
    г_настройкаБланка!"003_Место рождения" = "Да/Нет"
    г_настройкаБланка!"004_Адрес прописки" = "Да/Нет"
    г_настройкаБланка!"005_Паспортные данные" = "Да/Нет"
    
    ЕСЛИ документ = "Реестр собственников" ТО 
      г_настройкаБланка!"006_Телефоны" = "Да/Нет"
      г_настройкаБланка!"007_E-mail" = "Да/Нет"
      г_настройкаБланка!"010_Статус" = "Да/Нет"
    ИНАЧЕ
      г_настройкаБланка!"006_Телефон" = "Да/Нет"
      г_настройкаБланка!"007_Моб. тел. 1" = "Да/Нет"
      г_настройкаБланка!"008_Моб. тел. 2" = "Да/Нет"
      г_настройкаБланка!"009_E-mail" = "Да/Нет"
      г_настройкаБланка!"010_Дата принятия" = "Да/Нет"
      г_настройкаБланка!"011_№ протокола" = "Да/Нет"
      г_настройкаБланка!"012_Дата выбытия" = "Да/Нет"
    КОНЕЦ_ЕСЛИ
    
    ЕСЛИ документ = "Карточка " + текстЗагРП ТО
      г_значНастрПоУмолч!"013_Номер свидетельства" = "Да"
      г_значНастрПоУмолч!"014_Дата регистрации свидетельства" = "Да"
      г_значНастрПоУмолч!"015_Дата отчуждения собственности" = "Да"
      г_значНастрПоУмолч!"016_Доля" = "Да"
      г_значНастрПоУмолч!"017_Участок" = "Да"
    
      г_настройкаБланка!"013_Номер свидетельства" = "Да/Нет"
      г_настройкаБланка!"014_Дата регистрации свидетельства" = "Да/Нет"
      г_настройкаБланка!"015_Дата отчуждения собственности" = "Да/Нет"
      г_настройкаБланка!"016_Доля" = "Да/Нет"
    КОНЕЦ_ЕСЛИ  
    г_значНастрПоУмолч!"020_Комментарий" = "Нет"
    г_настройкаБланка!"020_Комментарий" = "Да/Нет"
  ИНАЧЕ
    ЕСЛИ документ = "Реестр " + текстЗагРПМнож ТО
      г_значНастрПоУмолч!"000_Ф.И.О. текущего владельца" = "Да"
      г_значНастрПоУмолч!"001_Площадь" = "Да"
      г_значНастрПоУмолч!"002_Кадастровый номер" = "Да"
      г_значНастрПоУмолч!"003_Номер свидетельства" = "Да"
      г_значНастрПоУмолч!"004_Прив." = "Да"
      г_значНастрПоУмолч!"005_Исп-ся" = "Да"
      
      г_настройкаБланка!"000_Ф.И.О. текущего владельца" = "Да/Нет"
      г_настройкаБланка!"001_Площадь" = "Да/Нет"
      г_настройкаБланка!"002_Кадастровый номер" = "Да/Нет"
      г_настройкаБланка!"003_Номер свидетельства" = "Да/Нет"
      г_настройкаБланка!"004_Прив." = "Да/Нет"
      г_настройкаБланка!"005_Исп-ся" = "Да/Нет"
    КОНЕЦ_ЕСЛИ
  КОНЕЦ_ЕСЛИ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ STG_ОбновитьДатуВСпрВлад
  СОЗДАТЬ(сп, ТИП_СПИСОК)
  IB_DBF_ДОБАВИТЬ_ПОЛЕ(ф_СпрВладельцев, "Д", "tmpf", 0, 0)
  
  сп.ДОБАВИТЬ("SELECT ID, CAST(ROG AS DATE) AS ROG_D FROM")
  сп.ДОБАВИТЬ("'" + ф_СпрВладельцев + "'")
  sql_1 = SQL_ЗАПРОС(сп)
  sql = SQL_ОТКРЫТЬ(ф_СпрВладельцев)
  ЦИКЛ ДЛЯ(и = 1, sql.ВСЕГО)
    sql.ПЕРЕЙТИ(и)
    sql_1.ПЕРЕЙТИ(и)
    sql.ЗАП_ПОЛЕ("tmpf", sql_1.ПОЛЕ("ROG_D"))
    sql.ЗАМЕНИТЬ
  КОНЕЦ_ЦИКЛА
  sql.ЗАКРЫТЬ
  sql_1.ЗАКРЫТЬ
  
  IB_DBF_УДАЛИТЬ_ПОЛЕ(ф_СпрВладельцев, "ROG")
  IB_DBF_ДОБАВИТЬ_ПОЛЕ(ф_СпрВладельцев, "Д", "ROG", 0, 0)
  
  сп.ОЧИСТИТЬ
  сп.ДОБАВИТЬ("UPDATE")
  сп.ДОБАВИТЬ("'" + ф_СпрВладельцев + "'")
  сп.ДОБАВИТЬ("SET ROG = tmpf")
  SQL_ЗАПРОС(сп)
  
  IB_DBF_УДАЛИТЬ_ПОЛЕ(ф_СпрВладельцев, "tmpf")
КОНЕЦ_ФУНКЦИИ

