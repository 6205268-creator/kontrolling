//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ STG_ДобавитьТипРасчетаПени
  IB_DBF_ДОБАВИТЬ_ПОЛЕ(ф_НастройкиПени, "С", "TYPE", 50, 0)
  //
  sql = SQL_ОТКРЫТЬ(ф_НастройкиПени)
  ЕСЛИ sql.ВСЕГО > 0 ТО
    sql.ПЕРЕЙТИ(1)
    ЕСЛИ sql.ПОЛЕ("CALC") ТО
      sql.ЗАП_ПОЛЕ("TYPE", к_ТипРасчетаПениПоГодам)
    ИНАЧЕ
      sql.ЗАП_ПОЛЕ("TYPE", к_ТипРасчетаПениПоДатам)
    КОНЕЦ_ЕСЛИ
    sql.ЗАМЕНИТЬ
  КОНЕЦ_ЕСЛИ  
  sql.ЗАКРЫТЬ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ STG_КорректКодУлДляИПУ
  СОЗДАТЬ(сп, ТИП_СПИСОК)
  sql = SQL_ОТКРЫТЬ(ф_СпрУлиц)
  ЦИКЛ ДЛЯ(и = 1, sql.ВСЕГО)
    sql.ПЕРЕЙТИ(и)
    кодУл = sql.ПОЛЕ("CODS")
    сп.ОЧИСТИТЬ
    сп.ДОБАВИТЬ("UPDATE")
    сп.ДОБАВИТЬ("'" + ф_СпрИндивСчетчики + "'")
    сп.ДОБАВИТЬ("SET CODS = '" + кодУл + "' WHERE CODS = '' AND ID_AREA IN (SELECT ID_AREA FROM")
    сп.ДОБАВИТЬ("'" + ф_СпрУчастковГаражей + "'")
    сп.ДОБАВИТЬ("WHERE CODS = '" + кодУл + "')")
    SQL_ЗАПРОС(сп)
    
    сп.ОЧИСТИТЬ
    сп.ДОБАВИТЬ("UPDATE")
    сп.ДОБАВИТЬ("'" + ф_ПоказанияИСЭЭ + "'")
    сп.ДОБАВИТЬ("SET CODS = '" + кодУл + "' WHERE CODS = '' AND ID_AREA IN (SELECT ID_AREA FROM")
    сп.ДОБАВИТЬ("'" + ф_СпрУчастковГаражей + "'")
    сп.ДОБАВИТЬ("WHERE CODS = '" + кодУл + "')")
    SQL_ЗАПРОС(сп)
  КОНЕЦ_ЦИКЛА
  sql.ЗАКРЫТЬ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ STG_КоррСуммыЖурнала
  СОЗДАТЬ(сп, ТИП_СПИСОК)
  сп.ДОБАВИТЬ("UPDATE")
  сп.ДОБАВИТЬ("'" + ф_Журнал + "'")
  сп.ДОБАВИТЬ("SET ADD_SUM = 0 WHERE REC_TYPE = 1 OR REC_TYPE = 2")
  SQL_ЗАПРОС(сп)
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ STG_КоррИдентВзносов
  файл!1 = ф_Журнал
  файл!2 = ф_ЖурналРасчетов
  идВзносов!"" = 0
  СОЗДАТЬ(сп, ТИП_СПИСОК)
  
  sql = SQL_ОТКРЫТЬ(ф_СпрЦелевыхВзносов)
  ЦИКЛ ДЛЯ(и = 1, sql.ВСЕГО)
    sql.ПЕРЕЙТИ(и)
    код = sql.ПОЛЕ("CODP")
    тар = СТР_ЗНАЧ(sql.ПОЛЕ("COT"))
    идВзносов!код!"_"!тар = sql.ПОЛЕ("ID")
  КОНЕЦ_ЦИКЛА
  sql.ЗАКРЫТЬ
  
  ЦИКЛ ДЛЯ(и = 1, 2)
    поле = ?(и = 1, "ID_VZN", "ID_TYPE")
    ЦИКЛ ИНДЕКС(ид = идВзносов!инд)
      ЕСЛИ ид > 0 ТО
        код = СТР_ФРАГ(инд, "_", 1)
         тар = СТР_ФРАГ(инд, "_", 2)
         сп.ОЧИСТИТЬ
        сп.ДОБАВИТЬ("UPDATE")
        сп.ДОБАВИТЬ("'" + файл!и + "'")
        сп.ДОБАВИТЬ("SET " + поле + " = " + СТР_ЗНАЧ(ид) + " WHERE TYPE = '" + код + "' AND " + поле + " = 0")
        ЕСЛИ код = "ЭЭ" ТО
          сп.ДОБАВИТЬ("AND ID_AREA IN (SELECT ID_AREA FROM")
          сп.ДОБАВИТЬ("'" + ф_СпрИндивСчетчики + "'")
          сп.ДОБАВИТЬ("WHERE COT = " + тар + " AND TYPE = 'ЭЭ')")
        КОНЕЦ_ЕСЛИ
        SQL_ЗАПРОС(сп)
      КОНЕЦ_ЕСЛИ
    КОНЕЦ_ЦИКЛА
  КОНЕЦ_ЦИКЛА
КОНЕЦ_ФУНКЦИИ

