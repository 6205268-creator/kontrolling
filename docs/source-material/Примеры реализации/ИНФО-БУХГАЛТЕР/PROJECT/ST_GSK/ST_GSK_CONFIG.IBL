//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ STG_C_СпрРеквОргСайт
  ЕСЛИ НЕ СУЩ_ФАЙЛ(ф_СпрРеквизитовОргСайт) ТО
    STG_R_НастройкиПечатиПД
    STG_ОпределитьРеквПолучателя
  
    sql = SQL_СОЗДАТЬ(ф_СпрРеквизитовОргСайт,
                      ["NAME"       : ТИП_СТРОКА : 50,
                       "VAL"        : ТИП_СТРОКА : 250,
                       //"VAL_NEW"    : ТИП_СТРОКА : 250,
                       "ID_RECSITE" : ТИП_ЧИСЛО  : 10,
                       "UUID"       : ТИП_СТРОКА : 40,
                       "IS_SYNCED"  : ТИП_ЛОГИКА
                       ])
    
    sql.STG_ДобРеквизитОтобр("Организация", г_реквПолучателя!"наимОрг")
    sql.STG_ДобРеквизитОтобр("Организация (полн.)", г_реквПолучателя!"наимОргПолн")
    sql.STG_ДобРеквизитОтобр("Банк", г_реквПолучателя!"наимБанк")
    sql.STG_ДобРеквизитОтобр("Расч. счет", г_реквПолучателя!"расчСч")
    sql.STG_ДобРеквизитОтобр("БИК", г_реквПолучателя!"бик")
    sql.STG_ДобРеквизитОтобр("Корр. счет", г_реквПолучателя!"коррСч")
    sql.STG_ДобРеквизитОтобр("ИНН", г_реквПолучателя!"иннОрг")
    sql.STG_ДобРеквизитОтобр("КПП", г_реквПолучателя!"кппОрг")
    sql.ЗАКРЫТЬ
  КОНЕЦ_ЕСЛИ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ STG_C_СпрНастроекСайт
  ЕСЛИ НЕ СУЩ_ФАЙЛ(ф_СпрНастроекСайт) ТО
    STG_R_НастройкиПечатиПД
  
    sql = SQL_СОЗДАТЬ(ф_СпрНастроекСайт,
                      ["NAME"       : ТИП_СТРОКА : 50,
                       "VAL"        : ТИП_СТРОКА : 250,
                       //"VAL_NEW"    : ТИП_СТРОКА : 250,
                       "ID_RECSITE" : ТИП_ЧИСЛО  : 10,
                       "UUID"       : ТИП_СТРОКА : 40,
                       "IS_SYNCED"  : ТИП_ЛОГИКА
                       ])
    
    sql.STG_ДобРеквизитОтобр("Кодировка ДШК", СТР_ЗНАЧ(ПараметрПечатиПД!"Кодировка ДШК"))
    sql.STG_ДобРеквизитОтобр("Рекв. ""Вид платежа"" для взносов", ПараметрПечатиПД!"Вид платежа остальные")
    sql.STG_ДобРеквизитОтобр("Рекв. ""Вид платежа"" для взносов по ИПУ", ПараметрПечатиПД!"Вид платежа ИПУ")
    
    STG_СчитатьШаблоны(к_ОбщиеРеквизиты)
    sql.STG_ДобРеквизитОтобр("Рекв. ДШК ""Адрес плательщика""", г_ПарамШаблонаДШК!к_ШаблонАдресПлательщика)
    
    STG_СчитатьШаблоны(к_ФормаПД4 + ", " + к_ФормаПДМнож)
    sql.STG_ДобРеквизитОтобр("Рекв. ДШК ""Назначение платежа"" для взносов", г_ПарамШаблонаДШК!к_ШаблонНазначениеПлатежа)
    
    STG_СчитатьШаблоны(к_ФормаПД4ЭЭ + ", " + к_ФормаПДСчСтд)
    sql.STG_ДобРеквизитОтобр("Рекв. ДШК ""Назначение платежа"" для ИПУ", г_ПарамШаблонаДШК!к_ШаблонНазначениеПлатежа)
    sql.STG_ДобРеквизитОтобр("Рекв. ДШК ""Назначение платежа"" для ИПУ без пок.", г_ПарамШаблонаДШК!к_ШаблонНазнПлатежаБезПок)
    sql.ЗАКРЫТЬ
  КОНЕЦ_ЕСЛИ
КОНЕЦ_ФУНКЦИИ


//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ ТИП_SQL STG_ДобРеквизитОтобр(ТИП_СТРОКА: имя, значение)
  ЗАП_ПОЛЕ("name", имя)
  ЗАП_ПОЛЕ("val", значение)
  //ЗАП_ПОЛЕ("val_new", значение)
  ЗАП_ПОЛЕ("is_synced", НЕТ)
  ДОБАВИТЬ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
//настройки счетов
ФУНКЦИЯ STG_C_НастройкиСчетов
  ЕСЛИ НЕ СУЩ_ФАЙЛ(ф_Настроек) ТО
    СОЗДАТЬ(сп, ТИП_СПИСОК)
    сп.ДОБАВИТЬ("CREATE TABLE")
    сп.ДОБАВИТЬ("'" + ф_Настроек + "'")
    сп.ДОБАВИТЬ("(ID NUMERIC(2,0)," + 
                " POL1 CHAR(50)," + 
                " POL2 CHAR(50))")
    SQL_ЗАПРОС(сп)
    
    //Заполнение умолчаниями
    субСч = ?(г_блокГСК ИЛИ г_блокГСКизСНТ, "ГСК", "СНТ")
    STG_I_НастройкиСчетов(1, "76/" + субСч, "76/" + субСч)
    STG_I_НастройкиСчетов(2, "86", "86")
    STG_I_НастройкиСчетов(10, "0", "0")
    //
    ЕСЛИ ЕСТЬ_СУБСЧ("50") ТО
      ЦИКЛ СЧЕТА(сч = "50/*")
        кассаСч = сч //первый попавшийся
        СТОП
      КОНЕЦ_ЦИКЛА
    ИНАЧЕ
      кассаСч = "50"
    КОНЕЦ_ЕСЛИ
    STG_I_НастройкиСчетов(3, кассаСч, кассаСч)
    //
    ЕСЛИ ЕСТЬ_СУБСЧ("51") ТО
      ЦИКЛ СЧЕТА(сч = "51/*")
        расчСчет = сч //первый попавшийся
        СТОП
      КОНЕЦ_ЦИКЛА
    ИНАЧЕ
      расчСчет = "51"
    КОНЕЦ_ЕСЛИ
    STG_I_НастройкиСчетов(5, расчСчет, расчСчет)
    
    ЕСЛИ г_блокСНТ ТО
      STG_I_НастройкиСчетов(4, "86/" + субСч + "/ЦФ", "86/" + субСч + "/ЦФ")
      STG_I_НастройкиСчетов(6, "", "")
      STG_I_НастройкиСчетов(7, "", "")
      STG_I_НастройкиСчетов(8, "Х", "Х") //сразу пусть правильно для новыз юзеров формируется
      STG_I_НастройкиСчетов(9, "", "")
    КОНЕЦ_ЕСЛИ
  ИНАЧЕ
    ЕСЛИ г_блокСНТ ТО //выкинуть в конвертер блока
      IB_DBF_ДОБАВИТЬ_ПОЛЕ(ф_Настроек, "С", "POL2", 50, 0)
      бдВсего = IB_DBF_ВсегоЗап(ф_Настроек)
      ЕСЛИ бдВсего = 4 ТО 
        ЕСЛИ ЕСТЬ_СУБСЧ("51") ТО
          ЦИКЛ СЧЕТА(сч = "51/*")
            расчСчет = сч //первый попавшийся
            СТОП
          КОНЕЦ_ЦИКЛА
        ИНАЧЕ
          расчСчет = "51"
        КОНЕЦ_ЕСЛИ
        STG_I_НастройкиСчетов(5, расчСчет, расчСчет)
      КОНЕЦ_ЕСЛИ
  
      ЕСЛИ бдВсего <= 5 ТО
        STG_I_НастройкиСчетов(6,"", "")
      КОНЕЦ_ЕСЛИ
  
      ЕСЛИ бдВсего <= 6 ТО
        STG_I_НастройкиСчетов(7, "Х", "Х")
      КОНЕЦ_ЕСЛИ
  
      ЕСЛИ бдВсего <= 7 ТО
        STG_I_НастройкиСчетов(8, "", "")
      КОНЕЦ_ЕСЛИ
  
      ЕСЛИ бдВсего <= 8 ТО
        STG_I_НастройкиСчетов(9, "", "")
      КОНЕЦ_ЕСЛИ
  
      ЕСЛИ бдВсего <= 9 ТО
        STG_I_НастройкиСчетов(10, "0", "0")
      КОНЕЦ_ЕСЛИ
    КОНЕЦ_ЕСЛИ
  КОНЕЦ_ЕСЛИ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ STG_I_НастройкиСчетов(ТИП_ЧИСЛО: id; 
                              ТИП_СТРОКА: знач, знач2)
  СОЗДАТЬ(сп, ТИП_СПИСОК)
  сп.ДОБАВИТЬ("INSERT INTO")
  сп.ДОБАВИТЬ("'" + ф_Настроек + "'")
  сп.ДОБАВИТЬ("(ID, POL1, POL2) VALUES (" + СТР_ЗНАЧ(id) + ", '" + знач + "', '" + знач2 + "')")
  SQL_ЗАПРОС(сп)
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ STG_U_НастройкиСчетов(ТИП_ЧИСЛО: id; 
                              ТИП_СТРОКА: знач, знач2)
  СОЗДАТЬ(сп, ТИП_СПИСОК)
  сп.ДОБАВИТЬ("UPDATE")
  сп.ДОБАВИТЬ("'" + ф_Настроек + "'")
  сп.ДОБАВИТЬ("SET POL1 = '" + знач + "', POL2 = '" + знач2 + "' WHERE ID = " + СТР_ЗНАЧ(id))
  SQL_ЗАПРОС(сп)
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
//Справочник настроек печати
ФУНКЦИЯ STG_C_НастройкиПечати
  ЕСЛИ НЕ СУЩ_ФАЙЛ(ф_НастройкиПечатиПД) ТО
    СОЗДАТЬ(сп, ТИП_СПИСОК)
    сп.ДОБАВИТЬ("CREATE TABLE")
    сп.ДОБАВИТЬ("'" + ф_НастройкиПечатиПД + "'")
    сп.ДОБАВИТЬ("(POL1 BOOLEAN," +        //Формирование ДШК
                " POL2 BOOLEAN," +        //Отправлять почту в фоне
                " POL3 NUMERIC(5,0)," +   //Таймаут отправки в секундах
                " POL4 BOOLEAN," +        //Банковские реквизиты из спр. организаций
                " POL5 NUMERIC(10,0), " + //ID банка
                " POL6 NUMERIC(10,0)," +  //ID организации
                " POL7 BOOLEAN," +        //Преобразование в PDF - не используется
                " POL8 BOOLEAN," +        //Округлять копейки - не используется
                " POL9 BOOLEAN," +        //Членские взносы в назначении платежа - не используется
                " POL10 CHAR(250), " +    //Логотип организации
                " POL11 CHAR(30)," +      //Реквизит Вид платежа для ИПУ
                " POL12 CHAR(30)," +      //Реквизит Вид платежа для остальных
                " POL13 NUMERIC(2,0)," +  //Кодировка ДШК
                " POL14 CHAR(50)," +      //Форма квитанции для ИПУ
                " POL15 CHAR(50))")       //Форма квитанции для остальных
    SQL_ЗАПРОС(сп)
    логДоб = ДА
  ИНАЧЕ
    sql = SQL_ОТКРЫТЬ(ф_НастройкиПечатиПД)
    логДоб = (sql.ВСЕГО = 0 И sql.КОЛ_ПОЛЕЙ = 15)
    sql.ЗАКРЫТЬ
  КОНЕЦ_ЕСЛИ
  
  ЕСЛИ логДоб ТО
    сп.ОЧИСТИТЬ
    сп.ДОБАВИТЬ("INSERT INTO")
    сп.ДОБАВИТЬ("'" + ф_НастройкиПечатиПД + "'")
    сп.ДОБАВИТЬ("(POL1, POL2, POL3, POL4, POL5, POL6, POL7, POL8, POL9, POL10, POL11, POL12, POL13, POL14, POL15) VALUES")
    сп.ДОБАВИТЬ("(TRUE, FALSE, 60, FALSE, 0, 0, FALSE, FALSE, FALSE, '', '', '', " + СТР_ЗНАЧ(к_КодировкаДШКWin1251) + ", '" + к_ФормаПДСчСтд + "', '" + к_ФормаПДМнож + "')")
    SQL_ЗАПРОС(сп)
  КОНЕЦ_ЕСЛИ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
//шаблоны полей ПД, ДШК и ХО
ФУНКЦИЯ STG_C_СправочникШаблонов
  ЕСЛИ НЕ СУЩ_ФАЙЛ(ф_ШаблоныПолейПД) ТО
    СОЗДАТЬ(сп,ТИП_СПИСОК)
    сп.ДОБАВИТЬ("CREATE TABLE")
    сп.ДОБАВИТЬ("'" + ф_ШаблоныПолейПД + "'")
    сп.ДОБАВИТЬ("(ID_PD NUMERIC(2)," +   //id формы ПД
                " ID_TMPL NUMERIC(2)," + //id шаблона
                " TEMPLATE CHAR(250))")  //шаблон
    SQL_ЗАПРОС(сп)
    //Заполнение шаблонов
    STG_ЗаполнитьШаблоны(к_ФормаПД4Код)
    STG_ЗаполнитьШаблоны(к_ФормаПД4ЭЭКод)
    STG_ЗаполнитьШаблоны(к_ФормаПДМножКод)
    STG_ЗаполнитьШаблоны(к_ФормаПДСчСтдКод)
    STG_ЗаполнитьШаблоны(к_ФормыПДВзносыКод)
    STG_ЗаполнитьШаблоны(к_ФормыПДИПУКод)
    STG_ЗаполнитьШаблоны(к_содХОПоНачВзносовКод)
    STG_ЗаполнитьШаблоны(к_содХОПоНачПоИПУКод)
    STG_ЗаполнитьШаблоны(к_содХОПоОплатамКод)
    STG_ЗаполнитьШаблоны(к_содХОПоПениКод)
    STG_ЗаполнитьШаблоны(к_содХОПоНачПриОплатеКод)
    STG_ЗаполнитьШаблоны(к_формаПКОКод)
    STG_ЗаполнитьШаблоны(к_ОбщиеРеквизитыКод)
  КОНЕЦ_ЕСЛИ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
//установка умолчаний
ФУНКЦИЯ STG_ЗаполнитьШаблоны(ТИП_ЧИСЛО: код)
  ВЫБОР(код)
   #к_ФормаПД4Код, к_ФормаПД4ЭЭКод, к_ФормаПДМножКод, к_ФормаПДСчСтдКод:
     STG_I_ШаблоныПолейПД(код, к_ШаблонНазначениеПлатежа, STG_ШаблонПоУмолчанию(код, к_ШаблонНазначениеПлатежа))
     STG_I_ШаблоныПолейПД(код, к_ШаблонФИОПлательщика, STG_ШаблонПоУмолчанию(код, к_ШаблонФИОПлательщика))
     STG_I_ШаблоныПолейПД(код, к_ШаблонАдресПлательщика, STG_ШаблонПоУмолчанию(код, к_ШаблонАдресПлательщика))
     STG_I_ШаблоныПолейПД(код, к_ШаблонНазнПлатежаБезПок, STG_ШаблонПоУмолчанию(код, к_ШаблонНазнПлатежаБезПок))

   #к_ФормыПДВзносыКод, к_ФормыПДИПУКод :
     STG_I_ШаблоныПолейПД(код, к_ШаблонНазначениеПлатежа, STG_ШаблонПоУмолчанию(код, к_ШаблонНазначениеПлатежа))

   #к_содХОПоНачВзносовКод, к_содХОПоНачПоИПУКод, к_содХОПоОплатамКод, к_содХОПоПениКод, к_содХОПоНачПриОплатеКод:
     STG_I_ШаблоныПолейПД(код, к_ШаблонСодержаниеХозОп, STG_ШаблонПоУмолчанию(код, к_ШаблонСодержаниеХозОп))

   #к_формаПКОКод:
     STG_I_ШаблоныПолейПД(код, к_формаПКОКод, STG_ШаблонПоУмолчанию(код, к_формаПКОКод))

   #к_ОбщиеРеквизитыКод:
     STG_I_ШаблоныПолейПД(код, к_ОбщиеРеквизитыКод, STG_ШаблонПоУмолчанию(код, к_ОбщиеРеквизитыКод))
  КОНЕЦ_ВЫБОРА
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
//добавление записи в справочник шаблонов
ФУНКЦИЯ STG_I_ШаблоныПолейПД(ТИП_ЧИСЛО: идентПД, идентШаблн;
                             ТИП_СТРОКА: шаблон)
  ЕСЛИ шаблон <> "" ТО
    СОЗДАТЬ(сп,ТИП_СПИСОК)
    сп.ДОБАВИТЬ("INSERT INTO")
    сп.ДОБАВИТЬ("'" + ф_ШаблоныПолейПД + "'")
    сп.ДОБАВИТЬ("(ID_PD, ID_TMPL, TEMPLATE) VALUES")
    сп.ДОБАВИТЬ("(" + СТР_ЗНАЧ(идентПД) + ", " + СТР_ЗНАЧ(идентШаблн) + ",")
    сп.ДОБАВИТЬ("'" + шаблон + "')")
    SQL_ЗАПРОС(сп)
  КОНЕЦ_ЕСЛИ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
//13. Справочник терминов
ФУНКЦИЯ STG_C_СпрТерминов
  ЕСЛИ НЕ СУЩ_ФАЙЛ(ф_СправочникТерминов) ТО
    СОЗДАТЬ(сп, ТИП_СПИСОК)
    сп.ДОБАВИТЬ("CREATE TABLE")
    сп.ДОБАВИТЬ("'" + ф_СправочникТерминов + "'")
    сп.ДОБАВИТЬ("(ID NUMERIC(2,0)," +  //id - линии или гаражи
                " IP CHAR(20)," +  //именительный падеж
                " RP CHAR(20)," +  //родительный
                " DP CHAR(20)," +  //дательный
                " VP CHAR(20)," +  //винительный
                " IPM CHAR(20)," +  //именительный множ.
                " RPM CHAR(20)," +  //родительный множ.
                " DPM CHAR(20)," +  //дательный множ.
                " VPM CHAR(20))")   //винительный множ.
    SQL_ЗАПРОС(сп)
    //
    STG_I_СпрТерминов(1, "гараж", "гаража", "гаражу", "гараж", 
                         "гаражи", "гаражей", "гаражам", "гаражи")
    STG_I_СпрТерминов(1, "гараж-бокс", "гаража-бокса", "гаражу-боксу", "гараж-бокс", 
                         "гаражи-боксы", "гаражей-боксов", "гаражам-боксам", "гаражи-боксы")
    STG_I_СпрТерминов(1, "машино-место", "машино-места", "машино-месту", "машино-место",
                         "машино-места", "машино-мест", "машино-местам", "машино-места")
                               
    STG_I_СпрТерминов(2, "линия", "линии", "линии", "линию", 
                         "линии", "линий", "линиям", "линии")
    STG_I_СпрТерминов(2, "проезд", "проезда", "проезду", "проезд", 
                         "проезды", "проездов", "проездам", "проезды")
    STG_I_СпрТерминов(2, "уровень", "уровня", "уровню", "уровням", 
                         "уровни", "уровней", "уровням", "уровни")
    STG_I_СпрТерминов(2, "этаж", "этажа", "этажу", "этаж", 
                         "этажи", "этажей", "этажам", "этажи")
  КОНЕЦ_ЕСЛИ
КОНЕЦ_ФУНКЦИИ

ФУНКЦИЯ STG_I_СпрТерминов(ТИП_ЧИСЛО: id; ТИП_СТРОКА: ип, рп, дп, вп, ипм, рпм, дпм, впм)
  sql = SQL_ОТКРЫТЬ(ф_СправочникТерминов)
  ЕСЛИ sql.НАЙТИ_ПОЗ("ID", id, "IP", ип) = 0 ТО
    sql.ЗАП_ПОЛЕ("ID", id)
    sql.ЗАП_ПОЛЕ("IP", ип)
    sql.ЗАП_ПОЛЕ("RP", рп)
    sql.ЗАП_ПОЛЕ("VP", вп)
    sql.ЗАП_ПОЛЕ("DP", дп)
    sql.ЗАП_ПОЛЕ("IPM", ипм)
    sql.ЗАП_ПОЛЕ("RPM", рпм)
    sql.ЗАП_ПОЛЕ("DPM", дпм)
    sql.ЗАП_ПОЛЕ("VPM", впм)
    sql.ДОБАВИТЬ
  КОНЕЦ_ЕСЛИ
  sql.ЗАКРЫТЬ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ STG_C_ДопКоррСчета
  ЕСЛИ НЕ СУЩ_ФАЙЛ(ф_НастройкиДокКоррСч) ТО
    SQL_СОЗДАТЬ(ф_НастройкиДокКоррСч,
                ["CORR_ACC" : ТИП_СТРОКА : 250,
                 "NAME"     : ТИП_СТРОКА : 100])
  КОНЕЦ_ЕСЛИ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ STG_C_СпрДиапОбъемовЭЭ
  ЕСЛИ НЕ СУЩ_ФАЙЛ(ф_СпрДиапОбъемовЭЭ) ТО
    sql = SQL_СОЗДАТЬ(ф_СпрДиапОбъемовЭЭ,
                      ["NAME"  : ТИП_СТРОКА : 50, //название
                       "ID"    : ТИП_СТРОКА : 10, //код
                       "VOL_S" : ТИП_ЧИСЛО  : 10, //начальный объем диапазона
                       "VOL_E" : ТИП_ЧИСЛО  : 10  //конечный объем диапазона
                       ])
                       
    sql.STG_ДобЗапДиапОбъемовЭЭ("1-й диапазон объемов потребление ЭЭ", "ДОЭЭ 1", 0, 11160)
    sql.STG_ДобЗапДиапОбъемовЭЭ("2-й диапазон объемов потребление ЭЭ", "ДОЭЭ 2", 11161, 22320)
    sql.STG_ДобЗапДиапОбъемовЭЭ("3-й диапазон объемов потребление ЭЭ", "ДОЭЭ 3", 22321, 0)
    sql.ЗАКРЫТЬ
  КОНЕЦ_ЕСЛИ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ ТИП_SQL STG_ДобЗапДиапОбъемовЭЭ(ТИП_СТРОКА: имя, ид; ТИП_ЧИСЛО: объемС, объемПо)
  ЗАП_ПОЛЕ("NAME", имя)
  ЗАП_ПОЛЕ("ID", ид)
  ЗАП_ПОЛЕ("VOL_S", объемС)
  ЗАП_ПОЛЕ("VOL_E", объемПо)
  
  ДОБАВИТЬ
КОНЕЦ_ФУНКЦИИ


