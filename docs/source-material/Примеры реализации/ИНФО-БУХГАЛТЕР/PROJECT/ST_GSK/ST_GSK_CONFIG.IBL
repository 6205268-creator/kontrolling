    сп.ДОБАВИТЬ(" PART CHAR(20)," + 
                " CONSIDER BOOLEAN," + 
                " FLS CHAR(20)," + 
                " MEMBER BOOLEAN," + 
                " ID_RECSITE NUMERIC(10)," +  
                " UUID CHAR(40)," +
                " IS_SYNCED BOOLEAN)")
    SQL_ЗАПРОС(сп)
  КОНЕЦ_ЕСЛИ
