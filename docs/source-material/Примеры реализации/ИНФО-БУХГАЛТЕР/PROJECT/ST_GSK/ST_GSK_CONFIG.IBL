КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ STG_КорректировкаПоляIsSynced
  СОЗДАТЬ(сп, ТИП_СПИСОК)
  
  файлы!1 = ф_СпрУчастковГаражей
  файлы!2 = ф_СпрЦелевыхВзносов
  файлы!3 = ф_СпрИндивСчетчики
  файлы!4 = ф_ПоказанияИСВГ
  файлы!5 = ф_ПоказанияИСЭЭ
  файлы!6 = ф_Журнал
  файлы!7 = ф_СпрТарифов
  файлы!8 = ф_СпрВладельцев
  файлы!9 = ф_СвязьВладУч
  файлы!10 = ф_СпрФЛС
  файлы!11 = ф_ЖурналРасчетов
  
  ЦИКЛ ИНДЕКС(файл = файлы!инд)
    IB_DBF_ДОБАВИТЬ_ПОЛЕ(файл, "Л", "IS_SYNC", 0, 0)
    
    сп.ОЧИСТИТЬ
    сп.ДОБАВИТЬ("UPDATE")
    сп.ДОБАВИТЬ("'" + файл + "'")
    сп.ДОБАВИТЬ("SET IS_SYNC = TRUE WHERE IS_SYNCED = TRUE")
    SQL_ЗАПРОС(сп)
    
    сп.ОЧИСТИТЬ
    сп.ДОБАВИТЬ("UPDATE")
    сп.ДОБАВИТЬ("'" + файл + "'")
    сп.ДОБАВИТЬ("SET IS_SYNCED = FALSE")
    SQL_ЗАПРОС(сп)
    
    сп.ОЧИСТИТЬ
    сп.ДОБАВИТЬ("UPDATE")
    сп.ДОБАВИТЬ("'" + файл + "'")
    сп.ДОБАВИТЬ("SET IS_SYNCED = TRUE WHERE IS_SYNC = TRUE")
    SQL_ЗАПРОС(сп)
    
    IB_DBF_УДАЛИТЬ_ПОЛЕ(файл, "IS_SYNC")
  КОНЕЦ_ЦИКЛА
КОНЕЦ_ФУНКЦИИ