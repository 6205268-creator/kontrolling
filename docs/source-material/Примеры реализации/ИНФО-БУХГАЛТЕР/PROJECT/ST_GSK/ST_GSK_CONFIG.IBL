//-------------------------------------------------------------------------------------------------------------------------//
//Файл показаний индивидуальных счетчиков (ЭЭ)
ФУНКЦИЯ STG_C_ЖурналПоказанийИПУЭЭ
  ЕСЛИ НЕ СУЩ_ФАЙЛ(ф_ПоказанияИСЭЭ) ТО
    СОЗДАТЬ(сп, ТИП_СПИСОК)
    сп.ДОБАВИТЬ("CREATE TABLE")
    сп.ДОБАВИТЬ("'"+ф_ПоказанияИСЭЭ+"'")
    сп.ДОБАВИТЬ("(CODS CHAR(50)," + 
                " ID_AREA NUMERIC(5,0)," + 
                " ID_SCH NUMERIC(5,0)," + 
                " DAT DATE,")
    сп.ДОБАВИТЬ(" NUM1 NUMERIC(15,4)," + 
                " NUM2 NUMERIC(15,4)," + 
                " NUM3 NUMERIC(15,4)," +
                " T1_VOL NUMERIC(15,4)," + 
                " T2_VOL NUMERIC(15,4)," + 
                " T3_VOL NUMERIC(15,4)," +
                " P1 NUMERIC(5,2)," + 
                " P2 NUMERIC(5,2)," + 
                " P3 NUMERIC(5,2)," + 
                " P CHAR(20),")
    сп.ДОБАВИТЬ(" CORR BOOLEAN," + 
                " COMM CHAR(250)," + 
                " ID_RECSITE NUMERIC(10)," +  
                " UUID CHAR(40)," +
                " IS_SYNCED BOOLEAN)")
    SQL_ЗАПРОС(сп)
