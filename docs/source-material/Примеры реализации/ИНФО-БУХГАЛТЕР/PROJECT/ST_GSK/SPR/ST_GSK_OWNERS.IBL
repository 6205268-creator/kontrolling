  //IB_DBF_ДобавитьНаУпаковку(ф_СпрВладельцев)
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
//Обработчик перед добавлением владельца
ФУНКЦИЯ ТИП_ЛОГИКА: STG_ПДобавитьСВлад(ПЕРЕМ ТИП_СТРОКА: стр)
  УСТ_РЕД_ПОЛЕ("DATEIN", к_МинДата)
  УСТ_РЕД_ПОЛЕ("DATEOUT", к_МаксДата)
  STG_ПДобавитьСВлад = ДА
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
//Обработчик добавления владельца
ФУНКЦИЯ ТИП_ЛОГИКА: STG_ДобавитьСВлад(ПЕРЕМ ТИП_СТРОКА: стр)
  ЕСЛИ РЕД_ПОЛЕ("FIO") = "" ТО
    СООБЩЕНИЕ("Необходимо указать Ф.И.О.")
  ИНАЧЕ
    УСТ_РЕД_ПОЛЕ("ID", IB_DBF_МаксЗначПоля(ф_СпрВладельцев,"ID") + 1)
    УСТ_РЕД_ПОЛЕ("ID_RECSITE", -1)
    УСТ_РЕД_ПОЛЕ("IS_SYNCED", НЕТ)
    STG_ДобавитьПарамСинхр(к_спрСайтаВладельцы, -1, "д", STG_ОписаниеВладельца)
    STG_ДобавитьСВлад = ДА
  КОНЕЦ_ЕСЛИ  
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
//Обработчик перед изменением владельца
ФУНКЦИЯ ТИП_ЛОГИКА: STG_ПИзменитьСВлад(ПЕРЕМ ТИП_СТРОКА: стр)
  цл_ФИО = РЕД_ПОЛЕ("FIO")
  STG_СчитатьТекЗапВПамять(к_спрСайтаВладельцы)
  STG_ПИзменитьСВлад = ДА
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
//Обработчик изменения владельца
ФУНКЦИЯ ТИП_ЛОГИКА: STG_ИзменитьСВлад(ПЕРЕМ ТИП_СТРОКА: стр)
  ЕСЛИ РЕД_ПОЛЕ("FIO") = "" ТО
    СООБЩЕНИЕ("Необходимо указать Ф.И.О.")
  ИНАЧЕ
    Id_Owner = РЕД_ПОЛЕ("ID")
    //
    ЕСЛИ цл_ФИО <> РЕД_ПОЛЕ("FIO") ТО
      stg_измененныеВладельцы!Id_Owner = РЕД_ПОЛЕ("FIO")
    КОНЕЦ_ЕСЛИ
    //
    ЕСЛИ STG_СравнитьСЗапВПамяти(к_спрСайтаВладельцы, "") ТО //!IS_SYNCED,!ID_RECSITE
      STG_ДобавитьПарамСинхр(к_спрСайтаВладельцы, РЕД_ПОЛЕ("ID_RECSITE"), "и", STG_ОписаниеВладельца)
      УСТ_РЕД_ПОЛЕ("IS_SYNCED", НЕТ)
    КОНЕЦ_ЕСЛИ
    //
    STG_ИзменитьСВлад = ДА
  КОНЕЦ_ЕСЛИ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
//Обработчик удаления владельца
ФУНКЦИЯ ТИП_ЛОГИКА: STG_УдалитьСВлад(ПЕРЕМ ТИП_СТРОКА: стр)
  ЕСЛИ ВОПРОС("Действие приведет к удалению владельца для всех участков/гаражей, у которых он установлен. Продолжить удаление?") ТО
    stg_удаленныеВладельцы[СТР_ЗНАЧ(РЕД_ПОЛЕ("ID"))] = РЕД_ПОЛЕ("FIO")
    STG_УдалитьСВлад = ДА 
    //ТЕСТОВОЕ!!!!
    //STG_ДобавитьПарамСинхр(к_спрСайтаВладельцы, РЕД_ПОЛЕ("ID_RECSITE"), "у", STG_ОписаниеВладельца)
    //добавить сюда удаление из спр связи с сайта
  КОНЕЦ_ЕСЛИ  
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ ТИП_СТРОКА: STG_ОписаниеВладельца
  STG_ОписаниеВладельца = "Ф.И.О.:" + РЕД_ПОЛЕ("FIO")
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ STG_ОбновитьСвязанныеСпр
  СОЗДАТЬ(СП, ТИП_СПИСОК)
  ЦИКЛ ИНДЕКС(фио = stg_измененныеВладельцы!инд)
    СП.ОЧИСТИТЬ
    СП.ДОБАВИТЬ("UPDATE")
    СП.ДОБАВИТЬ("'" + ф_СпрУчастковГаражей + "'")
    СП.ДОБАВИТЬ("SET FIO = '" + фио + "' WHERE ID_OWNER = " + инд)
    SQL_ЗАПРОС(СП)
    //
    СП.ОЧИСТИТЬ
    СП.ДОБАВИТЬ("UPDATE")
    СП.ДОБАВИТЬ("'" + ф_СвязьВладУч + "'")
    СП.ДОБАВИТЬ("SET FIO = '" + фио + "' WHERE ID_OWNER = " + инд)
    SQL_ЗАПРОС(СП)
  КОНЕЦ_ЦИКЛА
  
  ЦИКЛ ИНДЕКС(фио = stg_удаленныеВладельцы!инд)
    //попытка обновить владельца на другого для корректного отображения - может не обновить, если на участке нет других владельцев, 
    //что примут участие в расчете, но тогда уже дело за юзером
    участокОбработан!г_сервИнд = НЕТ
    СП.ОЧИСТИТЬ
    СП.ДОБАВИТЬ("SELECT * FROM")
    СП.ДОБАВИТЬ("'" + ф_СвязьВладУч + "'")
    СП.ДОБАВИТЬ("WHERE ID_AREA IN (SELECT ID_AREA FROM")
    СП.ДОБАВИТЬ("'" + ф_СвязьВладУч + "'")
    СП.ДОБАВИТЬ("WHERE ID_OWNER = " + инд + ") ORDER BY ID_AREA, DATOTCHSV DESC")
    sql = SQL_ЗАПРОС(СП)
    ЦИКЛ ДЛЯ(и = 1, sql.ВСЕГО)
      sql.ПЕРЕЙТИ(и)
      идВлад = sql.ПОЛЕ("ID_OWNER")
      идУчастка = sql.ПОЛЕ("ID_AREA")
      ЕСЛИ идВлад <> РЕД_ПОЛЕ("ID") И НЕ СУЩ_ПЕРЕМ(участокОбработан!идУчастка) ТО
        ЕСЛИ sql.ПОЛЕ("CONSIDER") ТО
          СП.ОЧИСТИТЬ
          СП.ДОБАВИТЬ("UPDATE")
          СП.ДОБАВИТЬ("'" + ф_СпрУчастковГаражей + "'")
          СП.ДОБАВИТЬ("SET ID_OWNER = " + СТР_ЗНАЧ(идВлад) + ", FIO = '" + sql.ПОЛЕ("FIO") + "' " + 
                      "WHERE ID_OWNER = " + инд + " AND ID_AREA = " + СТР_ЗНАЧ(идУчастка))
          SQL_ЗАПРОС(СП)
          участокОбработан!идУчастка = ДА
        КОНЕЦ_ЕСЛИ
     КОНЕЦ_ЕСЛИ
    КОНЕЦ_ЦИКЛА
    sql.ЗАКРЫТЬ
    //сброс там, где не удалось найти ранее. тут уже дело за юзером
    СП.ОЧИСТИТЬ
    СП.ДОБАВИТЬ("UPDATE")
    СП.ДОБАВИТЬ("'" + ф_СпрУчастковГаражей + "'")
    СП.ДОБАВИТЬ("SET ID_OWNER = 0, FIO = '' WHERE ID_OWNER = " + инд)
    SQL_ЗАПРОС(СП)
    //удаление из справочника владельцев участка
    СП.ОЧИСТИТЬ
    СП.ДОБАВИТЬ("DELETE FROM")
    СП.ДОБАВИТЬ("'" + ф_СвязьВладУч + "'")
    СП.ДОБАВИТЬ("WHERE ID_OWNER= " + инд)
    SQL_ЗАПРОС(СП)
  КОНЕЦ_ЦИКЛА
КОНЕЦ_ФУНКЦИИ