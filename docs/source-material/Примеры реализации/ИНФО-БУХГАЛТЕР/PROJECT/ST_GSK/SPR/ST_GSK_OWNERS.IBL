ИСПОЛЬЗОВАТЬ_БИБЛ("ST_GSK\ST_GSK_CONST")
ИСПОЛЬЗОВАТЬ_БИБЛ("ST_GSK\ST_GSK_PEREM")
ИСПОЛЬЗОВАТЬ_БИБЛ("ST_GSK\ST_GSK_LIB01")

ИСПОЛЬЗОВАТЬ_БИБЛ("IB_MAIL")
ИСПОЛЬЗОВАТЬ_БИБЛ("IB_DBF")

//-------------------------------------------------------------------------------------------------------------------------//
ПЕРЕМ stg_измененныеВладельцы!
ПЕРЕМ stg_удаленныеВладельцы!

//-------------------------------------------------------------------------------------------------------------------------//
//Редактор справочника владельцев
ПЕРЕМ ТИП_ЛОГИКА: г_спрВладельцевРежимСпр
ФУНКЦИЯ ТИП_ЛОГИКА: STG_СправочникВладельцев(ПЕРЕМ ТИП_СТРОКА: строка)
  STG_ВремСпрВладельцев
  STG_R_НастройкиБлока
  
  sql = SQL_ОТКРЫТЬ(ф_tmp_СпрВладельцев) //
  //поиск позиции
  текНом = 1
  ЕСЛИ Id_Owner > 0 ТО
    текНом = sql.НАЙТИ_ПОЗ("ID", Id_Owner)
  КОНЕЦ_ЕСЛИ
  текНом = ?(текНом = 0, 1, текНом)
  //
  набор = "владельцы"
  БД_СБРОС_СТОЛБЦОВ(набор)
  БД_ДОБАВИТЬ_СТОЛБЕЦ(набор, "FIO", "Ф.И.О.", 30, "Н")
  БД_ДОБАВИТЬ_СТОЛБЕЦ(набор, "ADDRESS", "Адрес регистрации", 35)
  БД_ДОБАВИТЬ_СТОЛБЕЦ(набор, "ADDR_F", "Адрес фактический", 35)
  БД_ДОБАВИТЬ_СТОЛБЕЦ(набор, "ADDR_P", "Адрес почтовый", 35)
  БД_ДОБАВИТЬ_СТОЛБЕЦ(набор, "ROG", "Дата" + СИМВ(13) + "рождения", 10)
  БД_ДОБАВИТЬ_СТОЛБЕЦ(набор, "MESTO", "Место рождения", 35)
  БД_ДОБАВИТЬ_СТОЛБЕЦ(набор, "PAS", "Паспортные данные", 35)
  БД_ДОБАВИТЬ_СТОЛБЕЦ(набор, "TEL", "Телефон", 14)
  БД_ДОБАВИТЬ_СТОЛБЕЦ(набор, "MOB1", "Мобильный", 14)
  БД_ДОБАВИТЬ_СТОЛБЕЦ(набор, "MOB2", "Мобильный(доп.)", 14)
  БД_ДОБАВИТЬ_СТОЛБЕЦ(набор, "EMAIL", "e-Mail", 20, "ПЗ", "выборПочты")
  БД_ДОБАВИТЬ_СТОЛБЕЦ(набор, "DATEIN", "Дата" + СИМВ(13) + "принятия", 10)
  БД_ДОБАВИТЬ_СТОЛБЕЦ(набор, "NOM_PROT", "№ протокола", 20)
  БД_ДОБАВИТЬ_СТОЛБЕЦ(набор, "DATEOUT", "Дата" + СИМВ(13) + "выбытия", 10)
  БД_ДОБАВИТЬ_СТОЛБЕЦ(набор, "COMM", "Комментарий", 35)
  БД_ДОБАВИТЬ_СТОЛБЕЦ(набор, "ID_OWNER", "ID влад", 1, "И")
  БД_ДОБАВИТЬ_СТОЛБЕЦ(набор, "ID_RECSITE", "ID сайта", 10, ?(г_работаССайтом, "З", "И"))
  БД_ДОБАВИТЬ_СТОЛБЕЦ(набор, "IS_SYNCED", "Синхр.", 6, ?(г_работаССайтом, "Ч", "И"))
  БД_ДОБАВИТЬ_СТОЛБЕЦ(набор, "LOGIN", "Логин", 20, ?(г_работаССайтом, "З", "И"))
  БД_ДОБАВИТЬ_СТОЛБЕЦ(набор, "UUID", "UUID сайта", 10, ?(г_работаССайтом, "З", "И"))
  БД_ДОБАВИТЬ_СТОЛБЕЦ(набор, "PASSW", "Пароль", 10, ?(г_работаССайтом, "З", "И"))
  //
  т = БД_РЕДАКТОР(sql, "Справочник владельцев",
                  [СТОЛБЦЫ(набор),
                   "выборПочты" : ("IB_MAIL", "IB_MAIL_ПарсингАдресаПочты"(ТИП_СТРОКА))
                  ], текНом, ДА, ДА, ДА, г_спрВладельцевРежимСпр,
                  [ Нач: ("ST_GSK\SPR\ST_GSK_OWNERS","STG_ПДобавитьСВлад"),
                    Доб: ("ST_GSK\SPR\ST_GSK_OWNERS","STG_ДобавитьСВлад"),
                    Изм: ("ST_GSK\SPR\ST_GSK_OWNERS","STG_ИзменитьСВлад"),
                    ПИз: ("ST_GSK\SPR\ST_GSK_OWNERS","STG_ПИзменитьСВлад"),
                    Уд:  ("ST_GSK\SPR\ST_GSK_OWNERS","STG_УдалитьСВлад")
                  ])
  логСохр = (т > 0)
  логИзм = sql.ИЗМЕНЕНА
  
  ЕСЛИ НЕ логСохр ТО
    ЕСЛИ логИзм ТО
      логСохр = ВОПРОС("Имеются несохранённые изменения. Сохранить их?", ДА) //если нет сохранения, то нет и сохранения в файл результатов
    КОНЕЦ_ЕСЛИ
  КОНЕЦ_ЕСЛИ
  
  ЕСЛИ логСохр ТО
    ЕСЛИ т > 0 И т <= sql.ВСЕГО ТО
      sql.ПЕРЕЙТИ(т)
      Id_Owner = sql.ПОЛЕ("ID")
      ЕСЛИ НЕ г_спрВладельцевРежимСпр ТО
        строка = sql.ПОЛЕ("FIO")
        УСТ_РЕД_ПОЛЕ("ID_OWNER", Id_Owner)
      КОНЕЦ_ЕСЛИ
    КОНЕЦ_ЕСЛИ
    sql.ЗАКРЫТЬ
    //сохранение
    ЕСЛИ логИзм ТО
      STG_СохранитьСпрВладельцев
      STG_ОбновитьСвязанныеСпр
      ЕСЛИ STG_ЗаписатьПарамСинхр ТО
        ЕСЛИ ВОПРОС("Синхронизировать изменения с сайтом?") ТО
          stg_списокСпрДляСинхр!1 = к_спрСайтаВладельцы
          STG_УпаковатьПарамСинхр
          //STG_СинхронизацияСайта
          ЕСЛИ НЕ г_блокСНТ ТО
            IB_FILE_СТАРТ_ПРОГ("__GSK_SITE_SYNC.IBX")
          ИНАЧЕ
            IB_FILE_СТАРТ_ПРОГ("__ST_SITE_SYNC.IBX")
          КОНЕЦ_ЕСЛИ
        КОНЕЦ_ЕСЛИ
      КОНЕЦ_ЕСЛИ
    КОНЕЦ_ЕСЛИ
  ИНАЧЕ
    sql.ЗАКРЫТЬ
  КОНЕЦ_ЕСЛИ
  
  STG_СправочникВладельцев = ДА
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ STG_ВремСпрВладельцев
  ЕСЛИ IB_FILE_ФайлУдалить(ф_tmp_СпрВладельцев) ТО
    СОЗДАТЬ(сп, ТИП_СПИСОК)
    сп.ДОБАВИТЬ("SELECT * FROM")
    сп.ДОБАВИТЬ("'" + ф_СпрВладельцев + "'")
    сп.ДОБАВИТЬ("ORDER BY FIO")
    sql = SQL_ЗАПРОС(сп)
    всегоЗап = sql.ВСЕГО
    sql.ЗАПИСАТЬ(ф_tmp_СпрВладельцев)
    sql.ЗАКРЫТЬ
    //
    /*сп.ОЧИСТИТЬ
    сп.ДОБАВИТЬ("ALTER TABLE")
    сп.ДОБАВИТЬ("'" + ф_tmp_СпрВладельцев + "'")
    сп.ДОБАВИТЬ("ADD EDITED BOOLEAN, ADD ADDED BOOLEAN")
    SQL_ЗАПРОС(сп)*/
  КОНЕЦ_ЕСЛИ
КОНЕЦ_ФУНКЦИИ

