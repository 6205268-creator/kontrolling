//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ STG_ЗапросУдалитьПоФлт(ТИП_СТРОКА: путьСпр)
  вр = ВРЕМЯ_ТЕК
  СОЗДАТЬ(сп, ТИП_СПИСОК)
  сп.ДОБАВИТЬ("SELECT ID_RECSITE, UUID FROM")
  сп.ДОБАВИТЬ("'" + путьСпр + "'")
  сп.ДОБАВИТЬ("WHERE ID_RECSITE > 0")
  ЕСЛИ г_колУчастков > 0 ТО
    сп.ДОБАВИТЬ("AND ID_AREA IN (")
    сп.STG_ARH_СчитатьАрхив(к_АрхивСпрУчастков, г_путьПрофиляСпрУчастков)
    сп.ДОБАВИТЬ(")")
  КОНЕЦ_ЕСЛИ
  sql = SQL_ЗАПРОС(сп)
  /*ОТЛАДКА(сп)
  БД_РЕДАКТОР(sql)*/
  Данные!ВсегоСтр!"C"++
  sql.STG_ЗаполнитьПеремНаУд(путьСпр)
  sql.ЗАКРЫТЬ
  rest_времяПолучения = ВРЕМЯ_ТЕК - вр
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ ТИП_SQL STG_ЗаполнитьПеремНаУд(ТИП_СТРОКА: путьСпр)
  ЦИКЛ ДЛЯ(и = 1, ВСЕГО)
    ПЕРЕЙТИ(и)
    ид = ПОЛЕ("ID_RECSITE")
    STG_УстПеремНаУд(путьСпр, СТР_ЗНАЧ(ид))
    STG_УстUUID(путьСпр, СТР_ЗНАЧ(ид), ПОЛЕ("UUID"))
  КОНЕЦ_ЦИКЛА
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ STG_УстПеремНаУд(ТИП_СТРОКА: путьСпр, ид)  
  ЕСЛИ г_запросНаСайт ТО
    ВЫБОР(путьСпр)
     #ф_СпрВладельцев : SPR_OWNERS_эл_id[ид] = ид
     #ф_СпрУчастковГаражей : SPR_OBJECTS_эл_id[ид] = ид
     #ф_СпрИндивСчетчики : SPR_SHETCH_эл_id[ид] = ид
     #ф_СпрФЛС : SPR_FLS_эл_id[ид] = ид
     #ф_Журнал : SPR_REGISTER_эл_id[ид] = ид
     #ф_СвязьВладУч : SPR_LINK_ALL_эл_id[ид] = ид
     #ф_ЖурналРасчетов : SPR_CALC_REG_эл_id[ид] = ид
     #ф_ЖурналСинхрОстатков: SPR_DEBTS_эл_id[ид] = ид
     #ф_Журнал: SPR_REGISTER_эл_id[ид] = ид
     #ф_ПоказанияИСВГ, ф_ПоказанияИСЭЭ : POK_SCH_эл_id[ид] = ид
     #mp_файлГолосований : MP_POLL_эл_id[ид] = ид
     #mp_файлВопросов : MP_QUESTION_эл_id[ид] = ид
     #mp_файлОтветов : MP_ANSWER_эл_id[ид] = ид
    КОНЕЦ_ВЫБОРА
  ИНАЧЕ
    ВЫБОР(путьСпр)
     #ф_СпрВладельцев : SPR_OWNERS_эл_уд[ид] = ид
     #ф_СпрУчастковГаражей : SPR_OBJECTS_эл_уд[ид] = ид
     #ф_СпрИндивСчетчики : SPR_SHETCH_эл_уд[ид] = ид
     #ф_СпрФЛС : SPR_FLS_эл_уд[ид] = ид
     #ф_Журнал : SPR_REGISTER_эл_уд[ид] = ид
     #ф_СвязьВладУч : SPR_LINK_ALL_эл_уд[ид] = ид
     #ф_ЖурналРасчетов : SPR_CALC_REG_эл_уд[ид] = ид
     #ф_ЖурналСинхрОстатков: SPR_DEBTS_эл_уд[ид] = ид
     #ф_Журнал: SPR_REGISTER_эл_уд[ид] = ид
     #ф_ПоказанияИСВГ, ф_ПоказанияИСЭЭ : POK_SCH_эл_уд[ид] = ид
     #mp_файлГолосований : MP_POLL_эл_уд[ид] = ид
     #mp_файлВопросов : MP_QUESTION_эл_уд[ид] = ид
     #mp_файлОтветов : MP_ANSWER_эл_уд[ид] = ид
    КОНЕЦ_ВЫБОРА
  КОНЕЦ_ЕСЛИ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ STG_УстUUID(ТИП_СТРОКА: путьСпр, ид, uuid)
  ЕСЛИ ДЛИНА(uuid) = 36 ТО 
    ВЫБОР(путьСпр)
     #ф_СпрВладельцев : SPR_OWNERS_эл_знач[ид + "|SPR_OWNERS_uuid"] = uuid
     #ф_СпрУчастковГаражей : SPR_OBJECTS_эл_знач[ид + "|SPR_OBJECTS_uuid"] = uuid
     #ф_СпрИндивСчетчики : SPR_SHETCH_эл_знач[ид + "|SPR_SHETCH_uuid"] = uuid
     #ф_СпрФЛС : SPR_FLS_эл_знач[ид + "|SPR_FLS_uuid"] = uuid
     #ф_Журнал : SPR_REGISTER_эл_знач[ид + "|SPR_REGISTER_uuid"] = uuid
     #ф_СвязьВладУч : SPR_LINK_ALL_эл_знач[ид + "|SPR_LINK_ALL_uuid"] = uuid
     #ф_ЖурналРасчетов : SPR_CALC_REG_эл_знач[ид + "|SPR_CALC_REG_uuid"] = uuid
     #ф_ЖурналСинхрОстатков: SPR_DEBTS_эл_знач[ид + "|SPR_DEBTS_uuid"] = uuid
     #ф_Журнал: SPR_REGISTER_эл_знач[ид + "|SPR_REGISTER_uuid"] = uuid
     #ф_ПоказанияИСВГ, ф_ПоказанияИСЭЭ : POK_SCH_эл_знач[ид + "|POK_SCH_uuid"] = uuid
     #mp_файлГолосований : MP_POLL_эл_знач[ид + "|MP_POLL_uuid"] = uuid
     #mp_файлВопросов : MP_QUESTION_эл_знач[ид + "|MP_QUESTION_uuid"] = uuid
     #mp_файлОтветов : MP_ANSWER_эл_знач[ид + "|MP_ANSWER_uuid"] = uuid
   КОНЕЦ_ВЫБОРА
 КОНЕЦ_ЕСЛИ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
//ПЕРЕМ г_администраторы!
ФУНКЦИЯ STG_УдалитьВладельцев //пока удаление с учетом ролей выпилил
  спр = "Справочник владельцев"
  rest_колЭлемПодЗапрУд = stg_профилиВыгрузкиСпр!спр!"_qty_del"
  
  СБРОС(SPR_OWNERS_эл_id, SPR_OWNERS_эл_уд, SPR_OWNERS_эл_знач, SPR_OWNERS_эл_изм, SPR_OWNERS_эл_счит, SPR_OWNERS_эл_доб)
  STG_ИниСтрокуОтчета("Справочник владельцев")
  
  ЕСЛИ IB_CONTEXT_СчитатьЛок("очиститьСайт") = "ДА" ТО
    SPR_OWNERS_ПолучитьСписок(ДА)
    СБРОС(SPR_OWNERS_эл_id, SPR_OWNERS_эл_уд)
    ЦИКЛ ИНДЕКС(знач = SPR_OWNERS_эл_счит!индекс)
      ЕСЛИ ПОЗ("SPR_OWNERS_id", индекс) > 0 ТО
        ЕСЛИ СУЩ_ПЕРЕМ(SPR_OWNERS_эл_знач!индекс) ТО
          ид = СТР_ФРАГ(индекс, "|", 1)
          ЕСЛИ НЕ СУЩ_ПЕРЕМ(SPR_OWNERS_эл_знач[ид+"|SPR_OWNERS_roles_meta"]) ТО
            STG_УстПеремНаУд(ф_СпрВладельцев, ид)
            Данные!ВсегоСтр!"C"++
          КОНЕЦ_ЕСЛИ
        КОНЕЦ_ЕСЛИ
      КОНЕЦ_ЕСЛИ
    КОНЕЦ_ЦИКЛА
  ИНАЧЕ
    вр = ВРЕМЯ_ТЕК
    СОЗДАТЬ(сп, ТИП_СПИСОК)
    сп.ДОБАВИТЬ("SELECT A.ID_RECSITE, A.UUID FROM")
    сп.ДОБАВИТЬ("'" + ф_СпрВладельцев + "' A")
    сп.ДОБАВИТЬ("RIGHT JOIN")
    сп.ДОБАВИТЬ("'" + ф_СвязьВладУч + "' B")
    сп.ДОБАВИТЬ("ON A.ID = B.ID_OWNER")
    сп.ДОБАВИТЬ("WHERE A.ID_RECSITE > 0")
    ЕСЛИ г_колУчастков > 0 ТО
      сп.ДОБАВИТЬ("AND B.ID_AREA IN (")
      сп.STG_ARH_СчитатьАрхив(к_АрхивСпрУчастков, г_путьПрофиляСпрУчастков)
      сп.ДОБАВИТЬ(")")
    КОНЕЦ_ЕСЛИ
    sql = SQL_ЗАПРОС(сп)
    //БД_РЕДАКТОР(sql)
    sql.STG_ЗаполнитьПеремНаУд(ф_СпрВладельцев)
    Данные!ВсегоСтр!"C" = sql.ВСЕГО
    sql.ЗАКРЫТЬ
    rest_времяПолучения = ВРЕМЯ_ТЕК - вр
  КОНЕЦ_ЕСЛИ
  
  ЕСЛИ г_запросНаСайт ТО
    ЕСЛИ stg_профилиВыгрузкиСпр!спр!"_prot_del" = "REST" ТО
      SPR_OWNERS_УдалитьМнож(stg_профилиВыгрузкиСпр!спр!"_subreq_del")
    ИНАЧЕ
      SPR_OWNERS_УдМножJSONAPI(stg_профилиВыгрузкиСпр!спр!"_subreq_del")
    КОНЕЦ_ЕСЛИ
    ЦИКЛ ИНДЕКС(лог = SPR_OWNERS_эл_уд!инд)
      ЕСЛИ лог ТО
        Данные!ВсегоСтр!"D"++
        Данные!ВсегоСтр!"E"++
      КОНЕЦ_ЕСЛИ
    КОНЕЦ_ЦИКЛА
  КОНЕЦ_ЕСЛИ
  STG_СбросПолейСинхрБД(ф_СпрВладельцев)
  //СБРОС(г_администраторы)
  Данные!ВсегоСтр!"F" = Данные!ВсегоСтр!"D" - Данные!ВсегоСтр!"E"
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ STG_УдалитьУчастки
  спр = "Справочник участков"
