    Данные!ВсегоСтр!"C" = КОЛ_ЭЛЕМ(REST_эл_id)
    
    ЕСЛИ stg_профилиВыгрузкиСпр!спр!"_prot_del" = "REST" ТО
      MP_RESULT_УдалитьМнож(stg_профилиВыгрузкиСпр!спр!"_subreq_del")
    ИНАЧЕ
