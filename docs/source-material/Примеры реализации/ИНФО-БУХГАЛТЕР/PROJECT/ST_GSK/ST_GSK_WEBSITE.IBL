//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ ТИП_SQL ТИП_ЛОГИКА: STG_ОбработатьОтвет(ТИП_СТРОКА: справочник)
  ВЫБОР(справочник)
   #к_спрСайтаВладельцы : РЕЗУЛЬТАТ = STG_СинхронизироватьВладельца("")
   #к_спрСайтаУчастки : РЕЗУЛЬТАТ = STG_СинхронизироватьУчасток("")
   #к_спрСайтаФЛС : РЕЗУЛЬТАТ = STG_СинхронизироватьФЛС("")
   #к_спрСайтаСвязи : РЕЗУЛЬТАТ = STG_СинхронизироватьСвязь("")
   #к_спрСайтаВзносы : РЕЗУЛЬТАТ = STG_СинхронизироватьВзнос("")
   #к_спрСайтаТарифы : РЕЗУЛЬТАТ = STG_СинхронизироватьТариф("")
   #к_спрСайтаИПУ : РЕЗУЛЬТАТ = STG_СинхронизироватьИПУ("")
   #к_спрСайтаПоказания : РЕЗУЛЬТАТ = STG_СинхронизироватьПоказания("")
   #к_спрСайтаЖурнал : РЕЗУЛЬТАТ = STG_СинхронизироватьЖурнал("")
   #к_спрСайтаРасчеты : РЕЗУЛЬТАТ = STG_СинхронизироватьРасчет("")
   #к_спрСайтаГолосования: РЕЗУЛЬТАТ = STG_СинхронизироватьГолос("")
                           ЕСЛИ РЕЗУЛЬТАТ ТО
                             РЕЗУЛЬТАТ = STG_ОбновитьLabelНаСайте(справочник, "POLL")
                           КОНЕЦ_ЕСЛИ
   #к_спрСайтаВопросы: РЕЗУЛЬТАТ = STG_СинхронизироватьВопросы("")
                       ЕСЛИ РЕЗУЛЬТАТ ТО
                         РЕЗУЛЬТАТ = STG_ОбновитьLabelНаСайте(справочник, "QUESTION")
                       КОНЕЦ_ЕСЛИ
   #к_спрСайтаОтветы: РЕЗУЛЬТАТ = STG_СинхронизироватьОтветы("")
                      ЕСЛИ РЕЗУЛЬТАТ ТО
                        РЕЗУЛЬТАТ = STG_ОбновитьLabelНаСайте(справочник, "ANSWER")
                      КОНЕЦ_ЕСЛИ
  ИНАЧЕ
    РЕЗУЛЬТАТ = НЕТ
  КОНЕЦ_ВЫБОРА
  STG_ОбработатьОтвет = РЕЗУЛЬТАТ
КОНЕЦ_ФУНКЦИИ

ФУНКЦИЯ ТИП_SQL ТИП_ЛОГИКА: STG_ОбновитьLabelНаСайте(ТИП_СТРОКА: справочник, имя)
  инд = СТР_ЗНАЧ(ПОЛЕ("ID_RECSITE"))
  STG_СбросИндексов(справочник)
  STG_ДобЗначLabelНаСайте(инд, справочник, имя)
  STG_ОбновитьLabelНаСайте = STG_ИзменитьНаСайте(справочник)
КОНЕЦ_ФУНКЦИИ

ФУНКЦИЯ ТИП_SQL STG_ДобЗначLabelНаСайте(ТИП_СТРОКА: инд, справочник, имя)
  STG_ДобавитьЭлИд(справочник, инд)
  ДобавитьЗначениеС(справочник, 
                    инд + "|MP_" + имя + "_uuid", 
                    ПОЛЕ("UUID"))
  ДобавитьЗначениеС(справочник, инд + "|MP_" + имя + "_label", ПОЛЕ("label"))
  ДобавитьЗначениеС(справочник, инд + "|MP_" + имя + "_type", "multipoll_" + ПРОП(имя) + "--multipoll_" + ПРОП(имя))
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ STG_СбросИндексов(ТИП_СТРОКА: справочник)
  ВЫБОР(справочник)
   #к_спрСайтаВладельцы : СБРОС(SPR_OWNERS_эл_доб, SPR_OWNERS_эл_счит, SPR_OWNERS_эл_знач, SPR_OWNERS_эл_изм)
   #к_спрСайтаУчастки : СБРОС(SPR_OBJECTS_эл_доб, SPR_OBJECTS_эл_id, SPR_OBJECTS_эл_счит, SPR_OBJECTS_эл_знач, SPR_OBJECTS_эл_изм)
   #к_спрСайтаФЛС : СБРОС(SPR_FLS_эл_доб, SPR_FLS_эл_счит, SPR_FLS_эл_знач, SPR_FLS_эл_изм)
   #к_спрСайтаСвязи : СБРОС(SPR_LINK_ALL_эл_доб, SPR_LINK_ALL_эл_счит, SPR_LINK_ALL_эл_знач, SPR_LINK_ALL_эл_изм)
   #к_спрСайтаВзносы : СБРОС(SPR_VZNOSI_эл_доб, SPR_VZNOSI_эл_счит, SPR_VZNOSI_эл_знач, SPR_VZNOSI_эл_изм)
   #к_спрСайтаТарифы : СБРОС(SPR_TARIF_эл_доб, SPR_TARIF_эл_счит, SPR_TARIF_эл_знач, SPR_TARIF_эл_изм)
   #к_спрСайтаИПУ : СБРОС(SPR_SHETCH_эл_доб, SPR_SHETCH_эл_счит, SPR_SHETCH_эл_знач, SPR_SHETCH_эл_изм)
   #к_спрСайтаПоказания : СБРОС(POK_SCH_эл_доб, POK_SCH_эл_счит, POK_SCH_эл_знач, POK_SCH_эл_изм)
   #к_спрСайтаЖурнал : СБРОС(SPR_REGISTER_эл_доб, SPR_REGISTER_эл_счит, SPR_REGISTER_эл_знач, SPR_REGISTER_эл_изм)
   #к_спрСайтаРасчеты : СБРОС(SPR_CALC_REG_эл_доб, SPR_CALC_REG_эл_счит, SPR_CALC_REG_эл_знач, SPR_CALC_REG_эл_изм)
   #к_спрСайтаГолосования: СБРОС(MP_POLL_эл_доб, MP_POLL_эл_счит, MP_POLL_эл_знач, MP_POLL_эл_изм)
   #к_спрСайтаВопросы: СБРОС(MP_QUESTION_эл_доб, MP_QUESTION_эл_счит, MP_QUESTION_эл_знач, MP_QUESTION_эл_изм)
   #к_спрСайтаОтветы: СБРОС(MP_ANSWER_эл_доб, MP_ANSWER_эл_счит, MP_ANSWER_эл_знач, MP_ANSWER_эл_изм)
 КОНЕЦ_ВЫБОРА
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ STG_ИниСтрокуОтчета(ТИП_СТРОКА: описание)
  ВсегоСтр++
  Данные!ВсегоСтр!"A" = ВсегоСтр
  Данные!ВсегоСтр!"B" = описание
  Данные!ВсегоСтр!"C" = 0  //запланировано
  Данные!ВсегоСтр!"D" = 0  //выгружено
  Данные!ВсегоСтр!"E" = 0  //синхронизировано
  Данные!ВсегоСтр!"F" = 0  //не синхронизировано на сайте
  Данные!ВсегоСтр!"G" = 0  //не синхронизировано в базе
  Данные!ВсегоСтр!"H" = 00:00:00  //Время выполнения
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
//ПЕРЕМ stg_ожидаемыеОбъемы!
//ПЕРЕМ stg_идИПУпоИДПок!
//ПЕРЕМ stg_идИПУ!

ФУНКЦИЯ STG_ПолучитьССайта
  ЕСЛИ НЕ СУЩ_ПЕРЕМ(оп_испСписокАтр) ТО
    оп_испСписокАтр = НЕТ
  КОНЕЦ_ЕСЛИ
  
  REST_испСписокАтр = оп_испСписокАтр
  СТРОКА_СТАТУСА("Получение показаний ИПУ")
  УСТ_АТРИБУТ(к_атрПолучитьТолькоНесинхр, "ДА")
  POK_SCH_ПолучитьСписок(НЕТ)
  //ОТЛАДКА(&POK_SCH_эл_знач)
  УСТ_АТРИБУТ(к_атрПолучитьТолькоНесинхр, "")
  ЕСЛИ КОЛ_ЭЛЕМ(POK_SCH_эл_id) = 0 ТО
    СООБЩЕНИЕ("Нет объектов для импорта.")
    ВЫХОД
  КОНЕЦ_ЕСЛИ
  //ВЫХОД
  //
  СТРОКА_СТАТУСА("Импорт показаний ИПУ")
  СтатусСоздать("Импорт показаний ИПУ")
  СтатусСтартПрогресс(КОЛ_ЭЛЕМ(POK_SCH_эл_id))
  //
  СОЗДАТЬ(сп, ТИП_СПИСОК)
  //
  СБРОС(stg_ожидаемыеОбъемы, stg_идИПУпоИДПок, г_парамИПУ, г_начПоказания)
  sql_el = SQL_ОТКРЫТЬ(ф_ПоказанияИСЭЭ)
  sql_wg = SQL_ОТКРЫТЬ(ф_ПоказанияИСВГ)
  ЦИКЛ ИНДЕКС(лог = POK_SCH_эл_id!идЭлемента)
    POK_SCH_Упаковать(идЭлемента)
    stg_идИПУ!POK_SCH_id_ipu = ДА
    uuid!идЭлемента = POK_SCH_uuid
    
    STG_ПрокачкаСтатуса("Импорт показаний ИПУ")
    ЕСЛИ НЕ sql_el.STG_ИмпортПоказаний(идЭлемента, ДА) ТО
      sql_wg.STG_ИмпортПоказаний(идЭлемента, НЕТ)
    КОНЕЦ_ЕСЛИ
  КОНЕЦ_ЦИКЛА
  sql_el.ЗАКРЫТЬ
  sql_wg.ЗАКРЫТЬ
  СтатусЗакрыть
  //ВЫХОД
  //расчет объемов
  СТРОКА_СТАТУСА("Расчёт объёмов")
  колЭлем = КОЛ_ЭЛЕМ(stg_идИПУ)
  
  файлПок!1 = ф_ПоказанияИСЭЭ
  файлПок!2 = ф_ПоказанияИСВГ
  
  //цикл по ИПУ
  STG_ФормСписокОбСинхр(к_спрСайтаИмпортПок, колЭлем)
  начСтр = 1
  СтатусСоздать("Считывание начальных показаний")
  сп.ОЧИСТИТЬ
  сп.ДОБАВИТЬ("SELECT ID, NPOK1, NPOK2, NPOK3, TYPE, CODS FROM")
  сп.ДОБАВИТЬ("'" + ф_СпрИндивСчетчики + "'")
  сп.ДОБАВИТЬ("WHERE ID IN (")
  сп.ЗаполнитьСписокЭлементов(2500, 500, начСтр)
  сп.ДОБАВИТЬ(")")
  sql = SQL_ЗАПРОС(сп)
  СтатусСтартПрогресс(sql.ВСЕГО)
  ЦИКЛ ДЛЯ(и = 1, sql.ВСЕГО)
    sql.ПЕРЕЙТИ(и)
    STG_ПрокачкаСтатуса("Считывание начальных показаний")
    идИПУ = sql.ПОЛЕ("ID")
    г_парамИПУ!идИПУ!"//тип" = sql.ПОЛЕ("TYPE")
    г_парамИПУ!идИПУ!"//кодУл" = sql.ПОЛЕ("CODS")
    г_начПоказания!идИПУ!"//Т1" = sql.ПОЛЕ("NPOK1")
    г_начПоказания!идИПУ!"//Т2" = sql.ПОЛЕ("NPOK2")
    г_начПоказания!идИПУ!"//Т3" = sql.ПОЛЕ("NPOK3")
  КОНЕЦ_ЦИКЛА
  sql.ЗАКРЫТЬ
  СтатусЗакрыть

  СТРОКА_СТАТУСА("Расчёт объёмов")
  ЦИКЛ ДЛЯ(и = 1, 2)
    начСтр = 1
    IB_FILE_ФайлУдалить(ф_tmp020)
    IB_DBF_СоздТаблПоТабл(ф_tmp020, файлПок!и)
    
    сп.ОЧИСТИТЬ
    сп.ДОБАВИТЬ("INSERT INTO")
    сп.ДОБАВИТЬ("'" + ф_tmp020 + "'")
    сп.ДОБАВИТЬ("SELECT * FROM")
    сп.ДОБАВИТЬ("'" + файлПок!и + "'")
    сп.ДОБАВИТЬ("WHERE ID_SCH IN (")
    сп.ЗаполнитьСписокЭлементов(2500, 500, начСтр)
    сп.ДОБАВИТЬ(")")
    SQL_ЗАПРОС(сп)
    
    ЕСЛИ IB_DBF_ВсегоЗап(ф_tmp020) > 0 ТО
      STG_ОбновитьОбъемыИПУ(ф_tmp020)
      
      сп.ОЧИСТИТЬ
      сп.ДОБАВИТЬ("DELETE FROM")
      сп.ДОБАВИТЬ("'" + файлПок!и + "'")
      сп.ДОБАВИТЬ("WHERE ID_SCH IN (SELECT ID_SCH FROM")
      сп.ДОБАВИТЬ("'" + ф_tmp020 + "')")
      SQL_ЗАПРОС(сп)
      
      сп.ОЧИСТИТЬ
      сп.ДОБАВИТЬ("INSERT INTO")
      сп.ДОБАВИТЬ("'" + файлПок!и + "'")
      сп.ДОБАВИТЬ("SELECT * FROM")
      сп.ДОБАВИТЬ("'" + ф_tmp020 + "'")
      SQL_ЗАПРОС(сп)
      
      IB_DBF_ДобавитьНаУпаковку(файлПок!и)
    КОНЕЦ_ЕСЛИ
  КОНЕЦ_ЦИКЛА
  
  СБРОС(POK_SCH_эл_знач, POK_SCH_эл_изм, г_парамИПУ, г_начПоказания) //заполним объемами
  //
  СТРОКА_СТАТУСА("Синхронизация показаний ИПУ")
  спр = "readings"
  ЦИКЛ ИНДЕКС(лог = POK_SCH_эл_id!идЭлемента)
    инд = stg_идИПУпоИДПок!идЭлемента
    
    POK_SCH_эл_знач[идЭлемента + "|POK_SCH_uuid"] = uuid!идЭлемента
    
    STG_ДобавитьЭлИд(к_спрСайтаПоказания, идЭлемента)
    ДобавитьЗначениеС(спр, идЭлемента + "|POK_SCH_type", "pok_sch--pok_sch")
    ДобавитьЗначениеЧ(спр, идЭлемента + "|POK_SCH_t1_vol", stg_ожидаемыеОбъемы!инд!"|t1_vol")
    ДобавитьЗначениеЧ(спр, идЭлемента + "|POK_SCH_t2_vol", stg_ожидаемыеОбъемы!инд!"|t2_vol")
    ДобавитьЗначениеЧ(спр, идЭлемента + "|POK_SCH_t3_vol", stg_ожидаемыеОбъемы!инд!"|t3_vol")
    ДобавитьЗначениеЛ(спр, идЭлемента + "|POK_SCH_is_synced", ДА)
  КОНЕЦ_ЦИКЛА
  
  ЕСЛИ НЕ СУЩ_ПЕРЕМ(оп_подзапрСинхронизация) ТО
    оп_подзапрСинхронизация = г_использоватьПоздапросы
  КОНЕЦ_ЕСЛИ
  
  POK_SCH_ИзменитьМнож(оп_подзапрСинхронизация)
  
  СТРОКА_СТАТУСА("")
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ ТИП_SQL STG_ИмпортПоказаний(ТИП_СТРОКА: id; ТИП_ЛОГИКА: файлЭЭ)
  поз = НАЙТИ_ПОЗ("id_sch", POK_SCH_id_ipu, 
                  "dat", POK_SCH_dat)
  /*ОТЛАДКА("---------")
  ОТЛАДКА(POK_SCH_id_ipu)
  ОТЛАДКА(POK_SCH_dat)
  ОТЛАДКА(поз)*/
//  ВЫХОД
  ЕСЛИ поз > 0 ТО //если есть, то надо синхронизировать
    ПЕРЕЙТИ(поз)
    ЕСЛИ POK_SCH_эл_счит[id + "|POK_SCH_is_synced"] ТО
      ЗАП_ПОЛЕ("IS_SYNCED", ДА)
    КОНЕЦ_ЕСЛИ
    ЕСЛИ POK_SCH_эл_счит[id + "|POK_SCH_id"] ТО
      ЗАП_ПОЛЕ("ID_RECSITE", POK_SCH_id)
    КОНЕЦ_ЕСЛИ
    ЗАМЕНИТЬ
  ИНАЧЕ //если нет, то надо добавить
    ЕСЛИ POK_SCH_эл_счит[id + "|POK_SCH_id_area"] ТО
      ЗАП_ПОЛЕ("id_area", POK_SCH_id_area)
    КОНЕЦ_ЕСЛИ
    ЕСЛИ POK_SCH_эл_счит[id + "|POK_SCH_id_ipu"] ТО
      ЗАП_ПОЛЕ("ID_SCH", POK_SCH_id_ipu)
    КОНЕЦ_ЕСЛИ
    ЕСЛИ POK_SCH_эл_счит[id + "|POK_SCH_dat"] ТО
      ЗАП_ПОЛЕ("dat", POK_SCH_dat)
    КОНЕЦ_ЕСЛИ
    ЕСЛИ POK_SCH_эл_счит[id + "|POK_SCH_num1"] ТО
      ЗАП_ПОЛЕ("num1", POK_SCH_num1)
    КОНЕЦ_ЕСЛИ
    ЕСЛИ файлЭЭ ТО
      ЕСЛИ POK_SCH_эл_счит[id + "|POK_SCH_num2"] ТО
        ЗАП_ПОЛЕ("num2", POK_SCH_num2)
      КОНЕЦ_ЕСЛИ
      ЕСЛИ POK_SCH_эл_счит[id + "|POK_SCH_num3"] ТО
        ЗАП_ПОЛЕ("num3", POK_SCH_num3)
      КОНЕЦ_ЕСЛИ
      ЕСЛИ POK_SCH_эл_счит[id + "|POK_SCH_p1"] ТО
        ЗАП_ПОЛЕ("p1", POK_SCH_p1)
      КОНЕЦ_ЕСЛИ
      ЕСЛИ POK_SCH_эл_счит[id + "|POK_SCH_p2"] ТО
        ЗАП_ПОЛЕ("p2", POK_SCH_p2)
      КОНЕЦ_ЕСЛИ
      ЕСЛИ POK_SCH_эл_счит[id + "|POK_SCH_p3"] ТО
        ЗАП_ПОЛЕ("p3", POK_SCH_p3)
      КОНЕЦ_ЕСЛИ
      ЕСЛИ POK_SCH_эл_счит[id + "|POK_SCH_p"] ТО
        ЗАП_ПОЛЕ("p", POK_SCH_p)
      КОНЕЦ_ЕСЛИ
    КОНЕЦ_ЕСЛИ
    ЕСЛИ POK_SCH_эл_счит[id + "|POK_SCH_corr"] ТО
      ЗАП_ПОЛЕ("corr", POK_SCH_corr)
    КОНЕЦ_ЕСЛИ
    ЕСЛИ POK_SCH_эл_счит[id + "|POK_SCH_comm"] ТО
      ЗАП_ПОЛЕ("comm", POK_SCH_comm)
    КОНЕЦ_ЕСЛИ
    ЕСЛИ POK_SCH_эл_счит[id + "|POK_SCH_is_synced"] ТО
      ЗАП_ПОЛЕ("is_synced", ДА)
    КОНЕЦ_ЕСЛИ
    ЕСЛИ POK_SCH_эл_счит[id + "|POK_SCH_id"] ТО
      ЗАП_ПОЛЕ("ID_RECSITE", POK_SCH_id)
    КОНЕЦ_ЕСЛИ
    ЕСЛИ POK_SCH_эл_счит[id + "|POK_SCH_uuid"] ТО
      ЗАП_ПОЛЕ("UUID", POK_SCH_uuid)
    КОНЕЦ_ЕСЛИ
    ДОБАВИТЬ
  КОНЕЦ_ЕСЛИ
    
  stg_идИПУпоИДПок!id = СТР_ЗНАЧ(POK_SCH_id_ipu) + "|" + СТР(POK_SCH_dat)
  инд = stg_идИПУпоИДПок!id
  stg_ожидаемыеОбъемы!инд!"|t1_vol" = 0
  stg_ожидаемыеОбъемы!инд!"|t2_vol" = 0
  stg_ожидаемыеОбъемы!инд!"|t3_vol" = 0
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ STG_РазослатьПароли
  СОЗДАТЬ(сп, ТИП_СПИСОК)
  сп.ДОБАВИТЬ("SELECT CAST('V' AS CHAR(1)) AS SLCTR, A.ID, A.FIO, A.EMAIL, A.ID_RECSITE, A.LOGIN, A.PASSW, A.IS_SYNCED, C.N_AREA, C.SRT FROM")
  сп.ДОБАВИТЬ("'" + ф_СпрВладельцев + "' A")
  сп.ДОБАВИТЬ("INNER JOIN")
  сп.ДОБАВИТЬ("'" + ф_СвязьВладУч + "' B ON A.ID = B.ID_OWNER ")
  сп.ДОБАВИТЬ("INNER JOIN")
  сп.ДОБАВИТЬ("'" + ф_СпрУчастковГаражей + "' C")
  сп.ДОБАВИТЬ("ON B.ID_AREA = C.ID_AREA WHERE A.EMAIL <> '' AND A.LOGIN <> '' AND A.PASSW <> ''")
  ЕСЛИ г_колУчастков > 0 ТО
    сп.ДОБАВИТЬ("AND B.ID_AREA IN (")
    сп.STG_ARH_СчитатьАрхив(к_АрхивСпрУчастков, г_путьПрофиляСпрУчастков)
    сп.ДОБАВИТЬ(")")
  КОНЕЦ_ЕСЛИ
  сп.ДОБАВИТЬ("ORDER BY C.SRT")
  
  sql = SQL_ЗАПРОС(сп)
  
  врем_таб_создана = НЕТ
  ЦИКЛ ДЛЯ (и = 1, 1000)
    путьВремТабл = иб_путь_врем_сет + "temp_multisel_" + СТР_ЗНАЧ(и) + ".dbf"
    ЕСЛИ НЕ СУЩ_ФАЙЛ(путьВремТабл) ТО
      sql.ЗАПИСАТЬ(путьВремТабл)
      врем_таб_создана = ДА
      СТОП
    КОНЕЦ_ЕСЛИ
  КОНЕЦ_ЦИКЛА
  sql.ЗАКРЫТЬ
  //
  ЕСЛИ врем_таб_создана ТО
    sql = SQL_ОТКРЫТЬ(путьВремТабл)
  ИНАЧЕ
    СООБЩЕНИЕ("Не удалось создать временную таблицу.")
    ВЫХОД
  КОНЕЦ_ЕСЛИ
  
  т = БД_РЕДАКТОР(sql, "Список получателей", 
                [%"SLCTR" : "" : 2,
                 %"N_AREA" : "Участок" : 10,
                 %"FIO" : "Ф.И.О." : 35,
                 "EMAIL" : "E-Mail" : 20,
                 %"ID_RECSITE" : "ID сайта": 10,
                 %"IS_SYNCED" : "Синхр." : 10
                 ], ДА, НЕТ, НЕТ, ДА,
                 [В: ("IB_DLG.IBL", "IB_DLG_ПереклПоляВыбора"),
                  Ж: ("IB_DLG.IBL", "IB_DLG_МножУстПоляВыбора")];
                 перекл_выбора = ДА;
                 @путь_файла = путьВремТабл;
                 @поле_выбора = "SLCTR")
  
  ЕСЛИ sql.ВСЕГО > 0 ТО
    ЦИКЛ ДЛЯ(и = 1, sql.ВСЕГО)
      sql.ПЕРЕЙТИ(и)
      текст = "Участок №" + sql.ПОЛЕ("N_AREA") + СИМВ(13) +
              "Логин: " + sql.ПОЛЕ("LOGIN") + СИМВ(13) + 
              "Пароль:" + sql.ПОЛЕ("PASSW")
      IB_MAIL_AddToDispatchList(sql.ПОЛЕ("FIO"),
                                sql.ПОЛЕ("EMAIL"),
                                "Данные аутентификации",
                                текст, "")
    КОНЕЦ_ЦИКЛА
    IB_MAIL_ОтправитьПочту
    IB_PROTOCOL_ОбработатьИВывестиОшибки
  ИНАЧЕ
    СООБЩЕНИЕ("Не обнаружены владельцы с указанным фильтром.")
  КОНЕЦ_ЕСЛИ
  sql.ЗАКРЫТЬ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ПЕРЕМ ТИП_ВРЕМЯ: stg_времяАнализа
ФУНКЦИЯ STG_Анализ
  REST_испСписокАтр = оп_испСписокАтр
  СБРОС_ТАБЛИЦ(ДА)
  STG_ПарамВыводаТаблиц
  НачСтр = 55
  ВыводИт = ДА
  
  ЦИКЛ ДЛЯ(и = 3, 11)
    Итоги!ЛИТЕР(и) = ДА
  КОНЕЦ_ЦИКЛА
  
  TBLPRINT_ДобавитьСтолбец(6, "№", 0)
  TBLPRINT_ДобавитьСтолбец(30, "Справочник", 0)
  TBLPRINT_ДобавитьСтолбец(15, "Всего на сайте", 0)
  TBLPRINT_ДобавитьСтолбец(15, "Всего в базе", 0)
  TBLPRINT_ДобавитьСтолбец(15, "Синхронизировано", 0)
  TBLPRINT_ДобавитьСтолбец(15, "Не синхронизировано на сайте", 0)
  TBLPRINT_ДобавитьСтолбец(15, "Не синхронизировано в базе", 0)
  пред = TBLPRINT_ДобавитьСтолбец(15, "Время выполнения", 0)
  ЕСЛИ оп_времяПодробно ТО
    TBLPRINT_ДобавитьСтолбец(15, "Получение с сайта", пред)
    TBLPRINT_ДобавитьСтолбец(15, "Анализ БД", пред)
    TBLPRINT_ДобавитьСтолбец(15, "Остальное", пред)
  КОНЕЦ_ЕСЛИ
  
  ЕСЛИ оп_справочникВлад ТО
    вр = ВРЕМЯ_ТЕК
    STG_АнализВладельцев
    STG_ЗаполнитьСтлбВремениАн(вр)
  КОНЕЦ_ЕСЛИ
  
  ЕСЛИ оп_справочникУч ТО
    вр = ВРЕМЯ_ТЕК
    STG_АнализУчастки
    STG_ЗаполнитьСтлбВремениАн(вр)
  КОНЕЦ_ЕСЛИ
  
  ЕСЛИ оп_справочникСвязи ТО
    вр = ВРЕМЯ_ТЕК
    STG_АнализСвязи
    STG_ЗаполнитьСтлбВремениАн(вр)
  КОНЕЦ_ЕСЛИ
  
  ЕСЛИ оп_справочникФЛС ТО
    вр = ВРЕМЯ_ТЕК
    STG_АнализФЛС
    STG_ЗаполнитьСтлбВремениАн(вр)
  КОНЕЦ_ЕСЛИ
  
  ЕСЛИ оп_справочникВзносы ТО
    вр = ВРЕМЯ_ТЕК
    STG_АнализВзносы
    STG_ЗаполнитьСтлбВремениАн(вр)
  КОНЕЦ_ЕСЛИ
  
  ЕСЛИ оп_справочникТарифы ТО
    вр = ВРЕМЯ_ТЕК
    STG_АнализТарифы
    STG_ЗаполнитьСтлбВремениАн(вр)
  КОНЕЦ_ЕСЛИ
  
  ЕСЛИ оп_справочникИПУ ТО
    вр = ВРЕМЯ_ТЕК
    STG_АнализИПУ
    STG_ЗаполнитьСтлбВремениАн(вр)
  КОНЕЦ_ЕСЛИ
  
  ЕСЛИ оп_журналПок ТО
    вр = ВРЕМЯ_ТЕК
    STG_АнализПоказания
    STG_ЗаполнитьСтлбВремениАн(вр)
  КОНЕЦ_ЕСЛИ
  
  ЕСЛИ оп_журнал ТО
    вр = ВРЕМЯ_ТЕК
    STG_АнализЖурнал
    STG_ЗаполнитьСтлбВремениАн(вр)
  КОНЕЦ_ЕСЛИ
  
  ЕСЛИ оп_журналРасчетов ТО
    вр = ВРЕМЯ_ТЕК
    STG_АнализРасчеты
    STG_ЗаполнитьСтлбВремениАн(вр)
  КОНЕЦ_ЕСЛИ
  
  ЕСЛИ оп_журналОстатков ТО
    вр = ВРЕМЯ_ТЕК
    STG_АнализОстатки
    STG_ЗаполнитьСтлбВремениАн(вр)
  КОНЕЦ_ЕСЛИ
  
  ЕСЛИ оп_справочникРекв ТО
    вр = ВРЕМЯ_ТЕК
    STG_АнализРеквизиты
    STG_ЗаполнитьСтлбВремениАн(вр)
  КОНЕЦ_ЕСЛИ
  
  ЕСЛИ оп_настройки ТО
    вр = ВРЕМЯ_ТЕК
    STG_АнализНастройки
    STG_ЗаполнитьСтлбВремениАн(вр)
  КОНЕЦ_ЕСЛИ
  
  ЕСЛИ оп_голосования ТО
    вр = ВРЕМЯ_ТЕК
    STG_АнализГолосования
    STG_ЗаполнитьСтлбВремениАн(вр)
    
    вр = ВРЕМЯ_ТЕК
    STG_АнализВопросы
    STG_ЗаполнитьСтлбВремениАн(вр)
    
    вр = ВРЕМЯ_ТЕК
    STG_АнализОтветы
    STG_ЗаполнитьСтлбВремениАн(вр)
    
    вр = ВРЕМЯ_ТЕК
    STG_АнализРезультаты
    STG_ЗаполнитьСтлбВремениАн(вр)
  КОНЕЦ_ЕСЛИ
  
  ЕСЛИ ВсегоСтр > 0 ТО
    ПЕЧАТЬ_ШАПКИ
    ПЕЧАТЬ_ТАБЛИЦЫ
  КОНЕЦ_ЕСЛИ
  СБРОС_ТАБЛИЦ(ДА)
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ STG_АнализБазы(ТИП_СТРОКА: файл)
  вр = ВРЕМЯ_ТЕК
  СОЗДАТЬ(сп, ТИП_СПИСОК)
  сп.ДОБАВИТЬ("SELECT COUNT(IS_SYNCED) AS C_RES FROM")
  сп.ДОБАВИТЬ("'" + файл + "'")
  сп.ДОБАВИТЬ("WHERE IS_SYNCED = TRUE")
  ВЫБОР(файл)
   #ф_Журнал: 
    сп.ДОБАВИТЬ("AND DAT BETWEEN '" + СТР(гр_датаОпераций) + "' AND '" + СТР(гр_датаОперацийПо) + "'")
    сп.ДОБАВИТЬ("AND (ADD_SUM <> 0 OR PAY_SUM <> 0)")
    сп.ДОБАВИТЬ("AND ID_AREA IN (SELECT ID_AREA FROM")
    сп.ДОБАВИТЬ("'" + ф_СпрУчастковГаражей + "')")
   #ф_ЖурналРасчетов: 
    сп.ДОБАВИТЬ("AND ID_CALC IN (SELECT ID_CALC FROM")
    сп.ДОБАВИТЬ("'" + ф_Журнал + "'")
    сп.ДОБАВИТЬ("WHERE DAT BETWEEN '" + СТР(гр_датаОпераций) + "' AND '" + СТР(гр_датаОперацийПо) + "')")
  КОНЕЦ_ВЫБОРА
  
  сп.ДОБАВИТЬ("UNION ALL")
  
  сп.ДОБАВИТЬ("SELECT COUNT(IS_SYNCED) AS C_RES FROM")
  сп.ДОБАВИТЬ("'" + файл + "'")
  сп.ДОБАВИТЬ("WHERE (IS_SYNCED = FALSE OR IS_SYNCED IS NULL)")
  ВЫБОР(файл)
   #ф_Журнал: 
    сп.ДОБАВИТЬ("AND DAT BETWEEN '" + СТР(гр_датаОпераций) + "' AND '" + СТР(гр_датаОперацийПо) + "'")
    сп.ДОБАВИТЬ("AND (ADD_SUM <> 0 OR PAY_SUM <> 0)")
    сп.ДОБАВИТЬ("AND ID_AREA IN (SELECT ID_AREA FROM")
    сп.ДОБАВИТЬ("'" + ф_СпрУчастковГаражей + "')")
   #ф_ЖурналРасчетов: 
    сп.ДОБАВИТЬ("AND ID_CALC IN (SELECT ID_CALC FROM")
    сп.ДОБАВИТЬ("'" + ф_Журнал + "'")
    сп.ДОБАВИТЬ("WHERE DAT BETWEEN '" + СТР(гр_датаОпераций) + "' AND '" + СТР(гр_датаОперацийПо) + "')")
  КОНЕЦ_ВЫБОРА
  
  sql = SQL_ЗАПРОС(сп)
  ЕСЛИ sql.ВСЕГО > 0 ТО
    sql.ПЕРЕЙТИ(1)
    Данные!ВсегоСтр!"D" = Данные!ВсегоСтр!"D" + sql.ПОЛЕ("C_RES")
    sql.ПЕРЕЙТИ(2)
    Данные!ВсегоСтр!"D" = Данные!ВсегоСтр!"D" + sql.ПОЛЕ("C_RES")
    Данные!ВсегоСтр!"G" = Данные!ВсегоСтр!"G" + sql.ПОЛЕ("C_RES")
  КОНЕЦ_ЕСЛИ
  
  ЕСЛИ Данные!ВсегоСтр!"G" <> Данные!ВсегоСтр!"F" ТО
    ЖирСтр!ВсегоСтр = ДА
  КОНЕЦ_ЕСЛИ
  stg_времяАнализа = stg_времяАнализа + ВРЕМЯ_ТЕК - вр 
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ STG_ЗаполнитьСтлбВремени(ТИП_ВРЕМЯ: вр)
  ЕСЛИ оп_времяПодробно ТО
    Данные!ВсегоСтр!"H" = rest_времяФормирования
    Данные!ВсегоСтр!"I" = rest_времяОтправки
    Данные!ВсегоСтр!"J" = rest_времяРазбора
    Данные!ВсегоСтр!"K" = ВРЕМЯ_ТЕК - вр - rest_времяРазбора - rest_времяФормирования - rest_времяОтправки
  ИНАЧЕ
    Данные!ВсегоСтр!"H" = ВРЕМЯ_ТЕК - вр
  КОНЕЦ_ЕСЛИ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ STG_ЗаполнитьСтлбВремениУд(ТИП_ВРЕМЯ: вр)
  ЕСЛИ оп_времяПодробно ТО
    Данные!ВсегоСтр!"H" = rest_времяПолучения
    Данные!ВсегоСтр!"I" = rest_времяФормирования
    Данные!ВсегоСтр!"J" = rest_времяОтправки
    Данные!ВсегоСтр!"K" = ВРЕМЯ_ТЕК - вр - rest_времяПолучения - rest_времяФормирования - rest_времяОтправки
  ИНАЧЕ
    Данные!ВсегоСтр!"H" = ВРЕМЯ_ТЕК - вр
  КОНЕЦ_ЕСЛИ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ STG_ЗаполнитьСтлбВремениАн(ТИП_ВРЕМЯ: вр)
  ЕСЛИ оп_времяПодробно ТО
    Данные!ВсегоСтр!"H" = rest_времяПолучения
    Данные!ВсегоСтр!"I" = stg_времяАнализа
    Данные!ВсегоСтр!"J" = ВРЕМЯ_ТЕК - вр - rest_времяПолучения - stg_времяАнализа
    stg_времяАнализа = 00:00:00
  ИНАЧЕ
    Данные!ВсегоСтр!"H" = ВРЕМЯ_ТЕК - вр
  КОНЕЦ_ЕСЛИ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ STG_АнализВладельцев
  СБРОС(SPR_OWNERS_эл_id, SPR_OWNERS_эл_уд, REST_эл_id)
  STG_ИниСтрокуОтчета("Справочник владельцев")
  
  SPR_OWNERS_ПолучитьСписок(ДА)
  
  Данные!ВсегоСтр!"C" = КОЛ_ЭЛЕМ(REST_эл_id)
  ЦИКЛ ИНДЕКС(знач = REST_эл_id!инд)
    ЕСЛИ SPR_OWNERS_УпаковатьПолеЛ(инд, "SPR_OWNERS_field_is_synced") ТО
      Данные!ВсегоСтр!"E"++
    ИНАЧЕ
      Данные!ВсегоСтр!"F"++
    КОНЕЦ_ЕСЛИ
  КОНЕЦ_ЦИКЛА
  
  СОЗДАТЬ(сп, ТИП_СПИСОК)
  сп.ДОБАВИТЬ("UPDATE")
  сп.ДОБАВИТЬ("'" + ф_СпрВладельцев + "'")
  сп.ДОБАВИТЬ("SET IS_SYNCED = FALSE WHERE IS_SYNCED <> TRUE")
  SQL_ЗАПРОС(сп)
  
  сп.ОЧИСТИТЬ
  сп.ДОБАВИТЬ("SELECT COUNT(IS_SYNCED) AS C_RES FROM")
  сп.ДОБАВИТЬ("'" + ф_СпрВладельцев + "'")
  сп.ДОБАВИТЬ("WHERE IS_SYNCED = TRUE AND ID IN (SELECT ID_OWNER FROM")
  сп.ДОБАВИТЬ("'" + ф_СвязьВладУч + "'")
  сп.ДОБАВИТЬ("WHERE  datotchsv > '" + СТР(ДАТА_ТЕК) + 
              "' AND CONSIDER = TRUE AND PART <> '')")
  сп.ДОБАВИТЬ("UNION ALL")
  сп.ДОБАВИТЬ("SELECT COUNT(IS_SYNCED) AS C_RES FROM")
  сп.ДОБАВИТЬ("'" + ф_СпрВладельцев + "'")
  сп.ДОБАВИТЬ("WHERE (IS_SYNCED = FALSE OR IS_SYNCED IS NULL) AND ID IN (SELECT ID_OWNER FROM")
  сп.ДОБАВИТЬ("'" + ф_СвязьВладУч + "'")
  сп.ДОБАВИТЬ("WHERE datotchsv > '" + СТР(ДАТА_ТЕК) + 
              "' AND CONSIDER = TRUE AND PART <> '')")
  sql = SQL_ЗАПРОС(сп)
  ЕСЛИ sql.ВСЕГО > 0 ТО
    sql.ПЕРЕЙТИ(1)
    Данные!ВсегоСтр!"D" = sql.ПОЛЕ("C_RES")
    sql.ПЕРЕЙТИ(2)
    Данные!ВсегоСтр!"D" = Данные!ВсегоСтр!"D" + sql.ПОЛЕ("C_RES")
    Данные!ВсегоСтр!"G" = sql.ПОЛЕ("C_RES")
  КОНЕЦ_ЕСЛИ
  
  ЕСЛИ Данные!ВсегоСтр!"G" <> Данные!ВсегоСтр!"F" ТО
    ЖирСтр!ВсегоСтр = ДА
  КОНЕЦ_ЕСЛИ
КОНЕЦ_ФУНКЦИИ

