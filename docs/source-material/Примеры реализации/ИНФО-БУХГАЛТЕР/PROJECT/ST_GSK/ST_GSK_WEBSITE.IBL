//-------------------------------------------------------------------------------------------------------------------------//
//-------------------------------------------------------------------------------------------------------------------------//
ПЕРЕМ ТИП_ЛОГИКА: г_запросНаСайт
ФУНКЦИЯ STG_УдалитьСправочники
  г_запросНаСайт = ДА
  STG_УдалитьСпрПоПарам
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ STG_СброситьIDвБД
  г_запросНаСайт = НЕТ
  STG_УдалитьСпрПоПарам
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ STG_УдалитьСпрПоПарам
  REST_испСписокАтр = оп_испСписокАтр
  STG_ПарамВыводаТаблиц
  НачСтр = 55
  ВыводИт = ДА
  
  ЦИКЛ ДЛЯ(и = 3, 12)
    Итоги!ЛИТЕР(и) = ДА
  КОНЕЦ_ЦИКЛА
  
  TBLPRINT_ДобавитьСтолбец(6, "№", 0)
  TBLPRINT_ДобавитьСтолбец(30, "Справочник", 0)
  TBLPRINT_ДобавитьСтолбец(15, "Запланировано", 0)
  TBLPRINT_ДобавитьСтолбец(15, "Удалено", 0)
  TBLPRINT_ДобавитьСтолбец(15, "Синхронизировано", 0)
  TBLPRINT_ДобавитьСтолбец(15, "Не синхронизировано", 0)
  TBLPRINT_ДобавитьСтолбец(0, "", 0)
  пред = TBLPRINT_ДобавитьСтолбец(15, "Время выполнения", 0)
  ЕСЛИ оп_времяПодробно ТО
    TBLPRINT_ДобавитьСтолбец(15, "Получение списков", пред)
    TBLPRINT_ДобавитьСтолбец(15, "Формирование запроса", пред)
    TBLPRINT_ДобавитьСтолбец(15, "Отправка запроса", пред)
    TBLPRINT_ДобавитьСтолбец(15, "Остальное", пред)
  КОНЕЦ_ЕСЛИ
  
  ЕСЛИ оп_справочникВлад ТО
    вр = ВРЕМЯ_ТЕК
    STG_УдалитьВладельцев
    STG_ЗаполнитьСтлбВремени(вр)
  КОНЕЦ_ЕСЛИ
  ЕСЛИ оп_справочникУч ТО
    вр = ВРЕМЯ_ТЕК
    STG_УдалитьУчастки
    STG_ЗаполнитьСтлбВремениУд(вр)
  КОНЕЦ_ЕСЛИ
  ЕСЛИ оп_справочникСвязи ТО
    вр = ВРЕМЯ_ТЕК
    STG_УдалитьСвязи
    STG_ЗаполнитьСтлбВремениУд(вр)
  КОНЕЦ_ЕСЛИ
  ЕСЛИ оп_справочникФЛС ТО
    вр = ВРЕМЯ_ТЕК
    STG_УдалитьФЛС
    STG_ЗаполнитьСтлбВремениУд(вр)
  КОНЕЦ_ЕСЛИ
  ЕСЛИ оп_справочникВзносы ТО
    вр = ВРЕМЯ_ТЕК
    STG_УдалитьВзносы
    STG_ЗаполнитьСтлбВремениУд(вр)
  КОНЕЦ_ЕСЛИ
  ЕСЛИ оп_справочникТарифы ТО
    вр = ВРЕМЯ_ТЕК
    STG_УдалитьТарифы
    STG_ЗаполнитьСтлбВремениУд(вр)
  КОНЕЦ_ЕСЛИ
  ЕСЛИ оп_справочникИПУ ТО
    вр = ВРЕМЯ_ТЕК
    STG_УдалитьИПУ
    STG_ЗаполнитьСтлбВремениУд(вр)
  КОНЕЦ_ЕСЛИ
  ЕСЛИ оп_журналПок ТО
    вр = ВРЕМЯ_ТЕК
    STG_УдалитьПоказания
    STG_ЗаполнитьСтлбВремениУд(вр)
  КОНЕЦ_ЕСЛИ
  ЕСЛИ оп_журнал ТО
    вр = ВРЕМЯ_ТЕК
    STG_УдалитьЖурнал
    STG_ЗаполнитьСтлбВремениУд(вр)
  КОНЕЦ_ЕСЛИ
  ЕСЛИ оп_журналРасчетов ТО
    вр = ВРЕМЯ_ТЕК
    STG_УдалитьРасчеты
    STG_ЗаполнитьСтлбВремениУд(вр)
  КОНЕЦ_ЕСЛИ
  ЕСЛИ оп_журналОстатков ТО
    вр = ВРЕМЯ_ТЕК
    STG_УдалитьОстатки
    STG_ЗаполнитьСтлбВремениУд(вр)
  КОНЕЦ_ЕСЛИ
  ЕСЛИ г_запросНаСайт ТО
    ЕСЛИ оп_справочникРекв ТО
      вр = ВРЕМЯ_ТЕК
      STG_УдалитьРеквизиты
      STG_ЗаполнитьСтлбВремениУд(вр)
    КОНЕЦ_ЕСЛИ
    ЕСЛИ оп_настройки ТО
      вр = ВРЕМЯ_ТЕК
      STG_УдалитьНастройки
      STG_ЗаполнитьСтлбВремениУд(вр)
    КОНЕЦ_ЕСЛИ
  КОНЕЦ_ЕСЛИ
  
  ЕСЛИ оп_голосования ТО
    вр = ВРЕМЯ_ТЕК
    STG_УдалитьГолосования
    STG_ЗаполнитьСтлбВремениУд(вр)
    
    вр = ВРЕМЯ_ТЕК
    STG_УдалитьВопросы
    STG_ЗаполнитьСтлбВремениУд(вр)
    
    вр = ВРЕМЯ_ТЕК
    STG_УдалитьОтветы
    STG_ЗаполнитьСтлбВремениУд(вр)
    
    вр = ВРЕМЯ_ТЕК
    STG_УдалитьРезультаты
    STG_ЗаполнитьСтлбВремениУд(вр)
  КОНЕЦ_ЕСЛИ
  
  ЕСЛИ ВсегоСтр > 0 ТО
    ПЕЧАТЬ_ШАПКИ
    ПЕЧАТЬ_ТАБЛИЦЫ
  КОНЕЦ_ЕСЛИ
  СБРОС_ТАБЛИЦ(ДА)
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ STG_УдалитьГолосования
  спр = "Голосования"
  rest_колЭлемПодЗапрУд = stg_профилиВыгрузкиСпр!спр!"_qty_del"
  
  СБРОС(MP_POLL_эл_id, MP_POLL_эл_уд, MP_POLL_эл_доб, MP_POLL_эл_счит, MP_POLL_эл_знач, MP_POLL_эл_изм, REST_эл_id)
  STG_ИниСтрокуОтчета("Голосования")
  ЕСЛИ г_запросНаСайт ТО
    MP_POLL_ПолучитьСписок(ДА)
    Данные!ВсегоСтр!"C" = КОЛ_ЭЛЕМ(REST_эл_id)
    
    ЕСЛИ stg_профилиВыгрузкиСпр!спр!"_prot_del" = "REST" ТО
      MP_POLL_УдалитьМнож(stg_профилиВыгрузкиСпр!спр!"_subreq_del")
    ИНАЧЕ
      MP_POLL_УдМножJSONAPI(stg_профилиВыгрузкиСпр!спр!"_subreq_del")
    КОНЕЦ_ЕСЛИ
    
    ЦИКЛ ИНДЕКС(лог = MP_POLL_эл_уд!инд)
      ЕСЛИ лог ТО
        Данные!ВсегоСтр!"D"++
        Данные!ВсегоСтр!"E"++
      КОНЕЦ_ЕСЛИ
    КОНЕЦ_ЦИКЛА
  КОНЕЦ_ЕСЛИ
  STG_СбросПолейСинхрБД(mp_файлГолосований)
  Данные!ВсегоСтр!"F" = Данные!ВсегоСтр!"D" - Данные!ВсегоСтр!"E"
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ STG_УдалитьВопросы
  спр = "Голосования"
