//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ ТИП_SQL ТИП_ЛОГИКА: STG_СинхронизироватьГолос(ТИП_СТРОКА: id)
  спр = "Голосования"
  ЕСЛИ id = "" ТО
    id = СТР_ЗНАЧ(MP_POLL_id)
  КОНЕЦ_ЕСЛИ
  РЕЗУЛЬТАТ = НЕТ
  ЕСЛИ СУЩ_ПЕРЕМ(MP_POLL_эл_счит[id + "|MP_POLL_id"]) ТО
    ЕСЛИ MP_POLL_эл_счит[id + "|MP_POLL_id"] ТО
      ЕСЛИ СУЩ_ПЕРЕМ(Данные!ВсегоСтр!"D") ТО
        Данные!ВсегоСтр!"D"++
      КОНЕЦ_ЕСЛИ
      ЕСЛИ stg_профилиВыгрузкиСпр!спр!"_subreq_add" ТО
        MP_POLL_Упаковать(id)
      КОНЕЦ_ЕСЛИ
      поз = НАЙТИ_ПОЗ("uuid", MP_POLL_uuid)
      ЕСЛИ поз > 0 ТО
        ЕСЛИ СУЩ_ПЕРЕМ(Данные!ВсегоСтр!"E") ТО
          Данные!ВсегоСтр!"E"++
        КОНЕЦ_ЕСЛИ
        ПЕРЕЙТИ(поз)
        ЕСЛИ MP_POLL_эл_счит[id + "|MP_POLL_is_synced"] ТО
          ЗАП_ПОЛЕ("IS_SYNCED", MP_POLL_is_synced)
        КОНЕЦ_ЕСЛИ
        ЕСЛИ MP_POLL_эл_счит[id + "|MP_POLL_label"] ТО
          ЗАП_ПОЛЕ("label", MP_POLL_label)
        КОНЕЦ_ЕСЛИ
        ЕСЛИ MP_POLL_эл_счит[id + "|MP_POLL_multipoll_poll_type"] ТО
          ЗАП_ПОЛЕ("mppltype", MP_POLL_multipoll_poll_type)
        КОНЕЦ_ЕСЛИ
        ЕСЛИ MP_POLL_эл_счит[id + "|MP_POLL_status"] ТО
          ЗАП_ПОЛЕ("status", MP_POLL_status)
        КОНЕЦ_ЕСЛИ
        ЕСЛИ MP_POLL_эл_счит[id + "|MP_POLL_pollactiveuntil"] ТО
          ЗАП_ПОЛЕ("pllctvnt", MP_POLL_pollactiveuntil)
        КОНЕЦ_ЕСЛИ
        ЗАМЕНИТЬ
        РЕЗУЛЬТАТ = ДА
      ИНАЧЕ
        ЕСЛИ СУЩ_ПЕРЕМ(stg_полеLabelПоGUID[MP_POLL_label]) И ПОЛЕ("uuid") = "" ТО
          поз = НАЙТИ_ПОЗ("id_db", stg_полеLabelПоGUID[MP_POLL_label])
          ЕСЛИ поз > 0 ТО
            ЕСЛИ СУЩ_ПЕРЕМ(Данные!ВсегоСтр!"E") ТО
              Данные!ВсегоСтр!"E"++
            КОНЕЦ_ЕСЛИ
            ПЕРЕЙТИ(поз)
            ЕСЛИ MP_POLL_эл_счит[id + "|MP_POLL_is_synced"] ТО
              ЗАП_ПОЛЕ("IS_SYNCED", MP_POLL_is_synced)
            КОНЕЦ_ЕСЛИ
            ЕСЛИ MP_POLL_эл_счит[id + "|MP_POLL_id"] ТО
              ЗАП_ПОЛЕ("id_recsite", MP_POLL_id)
            КОНЕЦ_ЕСЛИ
            ЕСЛИ MP_POLL_эл_счит[id + "|MP_POLL_uuid"] ТО
              ЗАП_ПОЛЕ("uuid", MP_POLL_uuid)
            КОНЕЦ_ЕСЛИ
            ЕСЛИ MP_POLL_эл_счит[id + "|MP_POLL_uid"] ТО
              ЗАП_ПОЛЕ("uid", MP_POLL_uid)
            КОНЕЦ_ЕСЛИ
            ЕСЛИ MP_POLL_эл_счит[id + "|MP_POLL_multipoll_poll_type"] ТО
              ЗАП_ПОЛЕ("mppltype", MP_POLL_multipoll_poll_type)
            КОНЕЦ_ЕСЛИ
            ЕСЛИ MP_POLL_эл_счит[id + "|MP_POLL_created"] ТО
              ЗАП_ПОЛЕ("created", MP_POLL_created)
            КОНЕЦ_ЕСЛИ
            ЕСЛИ MP_POLL_эл_счит[id + "|MP_POLL_changed"] ТО
              ЗАП_ПОЛЕ("changed", MP_POLL_changed)
            КОНЕЦ_ЕСЛИ  
            ЗАМЕНИТЬ
            РЕЗУЛЬТАТ = ДА
            
            СОЗДАТЬ(сп, ТИП_СПИСОК)
            сп.ДОБАВИТЬ("UPDATE")
            сп.ДОБАВИТЬ("'" + mp_файлВопросов + "'")
            сп.ДОБАВИТЬ("SET poll_id = '" + MP_POLL_uuid + "' WHERE p_id_db = " + СТР_ЗНАЧ(ПОЛЕ("id_db")))
            SQL_ЗАПРОС(сп)
          КОНЕЦ_ЕСЛИ
        ИНАЧЕ
          ЕСЛИ СУЩ_ПЕРЕМ(Данные!ВсегоСтр!"F") ТО
            Данные!ВсегоСтр!"F"++
          КОНЕЦ_ЕСЛИ
        КОНЕЦ_ЕСЛИ
      КОНЕЦ_ЕСЛИ
    КОНЕЦ_ЕСЛИ
  КОНЕЦ_ЕСЛИ
  STG_СинхронизироватьГолос = РЕЗУЛЬТАТ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ ТИП_SQL ТИП_ЛОГИКА: STG_СинхронизироватьВопросы(ТИП_СТРОКА: id)
  спр = "Голосования"
  ЕСЛИ id = "" ТО
    id = СТР_ЗНАЧ(MP_QUESTION_id)
  КОНЕЦ_ЕСЛИ
  РЕЗУЛЬТАТ = НЕТ
  ЕСЛИ СУЩ_ПЕРЕМ(MP_QUESTION_эл_счит[id + "|MP_QUESTION_id"]) ТО
    ЕСЛИ MP_QUESTION_эл_счит[id + "|MP_QUESTION_id"] ТО
      ЕСЛИ СУЩ_ПЕРЕМ(Данные!ВсегоСтр!"D") ТО
        Данные!ВсегоСтр!"D"++
      КОНЕЦ_ЕСЛИ
      ЕСЛИ stg_профилиВыгрузкиСпр!спр!"_subreq_add" ТО
        MP_QUESTION_Упаковать(id)
      КОНЕЦ_ЕСЛИ
      поз = НАЙТИ_ПОЗ("label", MP_QUESTION_label)
      ЕСЛИ поз > 0 ТО
        ЕСЛИ СУЩ_ПЕРЕМ(Данные!ВсегоСтр!"E") ТО
          Данные!ВсегоСтр!"E"++
        КОНЕЦ_ЕСЛИ
        ПЕРЕЙТИ(поз)
        ЕСЛИ MP_QUESTION_эл_счит[id + "|MP_QUESTION_is_synced"] ТО
          ЗАП_ПОЛЕ("IS_SYNCED", MP_QUESTION_is_synced)
        КОНЕЦ_ЕСЛИ
        ЕСЛИ MP_QUESTION_эл_счит[id + "|MP_QUESTION_id"] ТО
          ЗАП_ПОЛЕ("id_recsite", MP_QUESTION_id)
        КОНЕЦ_ЕСЛИ
        ЗАМЕНИТЬ
        РЕЗУЛЬТАТ = ДА
      ИНАЧЕ
        ЕСЛИ СУЩ_ПЕРЕМ(stg_полеLabelПоGUID[MP_QUESTION_label]) И ПОЛЕ("uuid") = "" ТО
          поз = НАЙТИ_ПОЗ("id_db", stg_полеLabelПоGUID[MP_QUESTION_label])
          ЕСЛИ поз > 0 ТО
            ЕСЛИ СУЩ_ПЕРЕМ(Данные!ВсегоСтр!"E") ТО
              Данные!ВсегоСтр!"E"++
            КОНЕЦ_ЕСЛИ
            ПЕРЕЙТИ(поз)
            ЕСЛИ MP_QUESTION_эл_счит[id + "|MP_QUESTION_is_synced"] ТО
              ЗАП_ПОЛЕ("IS_SYNCED", MP_QUESTION_is_synced)
            КОНЕЦ_ЕСЛИ
            ЕСЛИ MP_QUESTION_эл_счит[id + "|MP_QUESTION_id"] ТО
              ЗАП_ПОЛЕ("id_recsite", MP_QUESTION_id)
            КОНЕЦ_ЕСЛИ
            ЕСЛИ MP_QUESTION_эл_счит[id + "|MP_QUESTION_uuid"] ТО
              ЗАП_ПОЛЕ("uuid", MP_QUESTION_uuid)
            КОНЕЦ_ЕСЛИ
            ЕСЛИ MP_QUESTION_эл_счит[id + "|MP_QUESTION_uid"] ТО
              ЗАП_ПОЛЕ("uid", MP_QUESTION_uid)
            КОНЕЦ_ЕСЛИ
            ЕСЛИ MP_QUESTION_эл_счит[id + "|MP_QUESTION_mp_quest_type"] ТО
              ЗАП_ПОЛЕ("mpqstype", MP_QUESTION_mp_quest_type)
            КОНЕЦ_ЕСЛИ
            ЕСЛИ MP_QUESTION_эл_счит[id + "|MP_QUESTION_created"] ТО
              ЗАП_ПОЛЕ("created", MP_QUESTION_created)
            КОНЕЦ_ЕСЛИ
            ЕСЛИ MP_QUESTION_эл_счит[id + "|MP_QUESTION_changed"] ТО
              ЗАП_ПОЛЕ("changed", MP_QUESTION_changed)
            КОНЕЦ_ЕСЛИ
            ЕСЛИ MP_QUESTION_эл_счит[id + "|MP_QUESTION_weight"] ТО
              ЗАП_ПОЛЕ("weight", MP_QUESTION_weight)
            КОНЕЦ_ЕСЛИ
              
            ЗАМЕНИТЬ
            РЕЗУЛЬТАТ = ДА
            
            СОЗДАТЬ(сп, ТИП_СПИСОК)
            сп.ДОБАВИТЬ("UPDATE")
            сп.ДОБАВИТЬ("'" + mp_файлОтветов + "'")
            сп.ДОБАВИТЬ("SET quest_id = '" + MP_QUESTION_uuid + "' WHERE q_id_db = " + СТР_ЗНАЧ(ПОЛЕ("id_db")))
            SQL_ЗАПРОС(сп)
          КОНЕЦ_ЕСЛИ
        ИНАЧЕ
          ЕСЛИ СУЩ_ПЕРЕМ(Данные!ВсегоСтр!"F") ТО
            Данные!ВсегоСтр!"F"++
          КОНЕЦ_ЕСЛИ
        КОНЕЦ_ЕСЛИ
      КОНЕЦ_ЕСЛИ
    КОНЕЦ_ЕСЛИ
  КОНЕЦ_ЕСЛИ
  STG_СинхронизироватьВопросы = РЕЗУЛЬТАТ
КОНЕЦ_ФУНКЦИИ

