    ИНАЧЕ
      SPR_LINK_ALL_УдалитьМнож(stg_профилиВыгрузкиСпр!спр!"_subreq_del")
    КОНЕЦ_ЕСЛИ
    ЦИКЛ ИНДЕКС(лог = SPR_LINK_ALL_эл_уд!инд)
      ЕСЛИ лог ТО
        Данные!ВсегоСтр!"D"++
        Данные!ВсегоСтр!"E"++
      КОНЕЦ_ЕСЛИ
    КОНЕЦ_ЦИКЛА
  КОНЕЦ_ЕСЛИ
  STG_СбросПолейСинхрБД(ф_СвязьВладУч)
  Данные!ВсегоСтр!"F" = Данные!ВсегоСтр!"D" - Данные!ВсегоСтр!"E"
КОНЕЦ_ФУНКЦИИ

