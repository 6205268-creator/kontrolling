  ДобавитьЗначениеЧ(спр, инд + "|SPR_CALC_REG_add_sum", ПОЛЕ("add_sum"))
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ STG_ПоказатьРасчеты
  ВЫХОД
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ STG_ВыгрузитьПоказания
  СБРОС(POK_SCH_эл_доб, POK_SCH_эл_счит, POK_SCH_эл_знач, POK_SCH_эл_изм)
  спр = "Журнал показаний ИПУ"
  rest_колЭлемПодЗапрДоб = stg_профилиВыгрузкиСпр!спр!"_qty_add"
  
  ЕСЛИ оп_проверятьБазуПоСайту ТО
    ЕСЛИ POK_SCH_ПолучитьСписок(ДА) ТО
      STG_ПроверитьИдБазы(ф_ПоказанияИСЭЭ)
      STG_ПроверитьИдБазы(ф_ПоказанияИСВГ)
    КОНЕЦ_ЕСЛИ
    СБРОС(POK_SCH_эл_id, POK_SCH_эл_уд, POK_SCH_эл_счит, POK_SCH_эл_доб,  POK_SCH_эл_знач, POK_SCH_эл_изм, REST_эл)
  КОНЕЦ_ЕСЛИ
  
  СОЗДАТЬ(sql_loop, ТИП_SQL)
  sql_loop.STG_ЗапросВыгрузкиЖурналИПУ
  длина = ДЛИНА(СТР_ЗНАЧ(sql_loop.ВСЕГО))
  sql_el = SQL_ОТКРЫТЬ(ф_ПоказанияИСЭЭ)
  sql_wg = SQL_ОТКРЫТЬ(ф_ПоказанияИСВГ)
  STG_ИниСтрокуОтчета("Журнал показаний ИПУ")
  СтатусСоздать("Обработка показаний ИПУ для выгрузки")
  СтатусСтартПрогресс(sql_loop.ВСЕГО)
  ЦИКЛ ДЛЯ(и = sql_loop.ВСЕГО, 1, -1)
    sql_loop.ПЕРЕЙТИ(и)
    инд = СТР0(и, длина)
    POK_SCH_эл_доб!инд = НЕТ
    Данные!ВсегоСтр!"C"++
    
    STG_ПрокачкаСтатуса("обработка показания от " + СТР(sql_loop.ПОЛЕ("dat")))
    
    sql_loop.STG_ДобЗначПоказания(инд)
    
    ЕСЛИ НЕ stg_профилиВыгрузкиСпр!спр!"_subreq_add" ТО
      ЕСЛИ POK_SCH_ДобавитьМнож(НЕТ) ТО
        ЕСЛИ НЕ sql_el.STG_СинхронизироватьПоказания("") ТО
          sql_wg.STG_СинхронизироватьПоказания("")
        КОНЕЦ_ЕСЛИ
      ИНАЧЕ
        СТОП
      КОНЕЦ_ЕСЛИ
      СБРОС(POK_SCH_эл_доб, POK_SCH_эл_счит, POK_SCH_эл_знач, POK_SCH_эл_изм)
    КОНЕЦ_ЕСЛИ
  КОНЕЦ_ЦИКЛА
  СтатусЗакрыть
  
  ЕСЛИ stg_профилиВыгрузкиСпр!спр!"_subreq_add" ТО
    POK_SCH_ДобавитьМнож(stg_профилиВыгрузкиСпр!спр!"_subreq_add")
    СтатусСоздать("Синхронизация журнала показаний ИПУ")
    СтатусСтартПрогресс(КОЛ_ЭЛЕМ(REST_эл_id))
    ЦИКЛ ИНДЕКС(лог = POK_SCH_эл_доб!инд)
      ЕСЛИ лог ТО
        STG_ПрокачкаСтатуса("Синхронизация журнала показаний ИПУ")
        ЕСЛИ НЕ sql_el.STG_СинхронизироватьПоказания(инд) ТО
          sql_wg.STG_СинхронизироватьПоказания(инд)
        КОНЕЦ_ЕСЛИ
      КОНЕЦ_ЕСЛИ
    КОНЕЦ_ЦИКЛА
    СтатусЗакрыть
    СБРОС(POK_SCH_эл_доб, POK_SCH_эл_счит, POK_SCH_эл_знач, POK_SCH_эл_изм)
  КОНЕЦ_ЕСЛИ
  
  sql_loop.ЗАКРЫТЬ
  sql_el.ЗАКРЫТЬ
  sql_wg.ЗАКРЫТЬ
  //СтатусЗакрыть
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ ТИП_SQL STG_ЗапросВыгрузкиЖурналИПУ
  IB_FILE_ФайлУдалить(ф_tmp025)
  СОЗДАТЬ(сп, ТИП_СПИСОК)
  сп.ДОБАВИТЬ("SELECT ID_AREA, ID_SCH, DAT, NUM1, NUM2, NUM3, T1_VOL, T2_VOL, T3_VOL, P1, P2, P3, CORR, COMM, P, ID_RECSITE, IS_SYNCED FROM") // P,
  сп.ДОБАВИТЬ("'" + ф_ПоказанияИСЭЭ + "'")
  сп.ДОБАВИТЬ("WHERE ID_SCH > 0 AND ID_AREA > 0 AND (NUM1 > 0 OR NUM2 > 0 OR NUM3 > 0)")
  контекст = IB_CONTEXT_ИзвлечьЛок(к_атрПоказВсехЗаписей)
  ЕСЛИ контекст = "" ТО
    сп.ДОБАВИТЬ("AND (IS_SYNCED = FALSE OR IS_SYNCED IS NULL)")
  КОНЕЦ_ЕСЛИ
  ЕСЛИ г_колУчастков > 0 ТО
    сп.ДОБАВИТЬ("AND ID_AREA IN (")
    сп.STG_ARH_СчитатьАрхив(к_АрхивСпрУчастков, г_путьПрофиляСпрУчастков)
    сп.ДОБАВИТЬ(")")
  КОНЕЦ_ЕСЛИ
  сп.ДОБАВИТЬ("UNION")
  сп.ДОБАВИТЬ("SELECT ID_AREA, ID_SCH, DAT, NUM1, 0 AS NUM2, 0 AS NUM3, T1_VOL, 0 AS T2_VOL, 0 AS T3_VOL, 0 AS P1, 0 AS P2, 0 AS P3, CORR, COMM, CAST('' AS CHAR(20)) AS P, ID_RECSITE, IS_SYNCED FROM")
  сп.ДОБАВИТЬ("'" + ф_ПоказанияИСВГ + "'")
  сп.ДОБАВИТЬ("WHERE ID_SCH > 0 AND ID_AREA > 0 AND NUM1 > 0")
  ЕСЛИ контекст = "" ТО
    сп.ДОБАВИТЬ("AND (IS_SYNCED = FALSE OR IS_SYNCED IS NULL)")
  КОНЕЦ_ЕСЛИ
  ЕСЛИ г_колУчастков > 0 ТО
    сп.ДОБАВИТЬ("AND ID_AREA IN (")
    сп.STG_ARH_СчитатьАрхив(к_АрхивСпрУчастков, г_путьПрофиляСпрУчастков)
    сп.ДОБАВИТЬ(")")
  КОНЕЦ_ЕСЛИ
  sql = SQL_ЗАПРОС(сп)
  sql.ЗАПИСАТЬ(ф_tmp025)
  sql.ЗАКРЫТЬ
  
  сп.ОЧИСТИТЬ
  сп.ДОБАВИТЬ("SELECT A.*, B.SRT FROM")
  сп.ДОБАВИТЬ("'" + ф_tmp025 + "' A")
  сп.ДОБАВИТЬ("INNER JOIN")
  сп.ДОБАВИТЬ("'" + ф_СпрУчастковГаражей + "' B")
  сп.ДОБАВИТЬ("ON A.ID_AREA = B.ID_AREA ORDER BY A.DAT, B.SRT")
  ЗАПРОС(сп)
  
  IB_FILE_ФайлУдалить(ф_tmp025)
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ ТИП_SQL ТИП_ЛОГИКА: STG_СинхронизироватьПоказания(ТИП_СТРОКА: id)
  спр = "Журнал показаний ИПУ"
  РЕЗУЛЬТАТ = НЕТ 
  ЕСЛИ id = "" ТО
    id = СТР_ЗНАЧ(POK_SCH_id)
  КОНЕЦ_ЕСЛИ
  ЕСЛИ СУЩ_ПЕРЕМ(POK_SCH_эл_счит[id + "|POK_SCH_id_ipu"]) ТО
    ЕСЛИ POK_SCH_эл_счит[id + "|POK_SCH_id_ipu"] И 
         POK_SCH_эл_счит[id + "|POK_SCH_dat"] ТО
      ЕСЛИ СУЩ_ПЕРЕМ(Данные!ВсегоСтр!"D") ТО
        Данные!ВсегоСтр!"D"++
      КОНЕЦ_ЕСЛИ
      ЕСЛИ stg_профилиВыгрузкиСпр!спр!"_subreq_add" ТО
        POK_SCH_Упаковать(id)
      КОНЕЦ_ЕСЛИ
      поз = НАЙТИ_ПОЗ("id_sch", POK_SCH_id_ipu, 
                      "dat", POK_SCH_dat)
      ЕСЛИ поз > 0 ТО
        ЕСЛИ СУЩ_ПЕРЕМ(Данные!ВсегоСтр!"E") ТО
          Данные!ВсегоСтр!"E"++
        КОНЕЦ_ЕСЛИ
        ПЕРЕЙТИ(поз)
        ЕСЛИ POK_SCH_эл_счит[id + "|POK_SCH_is_synced"] ТО
          ЗАП_ПОЛЕ("IS_SYNCED", POK_SCH_is_synced)
        КОНЕЦ_ЕСЛИ
        ЕСЛИ POK_SCH_эл_счит[id + "|POK_SCH_id"] ТО
          ЗАП_ПОЛЕ("ID_RECSITE", POK_SCH_id)
        КОНЕЦ_ЕСЛИ
        ЕСЛИ POK_SCH_эл_счит[id + "|POK_SCH_uuid"] ТО
          ЗАП_ПОЛЕ("UUID", POK_SCH_uuid)
        КОНЕЦ_ЕСЛИ
        ЗАМЕНИТЬ
        РЕЗУЛЬТАТ = ДА
      ИНАЧЕ
        ЕСЛИ СУЩ_ПЕРЕМ(Данные!ВсегоСтр!"F") ТО
          Данные!ВсегоСтр!"F"++
        КОНЕЦ_ЕСЛИ
      КОНЕЦ_ЕСЛИ
    КОНЕЦ_ЕСЛИ
  КОНЕЦ_ЕСЛИ
  STG_СинхронизироватьПоказания = РЕЗУЛЬТАТ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ ТИП_SQL STG_ДобЗначПоказания(ТИП_СТРОКА: инд) //все значения
  спр = "readings"
  ДобавитьЗначениеС(спр, инд + "|POK_SCH_type", "pok_sch--pok_sch")
  ДобавитьЗначениеД(спр, инд + "|POK_SCH_dat", ПОЛЕ("dat"))
  ДобавитьЗначениеЧ(спр, инд + "|POK_SCH_num1", ПОЛЕ("num1"))
  ЕСЛИ IB_DBF_ПолеСущ("num2") ТО
    ДобавитьЗначениеЧ(спр, инд + "|POK_SCH_num2", ПОЛЕ("num2"))
  ИНАЧЕ
    ДобавитьЗначениеЧ(спр, инд + "|POK_SCH_num2", 0)
  КОНЕЦ_ЕСЛИ
  ib_dbf_логСущПолейФ!"num3" = IB_DBF_ПОЛЕ_СУЩ("num3")
  ЕСЛИ IB_DBF_ПолеСущ("num3") ТО
    ДобавитьЗначениеЧ(спр, инд + "|POK_SCH_num3", ПОЛЕ("num3"))
  ИНАЧЕ
    ДобавитьЗначениеЧ(спр, инд + "|POK_SCH_num3", 0)
  КОНЕЦ_ЕСЛИ
  ДобавитьЗначениеЧ(спр, инд + "|POK_SCH_t1_vol", ПОЛЕ("t1_vol"))
  ЕСЛИ IB_DBF_ПолеСущ("t2_vol") ТО
    ДобавитьЗначениеЧ(спр, инд + "|POK_SCH_t2_vol", ПОЛЕ("t2_vol"))
  ИНАЧЕ
    ДобавитьЗначениеЧ(спр, инд + "|POK_SCH_t2_vol", 0)
  КОНЕЦ_ЕСЛИ
  ЕСЛИ IB_DBF_ПолеСущ("t3_vol") ТО
    ДобавитьЗначениеЧ(спр, инд + "|POK_SCH_t3_vol", ПОЛЕ("t3_vol"))
  ИНАЧЕ
    ДобавитьЗначениеЧ(спр, инд + "|POK_SCH_t3_vol", 0)
  КОНЕЦ_ЕСЛИ
  ЕСЛИ IB_DBF_ПолеСущ("p1") ТО
    ДобавитьЗначениеЧ(спр, инд + "|POK_SCH_p1", ПОЛЕ("p1"))
  ИНАЧЕ
    ДобавитьЗначениеЧ(спр, инд + "|POK_SCH_p1", 0)
  КОНЕЦ_ЕСЛИ
  ЕСЛИ IB_DBF_ПолеСущ("p2") ТО
    ДобавитьЗначениеЧ(спр, инд + "|POK_SCH_p2", ПОЛЕ("p2"))
  ИНАЧЕ
    ДобавитьЗначениеЧ(спр, инд + "|POK_SCH_p2", 0)
  КОНЕЦ_ЕСЛИ
  ЕСЛИ IB_DBF_ПолеСущ("p3") ТО
    ДобавитьЗначениеЧ(спр, инд + "|POK_SCH_p3", ПОЛЕ("p3"))
  ИНАЧЕ
    ДобавитьЗначениеЧ(спр, инд + "|POK_SCH_p3", 0)
  КОНЕЦ_ЕСЛИ
  ЕСЛИ IB_DBF_ПолеСущ("p") ТО
    ДобавитьЗначениеС(спр, инд + "|POK_SCH_p", ПОЛЕ("p"))
  ИНАЧЕ
    ДобавитьЗначениеС(спр, инд + "|POK_SCH_p", "")
  КОНЕЦ_ЕСЛИ
  ДобавитьЗначениеЛ(спр, инд + "|POK_SCH_corr", ПОЛЕ("corr"))
  ДобавитьЗначениеС(спр, инд + "|POK_SCH_comm", ПОЛЕ("comm"))
  ДобавитьЗначениеЧ(спр, инд + "|POK_SCH_id_area", ПОЛЕ("id_area"))
  ДобавитьЗначениеЧ(спр, инд + "|POK_SCH_id_ipu", ПОЛЕ("id_sch"))
  ЕСЛИ IB_CONTEXT_СчитатьЛок("синхронизацияСайта") = "" ТО
    ДобавитьЗначениеЛ(спр, инд + "|POK_SCH_is_synced", НЕТ)
  ИНАЧЕ
    ДобавитьЗначениеЛ(спр, инд + "|POK_SCH_is_synced", ДА)
  КОНЕЦ_ЕСЛИ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
//-------------------------------------------------------------------------------------------------------------------------//------------------------------------------------------------------------------------------------------------------------------------------------
ПЕРЕМ stg_реквизитIdНаСайте!
ПЕРЕМ stg_реквизитUuidНаСайте!
ПЕРЕМ stg_реквизитЗначНаСайте!
ФУНКЦИЯ STG_ВыгрузитьРеквизиты
  СБРОС(SPR_REKV_эл_доб, SPR_REKV_эл_счит, SPR_REKV_эл_знач, SPR_REKV_эл_изм, SPR_REKV_эл_id)
  спр = "Справочник реквизитов"
  rest_колЭлемПодЗапрДоб = stg_профилиВыгрузкиСпр!спр!"_qty_add"
  
  ЕСЛИ оп_проверятьБазуПоСайту ТО
    ЕСЛИ SPR_REKV_ПолучитьСписок(ДА) ТО
      STG_ПроверитьИдБазы(ф_СпрРеквизитовОргСайт)
    КОНЕЦ_ЕСЛИ
    СБРОС(SPR_REKV_эл_id, SPR_REKV_эл_уд, SPR_REKV_эл_счит, SPR_REKV_эл_доб,  SPR_REKV_эл_знач, SPR_REKV_эл_изм, REST_эл)
  КОНЕЦ_ЕСЛИ
  
  СБРОС(stg_реквизитIdНаСайте, stg_реквизитUuidНаСайте, stg_реквизитЗначНаСайте)
  
  //STG_R_НастройкиПечатиПД
  //STG_ОпределитьРеквПолучателя
  
  STG_ПоказатьРеквизиты(НЕТ)
  sql = SQL_ОТКРЫТЬ(ф_СпрРеквизитовОргСайт)
  
  STG_ИниСтрокуОтчета("Реквизиты")
  
  реквизит!"Organisation" = г_реквПолучателя!"наимОрг"
  реквизит!"OrganisationFull" = г_реквПолучателя!"наимОргПолн"
  реквизит!"PersonalAcc" = г_реквПолучателя!"расчСч"
  реквизит!"BankName" = г_реквПолучателя!"наимБанк"
  реквизит!"BIC" = г_реквПолучателя!"бик"
  реквизит!"CorrespAcc" = г_реквПолучателя!"коррСч"
  реквизит!"PayeeINN" = г_реквПолучателя!"иннОрг"
  реквизит!"KPP" = г_реквПолучателя!"кппОрг"
  
  SPR_REKV_ПолучитьСписок(НЕТ)
  ЦИКЛ ИНДЕКС(знач0 = SPR_REKV_эл_счит!индекс)
    ЕСЛИ ПОЗ("SPR_REKV_name", индекс) > 0 ТО
      ЕСЛИ СУЩ_ПЕРЕМ(SPR_REKV_эл_знач!индекс) ТО
        текИд = СТР_ФРАГ(индекс, "|", 1)
        stg_реквизитIdНаСайте[SPR_REKV_эл_знач!индекс] = SPR_REKV_эл_знач!текИд!"|SPR_REKV_id"
        stg_реквизитUuidНаСайте[SPR_REKV_эл_знач!индекс] = SPR_REKV_эл_знач!текИд!"|SPR_REKV_uuid"
        stg_реквизитЗначНаСайте[SPR_REKV_эл_знач!индекс] = SPR_REKV_эл_знач!текИд!"|SPR_REKV_value"
      КОНЕЦ_ЕСЛИ
    КОНЕЦ_ЕСЛИ
  КОНЕЦ_ЦИКЛА
  СБРОС(SPR_REKV_эл_доб, SPR_REKV_эл_счит, SPR_REKV_эл_знач, SPR_REKV_эл_изм)

  и = 0
  ЦИКЛ ДЛЯ(ит = 1, ?(stg_профилиВыгрузкиСпр!спр!"_subreq_add", 2, 1))
    СтатусСоздать("Выгрузка реквизитов")
    СтатусСтартПрогресс(КОЛ_ЭЛЕМ(реквизит))
    ЦИКЛ ИНДЕКС(знач = реквизит!имяРекв)
      ЕСЛИ знач <> "" ТО
        и++
        инд = СТР_ЗНАЧ(и)
        ЕСЛИ СУЩ_ПЕРЕМ(Данные!ВсегоСтр!"C") И ит = 1 ТО
          Данные!ВсегоСтр!"C"++
          //Данные!ВсегоСтр!"D"++
          //Данные!ВсегоСтр!"E"++
        КОНЕЦ_ЕСЛИ
        
        STG_ПрокачкаСтатуса("обработка реквизита " + имяРекв)
        ЕСЛИ НЕ СУЩ_ПЕРЕМ(stg_реквизитUuidНаСайте!имяРекв) И ит = 1 ТО
          SPR_REKV_эл_доб!инд = НЕТ
          STG_ДобЗначРеквизит(инд, имяРекв, знач)
        ИНАЧЕ
          ЕСЛИ СУЩ_ПЕРЕМ(stg_реквизитЗначНаСайте!имяРекв) ТО
            ЕСЛИ ит = 2 И stg_реквизитЗначНаСайте!имяРекв <> знач ТО
              инд = СТР_ЗНАЧ(stg_реквизитIdНаСайте!имяРекв)
              STG_ДобавитьЭлИд(к_спрСайтаРеквизиты, инд)
              ДобавитьЗначениеС(к_спрСайтаРеквизиты, инд + "|SPR_REKV_uuid", stg_реквизитUuidНаСайте!имяРекв)
              ДобавитьЗначениеС(к_спрСайтаРеквизиты, инд + "|SPR_REKV_type", SPR_REKV_type)
              ДобавитьЗначениеС(к_спрСайтаРеквизиты, инд + "|SPR_REKV_value", знач)
            КОНЕЦ_ЕСЛИ
          КОНЕЦ_ЕСЛИ
        КОНЕЦ_ЕСЛИ
        
        ЕСЛИ НЕ stg_профилиВыгрузкиСпр!спр!"_subreq_add" ТО
          рез = ДА
          ЕСЛИ НЕ СУЩ_ПЕРЕМ(stg_реквизитUuidНаСайте!имяРекв) И ит = 1 ТО
            рез = SPR_REKV_ДобавитьМнож(stg_профилиВыгрузкиСпр!спр!"_subreq_add")
            ЕСЛИ рез ТО
              sql.STG_СинхронизироватьРекв(инд)
            КОНЕЦ_ЕСЛИ
          ИНАЧЕ
            ЕСЛИ stg_реквизитЗначНаСайте!имяРекв <> знач И ит = 2 ТО
              рез = SPR_REKV_ИзменитьМнож(stg_профилиВыгрузкиСпр!спр!"_subreq_add")
              ЕСЛИ рез ТО
                sql.STG_СинхронизироватьРекв(инд)
              КОНЕЦ_ЕСЛИ
            КОНЕЦ_ЕСЛИ
          КОНЕЦ_ЕСЛИ
          СБРОС(SPR_REKV_эл_доб, SPR_REKV_эл_счит, SPR_REKV_эл_знач, SPR_REKV_эл_изм, SPR_REKV_эл_id)
          ЕСЛИ НЕ рез ТО
            ПРОДОЛЖИТЬ
          КОНЕЦ_ЕСЛИ
        КОНЕЦ_ЕСЛИ
      КОНЕЦ_ЕСЛИ
    КОНЕЦ_ЦИКЛА
    СтатусЗакрыть
  
    ЕСЛИ stg_профилиВыгрузкиСпр!спр!"_subreq_add" ТО
      ЕСЛИ КОЛ_ЭЛЕМ(SPR_REKV_эл_доб) > 0 ТО
        ЕСЛИ SPR_REKV_ДобавитьМнож(stg_профилиВыгрузкиСпр!спр!"_subreq_add") ТО
          СтатусСоздать("Синхронизация реквизитов")
          СтатусСтартПрогресс(КОЛ_ЭЛЕМ(REST_эл_id))
          ЦИКЛ ИНДЕКС(лог = SPR_REKV_эл_доб!инд)
            ЕСЛИ лог ТО
              STG_ПрокачкаСтатуса("Синхронизация реквизитов")
              sql.STG_СинхронизироватьРекв(инд)
            КОНЕЦ_ЕСЛИ
          КОНЕЦ_ЦИКЛА
          СтатусЗакрыть
        КОНЕЦ_ЕСЛИ
        СБРОС(SPR_REKV_эл_доб, SPR_REKV_эл_счит, SPR_REKV_эл_знач, SPR_REKV_эл_изм, SPR_REKV_эл_id)
      КОНЕЦ_ЕСЛИ
      ЕСЛИ КОЛ_ЭЛЕМ(SPR_REKV_эл_id) > 0 ТО
        ЕСЛИ SPR_REKV_ИзменитьМнож(stg_профилиВыгрузкиСпр!спр!"_subreq_add") ТО
          СтатусСоздать("Синхронизация реквизитов")
          СтатусСтартПрогресс(КОЛ_ЭЛЕМ(REST_эл_id))
          ЦИКЛ ИНДЕКС(лог = SPR_REKV_эл_доб!инд)
            ЕСЛИ лог ТО
              STG_ПрокачкаСтатуса("Синхронизация реквизитов")
              sql.STG_СинхронизироватьРекв(инд)
            КОНЕЦ_ЕСЛИ
          КОНЕЦ_ЦИКЛА
          СтатусЗакрыть
        КОНЕЦ_ЕСЛИ
        СБРОС(SPR_REKV_эл_доб, SPR_REKV_эл_счит, SPR_REKV_эл_знач, SPR_REKV_эл_изм, SPR_REKV_эл_id)
      КОНЕЦ_ЕСЛИ
    КОНЕЦ_ЕСЛИ
  КОНЕЦ_ЦИКЛА
  
  sql.ЗАКРЫТЬ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ ТИП_СТРОКА: STG_РеквизитыСоотв(ТИП_СТРОКА: имя)
  ВЫБОР(имя)
    #"Organisation": STG_РеквизитыСоотв = "Организация"
    #"OrganisationFull": STG_РеквизитыСоотв = "Организация (полн.)"
    #"BankName":STG_РеквизитыСоотв = "Банк"
    #"PersonalAcc":STG_РеквизитыСоотв = "Расч. счет"
    #"BIC":STG_РеквизитыСоотв = "БИК"
    #"CorrespAcc": STG_РеквизитыСоотв = "Корр. счет"
    #"PayeeINN": STG_РеквизитыСоотв = "ИНН"
    #"KPP": STG_РеквизитыСоотв = "КПП"
  КОНЕЦ_ВЫБОРА
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ STG_ДобЗначРеквизит(ТИП_СТРОКА: инд, имя, значение) //все значения
  ДобавитьЗначениеС(к_спрСайтаРеквизиты, инд + "|SPR_REKV_type", "spr_rekv--spr_rekv")
  ДобавитьЗначениеС(к_спрСайтаРеквизиты, инд + "|SPR_REKV_name", имя)
  ДобавитьЗначениеС(к_спрСайтаРеквизиты, инд + "|SPR_REKV_value", значение)
  ЕСЛИ IB_CONTEXT_СчитатьЛок("синхронизацияСайта") = "" ТО
    ДобавитьЗначениеЛ(к_спрСайтаРеквизиты, инд + "|SPR_REKV_is_synced", НЕТ)
  ИНАЧЕ
    ДобавитьЗначениеЛ(к_спрСайтаРеквизиты, инд + "|SPR_REKV_is_synced", ДА)
  КОНЕЦ_ЕСЛИ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ ТИП_SQL ТИП_ЛОГИКА: STG_СинхронизироватьРекв(ТИП_СТРОКА: id)
  спр = "Справочник реквизитов"
  ЕСЛИ id = "" ТО
    id = СТР_ЗНАЧ(SPR_REKV_id)
  КОНЕЦ_ЕСЛИ
  РЕЗУЛЬТАТ = НЕТ
  ЕСЛИ СУЩ_ПЕРЕМ(SPR_REKV_эл_счит[id + "|SPR_REKV_name"]) ТО
    ЕСЛИ SPR_REKV_эл_счит[id + "|SPR_REKV_name"] ТО
      ЕСЛИ СУЩ_ПЕРЕМ(Данные!ВсегоСтр!"D") ТО
        Данные!ВсегоСтр!"D"++
      КОНЕЦ_ЕСЛИ
      ЕСЛИ stg_профилиВыгрузкиСпр!спр!"_subreq_add" ТО
        SPR_REKV_Упаковать(id)
      КОНЕЦ_ЕСЛИ
      поз = НАЙТИ_ПОЗ("name", STG_РеквизитыСоотв(SPR_REKV_name))
      ЕСЛИ поз > 0 ТО
        ЕСЛИ СУЩ_ПЕРЕМ(Данные!ВсегоСтр!"E") ТО
          Данные!ВсегоСтр!"E"++
        КОНЕЦ_ЕСЛИ
        ПЕРЕЙТИ(поз)
        ЕСЛИ SPR_REKV_эл_счит[id + "|SPR_REKV_is_synced"] ТО
          ЗАП_ПОЛЕ("IS_SYNCED", SPR_REKV_is_synced)
        КОНЕЦ_ЕСЛИ
        ЕСЛИ SPR_REKV_эл_счит[id + "|SPR_REKV_id"] ТО
          ЗАП_ПОЛЕ("ID_RECSITE", SPR_REKV_id)
        КОНЕЦ_ЕСЛИ
        ЕСЛИ SPR_REKV_эл_счит[id + "|SPR_REKV_uuid"] ТО
          ЗАП_ПОЛЕ("UUID", SPR_REKV_uuid)
        КОНЕЦ_ЕСЛИ
        ЗАМЕНИТЬ
        РЕЗУЛЬТАТ = ДА
      ИНАЧЕ
        ЕСЛИ СУЩ_ПЕРЕМ(Данные!ВсегоСтр!"F") ТО
          Данные!ВсегоСтр!"F"++
        КОНЕЦ_ЕСЛИ
      КОНЕЦ_ЕСЛИ
    КОНЕЦ_ЕСЛИ
  КОНЕЦ_ЕСЛИ
  STG_СинхронизироватьРекв = РЕЗУЛЬТАТ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
//-------------------------------------------------------------------------------------------------------------------------//
ПЕРЕМ stg_настройкиIdНаСайте!
ПЕРЕМ stg_настройкиUuidНаСайте!
ПЕРЕМ stg_настройкиЗначНаСайте!
ФУНКЦИЯ STG_ВыгрузитьНастройки
  СБРОС(SPR_SETS_эл_доб, SPR_SETS_эл_счит, SPR_SETS_эл_знач, SPR_SETS_эл_изм, SPR_SETS_эл_id)
  спр = "Настройки программы/сайта"
  rest_колЭлемПодЗапрДоб = stg_профилиВыгрузкиСпр!спр!"_qty_add"
  
  СБРОС(stg_настройкиIdНаСайте, stg_настройкиUuidНаСайте, stg_настройкиЗначНаСайте)
  
  ЕСЛИ оп_проверятьБазуПоСайту ТО
    ЕСЛИ SPR_SETS_ПолучитьСписок(ДА) ТО
      STG_ПроверитьИдБазы(ф_СпрНастроекСайт)
    КОНЕЦ_ЕСЛИ
    СБРОС(SPR_SETS_эл_id, SPR_SETS_эл_уд, SPR_SETS_эл_счит, SPR_SETS_эл_доб,  SPR_SETS_эл_знач, SPR_SETS_эл_изм, REST_эл)
  КОНЕЦ_ЕСЛИ
  
  STG_ПоказатьНастройки(НЕТ)
  sql = SQL_ОТКРЫТЬ(ф_СпрНастроекСайт)
  
  //STG_R_НастройкиПечатиПД
  STG_ИниСтрокуОтчета("Настройки")
  
  настройка!"Кодировка ДШК" = СТР_ЗНАЧ(ПараметрПечатиПД!"Кодировка ДШК")
  настройка!"Рекв. ""Вид платежа"" для взносов" = ПараметрПечатиПД!"Вид платежа остальные"
  настройка!"Рекв. ""Вид платежа"" для взносов по ИПУ" = ПараметрПечатиПД!"Вид платежа ИПУ"
  
  STG_СчитатьШаблоны(к_ОбщиеРеквизиты)
  настройка!"Рекв. ДШК ""Адрес плательщика""" = г_ПарамШаблонаДШК!к_ШаблонАдресПлательщика
  
  STG_СчитатьШаблоны(к_ФормаПД4 + ", " + к_ФормаПДМнож)
  настройка!"Рекв. ДШК ""Назначение платежа"" для взносов" = г_ПарамШаблонаДШК!к_ШаблонНазначениеПлатежа
  
  STG_СчитатьШаблоны(к_ФормаПД4ЭЭ + ", " + к_ФормаПДСчСтд)
  настройка!"Рекв. ДШК ""Назначение платежа"" для ИПУ" = г_ПарамШаблонаДШК!к_ШаблонНазначениеПлатежа
  настройка!"Рекв. ДШК ""Назначение платежа"" для ИПУ без пок." = г_ПарамШаблонаДШК!к_ШаблонНазнПлатежаБезПок

  SPR_SETS_ПолучитьСписок(НЕТ)
  ЦИКЛ ИНДЕКС(знач0 = SPR_SETS_эл_счит!индекс)
    ЕСЛИ ПОЗ("SPR_SETS_name", индекс) > 0 ТО
      ЕСЛИ СУЩ_ПЕРЕМ(SPR_SETS_эл_знач!индекс) ТО
        текИд = СТР_ФРАГ(индекс, "|", 1)
        stg_настройкиIdНаСайте[SPR_SETS_эл_знач!индекс] = SPR_SETS_эл_знач!текИд!"|SPR_SETS_id"
        stg_настройкиUuidНаСайте[SPR_SETS_эл_знач!индекс] = SPR_SETS_эл_знач!текИд!"|SPR_SETS_uuid"
        stg_настройкиЗначНаСайте[SPR_SETS_эл_знач!индекс] = SPR_SETS_эл_знач!текИд!"|SPR_SETS_value"
      КОНЕЦ_ЕСЛИ
    КОНЕЦ_ЕСЛИ
  КОНЕЦ_ЦИКЛА
  СБРОС(SPR_SETS_эл_доб, SPR_SETS_эл_счит, SPR_SETS_эл_знач, SPR_SETS_эл_изм)

  и = 0
  ЦИКЛ ДЛЯ(ит = 1, ?(stg_профилиВыгрузкиСпр!спр!"_subreq_add", 2, 1))
    СтатусСоздать("Выгрузка реквизитов")
    СтатусСтартПрогресс(КОЛ_ЭЛЕМ(настройка))
    ЦИКЛ ИНДЕКС(знач = настройка!имя)
      и++
      инд = СТР_ЗНАЧ(и)
      ЕСЛИ СУЩ_ПЕРЕМ(Данные!ВсегоСтр!"C") И ит = 1 ТО
        Данные!ВсегоСтр!"C"++
        //Данные!ВсегоСтр!"D"++
        //Данные!ВсегоСтр!"E"++
      КОНЕЦ_ЕСЛИ
      
      значК = ?(знач = "", " ", знач)
      
      STG_ПрокачкаСтатуса("обработка настройки " + имя)
      ЕСЛИ НЕ СУЩ_ПЕРЕМ(stg_настройкиUuidНаСайте!имя) И ит = 1 ТО
        SPR_SETS_эл_доб!инд = НЕТ
        STG_ДобЗначНастр(инд, имя, значК)
      ИНАЧЕ
        ЕСЛИ СУЩ_ПЕРЕМ(stg_настройкиЗначНаСайте!имя) ТО
          ЕСЛИ ит = 2 И stg_настройкиЗначНаСайте!имя <> значК ТО
            инд = СТР_ЗНАЧ(stg_настройкиIdНаСайте!имя)
            STG_ДобавитьЭлИд(к_спрСайтаНастройки, инд)
            ДобавитьЗначениеС(к_спрСайтаНастройки, инд + "|SPR_SETS_uuid", stg_настройкиUuidНаСайте!имя)
            ДобавитьЗначениеС(к_спрСайтаНастройки, инд + "|SPR_SETS_type", SPR_SETS_type)
            ДобавитьЗначениеС(к_спрСайтаНастройки, инд + "|SPR_SETS_value", знач)
          КОНЕЦ_ЕСЛИ
        КОНЕЦ_ЕСЛИ
      КОНЕЦ_ЕСЛИ
      
      ЕСЛИ НЕ stg_профилиВыгрузкиСпр!спр!"_subreq_add" ТО
        рез = ДА
        ЕСЛИ НЕ СУЩ_ПЕРЕМ(stg_настройкиUuidНаСайте!имя) И ит = 1 ТО
          рез = SPR_SETS_ДобавитьМнож(stg_профилиВыгрузкиСпр!спр!"_subreq_add")
          ЕСЛИ рез ТО
            sql.STG_СинхронизироватьНастрБл(инд)
          КОНЕЦ_ЕСЛИ
        ИНАЧЕ
          ЕСЛИ stg_настройкиЗначНаСайте!имя <> знач И ит = 2 ТО
            рез = SPR_SETS_ИзменитьМнож(stg_профилиВыгрузкиСпр!спр!"_subreq_add")
            ЕСЛИ рез ТО
              sql.STG_СинхронизироватьНастрБл(инд)
            КОНЕЦ_ЕСЛИ
          КОНЕЦ_ЕСЛИ
        КОНЕЦ_ЕСЛИ
        СБРОС(SPR_SETS_эл_доб, SPR_SETS_эл_счит, SPR_SETS_эл_знач, SPR_SETS_эл_изм, SPR_SETS_эл_id)
        ЕСЛИ НЕ рез ТО
          ПРОДОЛЖИТЬ
        КОНЕЦ_ЕСЛИ
      КОНЕЦ_ЕСЛИ
    КОНЕЦ_ЦИКЛА
    СтатусЗакрыть
  
    ЕСЛИ stg_профилиВыгрузкиСпр!спр!"_subreq_add" ТО
      ЕСЛИ КОЛ_ЭЛЕМ(SPR_SETS_эл_доб) > 0 ТО
        ЕСЛИ SPR_SETS_ДобавитьМнож(stg_профилиВыгрузкиСпр!спр!"_subreq_add") ТО
          СтатусСоздать("Синхронизация настроек")
          СтатусСтартПрогресс(КОЛ_ЭЛЕМ(REST_эл_id))
          ЦИКЛ ИНДЕКС(лог = SPR_SETS_эл_доб!инд)
            ЕСЛИ лог ТО
              STG_ПрокачкаСтатуса("Синхронизация настроек")
              sql.STG_СинхронизироватьНастрБл(инд)
            КОНЕЦ_ЕСЛИ
          КОНЕЦ_ЦИКЛА
          СтатусЗакрыть
        КОНЕЦ_ЕСЛИ
        СБРОС(SPR_SETS_эл_доб, SPR_SETS_эл_счит, SPR_SETS_эл_знач, SPR_SETS_эл_изм, SPR_SETS_эл_id)
      КОНЕЦ_ЕСЛИ
      ЕСЛИ КОЛ_ЭЛЕМ(SPR_SETS_эл_id) > 0 ТО
        ЕСЛИ SPR_SETS_ИзменитьМнож(stg_профилиВыгрузкиСпр!спр!"_subreq_add") ТО
          СтатусСоздать("Синхронизация настроек")
          СтатусСтартПрогресс(КОЛ_ЭЛЕМ(REST_эл_id))
          ЦИКЛ ИНДЕКС(лог = SPR_SETS_эл_доб!инд)
            ЕСЛИ лог ТО
              STG_ПрокачкаСтатуса("Синхронизация настроек")
              sql.STG_СинхронизироватьНастрБл(инд)
            КОНЕЦ_ЕСЛИ
          КОНЕЦ_ЦИКЛА
          СтатусЗакрыть
        КОНЕЦ_ЕСЛИ
        СБРОС(SPR_SETS_эл_доб, SPR_SETS_эл_счит, SPR_SETS_эл_знач, SPR_SETS_эл_изм, SPR_SETS_эл_id)
      КОНЕЦ_ЕСЛИ
    КОНЕЦ_ЕСЛИ
  КОНЕЦ_ЦИКЛА
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ STG_ДобЗначНастр(ТИП_СТРОКА: инд, имя, значение) //все значения
  ДобавитьЗначениеС(к_спрСайтаНастройки, инд + "|SPR_SETS_type", SPR_SETS_type)
  ДобавитьЗначениеС(к_спрСайтаНастройки, инд + "|SPR_SETS_name", имя)
  ДобавитьЗначениеС(к_спрСайтаНастройки, инд + "|SPR_SETS_value", значение)
  ДобавитьЗначениеЧ(к_спрСайтаНастройки, инд + "|SPR_SETS_id_owner", 0)
  ЕСЛИ IB_CONTEXT_СчитатьЛок("синхронизацияСайта") = "" ТО
    ДобавитьЗначениеЛ(к_спрСайтаНастройки, инд + "|SPR_SETS_is_synced", НЕТ)
  ИНАЧЕ
    ДобавитьЗначениеЛ(к_спрСайтаНастройки, инд + "|SPR_SETS_is_synced", ДА)
  КОНЕЦ_ЕСЛИ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ ТИП_SQL ТИП_ЛОГИКА: STG_СинхронизироватьНастрБл(ТИП_СТРОКА: id)
  спр = "Настройки программы/сайта"
  ЕСЛИ id = "" ТО
    id = СТР_ЗНАЧ(SPR_SETS_id)
  КОНЕЦ_ЕСЛИ
  РЕЗУЛЬТАТ = НЕТ
  ЕСЛИ СУЩ_ПЕРЕМ(SPR_SETS_эл_счит[id + "|SPR_SETS_name"]) ТО
    ЕСЛИ SPR_SETS_эл_счит[id + "|SPR_SETS_name"] ТО
      ЕСЛИ СУЩ_ПЕРЕМ(Данные!ВсегоСтр!"D") ТО
        Данные!ВсегоСтр!"D"++
      КОНЕЦ_ЕСЛИ
      ЕСЛИ stg_профилиВыгрузкиСпр!спр!"_subreq_add" ТО
        SPR_SETS_Упаковать(id)
      КОНЕЦ_ЕСЛИ
      поз = НАЙТИ_ПОЗ("name", SPR_SETS_name)
      ЕСЛИ поз > 0 ТО
        ЕСЛИ СУЩ_ПЕРЕМ(Данные!ВсегоСтр!"E") ТО
          Данные!ВсегоСтр!"E"++
        КОНЕЦ_ЕСЛИ
        ПЕРЕЙТИ(поз)
        ЕСЛИ SPR_SETS_эл_счит[id + "|SPR_SETS_is_synced"] ТО
          ЗАП_ПОЛЕ("IS_SYNCED", SPR_SETS_is_synced)
        КОНЕЦ_ЕСЛИ
        ЕСЛИ SPR_SETS_эл_счит[id + "|SPR_SETS_id"] ТО
          ЗАП_ПОЛЕ("ID_RECSITE", SPR_SETS_id)
        КОНЕЦ_ЕСЛИ
        ЕСЛИ SPR_SETS_эл_счит[id + "|SPR_SETS_uuid"] ТО
          ЗАП_ПОЛЕ("UUID", SPR_SETS_uuid)
        КОНЕЦ_ЕСЛИ
        ЗАМЕНИТЬ
        РЕЗУЛЬТАТ = ДА
      ИНАЧЕ
        ЕСЛИ СУЩ_ПЕРЕМ(Данные!ВсегоСтр!"F") ТО
          Данные!ВсегоСтр!"F"++
        КОНЕЦ_ЕСЛИ
      КОНЕЦ_ЕСЛИ
    КОНЕЦ_ЕСЛИ
  КОНЕЦ_ЕСЛИ
  STG_СинхронизироватьНастрБл = РЕЗУЛЬТАТ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ STG_ВыгрузитьГолосования
  СБРОС(MP_POLL_эл_доб, MP_POLL_эл_счит, MP_POLL_эл_знач, MP_POLL_эл_изм)
  спр = "Голосования"
  rest_колЭлемПодЗапрДоб = stg_профилиВыгрузкиСпр!спр!"_qty_add"
  
  ЕСЛИ оп_проверятьБазуПоСайту ТО
    ЕСЛИ MP_POLL_ПолучитьСписок(ДА) ТО
      STG_ПроверитьИдБазы(mp_файлГолосований)
    КОНЕЦ_ЕСЛИ
    СБРОС(MP_POLL_эл_id, MP_POLL_эл_уд, MP_POLL_эл_счит, MP_POLL_эл_доб,  MP_POLL_эл_знач, MP_POLL_эл_изм, REST_эл)
  КОНЕЦ_ЕСЛИ
  
  справочник = к_спрСайтаГолосования
  СОЗДАТЬ(сп, ТИП_СПИСОК)
  сп.ДОБАВИТЬ("SELECT * FROM")
  сп.ДОБАВИТЬ("'" + mp_файлГолосований + "'")
  сп.ДОБАВИТЬ("WHERE (IS_SYNCED = FALSE OR IS_SYNCED IS NULL) AND ID_RECSITE = 0")
  sql_loop = SQL_ЗАПРОС(сп)
  длина = ДЛИНА(СТР_ЗНАЧ(sql_loop.ВСЕГО))
  sql = SQL_ОТКРЫТЬ(mp_файлГолосований)
  STG_ИниСтрокуОтчета("Справочник голосований")
  СтатусСоздать("Обработка голосований для выгрузки")
  СтатусСтартПрогресс(sql_loop.ВСЕГО)
  ЦИКЛ ДЛЯ(и = sql_loop.ВСЕГО, 1, -1)
    sql_loop.ПЕРЕЙТИ(и)
    инд = СТР0(и, длина)
    MP_POLL_эл_доб!инд = НЕТ
    Данные!ВсегоСтр!"C"++
    
    STG_ПрокачкаСтатуса("обработка голосований: " + sql_loop.ПОЛЕ("label"))
    
    sql_loop.STG_ДобЗначГолосования(инд, "д")
    
    ЕСЛИ НЕ stg_профилиВыгрузкиСпр!спр!"_subreq_add" ТО
      ЕСЛИ MP_POLL_ДобавитьМнож(НЕТ) ТО
        ЕСЛИ sql.STG_СинхронизироватьГолос("") ТО
          sql.STG_ОбновитьLabelНаСайте(справочник, "POLL")
        КОНЕЦ_ЕСЛИ
      ИНАЧЕ
        СТОП
      КОНЕЦ_ЕСЛИ
      
      СБРОС(MP_POLL_эл_доб, MP_POLL_эл_счит, MP_POLL_эл_знач, MP_POLL_эл_изм)
    КОНЕЦ_ЕСЛИ
  КОНЕЦ_ЦИКЛА
  СтатусЗакрыть
  
  ЕСЛИ stg_профилиВыгрузкиСпр!спр!"_subreq_add" ТО
    MP_POLL_ДобавитьМнож(stg_профилиВыгрузкиСпр!спр!"_subreq_add")
    СтатусСоздать("Синхронизация справочника голосований")
    СтатусСтартПрогресс(КОЛ_ЭЛЕМ(REST_эл_id))
    //STG_СбросИндексов(справочник)
    ЦИКЛ ИНДЕКС(лог = MP_POLL_эл_доб!инд)
      ЕСЛИ лог ТО
        STG_ПрокачкаСтатуса("Синхронизация справочника голосований")
        ЕСЛИ sql.STG_СинхронизироватьГолос(инд) ТО
          sql.STG_ДобЗначLabelНаСайте(инд, справочник, "POLL")
          STG_ИзменитьНаСайте(справочник)
          СБРОС(MP_POLL_эл_изм)
        КОНЕЦ_ЕСЛИ
      КОНЕЦ_ЕСЛИ
    КОНЕЦ_ЦИКЛА
    СтатусЗакрыть
    СБРОС(MP_POLL_эл_доб, MP_POLL_эл_счит, MP_POLL_эл_знач, MP_POLL_эл_изм)
  КОНЕЦ_ЕСЛИ
  
  sql_loop.ЗАКРЫТЬ
  sql.ЗАКРЫТЬ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ STG_ВыгрузитьВопросы
  СБРОС(MP_QUESTION_эл_доб, MP_QUESTION_эл_счит, MP_QUESTION_эл_знач, MP_QUESTION_эл_изм)
  спр = "Голосования"
  rest_колЭлемПодЗапрДоб = stg_профилиВыгрузкиСпр!спр!"_qty_add"
  
  ЕСЛИ оп_проверятьБазуПоСайту ТО
    ЕСЛИ MP_QUESTION_ПолучитьСписок(ДА) ТО
      STG_ПроверитьИдБазы(mp_файлВопросов)
    КОНЕЦ_ЕСЛИ
    СБРОС(MP_QUESTION_эл_id, MP_QUESTION_эл_уд, MP_QUESTION_эл_счит, MP_QUESTION_эл_доб,  MP_QUESTION_эл_знач, MP_QUESTION_эл_изм, REST_эл)
  КОНЕЦ_ЕСЛИ
  
  справочник = к_спрСайтаВопросы
  СОЗДАТЬ(сп, ТИП_СПИСОК)
  сп.ДОБАВИТЬ("SELECT * FROM")
  сп.ДОБАВИТЬ("'" + mp_файлВопросов + "'")
  сп.ДОБАВИТЬ("WHERE (IS_SYNCED = FALSE OR IS_SYNCED IS NULL) AND ID_RECSITE = 0")
  sql_loop = SQL_ЗАПРОС(сп)
  длина = ДЛИНА(СТР_ЗНАЧ(sql_loop.ВСЕГО))
  sql = SQL_ОТКРЫТЬ(mp_файлВопросов)
  STG_ИниСтрокуОтчета("Справочник вопросов")
  СтатусСоздать("Обработка вопросов для выгрузки")
  СтатусСтартПрогресс(sql_loop.ВСЕГО)
  ЦИКЛ ДЛЯ(и = sql_loop.ВСЕГО, 1, -1)
    sql_loop.ПЕРЕЙТИ(и)
    инд = СТР0(и, длина)
    MP_QUESTION_эл_доб!инд = НЕТ
    Данные!ВсегоСтр!"C"++
    
    STG_ПрокачкаСтатуса("обработка вопросов: " + sql_loop.ПОЛЕ("label"))
    
    sql_loop.STG_ДобЗначВопросы(инд, "д")
    
    ЕСЛИ НЕ stg_профилиВыгрузкиСпр!спр!"_subreq_add" ТО
      ЕСЛИ MP_QUESTION_ДобавитьМнож(НЕТ) ТО
        ЕСЛИ sql.STG_СинхронизироватьВопросы("") ТО
          sql.STG_ОбновитьLabelНаСайте(справочник, "QUESTION")
        КОНЕЦ_ЕСЛИ
      ИНАЧЕ
        СТОП
      КОНЕЦ_ЕСЛИ
      
      СБРОС(MP_QUESTION_эл_доб, MP_QUESTION_эл_счит, MP_QUESTION_эл_знач, MP_QUESTION_эл_изм)
    КОНЕЦ_ЕСЛИ
  КОНЕЦ_ЦИКЛА
  СтатусЗакрыть
  
  ЕСЛИ stg_профилиВыгрузкиСпр!спр!"_subreq_add" ТО
    MP_QUESTION_ДобавитьМнож(stg_профилиВыгрузкиСпр!спр!"_subreq_add")
    СтатусСоздать("Синхронизация справочника вопросов")
    СтатусСтартПрогресс(КОЛ_ЭЛЕМ(REST_эл_id))
    ЦИКЛ ИНДЕКС(лог = MP_QUESTION_эл_доб!инд)
      ЕСЛИ лог ТО
        STG_ПрокачкаСтатуса("Синхронизация справочника вопросов")
        ЕСЛИ sql.STG_СинхронизироватьВопросы(инд) ТО
          sql.STG_ДобЗначLabelНаСайте(инд, справочник, "QUESTION")
        КОНЕЦ_ЕСЛИ
      КОНЕЦ_ЕСЛИ
    КОНЕЦ_ЦИКЛА
    СтатусЗакрыть
    STG_ИзменитьНаСайте(справочник)
    СБРОС(MP_QUESTION_эл_доб, MP_QUESTION_эл_счит, MP_QUESTION_эл_знач, MP_QUESTION_эл_изм)
  КОНЕЦ_ЕСЛИ
  
  sql_loop.ЗАКРЫТЬ
  sql.ЗАКРЫТЬ
КОНЕЦ_ФУНКЦИИ


//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ STG_ВыгрузитьОтветы
  СБРОС(MP_ANSWER_эл_доб, MP_ANSWER_эл_счит, MP_ANSWER_эл_знач, MP_ANSWER_эл_изм)
  спр = "Голосования"
  rest_колЭлемПодЗапрДоб = stg_профилиВыгрузкиСпр!спр!"_qty_add"
  
  ЕСЛИ оп_проверятьБазуПоСайту ТО
    ЕСЛИ MP_ANSWER_ПолучитьСписок(ДА) ТО
      STG_ПроверитьИдБазы(mp_файлОтветов)
    КОНЕЦ_ЕСЛИ
    СБРОС(MP_ANSWER_эл_id, MP_ANSWER_эл_уд, MP_ANSWER_эл_счит, MP_ANSWER_эл_доб,  MP_ANSWER_эл_знач, MP_ANSWER_эл_изм, REST_эл)
  КОНЕЦ_ЕСЛИ
  
  справочник = к_спрСайтаОтветы
  СОЗДАТЬ(сп, ТИП_СПИСОК)
  сп.ДОБАВИТЬ("SELECT * FROM")
  сп.ДОБАВИТЬ("'" + mp_файлОтветов + "'")
  сп.ДОБАВИТЬ("WHERE (IS_SYNCED = FALSE OR IS_SYNCED IS NULL) AND ID_RECSITE = 0")
  sql_loop = SQL_ЗАПРОС(сп)
  длина = ДЛИНА(СТР_ЗНАЧ(sql_loop.ВСЕГО))
  sql = SQL_ОТКРЫТЬ(mp_файлОтветов)
  STG_ИниСтрокуОтчета("Справочник ответов")
  СтатусСоздать("Обработка ответов для выгрузки")
  СтатусСтартПрогресс(sql_loop.ВСЕГО)
  ЦИКЛ ДЛЯ(и = sql_loop.ВСЕГО, 1, -1)
    sql_loop.ПЕРЕЙТИ(и)
    инд = СТР0(и, длина)
    MP_ANSWER_эл_доб!инд = НЕТ
    Данные!ВсегоСтр!"C"++
    
    STG_ПрокачкаСтатуса("обработка ответов: " + sql_loop.ПОЛЕ("label"))
    
    sql_loop.STG_ДобЗначОтветы(инд, "д")
    
    ЕСЛИ НЕ stg_профилиВыгрузкиСпр!спр!"_subreq_add" ТО
      ЕСЛИ MP_ANSWER_ДобавитьМнож(НЕТ) ТО
        ЕСЛИ sql.STG_СинхронизироватьОтветы("") ТО
          sql.STG_ОбновитьLabelНаСайте(справочник, "ANSWER")
        КОНЕЦ_ЕСЛИ
      ИНАЧЕ
        СТОП
      КОНЕЦ_ЕСЛИ
      
      СБРОС(MP_ANSWER_эл_доб, MP_ANSWER_эл_счит, MP_ANSWER_эл_знач, MP_ANSWER_эл_изм)
    КОНЕЦ_ЕСЛИ
  КОНЕЦ_ЦИКЛА
  СтатусЗакрыть
  
  ЕСЛИ stg_профилиВыгрузкиСпр!спр!"_subreq_add" ТО
    MP_ANSWER_ДобавитьМнож(stg_профилиВыгрузкиСпр!спр!"_subreq_add")
    СтатусСоздать("Синхронизация справочника ответов")
    СтатусСтартПрогресс(КОЛ_ЭЛЕМ(REST_эл_id))
    ЦИКЛ ИНДЕКС(лог = MP_ANSWER_эл_доб!инд)
      ЕСЛИ лог ТО
        STG_ПрокачкаСтатуса("Синхронизация справочника ответов")
        ЕСЛИ sql.STG_СинхронизироватьОтветы(инд) ТО
          sql.STG_ДобЗначLabelНаСайте(инд, справочник, "ANSWER")
        КОНЕЦ_ЕСЛИ
      КОНЕЦ_ЕСЛИ
    КОНЕЦ_ЦИКЛА
    СтатусЗакрыть
    STG_ИзменитьНаСайте(справочник)
    СБРОС(MP_ANSWER_эл_доб, MP_ANSWER_эл_счит, MP_ANSWER_эл_знач, MP_ANSWER_эл_изм)
  КОНЕЦ_ЕСЛИ
  
  sql_loop.ЗАКРЫТЬ
  sql.ЗАКРЫТЬ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
//-------------------------------------------------------------------------------------------------------------------------//
ПЕРЕМ stg_остатокНаСайте!
ПЕРЕМ stg_остатокРасчетный!
ФУНКЦИЯ STG_ВыгрузитьОстатки
  СБРОС(SPR_DEBTS_эл_доб, SPR_DEBTS_эл_счит, SPR_DEBTS_эл_знач, SPR_DEBTS_эл_изм, SPR_DEBTS_эл_id)
  спр = "Журнал остатков"
  rest_колЭлемПодЗапрДоб = stg_профилиВыгрузкиСпр!спр!"_qty_add"
  
  //ЕСЛИ оп_проверятьБазуПоСайту ТО
  //  ЕСЛИ MP_ANSWER_ПолучитьСписок(ДА) ТО
  //    STG_ПроверитьИдБазы(mp_файлОтветов)
  //  КОНЕЦ_ЕСЛИ
  //  СБРОС(MP_ANSWER_эл_id, MP_ANSWER_эл_уд, MP_ANSWER_эл_счит, MP_ANSWER_эл_доб,  MP_ANSWER_эл_знач, MP_ANSWER_эл_изм, REST_эл)
  //КОНЕЦ_ЕСЛИ
  
  //считываем остатки с сайта
  СБРОС(stg_остатокНаСайте, stg_остатокРасчетный)
  SPR_DEBTS_ПолучитьСписок(ДА)
  ЦИКЛ ИНДЕКС(знач = SPR_DEBTS_эл_счит!индекс)
    ЕСЛИ ПОЗ("SPR_DEBTS_id", индекс) > 0 ТО
      ЕСЛИ СУЩ_ПЕРЕМ(SPR_DEBTS_эл_знач!индекс) ТО
        текИд = СТР_ФРАГ(индекс, "|", 1)
        stg_остатокНаСайте[SPR_DEBTS_эл_знач!индекс] = SPR_DEBTS_эл_знач!текИд!"|SPR_DEBTS_uuid"
      КОНЕЦ_ЕСЛИ
    КОНЕЦ_ЕСЛИ
  КОНЕЦ_ЦИКЛА
  СБРОС(SPR_DEBTS_эл_доб, SPR_DEBTS_эл_счит, SPR_DEBTS_эл_знач, SPR_DEBTS_эл_изм)
  
  //расчет остатков
  СОЗДАТЬ(sql, ТИП_SQL)
  sql.STG_ЗапросВыгрузкиОстатки(путь) //это расчетные остатки
  //БД_РЕДАКТОР(sql)
  //СТОП_ВСЕ
  длина = ДЛИНА(СТР_ЗНАЧ(sql.ВСЕГО))
  sql_sync = SQL_ОТКРЫТЬ(ф_ЖурналСинхрОстатков)
  
  STG_ИниСтрокуОтчета("Журнал остатков")
  ЦИКЛ ДЛЯ(ит = 1, 3)
    //1 добавлена; 2 изменение; 3 удаление - но только для сабрек. если без них, то просто идём по циклу и ебашим всё без разбора
    СтатусСоздать("Выгрузка остатков")
    СтатусСтартПрогресс(sql.ВСЕГО)
    ЦИКЛ ДЛЯ(и = 1, sql.ВСЕГО)
      sql.ПЕРЕЙТИ(и)
      STG_ПрокачкаСтатуса("")
      
      инд = СТР0(и, длина)
      
      //Данные!ВсегоСтр!"D"++ //спорно, но пока пусть будет так
      //Данные!ВсегоСтр!"E"++
      
      ВЫБОР(ит)
       #1: 
         ЕСЛИ sql.ПОЛЕ("ID_RECSITE") <= 0 ТО
           Данные!ВсегоСтр!"C"++
           SPR_DEBTS_эл_доб!инд = НЕТ
           sql.STG_ДобЗначОстатка(инд)
         КОНЕЦ_ЕСЛИ
       #2: 
         ЕСЛИ sql.ПОЛЕ("ID_RECSITE") <> 0 И НЕ sql.ПОЛЕ("IS_SYNCED") И sql.ПОЛЕ("SALDO") <> 0 ТО
           Данные!ВсегоСтр!"C"++
           инд = СТР_ЗНАЧ(sql.ПОЛЕ("ID_RECSITE"))
           STG_ДобавитьЭлИд(к_спрСайтаОстатки, инд)
           ДобавитьЗначениеС("debts", инд + "|SPR_DEBTS_uuid", stg_остатокНаСайте[sql.ПОЛЕ("ID_RECSITE")])
           ДобавитьЗначениеС("debts", инд + "|SPR_DEBTS_type", SPR_DEBTS_type)
           ДобавитьЗначениеЧ("debts", инд + "|SPR_DEBTS_sum", sql.ПОЛЕ("SALDO"))
           ДобавитьЗначениеЛ("debts", инд + "|SPR_DEBTS_is_synced", ДА)
         КОНЕЦ_ЕСЛИ
       #3:
         ЕСЛИ sql.ПОЛЕ("ID_RECSITE") <> 0 И sql.ПОЛЕ("SALDO") = 0 ТО
           Данные!ВсегоСтр!"C"++
           STG_ДобавитьЭлИд(к_спрСайтаОстатки, СТР_ЗНАЧ(sql.ПОЛЕ("ID_RECSITE")))
         КОНЕЦ_ЕСЛИ
      КОНЕЦ_ВЫБОРА
      
      ЕСЛИ НЕ stg_профилиВыгрузкиСпр!спр!"_subreq_add" ТО
        ВЫБОР(ит)
         #1: рез = SPR_DEBTS_ДобавитьМнож(stg_профилиВыгрузкиСпр!спр!"_subreq_add")
         #2: рез = SPR_DEBTS_ИзменитьМнож(stg_профилиВыгрузкиСпр!спр!"_subreq_add")
         #3: рез = SPR_DEBTS_УдалитьМнож(stg_профилиВыгрузкиСпр!спр!"_subreq_add")
        КОНЕЦ_ВЫБОРА
        ЕСЛИ рез ТО
          ЕСЛИ НЕ sql_sync.STG_СинхронизироватьОстатки("") ТО
            Данные!ВсегоСтр!"F"++
          КОНЕЦ_ЕСЛИ
          СБРОС(SPR_DEBTS_эл_доб, SPR_DEBTS_эл_счит, SPR_DEBTS_эл_знач, SPR_DEBTS_эл_изм, SPR_DEBTS_эл_id)
        ИНАЧЕ
          ЕСЛИ КОЛ_ЭЛЕМ(SPR_DEBTS_эл_id) > 0 ИЛИ КОЛ_ЭЛЕМ(SPR_DEBTS_эл_доб) > 0 ТО
            Данные!ВсегоСтр!"F"++
          КОНЕЦ_ЕСЛИ
          СБРОС(SPR_DEBTS_эл_доб, SPR_DEBTS_эл_счит, SPR_DEBTS_эл_знач, SPR_DEBTS_эл_изм, SPR_DEBTS_эл_id)
          ПРОДОЛЖИТЬ
        КОНЕЦ_ЕСЛИ
      КОНЕЦ_ЕСЛИ
    КОНЕЦ_ЦИКЛА
    СтатусЗакрыть
    //
    ЕСЛИ stg_профилиВыгрузкиСпр!спр!"_subreq_add" ТО
      ВЫБОР(ит)
       #1: 
        ЕСЛИ КОЛ_ЭЛЕМ(SPR_DEBTS_эл_доб) > 0 ТО
          //ОТЛАДКА("ДОБАВЛЕНИЕ")
          SPR_DEBTS_ДобавитьМнож(stg_профилиВыгрузкиСпр!спр!"_subreq_add")
          СтатусСоздать("Синхронизация журнала остатков")
          СтатусСтартПрогресс(КОЛ_ЭЛЕМ(REST_эл_id))
          ЦИКЛ ИНДЕКС(лог = SPR_DEBTS_эл_доб!инд)
            ЕСЛИ лог ТО
              STG_ПрокачкаСтатуса("Синхронизация журнала остатков")
              sql_sync.STG_СинхронизироватьОстатки(инд)
            КОНЕЦ_ЕСЛИ
          КОНЕЦ_ЦИКЛА
          СтатусЗакрыть
        КОНЕЦ_ЕСЛИ
       #2: 
        ЕСЛИ КОЛ_ЭЛЕМ(SPR_DEBTS_эл_id) > 0 ТО
          //ОТЛАДКА("ИЗМЕНЕНИЕ")
          SPR_DEBTS_ИзменитьМнож(stg_профилиВыгрузкиСпр!спр!"_subreq_add")
          СтатусСоздать("Синхронизация журнала остатков")
          СтатусСтартПрогресс(КОЛ_ЭЛЕМ(REST_эл_id))
          ЦИКЛ ИНДЕКС(ид = SPR_DEBTS_эл_id!инд)
            STG_ПрокачкаСтатуса("Синхронизация журнала остатков")
            sql_sync.STG_СинхронизироватьОстатки(инд)
          КОНЕЦ_ЦИКЛА
          СтатусЗакрыть
        КОНЕЦ_ЕСЛИ
       #3: 
        ЕСЛИ КОЛ_ЭЛЕМ(SPR_DEBTS_эл_id) > 0 ТО
          //ОТЛАДКА("УДАЛЕНИЕ")
          г_запросНаСайт = ДА
          SPR_DEBTS_УдалитьМнож(stg_профилиВыгрузкиСпр!спр!"_subreq_add")
          STG_СбросПолейСинхрБД(ф_ЖурналСинхрОстатков)
          колЭл = КолЭлемУдаления(ф_ЖурналСинхрОстатков)
          Данные!ВсегоСтр!"E" = Данные!ВсегоСтр!"E" + колЭл
        КОНЕЦ_ЕСЛИ
      КОНЕЦ_ВЫБОРА
      СБРОС(SPR_DEBTS_эл_доб, SPR_DEBTS_эл_счит, SPR_DEBTS_эл_знач, SPR_DEBTS_эл_изм, SPR_DEBTS_эл_id)
    КОНЕЦ_ЕСЛИ
  КОНЕЦ_ЦИКЛА
  sql.ЗАКРЫТЬ
  sql_sync.ЗАКРЫТЬ
  
  IB_DBF_УпакТабл(ф_ЖурналСинхрОстатков)
  IB_FILE_ФайлУдалить(путь)
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ ТИП_SQL STG_ДобавитьОстаток(ТИП_ЧИСЛО: сумма, кодВзн, идУчастка; ТИП_СТРОКА: назв, флс, участок, фио, контекст)
  лог = ДА
  /*ЕСЛИ контекст = "" ТО
    лог = сумма <> 0
  КОНЕЦ_ЕСЛИ*/
  ЕСЛИ лог ТО
    поз = НАЙТИ_ПОЗ("id_area", идУчастка, 
                    "fls", флс,
                    "id_vzn", кодВзн)
                    
    ЕСЛИ IB_DBF_ПолеСущ("N_AREA") ТО
      ЗАП_ПОЛЕ("N_AREA", участок)
      ЗАП_ПОЛЕ("FIO", фио)
      ЗАП_ПОЛЕ("CAP", назв)
    КОНЕЦ_ЕСЛИ
    былоИзм = НЕТ
    
    ЕСЛИ поз = 0 ТО
      ЗАП_ПОЛЕ("ID_AREA", идУчастка)
      ЗАП_ПОЛЕ("FLS", флс)
      ЗАП_ПОЛЕ("ID_VZN", кодВзн)
      ЕСЛИ контекст = "" ТО //только если выгрузка
        ЗАП_ПОЛЕ("ID_RECSITE", 0)
        ЗАП_ПОЛЕ("IS_SYNCED", НЕТ)
      КОНЕЦ_ЕСЛИ
      stg_остатокРасчетный[ПОЛЕ("ID_RECSITE")] = ДА
    ИНАЧЕ
      ЕСЛИ контекст = "" ТО //только если выгрузка
        логСущ = СУЩ_ПЕРЕМ(stg_остатокНаСайте[ПОЛЕ("ID_RECSITE")])
        ЕСЛИ НЕ логСущ ТО
          ЗАП_ПОЛЕ("ID_RECSITE", 0)
          ЗАП_ПОЛЕ("IS_SYNCED", НЕТ)
          былоИзм = ДА
        ИНАЧЕ
          stg_остатокРасчетный[ПОЛЕ("ID_RECSITE")] = ДА
        КОНЕЦ_ЕСЛИ
        ЕСЛИ сумма <> ПОЛЕ("SALDO") И кодВзн = ПОЛЕ("ID_VZN") ТО
          ЗАП_ПОЛЕ("IS_SYNCED", НЕТ)
          былоИзм = ДА
        КОНЕЦ_ЕСЛИ
      ИНАЧЕ
        stg_остатокРасчетный[ПОЛЕ("ID_RECSITE")] = ДА
      КОНЕЦ_ЕСЛИ
    КОНЕЦ_ЕСЛИ
    
    ЕСЛИ контекст <> "соб_показатьЖурналОстатков" ТО //если не показ дбф
      ЗАП_ПОЛЕ("SALDO", ОКРУГЛЕНИЕ(сумма, 2))
    КОНЕЦ_ЕСЛИ
    
    ЕСЛИ поз = 0 ТО
      ДОБАВИТЬ
    ИНАЧЕ
      //ЕСЛИ былоИзм ТО //иначе не показывал фио
        ЗАМЕНИТЬ
      //КОНЕЦ_ЕСЛИ
    КОНЕЦ_ЕСЛИ
  ИНАЧЕ
    поз = НАЙТИ_ПОЗ("id_area", идУчастка, 
                    "fls", флс,
                    "id_vzn", кодВзн)
    ЕСЛИ поз > 0 ТО
      ЗАП_ПОЛЕ("SALDO", 0)
      ЗАП_ПОЛЕ("IS_SYNCED", НЕТ)
      ЗАМЕНИТЬ
    КОНЕЦ_ЕСЛИ
  КОНЕЦ_ЕСЛИ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ ТИП_SQL STG_ЗапросВыгрузкиОстатки(ПЕРЕМ ТИП_СТРОКА: путь)
  контекст = IB_CONTEXT_ИзвлечьЛок("событие")
  
  всегоЗап = IB_DBF_ВсегоЗап(ф_ЖурналСинхрОстатков)
  СОЗДАТЬ(сп, ТИП_СПИСОК)
  
  ЕСЛИ контекст <> "соб_показатьЖурналОстатков" ИЛИ
       всегоЗап = 0 ТО
    STG_R_НастройкиСчетов
    STG_ПодготовитьДанныеСтатей
  КОНЕЦ_ЕСЛИ
  
  ЕСЛИ контекст <> "соб_показатьЖурналОстатков" ТО
    STG_СоздатьФайлОстатков(путь)
    ОТКРЫТЬ(путь)
    
    сп.ОЧИСТИТЬ
    сп.ДОБАВИТЬ("INSERT INTO")
    сп.ДОБАВИТЬ("'" + путь + "'")
    сп.ДОБАВИТЬ("(ID_AREA, FLS, ID_VZN, SALDO, ID_RECSITE, UUID, IS_SYNCED)")
    сп.ДОБАВИТЬ("SELECT ID_AREA, FLS, ID_VZN, SALDO, ID_RECSITE, UUID, IS_SYNCED FROM")
    сп.ДОБАВИТЬ("'" + ф_ЖурналСинхрОстатков + "'")
    SQL_ЗАПРОС(сп)
    
    STG_РасчетОстатков(ДА, контекст)
    
    ЕСЛИ всегоЗап = 0 ТО
      сп.ОЧИСТИТЬ
      сп.ДОБАВИТЬ("INSERT INTO")
      сп.ДОБАВИТЬ("'" + ф_ЖурналСинхрОстатков + "'")
      сп.ДОБАВИТЬ("(ID_AREA, FLS, ID_VZN, SALDO, ID_RECSITE, UUID, IS_SYNCED)")
      сп.ДОБАВИТЬ("SELECT ID_AREA, FLS, ID_VZN, SALDO, ID_RECSITE, UUID, IS_SYNCED FROM")
      сп.ДОБАВИТЬ("'" + путь + "'")
      сп.ДОБАВИТЬ("WHERE SALDO <> 0")
      SQL_ЗАПРОС(сп)
    КОНЕЦ_ЕСЛИ
  ИНАЧЕ //кнопка DBF
    ЕСЛИ всегоЗап = 0 ТО
      ОТКРЫТЬ(ф_ЖурналСинхрОстатков)
      STG_РасчетОстатков(НЕТ, "расчет сальдо") //файл пустой - расчет остатков сделаем без учета фильтра
    ИНАЧЕ
      сп.ОЧИСТИТЬ
      сп.ДОБАВИТЬ("SELECT * FROM")
      сп.ДОБАВИТЬ("'" + ф_ЖурналСинхрОстатков + "'")
      ЕСЛИ г_колУчастков > 0 ТО
        сп.ДОБАВИТЬ("WHERE ID_AREA IN (")
        сп.STG_ARH_СчитатьАрхив(к_АрхивСпрУчастков, г_путьПрофиляСпрУчастков)
        сп.ДОБАВИТЬ(")")
      КОНЕЦ_ЕСЛИ
      ЗАПРОС(сп)
    КОНЕЦ_ЕСЛИ
  КОНЕЦ_ЕСЛИ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ ТИП_SQL STG_РасчетОстатков(ТИП_ЛОГИКА: фильтр; ТИП_СТРОКА: контекст)
  идПоКоду!"" = 0
  имяПоКоду!"" = ""
  sql = SQL_ОТКРЫТЬ(ф_СпрЦелевыхВзносов)
  ЦИКЛ ДЛЯ(и = 1, sql.ВСЕГО)
    sql.ПЕРЕЙТИ(и)
    код = sql.ПОЛЕ("CODP")
    ЕСЛИ НЕ СУЩ_ПЕРЕМ(идПоКоду!код) ТО
      идПоКоду!код = sql.ПОЛЕ("ID")
      имяПоКоду!код = sql.ПОЛЕ("CAP")
    КОНЕЦ_ЕСЛИ
  КОНЕЦ_ЦИКЛА
  sql.ЗАКРЫТЬ
    
  СОЗДАТЬ(сп, ТИП_СПИСОК)
  сп.ДОБАВИТЬ("SELECT A.CODS, A.ID_AREA, A.N_AREA, A.FIO, A.SRT, B.FLS FROM")
  сп.ДОБАВИТЬ("'" + ф_СпрУчастковГаражей + "' AS A")
  сп.ДОБАВИТЬ("INNER JOIN")
  сп.ДОБАВИТЬ("'" + ф_СпрФЛС + "' B")
  сп.ДОБАВИТЬ("ON A.ID_AREA = B.ID_AREA")
  ЕСЛИ г_колУчастков > 0 И фильтр ТО
    сп.ДОБАВИТЬ("WHERE A.ID_AREA IN (")
    сп.STG_ARH_СчитатьАрхив(к_АрхивСпрУчастков, г_путьПрофиляСпрУчастков)
    сп.ДОБАВИТЬ(")")
  КОНЕЦ_ЕСЛИ
  сп.ДОБАВИТЬ("ORDER BY A.SRT, A.FIO")
  sql = SQL_ЗАПРОС(сп)
  СтатусСоздать("Расчет остатков")
  СтатусСообщение("Расчет остатков")
  СтатусСтартПрогресс(sql.ВСЕГО)
  ЦИКЛ ДЛЯ(и = 1, sql.ВСЕГО)
    sql.ПЕРЕЙТИ(и)
    Id_Area = sql.ПОЛЕ("ID_AREA")
    цл_КодУл = sql.ПОЛЕ("CODS")
    цл_КодУчГарПольз = sql.ПОЛЕ("N_AREA")
    
    СтатусОбновитьПрогресс("")
  
    ЕСЛИ контекст <> "соб_показатьЖурналОстатков" ИЛИ контекст = "расчет сальдо" ТО
      счетУлицы = дебСчетПлаты + "/" + sql.ПОЛЕ("CODS")
      счетУчастка = счетУлицы + "/" + IB_STR_СтрСимвСлева(цл_КодУчГарПольз, "0", г_длинаКодаУчасткаПС)
      субсч = ?(аккСубСчета="", "", "/" + IB_STR_СтрСимвСлева(цл_КодУчГарПольз, "0", г_длинаКодаУчасткаПС))
      
      ЕСЛИ автоСписание = "" ТО
        ЕСЛИ услугиКакАналитикаУчастков = "" ТО
          сальдо = STG_РасчетСальдоПоСтатье("", "", счетУчастка, субсч, гр_датаОперацийПо, ДА, НЕТ)
          STG_ДобавитьОстаток(сальдо, 0, Id_Area, "ЧлВз", sql.ПОЛЕ("FLS"), 
                              цл_КодУчГарПольз, sql.ПОЛЕ("FIO"), контекст)
        ИНАЧЕ
          ЦИКЛ ИНДЕКС(счет = г_счетСтатьиПоКоду!код)
            ЕСЛИ ПОЗ("&", код) = 1 ИЛИ НЕ СУЩ_ПЕРЕМ(идПоКоду!код) ТО
              ПРОДОЛЖИТЬ
            ИНАЧЕ
              сальдо = STG_РасчетСальдоПоСтатье(код, счет, счетУчастка, субсч, гр_датаОперацийПо, ДА, НЕТ)
              STG_ДобавитьОстаток(сальдо, идПоКоду!код, Id_Area, имяПоКоду!код, sql.ПОЛЕ("FLS"), 
                                  цл_КодУчГарПольз, sql.ПОЛЕ("FIO"), контекст)
            КОНЕЦ_ЕСЛИ
          КОНЕЦ_ЦИКЛА
        КОНЕЦ_ЕСЛИ
      ИНАЧЕ
        ЦИКЛ ИНДЕКС(счет = г_счетСтатьиПоКоду!код)
          ЕСЛИ ПОЗ("&", код) = 1 ИЛИ НЕ СУЩ_ПЕРЕМ(идПоКоду!код) ТО
            ПРОДОЛЖИТЬ
          ИНАЧЕ
            ЕСЛИ СЧЕТ_СУЩ(счет + субсч) ТО
              сальдо = STG_РасчетСальдоПоСтатье(код, счет, счетУчастка, субсч, гр_датаОперацийПо, ДА, НЕТ)
              STG_ДобавитьОстаток(сальдо, идПоКоду!код, Id_Area, имяПоКоду!код, sql.ПОЛЕ("FLS"), 
                                  цл_КодУчГарПольз, sql.ПОЛЕ("FIO"), контекст)
            КОНЕЦ_ЕСЛИ
          КОНЕЦ_ЕСЛИ
        КОНЕЦ_ЦИКЛА
      КОНЕЦ_ЕСЛИ
    ИНАЧЕ
      ЦИКЛ ИНДЕКС(счет = г_счетСтатьиПоКоду!код)
        ЕСЛИ СУЩ_ПЕРЕМ(идПоКоду!код) ТО
          STG_ДобавитьОстаток(сальдо, идПоКоду!код, Id_Area, имяПоКоду!код, sql.ПОЛЕ("FLS"), 
                              цл_КодУчГарПольз, sql.ПОЛЕ("FIO"), контекст)
        КОНЕЦ_ЕСЛИ
      КОНЕЦ_ЦИКЛА
    КОНЕЦ_ЕСЛИ
  
    //Расчет сальдо по пени
    ///*предКод = г_КодСтатьиНачисления
    //ЦИКЛ ИНДЕКС(счет = г_счетСтатьиПоКоду!код)
    //  ЕСЛИ ?(ПОЗ("&", код) = 1, ДА, НЕТ) ТО
    //    г_КодСтатьиНачисления = ПОДСТР(код, 2)
    //    ЕСЛИ STG_СчетаПени(счет1) ТО
    //      сальдо = STG_РасчетСальдоПоСтатье(код, счет1, счетУчастка, субсч, дата, НЕТ, ДА)
    //      sql_loop.STG_ДобавитьОстаток(сальдо, идПоКоду!код, Id_Area, имяПоКоду!код, sql.ПОЛЕ("FLS"), 
    //                                   цл_КодУчГарПольз, sql.ПОЛЕ("FIO"))
    //    КОНЕЦ_ЕСЛИ
    //  КОНЕЦ_ЕСЛИ
    //КОНЕЦ_ЦИКЛА
    //г_КодСтатьиНачисления = предКод*/
    //
  КОНЕЦ_ЦИКЛА
  sql.ЗАКРЫТЬ
  СтатусЗакрыть
  
  Id_Area = 0
  цл_КодУл = ""
  цл_КодУчГарПольз = ""
    
  ЦИКЛ ДЛЯ(и = ВСЕГО, 1, -1)
    ПЕРЕЙТИ(и)
    ЕСЛИ НЕ СУЩ_ПЕРЕМ(stg_остатокРасчетный[ПОЛЕ("ID_RECSITE")]) ТО
      ЗАП_ПОЛЕ("SALDO", 0)
      ЗАП_ПОЛЕ("IS_SYNCED", НЕТ)
      ЗАМЕНИТЬ
    КОНЕЦ_ЕСЛИ
    
    ЕСЛИ ПОЛЕ("ID_RECSITE") = 0 И ПОЛЕ("SALDO") = 0 И НЕ ПОЛЕ("IS_SYNCED") ТО //остатка никогда не было
      УДАЛИТЬ
    КОНЕЦ_ЕСЛИ
  КОНЕЦ_ЦИКЛА
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ ТИП_SQL ТИП_ЛОГИКА: STG_СинхронизироватьОстатки(ТИП_СТРОКА: id)
  спр = "Журнал остатков"
  РЕЗУЛЬТАТ = НЕТ 
  ЕСЛИ id = "" ТО
    id = СТР_ЗНАЧ(SPR_DEBTS_id)
  КОНЕЦ_ЕСЛИ
  ЕСЛИ СУЩ_ПЕРЕМ(SPR_DEBTS_эл_счит[id + "|SPR_DEBTS_id_area"]) ТО
    ЕСЛИ SPR_DEBTS_эл_счит[id + "|SPR_DEBTS_fls"] И 
         SPR_DEBTS_эл_счит[id + "|SPR_DEBTS_id_vzn"] ТО
      Данные!ВсегоСтр!"D"++
      ЕСЛИ stg_профилиВыгрузкиСпр!спр!"_subreq_add" ТО
        SPR_DEBTS_Упаковать(id)
      КОНЕЦ_ЕСЛИ
      
      поз = НАЙТИ_ПОЗ("id_area", SPR_DEBTS_id_area, 
                      "fls", SPR_DEBTS_fls,
                      "id_vzn", SPR_DEBTS_id_vzn)
      
      ЕСЛИ поз > 0 ТО //обновление
        Данные!ВсегоСтр!"E"++
        ПЕРЕЙТИ(поз)
        ЕСЛИ SPR_DEBTS_эл_счит[id + "|SPR_DEBTS_sum"] ТО
          ЗАП_ПОЛЕ("SALDO", SPR_DEBTS_sum)
        КОНЕЦ_ЕСЛИ
        ЕСЛИ SPR_DEBTS_эл_счит[id + "|SPR_DEBTS_id"] ТО
          ЗАП_ПОЛЕ("ID_RECSITE", SPR_DEBTS_id)
        КОНЕЦ_ЕСЛИ
        ЕСЛИ SPR_DEBTS_эл_счит[id + "|SPR_DEBTS_uuid"] ТО
          ЗАП_ПОЛЕ("UUID", SPR_DEBTS_uuid)
        КОНЕЦ_ЕСЛИ
        ЗАП_ПОЛЕ("IS_SYNCED", ДА)
        ЗАМЕНИТЬ
      ИНАЧЕ //добавление
        Данные!ВсегоСтр!"E"++
        ЕСЛИ SPR_DEBTS_эл_счит[id + "|SPR_DEBTS_id_area"] ТО
          ЗАП_ПОЛЕ("id_area", SPR_DEBTS_id_area)
        КОНЕЦ_ЕСЛИ
        ЕСЛИ SPR_DEBTS_эл_счит[id + "|SPR_DEBTS_fls"] ТО
          ЗАП_ПОЛЕ("fls", SPR_DEBTS_fls)
        КОНЕЦ_ЕСЛИ
        ЕСЛИ SPR_DEBTS_эл_счит[id + "|SPR_DEBTS_id_vzn"] ТО
          ЗАП_ПОЛЕ("id_vzn", SPR_DEBTS_id_vzn)
        КОНЕЦ_ЕСЛИ
        ЕСЛИ SPR_DEBTS_эл_счит[id + "|SPR_DEBTS_sum"] ТО
          ЗАП_ПОЛЕ("SALDO", SPR_DEBTS_sum)
        КОНЕЦ_ЕСЛИ
        ЕСЛИ SPR_DEBTS_эл_счит[id + "|SPR_DEBTS_id"] ТО
          ЗАП_ПОЛЕ("ID_RECSITE", SPR_DEBTS_id)
        КОНЕЦ_ЕСЛИ
        ЕСЛИ SPR_DEBTS_эл_счит[id + "|SPR_DEBTS_uuid"] ТО
          ЗАП_ПОЛЕ("UUID", SPR_DEBTS_uuid)
        КОНЕЦ_ЕСЛИ
        ЗАП_ПОЛЕ("IS_SYNCED", ДА)
        ДОБАВИТЬ
      КОНЕЦ_ЕСЛИ
      РЕЗУЛЬТАТ = ДА
    КОНЕЦ_ЕСЛИ
  КОНЕЦ_ЕСЛИ
  STG_СинхронизироватьОстатки = РЕЗУЛЬТАТ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ STG_СоздатьФайлОстатков(ПЕРЕМ ТИП_СТРОКА: путь)
  путь = г_папкаВрем + "\" + НОВЫЙ_GUID + ".dbf"
  SQL_СОЗДАТЬ(путь,
              ["ID_AREA"    : ТИП_ЧИСЛО  : 5,
               "N_AREA"     : ТИП_СТРОКА : 30,
               "FIO"        : ТИП_СТРОКА : 100,
               "FLS"        : ТИП_СТРОКА : 20,
               "ID_VZN"     : ТИП_ЧИСЛО  : 10,
               "CAP"        : ТИП_СТРОКА : 100,
               "SALDO"      : ТИП_ЧИСЛО  : 15;2,
               "ID_RECSITE" : ТИП_ЧИСЛО  : 10;0,
               "UUID"       : ТИП_СТРОКА : 40,
               "IS_SYNCED"  : ТИП_ЛОГИКА
               ])
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ ТИП_SQL STG_ДобЗначОстатка(ТИП_СТРОКА: инд) //; ТИП_ЧИСЛО: код; ТИП_СТРОКА: имя)
  спр = "debts"
  ЕСЛИ ПОЛЕ("ID_RECSITE") = 0 ТО
    ДобавитьЗначениеС(спр, инд + "|SPR_DEBTS_type", SPR_DEBTS_type)
    ДобавитьЗначениеЧ(спр, инд + "|SPR_DEBTS_id_area", ПОЛЕ("id_area"))
    ДобавитьЗначениеС(спр, инд + "|SPR_DEBTS_fls", ПОЛЕ("fls"))
    ДобавитьЗначениеЧ(спр, инд + "|SPR_DEBTS_id_vzn", ПОЛЕ("id_vzn"))
    ДобавитьЗначениеС(спр, инд + "|SPR_DEBTS_cap", ПОЛЕ("cap"))
    ДобавитьЗначениеЧ(спр, инд + "|SPR_DEBTS_sum", ПОЛЕ("SALDO"))
    ДобавитьЗначениеС(спр, инд + "|SPR_DEBTS_comm", "")
    ДобавитьЗначениеЛ(спр, инд + "|SPR_DEBTS_is_synced", ДА)
  КОНЕЦ_ЕСЛИ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ ДобавитьЗначениеС(ТИП_СТРОКА: справочник, имя, знач)
  ВЫБОР(справочник)
   #"owners": SPR_OWNERS_эл_знач!имя = знач
              SPR_OWNERS_эл_изм!имя = ДА
   #"objects": SPR_OBJECTS_эл_знач!имя = знач
               SPR_OBJECTS_эл_изм!имя = ДА
   #"meters": SPR_SHETCH_эл_знач!имя = знач
               SPR_SHETCH_эл_изм!имя = ДА
   #"fls": SPR_FLS_эл_знач!имя = знач
           SPR_FLS_эл_изм!имя = ДА
   #"services": SPR_VZNOSI_эл_знач!имя = знач
                SPR_VZNOSI_эл_изм!имя = ДА
   #"tax": SPR_TARIF_эл_знач!имя = знач
           SPR_TARIF_эл_изм!имя = ДА
   #"register": SPR_REGISTER_эл_знач!имя = знач
                 SPR_REGISTER_эл_изм!имя = ДА
   #"link_all": SPR_LINK_ALL_эл_знач!имя = знач
                SPR_LINK_ALL_эл_изм!имя = ДА
   #"calc": SPR_CALC_REG_эл_знач!имя = знач
            SPR_CALC_REG_эл_изм!имя = ДА
   #"readings": POK_SCH_эл_знач!имя = знач
                POK_SCH_эл_изм!имя = ДА
   #к_спрСайтаНастройки: SPR_SETS_эл_знач!имя = знач
                SPR_SETS_эл_изм!имя = ДА
   #"debts": SPR_DEBTS_эл_знач!имя = знач
             SPR_DEBTS_эл_изм!имя = ДА
   #к_спрСайтаРеквизиты: SPR_REKV_эл_знач!имя = знач
                       SPR_REKV_эл_изм!имя = ДА
   #к_спрСайтаГолосования: MP_POLL_эл_знач!имя = знач
                           MP_POLL_эл_изм!имя = ДА
   #к_спрСайтаВопросы: MP_QUESTION_эл_знач!имя = знач
                       MP_QUESTION_эл_изм!имя = ДА
   #к_спрСайтаОтветы: MP_ANSWER_эл_знач!имя = знач
                      MP_ANSWER_эл_изм!имя = ДА
   #к_спрСайтаРезультаты: MP_RESULT_эл_знач!имя = знач
                          MP_RESULT_эл_изм!имя = ДА
  КОНЕЦ_ВЫБОРА
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ ДобавитьЗначениеД(ТИП_СТРОКА: справочник, имя; ТИП_ДАТА: знач)
  ЕСЛИ знач = к_МинДата И справочник <> к_спрСайтаТарифы ТО
    знач = 01.01.1980
  КОНЕЦ_ЕСЛИ
  стр = СТР(знач)
  д = СТР_ФРАГ(стр, ".", 1)
  м = СТР_ФРАГ(стр, ".", 2)
  г = СТР_ФРАГ(стр, ".", 3)
  дата = г + "-" + м + "-" + д
  ДобавитьЗначениеС(справочник, имя, дата)
КОНЕЦ_ФУНКЦИИ

