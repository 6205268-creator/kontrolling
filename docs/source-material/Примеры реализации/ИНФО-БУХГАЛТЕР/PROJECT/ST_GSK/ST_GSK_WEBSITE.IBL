//-------------------------------------------------------------------------------------------------------------------------//
//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ STG_ИниБланкВыгрузки
  ЕСЛИ НЕ IB_ATR_СущАтрибут(к_атрибутБылаИни) ТО
    
    STG_ОпределитьБлок
    STG_УстТекстБлока
    STG_УстПрофилиМножВыбора
    STG_УстОтобрГрафМножВыбБланк
    гр_длинаПароля = ?(гр_длинаПароля < 8, 8, гр_длинаПароля) 
    
    //гр_протоколДоб = ?(гр_протоколДоб = "", "JSONAPI", гр_протоколДоб)
    гр_протоколУд = ?(гр_протоколУд = "", "JSONAPI", гр_протоколУд)

    УСТ_АТРИБУТ(к_атрибутБылаИни, "ДА")
  КОНЕЦ_ЕСЛИ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ ТИП_ЛОГИКА: STG_ВыборПрофиляСайта(ПЕРЕМ ТИП_СТРОКА: знач)
  IB_CONTEXT_УстановитьЛок(rest_атрКонтекстДлг, "блокСНТ")
  УСТ_АТРИБУТ("&выборПрофиляСайта", "ДА")
  STG_ВыборПрофиляСайта = REST_СобВызовИстория(знач)
  УСТ_АТРИБУТ("&выборПрофиляСайта", "")
  IB_CONTEXT_УстановитьЛок(rest_атрКонтекстДлг, "")
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ STG_КнВыгрузкиНаСайт(ТИП_СТРОКА: соб, имя, текст)
  ИСПОЛЬЗОВАТЬ("SITEIB\POLL\MP_EDITOR")
  ИСПОЛЬЗОВАТЬ("SITEIB\POLL\MP_DOWNLOAD")
  ИСПОЛЬЗОВАТЬ("SITEIB\POLL\MP_RESULT")
    
  IB_FLT_СохранитьФильтр
  ВЫКЛ_ФИЛЬТР
   
  ЕСЛИ оп_включитьОтладку ТО
    IB_RAZR_ВклРежимОтладки
  ИНАЧЕ
    IB_RAZR_ВыклРежимОтладки
  КОНЕЦ_ЕСЛИ

  REST_испСписокАтр = оп_испСписокАтр

  IB_CONTEXT_УстановитьЛок("синхронизацияСайта", "ДА")
  
  STG_СчитатьПрофилиВыгрузкиСпр

  выполненаАвторизация = ДА
  УСТ_АТРИБУТ(REST_атрТекПрофиль, гр_профильОтправки)
  REST_Logout //принудительный логаут
  ST_BLW_ОпределитьПарамЗапуска(блок, файл)
  STG_ПутиПрофилейМножВыбора
  ВЫБОР(соб)
   #"кн_обновитьПринудительно":
    STG_ОбновитьПринудительно
   #"соб_сбросФлтПрофиля": 
    гр_профильОтправки = ""
    УСТ_АТРИБУТ(REST_атрТекПрофиль, "")
    //УСТ_АТРИБУТ("&REST_адрес", "")
   #"соб_выгрузить": 
    гр_длинаПароля = ?(гр_длинаПароля < 8, 8, гр_длинаПароля)   
    ЕСЛИ ВОПРОС(текст + "?", НЕТ) ТО
      КОМАНДА_БЛАНКА("RECALC")
      STG_ВыгрузитьСправочники
      REST_Logout
      //УСТ_АТРИБУТ("&REST_адрес", "")
      СООБЩЕНИЕ("Выгрузка завершена.")
    КОНЕЦ_ЕСЛИ
   #"соб_удалить", "соб_очиститьСайт": 
    ЕСЛИ ВОПРОС(текст + "?", НЕТ) ТО
      КОМАНДА_БЛАНКА("RECALC")
      ЕСЛИ соб = "соб_очиститьСайт" ТО
        IB_CONTEXT_УстановитьЛок("очиститьСайт", "ДА")
      КОНЕЦ_ЕСЛИ
      STG_УдалитьСправочники
      REST_Logout
      //УСТ_АТРИБУТ("&REST_адрес", "")
      ЕСЛИ соб = "соб_очиститьСайт" ТО
        СООБЩЕНИЕ("Очистка завершена.")
      ИНАЧЕ
        СООБЩЕНИЕ("Удаление завершено.")
      КОНЕЦ_ЕСЛИ
    КОНЕЦ_ЕСЛИ
   #"соб_сброс": 
    ЕСЛИ ВОПРОС(текст + "?", НЕТ) ТО
      КОМАНДА_БЛАНКА("RECALC")
      STG_СброситьIDвБД
      СООБЩЕНИЕ("Сброс завершен.")
    КОНЕЦ_ЕСЛИ
   #"соб_получить":
    ЕСЛИ ВОПРОС(текст + "?", НЕТ) ТО
      КОМАНДА_БЛАНКА("RECALC")
      STG_ПолучитьССайта
      REST_Logout
      //УСТ_АТРИБУТ("&REST_адрес", "")
      СООБЩЕНИЕ("Получение завершено.")
      ЕСЛИ ВОПРОС("Открыть бланк 3.01 для расчета начислений по полученным показаниям?", НЕТ) ТО
        IB_CONTEXT_Установить("получениеПокССайта", "ДА")
        БЛАНК("ST_02SPIS.BLW", ДА)
      КОНЕЦ_ЕСЛИ
    КОНЕЦ_ЕСЛИ
   #"соб_разослатьПароли":
    ЕСЛИ ВОПРОС(текст + "?", НЕТ) ТО
      STG_РазослатьПароли
    КОНЕЦ_ЕСЛИ
   #"соб_анализировать":
    ЕСЛИ ВОПРОС(текст + "?", НЕТ) ТО
      КОМАНДА_БЛАНКА("RECALC")
      STG_Анализ
      REST_Logout
      //УСТ_АТРИБУТ("&REST_адрес", "")
    КОНЕЦ_ЕСЛИ
   #"соб_показатьСпрУчастков": STG_СпрУчастковГаражей(стр)
   #"соб_показатьСпрВладельцев": STG_СправочникВладельцев(стр)
   #"соб_показатьСпрВзносов": ТИП_ОПЕР(блок + " : " + "Справочник взносов и тарифов" + " <" + файл + ".top>")
   #"соб_показатьСпрИПУ": ТИП_ОПЕР(блок + " : " + "Справочник ИПУ" + " <" + файл + ".top>")
   #"соб_показатьСпрВладУч": STG_ПоказатьСпрВладУч
   #"соб_показатьСпрФЛС": STG_ПоказатьСпрФЛС
   #"соб_показатьСпрТарифов": STG_ПоказатьСпрТарифов
   #"соб_показатьРеквизиты": STG_ПоказатьРеквизиты(ДА)
   #"соб_показатьНастройки": STG_ПоказатьНастройки(ДА)
   #"соб_показатьЖурнал": 
    IB_CONTEXT_УстановитьЛок(к_атрПоказВсехЗаписей, "ДА")
    IB_CONTEXT_УстановитьЛок("датаС", СТР(гр_датаОпераций))
    IB_CONTEXT_УстановитьЛок("датаПо", СТР(гр_датаОперацийПо))
    STG_ПоказатьЖурнал
   //#"соб_показатьРасчеты": STG_ПоказатьРасчеты
   //#"соб_показатьОстатки": STG_ПоказатьОстатки
   //
   #"соб_наСайтеСпрВлад": STG_ПоказатьНаСайте("/admin/people")
   #"соб_наСайтеСпрУчастков": STG_ПоказатьНаСайте("/admin/snt/spr-objects")
   #"соб_наСайтеСпрВладУч": STG_ПоказатьНаСайте("/admin/snt/spr-link-all")
   #"соб_наСайтеСпрФЛС": STG_ПоказатьНаСайте("/admin/snt/spr-fls")
   #"соб_наСайтеСпрВзносов": STG_ПоказатьНаСайте("/admin/snt/spr-vznosi")
   #"соб_наСайтеСпрТарифов": STG_ПоказатьНаСайте("/admin/snt/spr-tarif")
   #"соб_наСайтеСпрИПУ": STG_ПоказатьНаСайте("/admin/snt/spr-shetch")
   #"соб_наСайтеЖурналИПУ": STG_ПоказатьНаСайте("/admin/snt/pok-sch")
   #"соб_наСайтеСпрОпераций": STG_ПоказатьНаСайте("/admin/snt/spr-register")
   #"соб_наСайтеСпрРасчетов": STG_ПоказатьНаСайте("/admin/snt/spr-calculations-reg")
   #"соб_наСайтеСпрОстатков": STG_ПоказатьНаСайте("/admin/snt/spr-debts")
   #"соб_наСайтеСпрРеквизитов": STG_ПоказатьНаСайте("/admin/snt/spr-rekv")
   #"соб_наСайтеСпрНастроек": STG_ПоказатьНаСайте("/admin/snt/spr-pd-settings")
   #"соб_наСайтеГолосования": СОЗДАТЬ(сп, ТИП_СПИСОК)
                              сп.ДОБАВИТЬ("голосований")
                              сп.ДОБАВИТЬ("вопросов")
                              сп.ДОБАВИТЬ("ответов")
                              выб = ВЫБОР(сп, "Выбор справочника", "Справочник", 20)
                              ВЫБОР(выб)
                               #1: STG_ПоказатьНаСайте("/admin/content/polls")
                               #2: STG_ПоказатьНаСайте("/admin/content/questions")
                               #3: STG_ПоказатьНаСайте("/admin/content/answers")
                              ИНАЧЕ
                                ВЫХОД
                              КОНЕЦ_ВЫБОРА   
   #"соб_наСайтеРезультаты": STG_ПоказатьНаСайте("/admin/content/results")
   //
   #"соб_выгрузитьВсе": 
    оп_справочникВлад = оп_выгрузитьВсе
    оп_справочникУч = оп_выгрузитьВсе
    оп_справочникСвязи = оп_выгрузитьВсе
    оп_справочникФЛС = оп_выгрузитьВсе
    оп_справочникВзносы = оп_выгрузитьВсе
    оп_справочникТарифы = оп_выгрузитьВсе
    оп_справочникИПУ = оп_выгрузитьВсе
    оп_журналПок = оп_выгрузитьВсе
    оп_журнал = оп_выгрузитьВсе
    оп_журналРасчетов = оп_выгрузитьВсе
    оп_журналОстатков = оп_выгрузитьВсе
    оп_справочникРекв = оп_выгрузитьВсе
    оп_настройки = оп_выгрузитьВсе
    оп_голосования = оп_выгрузитьВсе
   #"соб_отчетныйПериод":
    гр_датаОпераций = ДАТА_НАЧ
    гр_датаОперацийПо = ДАТА_КОН
   #"соб_показГолосование":
    MP_РедакторГолосований
   #"соб_получитьГолосования":
    MP_ЗагрузитьГолосования
    STG_СинхрГолосПослеПолуч
    
    MP_ЗагрузитьВопросы
    STG_СинхрВопросыПослеПолуч
    
    MP_ЗагрузитьОтветы
    STG_СинхрОтветыПослеПолуч
    
    MP_ЗагрузитьРезультаты
    STG_СинхрРезультатыПослеПолуч
    REST_Logout
   #"соб_показРезультаты":
    MP_РедакторРезультатов
   #"соб_отчет":
    STG_ПарамВыводаТаблиц
    НачСтр = 55
    MP_ОтчетПоРезультатам
   #"соб_профилиВыгрузкиСпр":
    STG_РедПрофилейСпр(стр)
   #"соб_переформироватьЖурнал":
    ЕСЛИ ВОПРОС(текст + "?", НЕТ) ТО
      tmp_журнал = ф_Журнал
      ф_Журнал = ф_Журнал1
      ЕСЛИ IB_FILE_ФайлУдалить(ф_Журнал1) ТО
        ЕСЛИ НЕ СУЩ_ФАЙЛ(ф_Журнал1) ТО
          STG_КонвЖХОвDBF
        КОНЕЦ_ЕСЛИ
      КОНЕЦ_ЕСЛИ
      ф_Журнал = tmp_журнал
    КОНЕЦ_ЕСЛИ
   #"соб_актуализацияЖурнала":
    ЕСЛИ ВОПРОС(текст + "?", НЕТ) ТО
      //tmp_журнал = ф_Журнал
      //ф_Журнал = ф_Журнал1
      STG_КонвЖХОвDBFПоПарам(ДА, ДА, ДА, ДА, НЕТ, ДА)
      //ф_Журнал = tmp_журнал
      //STG_КонвЖХОвDBFПоПарам(ДА, ДА, ДА, ДА, НЕТ, ДА)
      СООБЩЕНИЕ("БД журнала актуализирована.")
    КОНЕЦ_ЕСЛИ
  КОНЕЦ_ВЫБОРА
  ЕСЛИ оп_включитьОтладку ТО
    IB_RAZR_ВыклРежимОтладки
  КОНЕЦ_ЕСЛИ
  IB_CONTEXT_УстановитьЛок("синхронизацияСайта", "")
  IB_FLT_ЗагрузитьФильтр
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ STG_КнПоказатьDBF(ТИП_СТРОКА: соб, имя, текст)
  IB_CONTEXT_УстановитьЛок(к_атрПоказВсехЗаписей, "ДА")
  STG_ПутиПрофилейМножВыбора
  СОЗДАТЬ(sql, ТИП_SQL)
  СОЗДАТЬ(сп, ТИП_СПИСОК)
  сп.ДОБАВИТЬ("SELECT * FROM")
  ВЫБОР(соб)
   #"соб_показатьСпрВПроводнике": 
     ВЫБОР(имя)
     #"кн_показатьСпрВладВПроводнике":
       IB_FILE_ПоказатьФайлВПроводнике(ф_СпрВладельцев)
     #"кн_показатьСпрУчВПроводнике":
       IB_FILE_ПоказатьФайлВПроводнике(ф_СпрУчастковГаражей)
     #"кн_показатьСпрСвязиВПроводнике":
       IB_FILE_ПоказатьФайлВПроводнике(ф_СвязьВладУч)
     #"кн_показатьСпрФЛСВПроводнике":
       IB_FILE_ПоказатьФайлВПроводнике(ф_СпрФЛС)
     #"кн_показатьСпрВзносВПроводнике":
       IB_FILE_ПоказатьФайлВПроводнике(ф_СпрЦелевыхВзносов)
     #"кн_показатьСпрТарВПроводнике":
       IB_FILE_ПоказатьФайлВПроводнике(ф_СпрТарифов)
     #"кн_показатьСпрИндСчВПроводнике":
       IB_FILE_ПоказатьФайлВПроводнике(ф_СпрИндивСчетчики)
     #"кн_показатьСпрПокСчВПроводнике":
       IB_FILE_ПоказатьФайлВПроводнике(ф_ПоказанияИСЭЭ)
     #"кн_показатьЖурналВПроводнике":
       IB_FILE_ПоказатьФайлВПроводнике(ф_Журнал)
     #"кн_показатьРасчетыВПроводнике":
       IB_FILE_ПоказатьФайлВПроводнике(ф_ЖурналРасчетов)
     #"кн_показатьОстаткиВПроводнике":
       IB_FILE_ПоказатьФайлВПроводнике(ф_ЖурналСинхрОстатков)
     #"кн_показатьРеквизитыВПроводнике":
       IB_FILE_ПоказатьФайлВПроводнике(ф_СпрРеквизитовОргСайт)
     #"кн_показатьНастройкиВПроводнике":
       IB_FILE_ПоказатьФайлВПроводнике(ф_СпрНастроекСайт)
     КОНЕЦ_ВЫБОРА
     ВЫХОД
   #"соб_показатьФСпрВлад", "соб_показатьЛК": 
    //sql.STG_ЗапросВыгрузкиСпрВлад
    //sql = SQL_ОТКРЫТЬ(ф_СпрВладельцев)
    сп.ДОБАВИТЬ("'" + ф_СпрВладельцев + "'")
    сп.ДОБАВИТЬ("WHERE ID IN (SELECT ID_OWNER FROM")
    сп.ДОБАВИТЬ("'" + ф_СвязьВладУч + "'")
    ЕСЛИ г_колУчастков > 0 ТО
      сп.ДОБАВИТЬ("WHERE ID_AREA IN (")
      сп.STG_ARH_СчитатьАрхив(к_АрхивСпрУчастков, г_путьПрофиляСпрУчастков)
      сп.ДОБАВИТЬ(")")
    КОНЕЦ_ЕСЛИ
    сп.ДОБАВИТЬ(")")
    sql = SQL_ЗАПРОС(сп)
    секции!1 = "SPR\SPR_OWNERS.DBF"
    секции!2 = "SPR\LINK_SITE_OWNER.DBF"
    секции!3 = "DACHNIKI.DBF"
   #"соб_показатьФСпрУч": 
    //sql.STG_ЗапросВыгрузкиСпрУч
    //sql = SQL_ОТКРЫТЬ(ф_СпрУчастковГаражей)
    сп.ДОБАВИТЬ("'" + ф_СпрУчастковГаражей + "'")
    секции!1 = "DACHNIKI.DBF"
   #"соб_показатьФСпрСвязи":
    //sql.STG_ЗапросВыгрузкиСпрСвязи
    //sql = SQL_ОТКРЫТЬ(ф_СвязьВладУч)
    сп.ДОБАВИТЬ("'" + ф_СвязьВладУч + "'")
    секции!1 = "SPR\LINK_SITE_OWNER.DBF"
   #"соб_показатьФСпрФЛС": 
    //sql.STG_ЗапросВыгрузкиСпрФЛС
    //sql = SQL_ОТКРЫТЬ(ф_СпрФЛС)
    сп.ДОБАВИТЬ("'" + ф_СпрФЛС + "'")
    секции!1 = "SPR\KP_CatalogPersAcc.dbf"
   #"соб_показатьФСпрВзносов":  
    //sql.STG_ЗапросВыгрузкиСпрВзн
    sql = SQL_ОТКРЫТЬ(ф_СпрЦелевыхВзносов)
    секции!1 = "VZNOSI.DBF"
   #"соб_показатьФСпрТарифов": 
    //sql.STG_ЗапросВыгрузкиСпрТар
    sql = SQL_ОТКРЫТЬ(ф_СпрТарифов)
    секции!1 = "SPR\SPR_TARIF.DBF"
    //секции!2 = "SPR\st_VolumeRange.DBF"
   #"соб_показатьФСпрИПУ": 
    //sql.STG_ЗапросВыгрузкиСпрИПУ
    //sql = SQL_ОТКРЫТЬ(ф_СпрИндивСчетчики)
    сп.ДОБАВИТЬ("'" + ф_СпрИндивСчетчики + "'")
    секции!1 = "SPR\SPR_SCHIND.DBF"
   #"соб_показатьФЖурналИПУ", "соб_показатьЖурналИПУ":
    sql.STG_ЗапросВыгрузкиЖурналИПУ
    //sql = SQL_ОТКРЫТЬ(ф_СпрУчастковГаражей)
    секции!1 = "POK_SCHIEE.DBF"
   #"соб_показатьФЖурнал": 
    sql.STG_ЗапросВыгрузкиЖурнал
    секции!1 = "REGISTER.DBF"
    секции!2 = "VZNOSI.DBF"
   #"соб_показатьФЖурналРасч", "соб_показатьРасчеты":
    sql.STG_ЗапросВыгрузкиРасчетов
    секции!1 = "SPR\CALCULATIONS_REG.DBF"
   #"соб_показатьОстатки", "соб_показатьЖурналОстатков":
    IB_CONTEXT_УстановитьЛок("событие", соб)
    sql.STG_ЗапросВыгрузкиОстатки(путь)
    секции!1 = "SPR\st_balance_log.DBF"
    секции!2 = "VZNOSI.DBF"
    секции!3 = "DACHNIKI.DBF"
    секции!4 = "SPR\KP_CatalogPersAcc.dbf"
   //#"соб_показатьФСпрРекв": заглушка = ""
   //#"соб_показатьФСпрНастроек": заглушка = ""
   #"соб_показатьГолосования": 
    сп.ОЧИСТИТЬ
    сп.ДОБАВИТЬ("голосования")
    сп.ДОБАВИТЬ("вопросы")
    сп.ДОБАВИТЬ("ответы")
    рез = ВЫБОР(сп, "Выбор файла", "Файл", 20)
    ВЫБОР(рез)
     #1: файл = mp_файлГолосований
     #2: файл = mp_файлВопросов
     #3: файл = mp_файлОтветов
    ИНАЧЕ
      ВЫХОД
    КОНЕЦ_ВЫБОРА
    sql = SQL_ОТКРЫТЬ(файл)
    сп.ОЧИСТИТЬ
   #"соб_показатьРезультаты":
    sql = SQL_ОТКРЫТЬ(mp_файлРезультатов)
  КОНЕЦ_ВЫБОРА
  //
  ЕСЛИ сп.ВСЕГО = 2 ТО
    ЕСЛИ г_колУчастков > 0 ТО
      сп.ДОБАВИТЬ("WHERE ID_AREA IN (")
      сп.STG_ARH_СчитатьАрхив(к_АрхивСпрУчастков, г_путьПрофиляСпрУчастков)
      сп.ДОБАВИТЬ(")")
    КОНЕЦ_ЕСЛИ
    sql = SQL_ЗАПРОС(сп)
  КОНЕЦ_ЕСЛИ
  
  //
  ST_BLW_ОпределитьПарамЗапуска(блок, префикс)
  путьINI = ТЕК_ДИР + "\DOC\Форматы\INI\" + префикс + "_DBFINFO.INI"
  IB_INIFILE_СбросПеременных
  резВыб = 0
  ЕСЛИ IB_INIFILE_Считать(путьINI) ТО
    набор = "набор"
    БД_СБРОС_СТОЛБЦОВ(набор)
    стлбДобавлен!"" = ДА
    ЦИКЛ ДЛЯ(и = 1, sql.КОЛ_ПОЛЕЙ)
      поле = sql.НАЗВ_ПОЛЯ(и)
      ЕСЛИ НЕ СУЩ_ПЕРЕМ(стлбДобавлен!поле) ТО
        длина = sql.ДЛИНА_ПОЛЯ(поле)
        максДлнДанных = 0
        
        ЕСЛИ sql.ТИП_ПОЛЯ(поле) = "С" ТО
          ЕСЛИ ПОЗ("ФЖурнал", соб) = 0 ТО
            ЦИКЛ ДЛЯ(ж = 1, sql.ВСЕГО)
              sql.ПЕРЕЙТИ(ж)
              длнДанных = ДЛИНА(sql.ПОЛЕ(поле))
              ЕСЛИ длнДанных > максДлнДанных ТО
                максДлнДанных = длнДанных
              КОНЕЦ_ЕСЛИ
            КОНЕЦ_ЦИКЛА
            //максДлнДанных = ?(максДлнДанных = 0, 1, максДлнДанных)
          ИНАЧЕ
            максДлнДанных = длина
          КОНЕЦ_ЕСЛИ
        КОНЕЦ_ЕСЛИ
        
        ЦИКЛ ИНДЕКС(секция = секции!инд)
          ЕСЛИ IB_INIFILE_СущСекция(секция) ТО
            значКл = IB_INIFILE_ЗначКлюча(секция, ЗАГЛ(поле))
            ЕСЛИ значКл <> "" ТО
              описание = СТР_ФРАГ(значКл, ";", 2)
              
              сп.ОЧИСТИТЬ
              сп.IB_STR_РазбитьНаСлова(описание, " ", НЕТ)
              макс = ДЛИНА(сп.СТРОКА(1))
              ЦИКЛ ДЛЯ(сл = 2, сп.ВСЕГО)
                длн = ДЛИНА(сп.СТРОКА(сл))
                ЕСЛИ длн > макс ТО
                  макс = длн
                КОНЕЦ_ЕСЛИ
              КОНЕЦ_ЦИКЛА
              
              ЕСЛИ сп.ВСЕГО <= 3 ТО
                описание = ""
                ЦИКЛ ДЛЯ(сл = 1, сп.ВСЕГО)
                  описание = описание + сп.СТРОКА(сл) + ?(сл = сп.ВСЕГО, "", СИМВ(13))
                КОНЕЦ_ЦИКЛА
                ЕСЛИ длина >= 30 И sql.ТИП_ПОЛЯ(поле) = "С" ТО
                  длина = 30
                  ЕСЛИ максДлнДанных <= 35 ТО
                    длина = максДлнДанных
                  КОНЕЦ_ЕСЛИ
                  ЕСЛИ длина < макс ТО
                    длина = макс
                  КОНЕЦ_ЕСЛИ
                ИНАЧЕ
                  длина = макс
                КОНЕЦ_ЕСЛИ
              ИНАЧЕ
                длнОпис = ДЛИНА(описание)
                длина = длнОпис/3
                опис = ПОДСТР(описание, 1, длина)
                опис = опис + ПОДСТР(описание, длина + 1, длина)
                описание = опис + ПОДСТР(описание, 2 * длина + 2, длина)
              КОНЕЦ_ЕСЛИ
              
              ЕСЛИ максДлнДанных = 0 ТО
                длина = макс
              КОНЕЦ_ЕСЛИ
              
              БД_ДОБАВИТЬ_СТОЛБЕЦ(набор, поле, описание, длина + 2)
              
              стлбДобавлен!поле = ДА
              СТОП
            КОНЕЦ_ЕСЛИ
          КОНЕЦ_ЕСЛИ
        КОНЕЦ_ЦИКЛА
        ЕСЛИ НЕ СУЩ_ПЕРЕМ(стлбДобавлен!поле) ТО
          макс = ДЛИНА(поле)
          ЕСЛИ длина >= 30 И sql.ТИП_ПОЛЯ(поле) = "С" ТО
            длина = 30
            ЕСЛИ максДлнДанных <= 35 ТО
              длина = максДлнДанных
            КОНЕЦ_ЕСЛИ
            ЕСЛИ длина < макс ТО
              длина = макс
            КОНЕЦ_ЕСЛИ
          ИНАЧЕ
            длина = макс
          КОНЕЦ_ЕСЛИ
          ЕСЛИ максДлнДанных = 0 ТО
            длина = макс
          КОНЕЦ_ЕСЛИ
          
          БД_ДОБАВИТЬ_СТОЛБЕЦ(набор, поле, поле, длина + 2)
          стлбДобавлен!поле = ДА
        КОНЕЦ_ЕСЛИ
      КОНЕЦ_ЕСЛИ
    КОНЕЦ_ЦИКЛА
    резВыб = БД_РЕДАКТОР(sql, [СТОЛБЦЫ(набор)], НЕТ, НЕТ, НЕТ, НЕТ)
  ИНАЧЕ
    резВыб = БД_РЕДАКТОР(sql, НЕТ, НЕТ, НЕТ, НЕТ)
  КОНЕЦ_ЕСЛИ
  
  ЕСЛИ соб = "соб_показатьЛК" ТО//откроем лк с логин/паролем выбранного владельца - 25.05.2023 Дьяченко В.И.
    ЕСЛИ резВыб <> 0 ТО
      sql.ПЕРЕЙТИ(резВыб)
      имяПольз = sql.ПОЛЕ("LOGIN")
      парольПольз = sql.ПОЛЕ("PASSW")
      id_site = sql.ПОЛЕ("ID_RECSITE")
      ЕСЛИ АТРИБУТ("&REST_адрес") <> "" ТО
        сайт = АТРИБУТ("&REST_адрес")
      ИНАЧЕ
        сайт = "http://snt.ib.ru"
      КОНЕЦ_ЕСЛИ
      адрес = сайт + "/user"
      ЕСЛИ имяПольз = "" ИЛИ парольПольз = "" ИЛИ id_site <= 0 ИЛИ НЕ sql.ПОЛЕ("IS_SYNCED") ТО
        ЕСЛИ имяПольз = "" И парольПольз = "" ТО
          ОКНО_СООБ("Не указано имя пользователя и его пароль", "", "", "ERROR")
        ИНАЧЕ
          ЕСЛИ имяПольз = "" ТО
            ОКНО_СООБ("Не указано имя пользователя", "", "", "ERROR")
          КОНЕЦ_ЕСЛИ
          ЕСЛИ парольПольз = "" ТО
            ОКНО_СООБ("Не указан пароль пользователя", "", "", "ERROR")
          КОНЕЦ_ЕСЛИ
          ЕСЛИ id_site <= 0 ИЛИ НЕ sql.ПОЛЕ("IS_SYNCED") ТО
            ОКНО_СООБ("Пользователь не выгружен на сайт", "", "", "ERROR")
          КОНЕЦ_ЕСЛИ
        КОНЕЦ_ЕСЛИ
      ИНАЧЕ
        //попробуем найти Ib10_vmxcl
        колИт = 0 //не на сервере не выходит из цикла ПОКА
        общДир = АТРИБУТ("common_path")
        ЦИКЛ ПОКА(общДир <> "")
          иб10Дир = общДир + "\" + "Ib10_vmxcl"
          ЕСЛИ НЕ СУЩ_ДИР(иб10Дир) ТО 
            ЕСЛИ колИт < 10 ТО
              общДир = IB_FILE_ПутьДир(общДир)
              колИт++
            ИНАЧЕ
              СТОП
            КОНЕЦ_ЕСЛИ
          ИНАЧЕ
            СТОП
          КОНЕЦ_ЕСЛИ
        КОНЕЦ_ЦИКЛА
        ЕСЛИ общДир <> "" И СУЩ_ДИР(иб10Дир) ТО
          //стартуем vmxcl.bat с АвторизацияВебБраузер.ibx адресом логином паролем
          иб10Бат = иб10Дир + "\" + "vmxcl.bat"
          ЕСЛИ СУЩ_ФАЙЛ(иб10Бат) ТО
            СОЗДАТЬ(спПроц, ТИП_СПИСОК)
            спПроц.ДОБАВИТЬ("vmxcl.bat" + " " + """АвторизацияВебБраузер.ibx""" + " ")
            спПроц.ДОБАВИТЬ("""" + сайт + """" + " ")//урл для логина
            спПроц.ДОБАВИТЬ("""" + имяПольз + """" + " ")//логин
            спПроц.ДОБАВИТЬ("""" + парольПольз + """" + " ")//пароль
            спПроц.ДОБАВИТЬ("""" + адрес + """" + " ")//адрес для показа в окне
            РЕЗУЛЬТАТ = спПроц.IB_FILE_ЗапускПрограммыСписок(иб10Дир, "")
          КОНЕЦ_ЕСЛИ
        КОНЕЦ_ЕСЛИ        
      КОНЕЦ_ЕСЛИ
    КОНЕЦ_ЕСЛИ
  КОНЕЦ_ЕСЛИ
  
  sql.ЗАКРЫТЬ
  ЕСЛИ соб = "соб_показатьФЖурналОст" ИЛИ соб = "соб_показатьОстатки" ТО
    //sql.IB_DBF_ЗакрытьSqlВрем
    IB_FILE_ФайлУдалить(путь)
  КОНЕЦ_ЕСЛИ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ STG_ПоказатьНаСайте(ТИП_СТРОКА: ссылка)
  ЕСЛИ АТРИБУТ(REST_атрТекПрофиль) = "" ТО
    ЕСЛИ АТРИБУТ("&REST_адрес") = "" ТО
      УСТ_АТРИБУТ("&выборПрофиляСайта", "ДА")
      ТИП_ОПЕР("Подключение к сайту <REST.TOP>")
      УСТ_АТРИБУТ("&выборПрофиляСайта", "")
      ЕСЛИ АТРИБУТ("&REST_имяПрофиляСайта") <> "" ТО
        гр_профильОтправки = АТРИБУТ("&REST_имяПрофиляСайта")
      КОНЕЦ_ЕСЛИ
    КОНЕЦ_ЕСЛИ
  ИНАЧЕ
    REST_ЗагрузИни(АТРИБУТ(REST_атрТекПрофиль), ДА)
    //REST_INI_ПроверитьПодключение
  КОНЕЦ_ЕСЛИ
  
  ЕСЛИ АТРИБУТ("&REST_адрес") <> "" ТО
    сайт = АТРИБУТ("&REST_адрес")
  ИНАЧЕ
    сайт = "http://snt.ib.ru"
  КОНЕЦ_ЕСЛИ
  адрес = сайт + ссылка
  РЕЗУЛЬТАТ = КОМАНДА_ОБОЛОЧКИ(адрес, "open", "", "", "")
  /*
  //попробуем найти Ib10_vmxcl
  колИт = 0 //не на сервере не выходит из цикла ПОКА
  общДир = АТРИБУТ("common_path")
  ЦИКЛ ПОКА(общДир <> "")
    иб10Дир = общДир + "\" + "Ib10_vmxcl"
    ЕСЛИ НЕ СУЩ_ДИР(иб10Дир) ТО 
      ЕСЛИ колИт < 10 ТО
        общДир = IB_FILE_ПутьДир(общДир)
        колИт++
      ИНАЧЕ
        СТОП
      КОНЕЦ_ЕСЛИ
    ИНАЧЕ
      СТОП
    КОНЕЦ_ЕСЛИ
  КОНЕЦ_ЦИКЛА
  РЕЗУЛЬТАТ = НЕТ
  ЕСЛИ общДир <> "" И СУЩ_ДИР(иб10Дир) ТО
    //стартуем vmxcl.bat с АвторизацияВебБраузер.ibx адресом логином паролем
    иб10Бат = иб10Дир + "\" + "vmxcl.bat"
    ЕСЛИ СУЩ_ФАЙЛ(иб10Бат) ТО
      СОЗДАТЬ(спПроц, ТИП_СПИСОК)
      спПроц.ДОБАВИТЬ("vmxcl.bat" + " " + """АвторизацияВебБраузер.ibx""" + " ")
      спПроц.ДОБАВИТЬ("""" + сайт + """" + " ")//урл для логина
      спПроц.ДОБАВИТЬ("""" + АТРИБУТ("&REST_логин") + """" + " ")//логин
      спПроц.ДОБАВИТЬ("""" + АТРИБУТ("&REST_пароль") + """" + " ")//пароль
      спПроц.ДОБАВИТЬ("""" + адрес + """" + " ")//адрес для показа в окне
      РЕЗУЛЬТАТ = спПроц.IB_FILE_ЗапускПрограммыСписок(иб10Дир, "")
    КОНЕЦ_ЕСЛИ
  КОНЕЦ_ЕСЛИ
  ЕСЛИ НЕ РЕЗУЛЬТАТ ТО
    РЕЗУЛЬТАТ = КОМАНДА_ОБОЛОЧКИ(адрес, "open", "", "", "")
  КОНЕЦ_ЕСЛИ
  ЕСЛИ НЕ РЕЗУЛЬТАТ ТО
    IB_DBG_ОтладкаОшибка("Не удалось открыть " + ссылка)
  КОНЕЦ_ЕСЛИ*/
  STG_ПоказатьНаСайте = РЕЗУЛЬТАТ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ STG_ПоказатьРеквизиты(ТИП_ЛОГИКА: показать)
  //STG_C_СпрРеквОргСайт
  
  STG_R_НастройкиПечатиПД
  STG_ОпределитьРеквПолучателя
  
  sql = SQL_ОТКРЫТЬ(ф_СпрРеквизитовОргСайт)
  
  stg_параметрДляПроверки!"Организация" = ДА
  stg_параметрДляПроверки!"Организация (полн.)" = ДА
  stg_параметрДляПроверки!"Банк" = ДА
  stg_параметрДляПроверки!"Расч. счет" = ДА
  stg_параметрДляПроверки!"БИК" = ДА
  stg_параметрДляПроверки!"Корр. счет" = ДА
  stg_параметрДляПроверки!"ИНН" = ДА
  stg_параметрДляПроверки!"КПП" = ДА
  sql.STG_ПроверитьПарамНаСущ
  
  sql.STG_ОбновитьРеквизитОрг("Организация", г_реквПолучателя!"наимОрг")
  sql.STG_ОбновитьРеквизитОрг("Организация (полн.)", г_реквПолучателя!"наимОргПолн")
  sql.STG_ОбновитьРеквизитОрг("Банк", г_реквПолучателя!"наимБанк")
  sql.STG_ОбновитьРеквизитОрг("Расч. счет", г_реквПолучателя!"расчСч")
  sql.STG_ОбновитьРеквизитОрг("БИК", г_реквПолучателя!"бик")
  sql.STG_ОбновитьРеквизитОрг("Корр. счет", г_реквПолучателя!"коррСч")
  sql.STG_ОбновитьРеквизитОрг("ИНН", г_реквПолучателя!"иннОрг")
  sql.STG_ОбновитьРеквизитОрг("КПП", г_реквПолучателя!"кппОрг")
  
  ЕСЛИ показать ТО
    БД_ВЫБОР(sql, "Реквизиты на выгрузку",
            ["name"       : "Реквизит" : 15,
             "val"        : "Значение" : 50,
             "is_synced"  : "Синхр."   : 7,
             "id_recsite" : "id"       : 7,
             "uuid"       : "uuid"     : 7
             ])
  ИНАЧЕ
    ЦИКЛ ДЛЯ(и = 1, sql.ВСЕГО)
      sql.ПЕРЕЙТИ(и)
      ВЫБОР(sql.ПОЛЕ("name"))
       #"Организация" : г_реквПолучателя!"наимОрг" = sql.ПОЛЕ("val")
       #"Организация (полн.)" : г_реквПолучателя!"наимОргПолн" = sql.ПОЛЕ("val")
       #"Банк" : г_реквПолучателя!"наимБанк" = sql.ПОЛЕ("val")
       #"Расч. счет" : г_реквПолучателя!"расчСч" = sql.ПОЛЕ("val")
       #"БИК" : г_реквПолучателя!"бик" = sql.ПОЛЕ("val")
       #"Корр. счет" : г_реквПолучателя!"коррСч" = sql.ПОЛЕ("val")
       #"ИНН" : г_реквПолучателя!"иннОрг" = sql.ПОЛЕ("val")
       #"КПП" : г_реквПолучателя!"кппОрг" = sql.ПОЛЕ("val")
      КОНЕЦ_ВЫБОРА
    КОНЕЦ_ЦИКЛА
  КОНЕЦ_ЕСЛИ
           
  sql.ЗАКРЫТЬ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ ТИП_SQL STG_ОбновитьРеквизитОрг(ТИП_СТРОКА: имя, значение)
  поз = НАЙТИ_ПОЗ("name", имя)
  ЕСЛИ поз > 0 ТО
    ПЕРЕЙТИ(поз)
    ЕСЛИ значение <> ПОЛЕ("VAL") ТО
      ЗАП_ПОЛЕ("val", значение)
      ЗАП_ПОЛЕ("IS_SYNCED", НЕТ)
    КОНЕЦ_ЕСЛИ
    ЗАМЕНИТЬ
  ИНАЧЕ
    ЗАП_ПОЛЕ("name", имя)
    ЗАП_ПОЛЕ("val", значение)
    ЗАП_ПОЛЕ("IS_SYNCED", НЕТ)
    ДОБАВИТЬ
  КОНЕЦ_ЕСЛИ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ПЕРЕМ stg_параметрДляПроверки!
ФУНКЦИЯ ТИП_SQL STG_ПроверитьПарамНаСущ
  ЦИКЛ ДЛЯ(и = ВСЕГО, 1, -1)
    ПЕРЕЙТИ(и)
    имяПарам = ПОЛЕ("NAME")
    удалять = ДА
    ЦИКЛ ИНДЕКС(знач = stg_параметрДляПроверки!инд)
      ЕСЛИ имяПарам = инд ТО
        удалять = НЕТ
        СТОП
      КОНЕЦ_ЕСЛИ
    КОНЕЦ_ЦИКЛА
    ЕСЛИ удалять ТО
      УДАЛИТЬ
    КОНЕЦ_ЕСЛИ
  КОНЕЦ_ЦИКЛА
  СБРОС(stg_параметрДляПроверки)
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ STG_ПоказатьНастройки(ТИП_ЛОГИКА: показать)
  //STG_C_СпрНастроекСайт
  
  STG_R_НастройкиПечатиПД
  
  sql = SQL_ОТКРЫТЬ(ф_СпрНастроекСайт)
  
  stg_параметрДляПроверки!"Кодировка ДШК" = ДА
  stg_параметрДляПроверки!"Рекв. ""Вид платежа"" для взносов" = ДА
  stg_параметрДляПроверки!"Рекв. ""Вид платежа"" для взносов по ИПУ" = ДА
  stg_параметрДляПроверки!"Рекв. ДШК ""Адрес плательщика""" = ДА
  stg_параметрДляПроверки!"Рекв. ДШК ""Назначение платежа"" для взносов" = ДА
  stg_параметрДляПроверки!"Рекв. ДШК ""Назначение платежа"" для ИПУ" = ДА
  stg_параметрДляПроверки!"Рекв. ДШК ""Назначение платежа"" для ИПУ без пок." = ДА
  sql.STG_ПроверитьПарамНаСущ
  
  sql.STG_ОбновитьРеквизитОрг("Кодировка ДШК", СТР_ЗНАЧ(ПараметрПечатиПД!"Кодировка ДШК"))
  sql.STG_ОбновитьРеквизитОрг("Рекв. ""Вид платежа"" для взносов", ПараметрПечатиПД!"Вид платежа остальные")
  sql.STG_ОбновитьРеквизитОрг("Рекв. ""Вид платежа"" для взносов по ИПУ", ПараметрПечатиПД!"Вид платежа ИПУ")
  
  STG_СчитатьШаблоны(к_ОбщиеРеквизиты)
  sql.STG_ОбновитьРеквизитОрг("Рекв. ДШК ""Адрес плательщика""", г_ПарамШаблонаДШК!к_ШаблонАдресПлательщика)
  
  STG_СчитатьШаблоны(к_ФормаПД4 + ", " + к_ФормаПДМнож)
  sql.STG_ОбновитьРеквизитОрг("Рекв. ДШК ""Назначение платежа"" для взносов", г_ПарамШаблонаДШК!к_ШаблонНазначениеПлатежа)
  
  STG_СчитатьШаблоны(к_ФормаПД4ЭЭ + ", " + к_ФормаПДСчСтд)
  sql.STG_ОбновитьРеквизитОрг("Рекв. ДШК ""Назначение платежа"" для ИПУ", г_ПарамШаблонаДШК!к_ШаблонНазначениеПлатежа)
  sql.STG_ОбновитьРеквизитОрг("Рекв. ДШК ""Назначение платежа"" для ИПУ без пок.", г_ПарамШаблонаДШК!к_ШаблонНазнПлатежаБезПок)

  ЕСЛИ показать ТО
    БД_ВЫБОР(sql, "Настройки на выгрузку",
            ["name"       : "Название" : 50,
             "val"        : "Значение" : 50,
             "is_synced"  : "Синхр."   : 7,
             "id_recsite" : "id"       : 7,
             "uuid"       : "uuid"     : 7
             ])
  ИНАЧЕ
    ЦИКЛ ДЛЯ(и = 1, sql.ВСЕГО)
      sql.ПЕРЕЙТИ(и)
      ВЫБОР(sql.ПОЛЕ("name"))
       #"Кодировка ДШК" : ЕСЛИ ЗНАЧ_ТЕСТ(sql.ПОЛЕ("val")) ТО
                            ПараметрПечатиПД!"Кодировка ДШК" = ЗНАЧ(sql.ПОЛЕ("val"))
                          ИНАЧЕ
                            ПараметрПечатиПД!"Кодировка ДШК" = 1
                          КОНЕЦ_ЕСЛИ
       #"Рекв. ""Вид платежа"" для взносов" : ПараметрПечатиПД!"Вид платежа остальные" = sql.ПОЛЕ("val")
       #"Рекв. ""Вид платежа"" для взносов по ИПУ" : ПараметрПечатиПД!"Вид платежа ИПУ" = sql.ПОЛЕ("val")
       #"Рекв. ДШК ""Адрес плательщика""" : ПараметрПечатиПД!к_ШаблонАдресПлательщика = sql.ПОЛЕ("val")
       #"Рекв. ДШК ""Назначение платежа"" для взносов" : ПараметрПечатиПД!к_ШаблонНазначениеПлатежа = sql.ПОЛЕ("val")
       #"Рекв. ДШК ""Назначение платежа"" для ИПУ" : ПараметрПечатиПД!к_ШаблонНазначениеПлатежа = sql.ПОЛЕ("val")
       #"Рекв. ДШК ""Назначение платежа"" для ИПУ без пок." : ПараметрПечатиПД!к_ШаблонНазнПлатежаБезПок = sql.ПОЛЕ("val")
      КОНЕЦ_ВЫБОРА
    КОНЕЦ_ЦИКЛА
  КОНЕЦ_ЕСЛИ
           
  sql.ЗАКРЫТЬ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
//-------------------------------------------------------------------------------------------------------------------------//
//Полная выгрузка всех
ФУНКЦИЯ STG_ВыгрузитьСправочники
  REST_испСписокАтр = оп_испСписокАтр
  STG_R_НастройкиБлока
  STG_ПарамВыводаТаблиц
  НачСтр = 55
  ВыводИт = ДА
  
  ЦИКЛ ДЛЯ(и = 3, 12)
    Итоги!ЛИТЕР(и) = ДА
  КОНЕЦ_ЦИКЛА
  
  TBLPRINT_ДобавитьСтолбец(6, "№", 0)
  TBLPRINT_ДобавитьСтолбец(30, "Справочник", 0)
  TBLPRINT_ДобавитьСтолбец(15, "Запланировано", 0)
  TBLPRINT_ДобавитьСтолбец(15, "Выгружено", 0)
  TBLPRINT_ДобавитьСтолбец(15, "Синхронизировано", 0)
  TBLPRINT_ДобавитьСтолбец(15, "Не синхронизировано", 0)
  TBLPRINT_ДобавитьСтолбец(0, "", 0)
  пред = TBLPRINT_ДобавитьСтолбец(15, "Время выполнения", 0)
  ЕСЛИ оп_времяПодробно ТО
    TBLPRINT_ДобавитьСтолбец(15, "Формирование запроса", пред)
    TBLPRINT_ДобавитьСтолбец(15, "Отправка запроса", пред)
    TBLPRINT_ДобавитьСтолбец(15, "Разбор ответа", пред)
    TBLPRINT_ДобавитьСтолбец(15, "Остальное", пред)
  КОНЕЦ_ЕСЛИ
  
  ЕСЛИ оп_справочникВлад ТО
    вр = ВРЕМЯ_ТЕК
    STG_ВыгрузитьВладельцев
    STG_ЗаполнитьСтлбВремени(вр)
  КОНЕЦ_ЕСЛИ
  ЕСЛИ оп_справочникУч ТО
    вр = ВРЕМЯ_ТЕК
    STG_ВыгрузитьУчастки
    STG_ЗаполнитьСтлбВремени(вр)
  КОНЕЦ_ЕСЛИ
  ЕСЛИ оп_справочникСвязи ТО
    вр = ВРЕМЯ_ТЕК
    STG_ВыгрузитьСвязи
    STG_ЗаполнитьСтлбВремени(вр)
  КОНЕЦ_ЕСЛИ
  ЕСЛИ оп_справочникФЛС ТО
    вр = ВРЕМЯ_ТЕК
    STG_ВыгрузитьФЛС
    STG_ЗаполнитьСтлбВремени(вр)
  КОНЕЦ_ЕСЛИ
  ЕСЛИ оп_справочникВзносы ТО
    вр = ВРЕМЯ_ТЕК
    STG_ВыгрузитьВзносы
    STG_ЗаполнитьСтлбВремени(вр)
  КОНЕЦ_ЕСЛИ
  ЕСЛИ оп_справочникТарифы ТО
    вр = ВРЕМЯ_ТЕК
    STG_ВыгрузитьТарифы
    STG_ЗаполнитьСтлбВремени(вр)
  КОНЕЦ_ЕСЛИ
  ЕСЛИ оп_справочникИПУ ТО
    вр = ВРЕМЯ_ТЕК
    STG_ВыгрузитьИПУ
    STG_ЗаполнитьСтлбВремени(вр)
  КОНЕЦ_ЕСЛИ
  ЕСЛИ оп_журналПок ТО
    вр = ВРЕМЯ_ТЕК
    STG_ВыгрузитьПоказания
    STG_ЗаполнитьСтлбВремени(вр)
  КОНЕЦ_ЕСЛИ
  ЕСЛИ оп_журнал ТО
    вр = ВРЕМЯ_ТЕК
    STG_ВыгрузитьЖурнал
    STG_ЗаполнитьСтлбВремени(вр)
  КОНЕЦ_ЕСЛИ
  ЕСЛИ оп_журналРасчетов ТО
    вр = ВРЕМЯ_ТЕК
    STG_ВыгрузитьРасчеты
    STG_ЗаполнитьСтлбВремени(вр)
  КОНЕЦ_ЕСЛИ
  ЕСЛИ оп_журналОстатков ТО
    вр = ВРЕМЯ_ТЕК
    STG_ВыгрузитьОстатки
    STG_ЗаполнитьСтлбВремени(вр)
  КОНЕЦ_ЕСЛИ
  ЕСЛИ оп_справочникРекв ТО
    вр = ВРЕМЯ_ТЕК
    STG_ВыгрузитьРеквизиты
    STG_ЗаполнитьСтлбВремени(вр)
  КОНЕЦ_ЕСЛИ
  ЕСЛИ оп_настройки ТО
    вр = ВРЕМЯ_ТЕК
    STG_ВыгрузитьНастройки
    STG_ЗаполнитьСтлбВремени(вр)
  КОНЕЦ_ЕСЛИ
  ЕСЛИ оп_голосования ТО
    вр = ВРЕМЯ_ТЕК
    STG_ВыгрузитьГолосования
    STG_ЗаполнитьСтлбВремени(вр)
    
    вр = ВРЕМЯ_ТЕК
    STG_ВыгрузитьВопросы
    STG_ЗаполнитьСтлбВремени(вр)
    
    вр = ВРЕМЯ_ТЕК
    STG_ВыгрузитьОтветы
    STG_ЗаполнитьСтлбВремени(вр)
  КОНЕЦ_ЕСЛИ
  
  ЕСЛИ ВсегоСтр > 0 ТО
    ПЕЧАТЬ_ШАПКИ
    ПЕЧАТЬ_ТАБЛИЦЫ
  КОНЕЦ_ЕСЛИ
  СБРОС_ТАБЛИЦ(ДА)
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ ТИП_ЛОГИКА: STG_ПрокачкаСтатуса(ТИП_СТРОКА: сообщение)
  СтатусСообщение(сообщение)
  ЕСЛИ НЕ СтатусОбновитьПрогресс("") ТО
    REST_Logout
    СТОП_ВСЕ
  КОНЕЦ_ЕСЛИ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ STG_ПроверитьИдБазы(ТИП_СТРОКА: справочник)
  //первый прогон будет по ид
  //второй прогон будет по uuid
  ЦИКЛ ДЛЯ(ит = 1, 2)
    СБРОС(г_строкиЗапроса)
    г_колСтрокЗапроса = 0
    г_колИтер = 0
    текСтрока = ""
    
    ВЫБОР(справочник)
     #ф_СпрВладельцев:
      ЦИКЛ ИНДЕКС(uuid = SPR_OWNERS_эл_id!номЭл)
        СформироватьСтрокуЗапроса(текСтрока, ?(ит = 1, номЭл, "'" + uuid + "'"), КОЛ_ЭЛЕМ(SPR_OWNERS_эл_id))
      КОНЕЦ_ЦИКЛА
     #ф_СпрУчастковГаражей:
      ЦИКЛ ИНДЕКС(uuid = SPR_OBJECTS_эл_id!номЭл)
        СформироватьСтрокуЗапроса(текСтрока, ?(ит = 1, номЭл, "'" + uuid + "'"), КОЛ_ЭЛЕМ(SPR_OBJECTS_эл_id))
      КОНЕЦ_ЦИКЛА
     #ф_СпрИндивСчетчики:
      ЦИКЛ ИНДЕКС(uuid = SPR_SHETCH_эл_id!номЭл)
        СформироватьСтрокуЗапроса(текСтрока, ?(ит = 1, номЭл, "'" + uuid + "'"), КОЛ_ЭЛЕМ(SPR_SHETCH_эл_id))
      КОНЕЦ_ЦИКЛА
     #ф_СпрФЛС:
      ЦИКЛ ИНДЕКС(uuid = SPR_FLS_эл_id!номЭл)
        СформироватьСтрокуЗапроса(текСтрока, ?(ит = 1, номЭл, "'" + uuid + "'"), КОЛ_ЭЛЕМ(SPR_FLS_эл_id))
      КОНЕЦ_ЦИКЛА
     #ф_СвязьВладУч: 
      ЦИКЛ ИНДЕКС(uuid = SPR_LINK_ALL_эл_id!номЭл)
        СформироватьСтрокуЗапроса(текСтрока, ?(ит = 1, номЭл, "'" + uuid + "'"), КОЛ_ЭЛЕМ(SPR_LINK_ALL_эл_id))
      КОНЕЦ_ЦИКЛА
     #ф_СпрЦелевыхВзносов:
      ЦИКЛ ИНДЕКС(uuid = SPR_VZNOSI_эл_id!номЭл)
        СформироватьСтрокуЗапроса(текСтрока, ?(ит = 1, номЭл, "'" + uuid + "'"), КОЛ_ЭЛЕМ(SPR_VZNOSI_эл_id))
      КОНЕЦ_ЦИКЛА
     #ф_СпрТарифов:
      ЦИКЛ ИНДЕКС(uuid = SPR_TARIF_эл_id!номЭл)
        СформироватьСтрокуЗапроса(текСтрока, ?(ит = 1, номЭл, "'" + uuid + "'"), КОЛ_ЭЛЕМ(SPR_TARIF_эл_id))
      КОНЕЦ_ЦИКЛА
     #ф_Журнал:
      ЦИКЛ ИНДЕКС(uuid = SPR_REGISTER_эл_id!номЭл)
        СформироватьСтрокуЗапроса(текСтрока, ?(ит = 1, номЭл, "'" + uuid + "'"), КОЛ_ЭЛЕМ(SPR_REGISTER_эл_id))
      КОНЕЦ_ЦИКЛА
     #ф_ЖурналРасчетов: 
      ЦИКЛ ИНДЕКС(uuid = SPR_CALC_REG_эл_id!номЭл)
        СформироватьСтрокуЗапроса(текСтрока, ?(ит = 1, номЭл, "'" + uuid + "'"), КОЛ_ЭЛЕМ(SPR_CALC_REG_эл_id))
      КОНЕЦ_ЦИКЛА
     #ф_ПоказанияИСЭЭ, ф_ПоказанияИСВГ: 
      ЦИКЛ ИНДЕКС(uuid = POK_SCH_эл_id!номЭл)
        СформироватьСтрокуЗапроса(текСтрока, ?(ит = 1, номЭл, "'" + uuid + "'"), КОЛ_ЭЛЕМ(POK_SCH_эл_id))
      КОНЕЦ_ЦИКЛА
     #ф_ЖурналСинхрОстатков: 
      ЦИКЛ ИНДЕКС(uuid = SPR_DEBTS_эл_id!номЭл)
        СформироватьСтрокуЗапроса(текСтрока, ?(ит = 1, номЭл, "'" + uuid + "'"), КОЛ_ЭЛЕМ(SPR_DEBTS_эл_id))
      КОНЕЦ_ЦИКЛА
     #к_спрСайтаГолосования, mp_файлГолосований: 
      ЦИКЛ ИНДЕКС(uuid = MP_POLL_эл_id!номЭл)
        СформироватьСтрокуЗапроса(текСтрока, ?(ит = 1, номЭл, "'" + uuid + "'"), КОЛ_ЭЛЕМ(MP_POLL_эл_id))
      КОНЕЦ_ЦИКЛА
     #к_спрСайтаВопросы, mp_файлВопросов: 
      ЦИКЛ ИНДЕКС(uuid = MP_QUESTION_эл_id!номЭл)
        СформироватьСтрокуЗапроса(текСтрока, ?(ит = 1, номЭл, "'" + uuid + "'"), КОЛ_ЭЛЕМ(MP_QUESTION_эл_id))
      КОНЕЦ_ЦИКЛА
     #к_спрСайтаОтветы, mp_файлОтветов: 
      ЦИКЛ ИНДЕКС(uuid = MP_ANSWER_эл_id!номЭл)
        СформироватьСтрокуЗапроса(текСтрока, ?(ит = 1, номЭл, "'" + uuid + "'"), КОЛ_ЭЛЕМ(MP_ANSWER_эл_id))
      КОНЕЦ_ЦИКЛА
     #mp_файлРезультатов: 
      ЦИКЛ ИНДЕКС(uuid = MP_RESULT_эл_id!номЭл)
        СформироватьСтрокуЗапроса(текСтрока, ?(ит = 1, номЭл, "'" + uuid + "'"), КОЛ_ЭЛЕМ(MP_RESULT_эл_id))
      КОНЕЦ_ЦИКЛА
      #ф_СпрРеквизитовОргСайт:
      ЦИКЛ ИНДЕКС(uuid = SPR_REKV_эл_id!номЭл)
        СформироватьСтрокуЗапроса(текСтрока, ?(ит = 1, номЭл, "'" + uuid + "'"), КОЛ_ЭЛЕМ(SPR_REKV_эл_id))
      КОНЕЦ_ЦИКЛА
      #ф_СпрНастроекСайт:
      ЦИКЛ ИНДЕКС(uuid = SPR_SETS_эл_id!номЭл)
        СформироватьСтрокуЗапроса(текСтрока, ?(ит = 1, номЭл, "'" + uuid + "'"), КОЛ_ЭЛЕМ(SPR_SETS_эл_id))
      КОНЕЦ_ЦИКЛА
    КОНЕЦ_ВЫБОРА
    
    СОЗДАТЬ(сп, ТИП_СПИСОК)
    ЕСЛИ г_колСтрокЗапроса > 0 ТО
      начСтр = 1
      ЦИКЛ ПОКА(ДА)
        сп.ОЧИСТИТЬ
        сп.ДОБАВИТЬ("UPDATE")
        сп.ДОБАВИТЬ("'" + справочник + "'")
        сп.ДОБАВИТЬ("SET ID_RECSITE = 0, UUID = '', IS_SYNCED = FALSE")
        сп.ДОБАВИТЬ("WHERE " + ?(ит = 1, "ID_RECSITE", "UUID") + " NOT IN (")
        сп.ЗаполнитьСписокЭлементов(2500, 500, начСтр)
        сп.ДОБАВИТЬ(")")
        SQL_ЗАПРОС(сп)
        ЕСЛИ начСтр >= г_колСтрокЗапроса ТО
          СТОП
        КОНЕЦ_ЕСЛИ
      КОНЕЦ_ЦИКЛА
    КОНЕЦ_ЕСЛИ
  КОНЕЦ_ЦИКЛА
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
//-------------------------------------------------------------------------------------------------------------------------//
ПЕРЕМ г_выгруженВладелец!
ПЕРЕМ г_выгруженВладелецИд!
ПЕРЕМ г_сальдоВлад!
ПЕРЕМ г_участкиВлад!

ФУНКЦИЯ STG_ВыгрузитьВладельцев
  СБРОС(SPR_OWNERS_эл_доб, SPR_OWNERS_эл_счит, SPR_OWNERS_эл_знач, SPR_OWNERS_эл_изм)
  спр = "Справочник владельцев"
  rest_колЭлемПодЗапрДоб = stg_профилиВыгрузкиСпр!спр!"_qty_add"
  
  СОЗДАТЬ(sql_loop, ТИП_SQL)
  sql_loop.STG_ЗапросВыгрузкиСпрВлад
  STG_ИниСтрокуОтчета("Справочник владельцев")
  //
  врем_таб_создана = НЕТ
  ЦИКЛ ДЛЯ (и = 1, 1000)
    путьВремТабл = иб_путь_врем_сет + "temp_multisel_" + СТР_ЗНАЧ(и) + ".dbf"
    ЕСЛИ НЕ СУЩ_ФАЙЛ(путьВремТабл) ТО
      sql_loop.ЗАПИСАТЬ(путьВремТабл)
      врем_таб_создана = ДА
      СТОП
    КОНЕЦ_ЕСЛИ
  КОНЕЦ_ЦИКЛА
  sql_loop.ЗАКРЫТЬ
  //
  ЕСЛИ врем_таб_создана ТО
    sql_loop = SQL_ОТКРЫТЬ(путьВремТабл)
  ИНАЧЕ
    ВЫХОД
  КОНЕЦ_ЕСЛИ
  
  /*т = БД_РЕДАКТОР(sql_loop, "Справочник владельцев", 
                  ["SLCTR" : "" : 2,
                   "N_AREA" : "Участок" : 10,
                   "FIO" : "Ф.И.О." : 35,
                   "PART" : "Доля" : 6,
                   "EMAIL" : "E-Mail" : 20,
                   "ID_RECSITE" : "ID сайта": 10,
                   "IS_SYNCED" : "Синхр." : 10
                   ], НЕТ, НЕТ, НЕТ, ДА,
                   [В: ("IB_DLG.IBL", "IB_DLG_ПереклПоляВыбора"),
                    Ж: ("IB_DLG.IBL", "IB_DLG_МножУстПоляВыбора")];
                   перекл_выбора = ДА;
                   @путь_файла = путьВремТабл;
                   @поле_выбора = "SLCTR")*/
  //ВЫХОД
  //выгрузка участков и сальдо
  СОЗДАТЬ(sql, ТИП_SQL)
  sql.STG_ЗапросВыгрузкиОстатки(путь)
  sql.ЗАКРЫТЬ
  
  СОЗДАТЬ(сп, ТИП_СПИСОК)
  сп.ДОБАВИТЬ("SELECT A.ID_OWNER, B.SRT, C.ID_AREA, C.N_AREA, SUM(C.SALDO) AS SUMM FROM")
  сп.ДОБАВИТЬ("'" + ф_СвязьВладУч + "' A")
  сп.ДОБАВИТЬ("INNER JOIN")
  сп.ДОБАВИТЬ("'" + ф_СпрУчастковГаражей + "' B")
  сп.ДОБАВИТЬ("ON A.ID_AREA = B.ID_AREA")
  сп.ДОБАВИТЬ("INNER JOIN")
  сп.ДОБАВИТЬ("'" + путь + "' C")
  сп.ДОБАВИТЬ("ON B.ID_AREA = C.ID_AREA GROUP BY A.ID_OWNER, B.SRT, C.ID_AREA, C.N_AREA ORDER BY B.SRT")
  sql = SQL_ЗАПРОС(сп)
  //БД_РЕДАКТОР(sql)
  //СТОП_ВСЕ
  ЦИКЛ ДЛЯ(и = 1, sql.ВСЕГО)
    sql.ПЕРЕЙТИ(и)
    идВладельца = sql.ПОЛЕ("ID_OWNER")
    
    ЕСЛИ НЕ СУЩ_ПЕРЕМ(г_сальдоВлад!идВладельца) ТО
      г_сальдоВлад!идВладельца = 0
    КОНЕЦ_ЕСЛИ
    г_сальдоВлад!идВладельца = г_сальдоВлад!идВладельца + sql.ПОЛЕ("SUMM")
    
    /*ЕСЛИ НЕ СУЩ_ПЕРЕМ(г_участкиВлад!идВладельца) ТО
      г_участкиВлад!идВладельца = ""
    КОНЕЦ_ЕСЛИ
    г_участкиВлад!идВладельца = г_участкиВлад!идВладельца + ?(г_участкиВлад!идВладельца = "", "", ", ") + sql.ПОЛЕ("N_AREA")*/
  КОНЕЦ_ЦИКЛА
  sql.ЗАКРЫТЬ
  IB_FILE_ФайлУдалить(путь)
  //
  ЦИКЛ ДЛЯ(и = 1, sql_loop.ВСЕГО)
    sql_loop.ПЕРЕЙТИ(и)
    идВладельца = sql_loop.ПОЛЕ("ID")
    ЕСЛИ НЕ СУЩ_ПЕРЕМ(г_участкиВлад!идВладельца) ТО
      г_участкиВлад!идВладельца = ""
      неБылВыгружен!идВладельца = ДА
    КОНЕЦ_ЕСЛИ
    ЕСЛИ НЕ СУЩ_ПЕРЕМ(г_сальдоВлад!идВладельца) ТО
      г_сальдоВлад!идВладельца = 0
    КОНЕЦ_ЕСЛИ
    ЕСЛИ СУЩ_ПЕРЕМ(неБылВыгружен!идВладельца) ТО
      ЕСЛИ ПОЗ(sql_loop.ПОЛЕ("N_AREA"), г_участкиВлад!идВладельца) = 0 ТО
        г_участкиВлад!идВладельца = г_участкиВлад!идВладельца + ?(г_участкиВлад!идВладельца = "", "", ", ") + sql_loop.ПОЛЕ("N_AREA")
      КОНЕЦ_ЕСЛИ
    КОНЕЦ_ЕСЛИ
  КОНЕЦ_ЦИКЛА
  //
  СБРОС(г_выгруженВладелецИд, г_выгруженВладелец, stg_passwords)
  SPR_OWNERS_ПолучитьСписок(ДА)
  ЦИКЛ ИНДЕКС(знач = SPR_OWNERS_эл_счит!индекс)
    ЕСЛИ ПОЗ("SPR_OWNERS_id", индекс) > 0 ТО
      ЕСЛИ СУЩ_ПЕРЕМ(SPR_OWNERS_эл_знач!индекс) ТО
        г_выгруженВладелецИд[SPR_OWNERS_эл_знач!индекс] = ДА
      КОНЕЦ_ЕСЛИ
    КОНЕЦ_ЕСЛИ
    ЕСЛИ ПОЗ("SPR_OWNERS_name", индекс) > 0 ТО
      ЕСЛИ СУЩ_ПЕРЕМ(SPR_OWNERS_эл_знач!индекс) ТО
        г_выгруженВладелец[SPR_OWNERS_эл_знач!индекс] = ДА
      КОНЕЦ_ЕСЛИ
    КОНЕЦ_ЕСЛИ
  КОНЕЦ_ЦИКЛА
  
  СБРОС(SPR_OWNERS_эл_доб, SPR_OWNERS_эл_счит, SPR_OWNERS_эл_знач, SPR_OWNERS_эл_изм)
  //
  длина = ДЛИНА(СТР_ЗНАЧ(sql_loop.ВСЕГО))
  //БД_РЕДАКТОР(sql_loop)
  sql = SQL_ОТКРЫТЬ(ф_СпрВладельцев)
  
  СтатусСоздать("Обработка пользователей для выгрузки")
  СтатусСтартПрогресс(sql_loop.ВСЕГО)  
  ЦИКЛ ДЛЯ(и = 1, sql_loop.ВСЕГО) //, 1, -1)
    sql_loop.ПЕРЕЙТИ(и)
    ЕСЛИ sql_loop.ПОЛЕ("SLCTR") = "" ТО
      ПРОДОЛЖИТЬ
    КОНЕЦ_ЕСЛИ
    
    инд = СТР0(и, длина)
    
    STG_ПрокачкаСтатуса(sql.ПОЛЕ("fio"))
    
    ЕСЛИ НЕ stg_профилиВыгрузкиСпр!спр!"_subreq_add" ТО
      ЕСЛИ sql_loop.STG_ДобЗначВладельцы(инд) ТО
        ЕСЛИ SPR_OWNERS_ДобавитьМнож(НЕТ) ТО
          sql.STG_СинхронизироватьВладельца("")
          г_выгруженВладелец!инд = ДА
          г_выгруженВладелецИд[sql.ПОЛЕ("ID")] = ДА
        ИНАЧЕ
          СТОП
        КОНЕЦ_ЕСЛИ
      КОНЕЦ_ЕСЛИ
    
      СБРОС(SPR_OWNERS_эл_доб, SPR_OWNERS_эл_счит, SPR_OWNERS_эл_знач, SPR_OWNERS_эл_изм)
    ИНАЧЕ
      sql_loop.STG_ДобЗначВладельцы(инд)
    КОНЕЦ_ЕСЛИ
  КОНЕЦ_ЦИКЛА
  СтатусЗакрыть
  //ВЫХОД
  ЕСЛИ stg_профилиВыгрузкиСпр!спр!"_subreq_add" ТО
    SPR_OWNERS_ДобавитьМнож(stg_профилиВыгрузкиСпр!спр!"_subreq_add")
    СтатусСоздать("Синхронизация справочника владельцев")
    СтатусСтартПрогресс(КОЛ_ЭЛЕМ(REST_эл_id))
    ЦИКЛ ИНДЕКС(лог = SPR_OWNERS_эл_доб!инд)
      ЕСЛИ лог ТО
        STG_ПрокачкаСтатуса("Синхронизация справочника владельцев")
        sql.STG_СинхронизироватьВладельца(инд)
      КОНЕЦ_ЕСЛИ
    КОНЕЦ_ЦИКЛА
    СтатусЗакрыть
    СБРОС(SPR_OWNERS_эл_доб, SPR_OWNERS_эл_счит, SPR_OWNERS_эл_знач, SPR_OWNERS_эл_изм)
  КОНЕЦ_ЕСЛИ

  sql_loop.ЗАКРЫТЬ
  sql.ЗАКРЫТЬ
  IB_FILE_ФайлУдалить(путьВремТабл)
  СБРОС(г_участкиВлад, г_сальдоВлад)
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ ТИП_SQL STG_ЗапросВыгрузкиСпрВлад
  СОЗДАТЬ(сп, ТИП_СПИСОК)
  сп.ДОБАВИТЬ("SELECT A.*, B.PART, C.SRT, C.N_AREA, CAST('V' AS CHAR(2)) AS SLCTR FROM")
  сп.ДОБАВИТЬ("'" + ф_СпрВладельцев + "' A")
  сп.ДОБАВИТЬ("RIGHT JOIN")
  сп.ДОБАВИТЬ("'" + ф_СвязьВладУч + "' B")
  сп.ДОБАВИТЬ("ON A.ID = B.ID_OWNER")
  сп.ДОБАВИТЬ("INNER JOIN")
  сп.ДОБАВИТЬ("'" + ф_СпрУчастковГаражей + "' C")
  сп.ДОБАВИТЬ("ON B.ID_AREA = C.ID_AREA")
  сп.ДОБАВИТЬ("WHERE (A.IS_SYNCED = FALSE OR A.IS_SYNCED IS NULL) AND B.datotchsv > '" + СТР(ДАТА_ТЕК) + 
              "'") // AND B.CONSIDER = TRUE AND B.PART <> ''")
  ЕСЛИ г_колУчастков > 0 ТО
    сп.ДОБАВИТЬ("AND B.ID_AREA IN (")
    сп.STG_ARH_СчитатьАрхив(к_АрхивСпрУчастков, г_путьПрофиляСпрУчастков)
    сп.ДОБАВИТЬ(")")
  КОНЕЦ_ЕСЛИ
  сп.ДОБАВИТЬ("ORDER BY C.SRT, B.PART, A.FIO DESC")
  //ОТЛАДКА(сп)
  ЗАПРОС(сп)
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ ТИП_SQL ТИП_ЛОГИКА: STG_СинхронизироватьВладельца(ТИП_СТРОКА: id)
  спр = "Справочник владельцев"
  ЕСЛИ id = "" ТО
    id = СТР_ЗНАЧ(SPR_OWNERS_id)
  КОНЕЦ_ЕСЛИ
  ЕСЛИ СУЩ_ПЕРЕМ(SPR_OWNERS_эл_счит[id + "|SPR_OWNERS_field_id"]) ТО
    ЕСЛИ СУЩ_ПЕРЕМ(Данные!ВсегоСтр!"D") ТО
      Данные!ВсегоСтр!"D"++
    КОНЕЦ_ЕСЛИ
    ЕСЛИ stg_профилиВыгрузкиСпр!спр!"_subreq_add" ТО
      SPR_OWNERS_Упаковать(id)
    КОНЕЦ_ЕСЛИ
    ЕСЛИ SPR_OWNERS_эл_счит[id + "|SPR_OWNERS_field_id"] ТО
      поз = НАЙТИ_ПОЗ("ID", SPR_OWNERS_field_id)
      ЕСЛИ поз > 0 ТО
        ЕСЛИ СУЩ_ПЕРЕМ(Данные!ВсегоСтр!"E") ТО
          Данные!ВсегоСтр!"E"++
        КОНЕЦ_ЕСЛИ
        ПЕРЕЙТИ(поз)
        ЕСЛИ SPR_OWNERS_эл_счит[id + "|SPR_OWNERS_field_is_synced"] ТО
          ЗАП_ПОЛЕ("IS_SYNCED", SPR_OWNERS_field_is_synced)
        КОНЕЦ_ЕСЛИ
        ЕСЛИ SPR_OWNERS_эл_счит[id + "|SPR_OWNERS_id"] ТО
          ЗАП_ПОЛЕ("ID_RECSITE", SPR_OWNERS_id)
        КОНЕЦ_ЕСЛИ
        ЕСЛИ SPR_OWNERS_эл_счит[id + "|SPR_OWNERS_uuid"] ТО
          ЗАП_ПОЛЕ("UUID", SPR_OWNERS_uuid)
        КОНЕЦ_ЕСЛИ
        ЕСЛИ SPR_OWNERS_эл_счит[id + "|SPR_OWNERS_name"] ТО
          ЗАП_ПОЛЕ("LOGIN", SPR_OWNERS_name)
          ЗАП_ПОЛЕ("PASSW", stg_passwords!SPR_OWNERS_name)
        КОНЕЦ_ЕСЛИ
        ЗАМЕНИТЬ
        РЕЗУЛЬТАТ = ДА
      ИНАЧЕ
        ЕСЛИ СУЩ_ПЕРЕМ(Данные!ВсегоСтр!"F") ТО
          Данные!ВсегоСтр!"F"++
        КОНЕЦ_ЕСЛИ
      КОНЕЦ_ЕСЛИ
    КОНЕЦ_ЕСЛИ
  КОНЕЦ_ЕСЛИ
  STG_СинхронизироватьВладельца = РЕЗУЛЬТАТ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ПЕРЕМ stg_passwords!
ФУНКЦИЯ ТИП_SQL ТИП_ЛОГИКА: STG_ДобЗначВладельцы(ТИП_СТРОКА: инд) //добавление нового //ПЕРЕМ
  //ОТЛАДКА(ПОЛЕ("FIO") + " - " + ПОЛЕ("N_AREA"))
  ЕСЛИ НЕ СУЩ_ПЕРЕМ(оп_проверкаПочты) ТО
    оп_проверкаПочты = ДА
  КОНЕЦ_ЕСЛИ
  ЕСЛИ НЕ СУЩ_ПЕРЕМ(оп_подзапрДобавление) ТО
    оп_подзапрДобавление = НЕТ
  КОНЕЦ_ЕСЛИ
  ЕСЛИ НЕ СУЩ_ПЕРЕМ(гр_длинаПароля) ТО
    гр_длинаПароля = 8
  КОНЕЦ_ЕСЛИ
  
  РЕЗУЛЬТАТ = НЕТ
  ид = ПОЛЕ("id_recsite")
  ЕСЛИ оп_проверкаПочты ТО
    логПров = СУЩ_ПЕРЕМ(г_выгруженВладелецИд!ид)
  ИНАЧЕ
    логПров = НЕТ
  КОНЕЦ_ЕСЛИ
  ЕСЛИ НЕ логПров ТО
    спр = "owners"
    email = СТР_ФРАГ(ПОЛЕ("email"), ib_mail_разделительАдресов, 1)
    login = "SPR_OWNERS_" + IB_STR_ИсправитьКод(ПОЛЕ("n_area")) //логин по номеру участка
    login_id = "SPR_OWNERS_ID_" + СТР_ЗНАЧ(ПОЛЕ("id")) //логин по ид юзера - по нему основная проверка на выгрузку, чтобы не плодить
    //ОТЛАДКА("login = " + login)
    //ОТЛАДКА("login_id = " + login_id)
    ЕСЛИ email <> "" ТО
      ЕСЛИ IB_STR_ПроверкаЕмейла(email, ошибка) ТО
        ЕСЛИ НЕ СУЩ_ПЕРЕМ(г_выгруженВладелецИд!email) ТО
          login = email
        КОНЕЦ_ЕСЛИ
      ИНАЧЕ
        IB_DBG_ОтладкаОшибка(ошибка + ": " + email)
        email = ""
      КОНЕЦ_ЕСЛИ
    КОНЕЦ_ЕСЛИ
    //ОТЛАДКА("login_email = " + login)
    
    //проверка выгрузки по логину
    ЕСЛИ СУЩ_ПЕРЕМ(г_выгруженВладелецИд!login) ТО
      ит = 0
      ЕСЛИ login = email ТО //если выгружен по такому мылу был, то пропускаем выгрузку, хотя мб и не правильно это..
        ВЫХОД
      ИНАЧЕ
        стр = login
        ЦИКЛ ПОКА(ДА) //тут генерим логин, если юзеров на участке больше 1
          ЕСЛИ НЕ СУЩ_ПЕРЕМ(г_выгруженВладелецИд!стр) ТО
            login = стр
            СТОП
          КОНЕЦ_ЕСЛИ
          ит++
          стр = login + "_" + СТР_ЗНАЧ(ит)
        КОНЕЦ_ЦИКЛА
      КОНЕЦ_ЕСЛИ
    КОНЕЦ_ЕСЛИ
    //ОТЛАДКА("login_str = " + login)
    
    //проверка выгрузки по логину через ид - основная проверка, наверное
    //ОТЛАДКА(СУЩ_ПЕРЕМ(г_выгруженВладелецИд!login_id))
    ЕСЛИ НЕ СУЩ_ПЕРЕМ(г_выгруженВладелецИд!login_id) ТО
      SPR_OWNERS_эл_доб!инд = НЕТ
      password = ПОЛЕ("PASSW")
      ЕСЛИ password = "" ТО
        password = IB_STR_СгенерироватьПароль(гр_длинаПароля, ДА, ДА, НЕТ, ДА)
      КОНЕЦ_ЕСЛИ
      stg_passwords!login = password
      ДобавитьЗначениеЧ(спр, инд + "|SPR_OWNERS_field_sortorder", ЗНАЧ(инд))
      ДобавитьЗначениеС(спр, инд + "|SPR_OWNERS_name", login)
      ДобавитьЗначениеС(спр, инд + "|SPR_OWNERS_pass", password)
      ЕСЛИ оп_проверкаПочты ТО
        ЕСЛИ email <> "" ТО
          ЕСЛИ НЕ г_выгруженВладелецИд!email ТО
            ДобавитьЗначениеС(спр, инд + "|SPR_OWNERS_mail", email)
            ДобавитьЗначениеС(спр, инд + "|SPR_OWNERS_init", email)
          КОНЕЦ_ЕСЛИ
        КОНЕЦ_ЕСЛИ
      ИНАЧЕ
        ЕСЛИ email <> "" ТО
          ДобавитьЗначениеС(спр, инд + "|SPR_OWNERS_mail", email)
          ДобавитьЗначениеС(спр, инд + "|SPR_OWNERS_init", email)
        КОНЕЦ_ЕСЛИ
      КОНЕЦ_ЕСЛИ
      ДобавитьЗначениеЛ(спр, инд + "|SPR_OWNERS_status", ДА)
    
      STG_ИзмЗначВладельцы(инд)
      //инд = login_id //тут руинило сортировку, наверное
      //ЕСЛИ НЕ оп_подзапрДобавление ТО //не выгружен, а добавлен в выгрузку в файл
        //г_выгруженВладелец!login_id = ДА
        //г_выгруженВладелец!email = ДА
        
        г_выгруженВладелецИд!login = ДА
        //г_выгруженВладелецИд[ид] = ДА
        //г_выгруженВладелецИд[email] = ДА
        г_выгруженВладелецИд!login_id = ДА
      //ИНАЧЕ
      //  г_выгруженВладелецИд!login_id = ДА
      //КОНЕЦ_ЕСЛИ
      Данные!ВсегоСтр!"C"++
      РЕЗУЛЬТАТ = ДА
    КОНЕЦ_ЕСЛИ
  КОНЕЦ_ЕСЛИ
  //ОТЛАДКА(РЕЗУЛЬТАТ)
  STG_ДобЗначВладельцы = РЕЗУЛЬТАТ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ ТИП_SQL STG_ИзмЗначВладельцы(ТИП_СТРОКА: инд) //только для изменения
  спр = "owners"
  ид = ПОЛЕ("id")
  ДобавитьЗначениеС(спр, инд + "|SPR_OWNERS_type", "user--user")
  ДобавитьЗначениеЧ(спр, инд + "|SPR_OWNERS_field_id", ид)
  ДобавитьЗначениеС(спр, инд + "|SPR_OWNERS_field_n_area", г_участкиВлад!ид)
  ДобавитьЗначениеЧ(спр, инд + "|SPR_OWNERS_field_sum_debt", г_сальдоВлад!ид)
  ДобавитьЗначениеС(спр, инд + "|SPR_OWNERS_field_fio", ПОЛЕ("fio"))
  ДобавитьЗначениеС(спр, инд + "|SPR_OWNERS_field_addr_p", ПОЛЕ("addr_p"))
  ДобавитьЗначениеС(спр, инд + "|SPR_OWNERS_field_address", ПОЛЕ("address"))
  ДобавитьЗначениеС(спр, инд + "|SPR_OWNERS_field_addr_f", ПОЛЕ("addr_f"))
  ДобавитьЗначениеД(спр, инд + "|SPR_OWNERS_field_dateout", ПОЛЕ("dateout"))
  ДобавитьЗначениеД(спр, инд + "|SPR_OWNERS_field_datein", ПОЛЕ("datein"))
  ДобавитьЗначениеД(спр, инд + "|SPR_OWNERS_field_rog", ПОЛЕ("rog"))
  ДобавитьЗначениеС(спр, инд + "|SPR_OWNERS_field_comm", ПОЛЕ("comm"))
  ДобавитьЗначениеС(спр, инд + "|SPR_OWNERS_field_mesto", ПОЛЕ("mesto"))
  ДобавитьЗначениеС(спр, инд + "|SPR_OWNERS_field_mob1", ПОЛЕ("mob1"))
  ДобавитьЗначениеС(спр, инд + "|SPR_OWNERS_field_mob2", ПОЛЕ("mob2"))
  ДобавитьЗначениеС(спр, инд + "|SPR_OWNERS_field_nom_prot", ПОЛЕ("nom_prot"))
  ДобавитьЗначениеС(спр, инд + "|SPR_OWNERS_field_pas", ПОЛЕ("pas"))
  ДобавитьЗначениеС(спр, инд + "|SPR_OWNERS_field_tel", ПОЛЕ("tel"))
  ДобавитьЗначениеЛ(спр, инд + "|SPR_OWNERS_field_is_synced", ДА)
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ STG_ВыгрузитьУчастки
  СБРОС(SPR_OBJECTS_эл_доб, SPR_OBJECTS_эл_id, SPR_OBJECTS_эл_счит, SPR_OBJECTS_эл_знач, SPR_OBJECTS_эл_изм)
  спр = "Справочник участков"
  rest_колЭлемПодЗапрДоб = stg_профилиВыгрузкиСпр!спр!"_qty_add"
  
  ЕСЛИ оп_проверятьБазуПоСайту ТО
    ЕСЛИ SPR_OBJECTS_ПолучитьСписок(ДА) ТО
      STG_ПроверитьИдБазы(ф_СпрУчастковГаражей)
    КОНЕЦ_ЕСЛИ
    СБРОС(SPR_OBJECTS_эл_id, SPR_OBJECTS_эл_уд, SPR_OBJECTS_эл_счит, SPR_OBJECTS_эл_доб,  SPR_OBJECTS_эл_знач, SPR_OBJECTS_эл_изм, REST_эл)
  КОНЕЦ_ЕСЛИ
  
  СОЗДАТЬ(sql_loop, ТИП_SQL)
  sql_loop.STG_ЗапросВыгрузкиСпрУч
  sql = SQL_ОТКРЫТЬ(ф_СпрУчастковГаражей)
  длина = ДЛИНА(СТР_ЗНАЧ(sql_loop.ВСЕГО))
  STG_ИниСтрокуОтчета("Справочник участков")
  СтатусСоздать("Обработка участков для выгрузки")
  СтатусСтартПрогресс(sql_loop.ВСЕГО)
  ЦИКЛ ДЛЯ(и = sql_loop.ВСЕГО, 1, -1)
    sql_loop.ПЕРЕЙТИ(и)
    
    инд = СТР0(и, длина)
    
    SPR_OBJECTS_эл_доб!инд = НЕТ
    Данные!ВсегоСтр!"C"++
    
    STG_ПрокачкаСтатуса("обработка участка: " + sql_loop.ПОЛЕ("n_area"))
    
    sql_loop.STG_ДобЗначУчастки(инд)
    
    ЕСЛИ НЕ stg_профилиВыгрузкиСпр!спр!"_subreq_add" ТО
      ЕСЛИ SPR_OBJECTS_ДобавитьМнож(НЕТ) ТО
        sql.STG_СинхронизироватьУчасток("")
      ИНАЧЕ
        СТОП
      КОНЕЦ_ЕСЛИ
      
      СБРОС(SPR_OBJECTS_эл_доб, SPR_OBJECTS_эл_id, SPR_OBJECTS_эл_счит, SPR_OBJECTS_эл_знач, SPR_OBJECTS_эл_изм)
    КОНЕЦ_ЕСЛИ
  КОНЕЦ_ЦИКЛА
  СтатусЗакрыть
  
  ЕСЛИ stg_профилиВыгрузкиСпр!спр!"_subreq_add" ТО
    SPR_OBJECTS_ДобавитьМнож(stg_профилиВыгрузкиСпр!спр!"_subreq_add")
    СтатусСоздать("Синхронизация справочника участков")
    СтатусСтартПрогресс(КОЛ_ЭЛЕМ(REST_эл_id))
    ЦИКЛ ИНДЕКС(лог = SPR_OBJECTS_эл_доб!инд)
      ЕСЛИ лог ТО
        STG_ПрокачкаСтатуса("Синхронизация справочника участков")
        sql.STG_СинхронизироватьУчасток(инд)
      КОНЕЦ_ЕСЛИ
    КОНЕЦ_ЦИКЛА
    СтатусЗакрыть
    СБРОС(SPR_OBJECTS_эл_доб, SPR_OBJECTS_эл_id, SPR_OBJECTS_эл_счит, SPR_OBJECTS_эл_знач, SPR_OBJECTS_эл_изм)
  КОНЕЦ_ЕСЛИ
  
  sql_loop.ЗАКРЫТЬ
  sql.ЗАКРЫТЬ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ ТИП_SQL STG_ЗапросВыгрузкиСпрУч
  СОЗДАТЬ(сп, ТИП_СПИСОК)
  сп.ДОБАВИТЬ("SELECT * FROM")
  сп.ДОБАВИТЬ("'" + ф_СпрУчастковГаражей + "'")
  сп.ДОБАВИТЬ("WHERE (IS_SYNCED = FALSE OR IS_SYNCED IS NULL)")
  ЕСЛИ г_колУчастков > 0 ТО
    сп.ДОБАВИТЬ("AND ID_AREA IN (")
    сп.STG_ARH_СчитатьАрхив(к_АрхивСпрУчастков, г_путьПрофиляСпрУчастков)
    сп.ДОБАВИТЬ(")")
  КОНЕЦ_ЕСЛИ
  сп.ДОБАВИТЬ("ORDER BY SRT")
  ЗАПРОС(сп)
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ ТИП_SQL ТИП_ЛОГИКА: STG_СинхронизироватьУчасток(ТИП_СТРОКА: id)
  спр = "Справочник участков"
  ЕСЛИ id = "" ТО
    id = СТР_ЗНАЧ(SPR_OBJECTS_id)
  КОНЕЦ_ЕСЛИ
  РЕЗУЛЬТАТ = НЕТ
  
  ЕСЛИ СУЩ_ПЕРЕМ(SPR_OBJECTS_эл_счит[id + "|SPR_OBJECTS_id_area"]) ТО
    ЕСЛИ SPR_OBJECTS_эл_счит[id + "|SPR_OBJECTS_id_area"] ТО
      ЕСЛИ СУЩ_ПЕРЕМ(Данные!ВсегоСтр!"D") ТО
        Данные!ВсегоСтр!"D"++
      КОНЕЦ_ЕСЛИ
      ЕСЛИ stg_профилиВыгрузкиСпр!спр!"_subreq_add" ТО
        SPR_OBJECTS_Упаковать(id)
      КОНЕЦ_ЕСЛИ
      поз = НАЙТИ_ПОЗ("id_area", SPR_OBJECTS_id_area)
      ЕСЛИ поз > 0 ТО
        ЕСЛИ СУЩ_ПЕРЕМ(Данные!ВсегоСтр!"E") ТО
          Данные!ВсегоСтр!"E"++
        КОНЕЦ_ЕСЛИ
        ПЕРЕЙТИ(поз)
        ЕСЛИ SPR_OBJECTS_эл_счит[id + "|SPR_OBJECTS_is_synced"] ТО
          ЗАП_ПОЛЕ("IS_SYNCED", SPR_OBJECTS_is_synced)
        КОНЕЦ_ЕСЛИ
        ЕСЛИ SPR_OBJECTS_эл_счит[id + "|SPR_OBJECTS_id"] ТО
          ЗАП_ПОЛЕ("ID_RECSITE", SPR_OBJECTS_id)
        КОНЕЦ_ЕСЛИ
        ЕСЛИ SPR_OBJECTS_эл_счит[id + "|SPR_OBJECTS_uuid"] ТО
          ЗАП_ПОЛЕ("UUID", SPR_OBJECTS_uuid)
        КОНЕЦ_ЕСЛИ
        ЗАМЕНИТЬ
        РЕЗУЛЬТАТ = ДА
      ИНАЧЕ
        ЕСЛИ СУЩ_ПЕРЕМ(Данные!ВсегоСтр!"F") ТО
          Данные!ВсегоСтр!"F"++
        КОНЕЦ_ЕСЛИ
      КОНЕЦ_ЕСЛИ
    КОНЕЦ_ЕСЛИ
  ИНАЧЕ
    ЕСЛИ СУЩ_ПЕРЕМ(Данные!ВсегоСтр!"F") ТО
      Данные!ВсегоСтр!"F"++
    КОНЕЦ_ЕСЛИ
  КОНЕЦ_ЕСЛИ
  STG_СинхронизироватьУчасток = РЕЗУЛЬТАТ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ ТИП_SQL STG_ДобЗначУчастки(ТИП_СТРОКА: инд) //все значения
  спр = "objects"
  ДобавитьЗначениеС(спр, инд + "|SPR_OBJECTS_type", "spr_objects--spr_objects")
  ДобавитьЗначениеЧ(спр, инд + "|SPR_OBJECTS_id_area", ПОЛЕ("id_area"))
  ДобавитьЗначениеС(спр, инд + "|SPR_OBJECTS_n_area", ПОЛЕ("n_area"))
  ДобавитьЗначениеЧ(спр, инд + "|SPR_OBJECTS_square", ПОЛЕ("square"))
  ДобавитьЗначениеС(спр, инд + "|SPR_OBJECTS_kadn", ПОЛЕ("kadn"))
  ЕСЛИ IB_CONTEXT_СчитатьЛок("синхронизацияСайта") = "" ТО
    ДобавитьЗначениеЛ(спр, инд + "|SPR_OBJECTS_is_synced", НЕТ)
  ИНАЧЕ
    ДобавитьЗначениеЛ(спр, инд + "|SPR_OBJECTS_is_synced", ДА)
  КОНЕЦ_ЕСЛИ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ STG_ВыгрузитьИПУ
  СБРОС(SPR_SHETCH_эл_доб, SPR_SHETCH_эл_счит, SPR_SHETCH_эл_знач, SPR_SHETCH_эл_изм)
  спр = "Справочник ИПУ"
  rest_колЭлемПодЗапрДоб = stg_профилиВыгрузкиСпр!спр!"_qty_add"
  
  ЕСЛИ оп_проверятьБазуПоСайту ТО
    ЕСЛИ SPR_SHETCH_ПолучитьСписок(ДА) ТО
      STG_ПроверитьИдБазы(ф_СпрИндивСчетчики)
    КОНЕЦ_ЕСЛИ
    СБРОС(SPR_SHETCH_эл_id, SPR_SHETCH_эл_уд, SPR_SHETCH_эл_счит, SPR_SHETCH_эл_доб,  SPR_SHETCH_эл_знач, SPR_SHETCH_эл_изм, REST_эл)
  КОНЕЦ_ЕСЛИ
  
  СОЗДАТЬ(sql_loop, ТИП_SQL)
  sql_loop.STG_ЗапросВыгрузкиСпрИПУ
  sql = SQL_ОТКРЫТЬ(ф_СпрИндивСчетчики)
  длина = ДЛИНА(СТР_ЗНАЧ(sql_loop.ВСЕГО))
  STG_ИниСтрокуОтчета("Справочник ИПУ")
  СтатусСоздать("Обработка ИПУ для выгрузки")
  СтатусСтартПрогресс(sql_loop.ВСЕГО)
  ЦИКЛ ДЛЯ(и = sql_loop.ВСЕГО, 1, -1)
    sql_loop.ПЕРЕЙТИ(и)
    
    инд = СТР0(и, длина)
    
    SPR_SHETCH_эл_доб!инд = НЕТ
    Данные!ВсегоСтр!"C"++
    
    STG_ПрокачкаСтатуса("обработка ИПУ: " + sql_loop.ПОЛЕ("nom"))
    
    sql_loop.STG_ДобЗначИПУ(инд)
    
    ЕСЛИ НЕ stg_профилиВыгрузкиСпр!спр!"_subreq_add" ТО
      ЕСЛИ SPR_SHETCH_ДобавитьМнож(НЕТ) ТО
        sql.STG_СинхронизироватьИПУ("")
      ИНАЧЕ
        СТОП
      КОНЕЦ_ЕСЛИ
      СБРОС(SPR_SHETCH_эл_доб, SPR_SHETCH_эл_счит, SPR_SHETCH_эл_знач, SPR_SHETCH_эл_изм)
    КОНЕЦ_ЕСЛИ
  КОНЕЦ_ЦИКЛА
  СтатусЗакрыть
  
  ЕСЛИ stg_профилиВыгрузкиСпр!спр!"_subreq_add" ТО
    SPR_SHETCH_ДобавитьМнож(stg_профилиВыгрузкиСпр!спр!"_subreq_add")
    СтатусСоздать("Синхронизация справочника ИПУ")
    СтатусСтартПрогресс(КОЛ_ЭЛЕМ(REST_эл_id))
    ЦИКЛ ИНДЕКС(лог = SPR_SHETCH_эл_доб!инд)
      ЕСЛИ лог ТО
        STG_ПрокачкаСтатуса("Синхронизация справочника ИПУ")
        sql.STG_СинхронизироватьИПУ(инд)
      КОНЕЦ_ЕСЛИ
    КОНЕЦ_ЦИКЛА
    СтатусЗакрыть
    СБРОС(SPR_SHETCH_эл_доб, SPR_SHETCH_эл_счит, SPR_SHETCH_эл_знач, SPR_SHETCH_эл_изм)
  КОНЕЦ_ЕСЛИ
  
  sql_loop.ЗАКРЫТЬ
  sql.ЗАКРЫТЬ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ ТИП_SQL STG_ЗапросВыгрузкиСпрИПУ
  СОЗДАТЬ(сп, ТИП_СПИСОК)
  сп.ДОБАВИТЬ("SELECT A.*, B.SRT FROM")
  сп.ДОБАВИТЬ("'" + ф_СпрИндивСчетчики + "' A")
  сп.ДОБАВИТЬ("INNER JOIN")
  сп.ДОБАВИТЬ("'" + ф_СпрУчастковГаражей + "' B")
  сп.ДОБАВИТЬ("ON A.ID_AREA = B.ID_AREA WHERE (A.IS_SYNCED = FALSE OR A.IS_SYNCED IS NULL)") // AND A.DATEND > '" + СТР(ДАТА_ТЕК) + "'")
  ЕСЛИ г_колУчастков > 0 ТО
    сп.ДОБАВИТЬ("AND A.ID_AREA IN (")
    сп.STG_ARH_СчитатьАрхив(к_АрхивСпрУчастков, г_путьПрофиляСпрУчастков)
    сп.ДОБАВИТЬ(")")
  КОНЕЦ_ЕСЛИ
  сп.ДОБАВИТЬ("ORDER BY B.SRT")
  ЗАПРОС(сп)
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ ТИП_SQL ТИП_ЛОГИКА: STG_СинхронизироватьИПУ(ТИП_СТРОКА: id)
  спр = "Справочник ИПУ"
  ЕСЛИ id = "" ТО
    id = СТР_ЗНАЧ(SPR_SHETCH_id)
  КОНЕЦ_ЕСЛИ
  РЕЗУЛЬТАТ = НЕТ
  ЕСЛИ СУЩ_ПЕРЕМ(SPR_SHETCH_эл_счит[id + "|SPR_SHETCH_id_ipu"]) ТО
    ЕСЛИ SPR_SHETCH_эл_счит[id + "|SPR_SHETCH_id_ipu"] ТО
      ЕСЛИ СУЩ_ПЕРЕМ(Данные!ВсегоСтр!"D") ТО
        Данные!ВсегоСтр!"D"++
      КОНЕЦ_ЕСЛИ
      ЕСЛИ stg_профилиВыгрузкиСпр!спр!"_subreq_add" ТО
        SPR_SHETCH_Упаковать(id)
      КОНЕЦ_ЕСЛИ
      поз = НАЙТИ_ПОЗ("ID", SPR_SHETCH_id_ipu)
      ЕСЛИ поз > 0 ТО
        ЕСЛИ СУЩ_ПЕРЕМ(Данные!ВсегоСтр!"E") ТО
          Данные!ВсегоСтр!"E"++
        КОНЕЦ_ЕСЛИ
        ПЕРЕЙТИ(поз)
        ЕСЛИ SPR_SHETCH_эл_счит[id + "|SPR_SHETCH_is_synced"] ТО
          ЗАП_ПОЛЕ("IS_SYNCED", SPR_SHETCH_is_synced)
        КОНЕЦ_ЕСЛИ
        ЕСЛИ SPR_SHETCH_эл_счит[id + "|SPR_SHETCH_id"] ТО
          ЗАП_ПОЛЕ("ID_RECSITE", SPR_SHETCH_id)
        КОНЕЦ_ЕСЛИ
        ЕСЛИ SPR_SHETCH_эл_счит[id + "|SPR_SHETCH_uuid"] ТО
          ЗАП_ПОЛЕ("UUID", SPR_SHETCH_uuid)
        КОНЕЦ_ЕСЛИ
        ЗАМЕНИТЬ
        РЕЗУЛЬТАТ = ДА
      ИНАЧЕ
        ЕСЛИ СУЩ_ПЕРЕМ(Данные!ВсегоСтр!"F") ТО
          Данные!ВсегоСтр!"F"++
        КОНЕЦ_ЕСЛИ
      КОНЕЦ_ЕСЛИ
    КОНЕЦ_ЕСЛИ
  КОНЕЦ_ЕСЛИ
  STG_СинхронизироватьИПУ = РЕЗУЛЬТАТ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ ТИП_SQL STG_ДобЗначИПУ(ТИП_СТРОКА: инд) //все значения
  спр = "meters"
  ДобавитьЗначениеС(спр, инд + "|SPR_SHETCH_type", "spr_shetch--spr_shetch")
  ДобавитьЗначениеЧ(спр, инд + "|SPR_SHETCH_cot", ПОЛЕ("cot"))
  ДобавитьЗначениеД(спр, инд + "|SPR_SHETCH_token_date", ПОЛЕ("token_date"))
  ДобавитьЗначениеД(спр, инд + "|SPR_SHETCH_datend", ПОЛЕ("datend"))
  ДобавитьЗначениеД(спр, инд + "|SPR_SHETCH_datpov", ПОЛЕ("datpov"))
  ДобавитьЗначениеД(спр, инд + "|SPR_SHETCH_datust", ПОЛЕ("datust"))
  ДобавитьЗначениеЧ(спр, инд + "|SPR_SHETCH_npok3", ПОЛЕ("npok3"))
  ДобавитьЗначениеЧ(спр, инд + "|SPR_SHETCH_npok2", ПОЛЕ("npok2"))
  ДобавитьЗначениеЧ(спр, инд + "|SPR_SHETCH_npok1", ПОЛЕ("npok1"))
  ДобавитьЗначениеЧ(спр, инд + "|SPR_SHETCH_token", ПОЛЕ("token"))
  ДобавитьЗначениеЧ(спр, инд + "|SPR_SHETCH_id_ipu", ПОЛЕ("id"))
  ДобавитьЗначениеС(спр, инд + "|SPR_SHETCH_nom", ПОЛЕ("nom"))
  ДобавитьЗначениеС(спр, инд + "|SPR_SHETCH_model", ПОЛЕ("model"))
  кодТипа = ПОЛЕ("type")
  типУслуги = ?(кодТипа = к_СтатьиЭЭКод, к_СтатьиЭЭ,
                ?(кодТипа = к_СтатьиВКод, к_СтатьиВ,
                  ?(кодТипа = к_СтатьиГКод, к_СтатьиГ, к_СтатьиОТ)))
  ДобавитьЗначениеС(спр, инд + "|SPR_SHETCH_spr_shetch_type", кодТипа)  //IPU service type: не может превышать 2 символов.
  ДобавитьЗначениеЧ(спр, инд + "|SPR_SHETCH_id_area", ПОЛЕ("id_area"))
  
  ЕСЛИ IB_CONTEXT_СчитатьЛок("синхронизацияСайта") = "" ТО
    ДобавитьЗначениеЛ(спр, инд + "|SPR_SHETCH_is_synced", НЕТ)
  ИНАЧЕ
    ДобавитьЗначениеЛ(спр, инд + "|SPR_SHETCH_is_synced", ДА)
  КОНЕЦ_ЕСЛИ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ STG_ВыгрузитьФЛС
  СБРОС(SPR_FLS_эл_доб, SPR_FLS_эл_счит, SPR_FLS_эл_знач, SPR_FLS_эл_изм)
  спр = "Справочник ФЛС"
  rest_колЭлемПодЗапрДоб = stg_профилиВыгрузкиСпр!спр!"_qty_add"
  
  ЕСЛИ оп_проверятьБазуПоСайту ТО
    ЕСЛИ SPR_FLS_ПолучитьСписок(ДА) ТО
      STG_ПроверитьИдБазы(ф_СпрФЛС)
    КОНЕЦ_ЕСЛИ
    СБРОС(SPR_FLS_эл_id, SPR_FLS_эл_уд, SPR_FLS_эл_счит, SPR_FLS_эл_доб,  SPR_FLS_эл_знач, SPR_FLS_эл_изм, REST_эл)
  КОНЕЦ_ЕСЛИ
  
  СОЗДАТЬ(sql_loop, ТИП_SQL)
  sql_loop.STG_ЗапросВыгрузкиСпрФЛС
  sql = SQL_ОТКРЫТЬ(ф_СпрФЛС)
  длина = ДЛИНА(СТР_ЗНАЧ(sql_loop.ВСЕГО))
  STG_ИниСтрокуОтчета("Справочник ФЛС")
  СтатусСоздать("Обработка ФЛС для выгрузки")
  СтатусСтартПрогресс(sql_loop.ВСЕГО)
  ЦИКЛ ДЛЯ(и = sql_loop.ВСЕГО, 1, -1)
    sql_loop.ПЕРЕЙТИ(и)
    инд = СТР0(и, длина)
    SPR_FLS_эл_доб!инд = НЕТ
    Данные!ВсегоСтр!"C"++
    
    STG_ПрокачкаСтатуса("обработка ФЛС: " + sql_loop.ПОЛЕ("fls"))
    
    sql_loop.STG_ДобЗначФЛС(инд)
    
    ЕСЛИ НЕ stg_профилиВыгрузкиСпр!спр!"_subreq_add" ТО
      ЕСЛИ SPR_FLS_ДобавитьМнож(НЕТ) ТО
        sql.STG_СинхронизироватьФЛС("")
      ИНАЧЕ
        СТОП
      КОНЕЦ_ЕСЛИ
      
      СБРОС(SPR_FLS_эл_доб, SPR_FLS_эл_счит, SPR_FLS_эл_знач, SPR_FLS_эл_изм)
    КОНЕЦ_ЕСЛИ
  КОНЕЦ_ЦИКЛА
  СтатусЗакрыть
  
  ЕСЛИ stg_профилиВыгрузкиСпр!спр!"_subreq_add" ТО
    SPR_FLS_ДобавитьМнож(stg_профилиВыгрузкиСпр!спр!"_subreq_add")
    СтатусСоздать("Синхронизация справочника ФЛС")
    СтатусСтартПрогресс(КОЛ_ЭЛЕМ(REST_эл_id))
    ЦИКЛ ИНДЕКС(лог = SPR_FLS_эл_доб!инд)
      ЕСЛИ лог ТО
        STG_ПрокачкаСтатуса("Синхронизация справочника ФЛС")
        sql.STG_СинхронизироватьФЛС(инд)
      КОНЕЦ_ЕСЛИ
    КОНЕЦ_ЦИКЛА
    СтатусЗакрыть
    СБРОС(SPR_FLS_эл_доб, SPR_FLS_эл_счит, SPR_FLS_эл_знач, SPR_FLS_эл_изм)
  КОНЕЦ_ЕСЛИ
  
  sql_loop.ЗАКРЫТЬ
  sql.ЗАКРЫТЬ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ ТИП_SQL STG_ЗапросВыгрузкиСпрФЛС
  СОЗДАТЬ(сп, ТИП_СПИСОК)
  сп.ДОБАВИТЬ("SELECT A.*, B.SRT FROM")
  сп.ДОБАВИТЬ("'" + ф_СпрФЛС + "' A")
  сп.ДОБАВИТЬ("INNER JOIN")
  сп.ДОБАВИТЬ("'" + ф_СпрУчастковГаражей + "' B")
  сп.ДОБАВИТЬ("ON A.ID_AREA = B.ID_AREA WHERE (A.IS_SYNCED = FALSE OR A.IS_SYNCED IS NULL) AND A.FLS <> ''")
  ЕСЛИ г_колУчастков > 0 ТО
    сп.ДОБАВИТЬ("AND A.ID_AREA IN (")
    сп.STG_ARH_СчитатьАрхив(к_АрхивСпрУчастков, г_путьПрофиляСпрУчастков)
    сп.ДОБАВИТЬ(")")
  КОНЕЦ_ЕСЛИ
  сп.ДОБАВИТЬ("ORDER BY B.SRT")
  ЗАПРОС(сп)
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ ТИП_SQL ТИП_ЛОГИКА: STG_СинхронизироватьФЛС(ТИП_СТРОКА: id)
  спр = "Справочник ФЛС"
  ЕСЛИ id = "" ТО
    id = СТР_ЗНАЧ(SPR_FLS_id)
  КОНЕЦ_ЕСЛИ
  РЕЗУЛЬТАТ = НЕТ
  ЕСЛИ СУЩ_ПЕРЕМ(SPR_FLS_эл_счит[id + "|SPR_FLS_fls"]) ТО
    ЕСЛИ SPR_FLS_эл_счит[id + "|SPR_FLS_fls"] И 
         SPR_FLS_эл_счит[id + "|SPR_FLS_id_area"] ТО
      ЕСЛИ СУЩ_ПЕРЕМ(Данные!ВсегоСтр!"D") ТО
        Данные!ВсегоСтр!"D"++
      КОНЕЦ_ЕСЛИ
      ЕСЛИ stg_профилиВыгрузкиСпр!спр!"_subreq_add" ТО
        SPR_FLS_Упаковать(id)
      КОНЕЦ_ЕСЛИ
      поз = НАЙТИ_ПОЗ("fls", SPR_FLS_fls, "id_area", SPR_FLS_id_area)
      ЕСЛИ поз > 0 ТО
        ЕСЛИ СУЩ_ПЕРЕМ(Данные!ВсегоСтр!"E") ТО
          Данные!ВсегоСтр!"E"++
        КОНЕЦ_ЕСЛИ
        ПЕРЕЙТИ(поз)
        ЕСЛИ SPR_FLS_эл_счит[id + "|SPR_FLS_is_synced"] ТО
          ЗАП_ПОЛЕ("IS_SYNCED", SPR_FLS_is_synced)
        КОНЕЦ_ЕСЛИ
        ЕСЛИ SPR_FLS_эл_счит[id + "|SPR_FLS_id"] ТО
          ЗАП_ПОЛЕ("ID_RECSITE", SPR_FLS_id)
        КОНЕЦ_ЕСЛИ
        ЕСЛИ SPR_FLS_эл_счит[id + "|SPR_FLS_uuid"] ТО
          ЗАП_ПОЛЕ("UUID", SPR_FLS_uuid)
        КОНЕЦ_ЕСЛИ
        ЗАМЕНИТЬ
        РЕЗУЛЬТАТ = ДА
      ИНАЧЕ
        ЕСЛИ СУЩ_ПЕРЕМ(Данные!ВсегоСтр!"F") ТО
          Данные!ВсегоСтр!"F"++
        КОНЕЦ_ЕСЛИ
      КОНЕЦ_ЕСЛИ
    КОНЕЦ_ЕСЛИ
  КОНЕЦ_ЕСЛИ
  STG_СинхронизироватьФЛС = РЕЗУЛЬТАТ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ ТИП_SQL STG_ДобЗначФЛС(ТИП_СТРОКА: инд) //все значения
  спр = "fls"
  ДобавитьЗначениеС(спр, инд + "|SPR_FLS_type", "spr_fls--spr_fls")
  ДобавитьЗначениеЧ(спр, инд + "|SPR_FLS_id_area", ПОЛЕ("id_area"))
  ДобавитьЗначениеС(спр, инд + "|SPR_FLS_fls", ПОЛЕ("fls"))
  
  ЕСЛИ IB_CONTEXT_СчитатьЛок("синхронизацияСайта") = "" ТО
    ДобавитьЗначениеЛ(спр, инд + "|SPR_FLS_is_synced", НЕТ)
  ИНАЧЕ
    ДобавитьЗначениеЛ(спр, инд + "|SPR_FLS_is_synced", ДА)
  КОНЕЦ_ЕСЛИ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ STG_ВыгрузитьВзносы
  СБРОС(SPR_VZNOSI_эл_доб, SPR_VZNOSI_эл_счит, SPR_VZNOSI_эл_знач, SPR_VZNOSI_эл_изм)
  
  спр = "Справочник взносов"
  rest_колЭлемПодЗапрДоб = stg_профилиВыгрузкиСпр!спр!"_qty_add"
  
  ЕСЛИ оп_проверятьБазуПоСайту ТО
    ЕСЛИ SPR_VZNOSI_ПолучитьСписок(ДА) ТО
      STG_ПроверитьИдБазы(ф_СпрЦелевыхВзносов)
    КОНЕЦ_ЕСЛИ
    СБРОС(SPR_VZNOSI_эл_id, SPR_VZNOSI_эл_уд, SPR_VZNOSI_эл_счит, SPR_VZNOSI_эл_доб,  SPR_VZNOSI_эл_знач, SPR_VZNOSI_эл_изм, REST_эл)
  КОНЕЦ_ЕСЛИ
  
  СОЗДАТЬ(sql_loop, ТИП_SQL)
  sql_loop.STG_ЗапросВыгрузкиСпрВзн
  sql = SQL_ОТКРЫТЬ(ф_СпрЦелевыхВзносов)
  длина = ДЛИНА(СТР_ЗНАЧ(sql_loop.ВСЕГО))
  STG_ИниСтрокуОтчета("Справочник взносов")
  СтатусСоздать("Обработка взносов для выгрузки")
  СтатусСтартПрогресс(sql_loop.ВСЕГО)
  ЦИКЛ ДЛЯ(и = sql_loop.ВСЕГО, 1, -1)
    sql_loop.ПЕРЕЙТИ(и)
    инд = СТР0(и, длина)
    SPR_VZNOSI_эл_доб!инд = НЕТ
    Данные!ВсегоСтр!"C"++
    
    STG_ПрокачкаСтатуса("обработка взносов: " + sql_loop.ПОЛЕ("cap"))
    
    sql_loop.STG_ДобЗначВзносы(инд)
    
    ЕСЛИ НЕ stg_профилиВыгрузкиСпр!спр!"_subreq_add" ТО
      ЕСЛИ SPR_VZNOSI_ДобавитьМнож(НЕТ) ТО
        sql.STG_СинхронизироватьВзнос("")
      ИНАЧЕ
        СТОП
      КОНЕЦ_ЕСЛИ
      СБРОС(SPR_VZNOSI_эл_доб, SPR_VZNOSI_эл_счит, SPR_VZNOSI_эл_знач, SPR_VZNOSI_эл_изм)
    КОНЕЦ_ЕСЛИ
  КОНЕЦ_ЦИКЛА
  СтатусЗакрыть
  
  ЕСЛИ stg_профилиВыгрузкиСпр!спр!"_subreq_add" ТО
    SPR_VZNOSI_ДобавитьМнож(stg_профилиВыгрузкиСпр!спр!"_subreq_add")
    СтатусСоздать("Синхронизация справочника взносов")
    СтатусСтартПрогресс(КОЛ_ЭЛЕМ(REST_эл_id))
    ЦИКЛ ИНДЕКС(лог = SPR_VZNOSI_эл_доб!инд)
      ЕСЛИ лог ТО
        STG_ПрокачкаСтатуса("Синхронизация справочника взносов")
        sql.STG_СинхронизироватьВзнос(инд)
      КОНЕЦ_ЕСЛИ
    КОНЕЦ_ЦИКЛА
    СтатусЗакрыть
    СБРОС(SPR_VZNOSI_эл_доб, SPR_VZNOSI_эл_счит, SPR_VZNOSI_эл_знач, SPR_VZNOSI_эл_изм)
  КОНЕЦ_ЕСЛИ
  
  sql_loop.ЗАКРЫТЬ
  sql.ЗАКРЫТЬ
  //СтатусЗакрыть
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ ТИП_SQL STG_ЗапросВыгрузкиСпрВзн
  СОЗДАТЬ(сп, ТИП_СПИСОК)
  сп.ДОБАВИТЬ("SELECT * FROM")
  сп.ДОБАВИТЬ("'" + ф_СпрЦелевыхВзносов + "'")
  сп.ДОБАВИТЬ("WHERE (IS_SYNCED = FALSE OR IS_SYNCED IS NULL)")
  ЗАПРОС(сп)
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ ТИП_SQL ТИП_ЛОГИКА: STG_СинхронизироватьВзнос(ТИП_СТРОКА: id)
  спр = "Справочник взносов"
  ЕСЛИ id = "" ТО
    id = СТР_ЗНАЧ(SPR_VZNOSI_id)
  КОНЕЦ_ЕСЛИ
  РЕЗУЛЬТАТ = НЕТ
  ЕСЛИ СУЩ_ПЕРЕМ(SPR_VZNOSI_эл_счит[id + "|SPR_VZNOSI_id_vzn"]) ТО
    ЕСЛИ SPR_VZNOSI_эл_счит[id + "|SPR_VZNOSI_id_vzn"] ТО
      ЕСЛИ СУЩ_ПЕРЕМ(Данные!ВсегоСтр!"D") ТО
        Данные!ВсегоСтр!"D"++
      КОНЕЦ_ЕСЛИ
      ЕСЛИ stg_профилиВыгрузкиСпр!спр!"_subreq_add" ТО
        SPR_VZNOSI_Упаковать(id)
      КОНЕЦ_ЕСЛИ
      поз = НАЙТИ_ПОЗ("id", SPR_VZNOSI_id_vzn)
      ЕСЛИ поз > 0 ТО
        ЕСЛИ СУЩ_ПЕРЕМ(Данные!ВсегоСтр!"E") ТО
          Данные!ВсегоСтр!"E"++
        КОНЕЦ_ЕСЛИ
        ПЕРЕЙТИ(поз)
        ЕСЛИ SPR_VZNOSI_эл_счит[id + "|SPR_VZNOSI_is_synced"] ТО
          ЗАП_ПОЛЕ("IS_SYNCED", SPR_VZNOSI_is_synced)
        КОНЕЦ_ЕСЛИ
        ЕСЛИ SPR_VZNOSI_эл_счит[id + "|SPR_VZNOSI_id"] ТО
          ЗАП_ПОЛЕ("ID_RECSITE", SPR_VZNOSI_id)
        КОНЕЦ_ЕСЛИ
        ЕСЛИ SPR_VZNOSI_эл_счит[id + "|SPR_VZNOSI_uuid"] ТО
          ЗАП_ПОЛЕ("UUID", SPR_VZNOSI_uuid)
        КОНЕЦ_ЕСЛИ
        ЗАМЕНИТЬ
        РЕЗУЛЬТАТ = ДА
      ИНАЧЕ
        ЕСЛИ СУЩ_ПЕРЕМ(Данные!ВсегоСтр!"F") ТО
          Данные!ВсегоСтр!"F"++
        КОНЕЦ_ЕСЛИ
      КОНЕЦ_ЕСЛИ
    КОНЕЦ_ЕСЛИ
  КОНЕЦ_ЕСЛИ
  STG_СинхронизироватьВзнос = РЕЗУЛЬТАТ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ ТИП_SQL STG_ДобЗначВзносы(ТИП_СТРОКА: инд) //все значения
  спр = "services"
  ДобавитьЗначениеС(спр, инд + "|SPR_VZNOSI_type", "spr_vznosi--spr_vznosi")
  ДобавитьЗначениеЧ(спр, инд + "|SPR_VZNOSI_cot", ПОЛЕ("cot"))
  ДобавитьЗначениеС(спр, инд + "|SPR_VZNOSI_spr_vznosi_type", ПОЛЕ("type"))
  ДобавитьЗначениеС(спр, инд + "|SPR_VZNOSI_naim", ПОЛЕ("cap"))
  ДобавитьЗначениеЧ(спр, инд + "|SPR_VZNOSI_id_vzn", ПОЛЕ("id"))
  
  ЕСЛИ IB_CONTEXT_СчитатьЛок("синхронизацияСайта") = "" ТО
    ДобавитьЗначениеЛ(спр, инд + "|SPR_VZNOSI_is_synced", НЕТ)
  ИНАЧЕ
    ДобавитьЗначениеЛ(спр, инд + "|SPR_VZNOSI_is_synced", ДА)
  КОНЕЦ_ЕСЛИ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ STG_ВыгрузитьТарифы
  СБРОС(SPR_TARIF_эл_доб, SPR_TARIF_эл_счит, SPR_TARIF_эл_знач, SPR_TARIF_эл_изм)
  
  спр = "Справочник тарифов"
  rest_колЭлемПодЗапрДоб = stg_профилиВыгрузкиСпр!спр!"_qty_add"
  
  ЕСЛИ оп_проверятьБазуПоСайту ТО
    ЕСЛИ SPR_TARIF_ПолучитьСписок(ДА) ТО
      STG_ПроверитьИдБазы(ф_СпрТарифов)
    КОНЕЦ_ЕСЛИ
    СБРОС(SPR_TARIF_эл_id, SPR_TARIF_эл_уд, SPR_TARIF_эл_счит, SPR_TARIF_эл_доб,  SPR_TARIF_эл_знач, SPR_TARIF_эл_изм, REST_эл)
  КОНЕЦ_ЕСЛИ
  
  СОЗДАТЬ(sql_loop, ТИП_SQL)
  sql_loop.STG_ЗапросВыгрузкиСпрТар(НЕТ, "", "", "")
  //БД_РЕДАКТОР(sql_loop)
  //ВЫХОД
  sql = SQL_ОТКРЫТЬ(ф_СпрТарифов)
  длина = ДЛИНА(СТР_ЗНАЧ(sql_loop.ВСЕГО))
  STG_ИниСтрокуОтчета("Справочник тарифов")
  СтатусСоздать("Обработка тарифов для выгрузки")
  СтатусСтартПрогресс(sql_loop.ВСЕГО)
  ЦИКЛ ДЛЯ(и = sql_loop.ВСЕГО, 1, -1)
    sql_loop.ПЕРЕЙТИ(и)
    инд = СТР0(и, длина)
    SPR_TARIF_эл_доб!инд = НЕТ
    Данные!ВсегоСтр!"C"++
    
    STG_ПрокачкаСтатуса("обработка тарифов")
    
    sql_loop.STG_ДобЗначТарифы(инд)
    
    ЕСЛИ НЕ stg_профилиВыгрузкиСпр!спр!"_subreq_add" ТО
      ЕСЛИ SPR_TARIF_ДобавитьМнож(НЕТ) ТО
        sql.STG_СинхронизироватьТариф("")
      ИНАЧЕ
        СТОП
      КОНЕЦ_ЕСЛИ
      
      СБРОС(SPR_TARIF_эл_доб, SPR_TARIF_эл_счит, SPR_TARIF_эл_знач, SPR_TARIF_эл_изм)
    КОНЕЦ_ЕСЛИ
  КОНЕЦ_ЦИКЛА
  СтатусЗакрыть
  
  ЕСЛИ stg_профилиВыгрузкиСпр!спр!"_subreq_add" ТО
    SPR_TARIF_ДобавитьМнож(stg_профилиВыгрузкиСпр!спр!"_subreq_add")
    СтатусСоздать("Синхронизация справочника тарифов")
    СтатусСтартПрогресс(КОЛ_ЭЛЕМ(REST_эл_id))
    ЦИКЛ ИНДЕКС(лог = SPR_TARIF_эл_доб!инд)
      ЕСЛИ лог ТО
        STG_ПрокачкаСтатуса("Синхронизация справочника тарифов")
        sql.STG_СинхронизироватьТариф(инд)
      КОНЕЦ_ЕСЛИ
    КОНЕЦ_ЦИКЛА
    СтатусЗакрыть
    СБРОС(SPR_TARIF_эл_доб, SPR_TARIF_эл_счит, SPR_TARIF_эл_знач, SPR_TARIF_эл_изм)
  КОНЕЦ_ЕСЛИ
  
  sql_loop.ЗАКРЫТЬ
  sql.ЗАКРЫТЬ
  //СтатусЗакрыть
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ ТИП_SQL STG_ЗапросВыгрузкиСпрТар(ТИП_ЛОГИКА: синхр; ТИП_СТРОКА: файлВыгрузки, справочник, акт)
  
  СОЗДАТЬ(сп, ТИП_СПИСОК)
  сп.ДОБАВИТЬ("SELECT A.*, CAST('' AS CHAR(50)) AS NAME, CAST(0 AS NUMERIC(10)) AS VOL_S, CAST(0 AS NUMERIC(10)) AS VOL_E FROM")
  сп.ДОБАВИТЬ("'" + ф_СпрТарифов + "' A")
  сп.ДОБАВИТЬ("INNER JOIN")
  сп.ДОБАВИТЬ("'" + ф_СпрЦелевыхВзносов + "' B")
  сп.ДОБАВИТЬ("ON A.ID = B.ID") 
  ЕСЛИ синхр ТО
    сп.ДОБАВИТЬ("INNER JOIN")
    сп.ДОБАВИТЬ("'" + файлВыгрузки + "' C")
    сп.ДОБАВИТЬ("ON A.ID_RECSITE = C.ID")
  КОНЕЦ_ЕСЛИ
  сп.ДОБАВИТЬ("WHERE (A.IS_SYNCED = FALSE OR A.IS_SYNCED IS NULL)")
  ЕСЛИ синхр ТО
    сп.ДОБАВИТЬ("AND C.CAT = '" + справочник + "' AND C.ACT = '" + акт + "'")
  КОНЕЦ_ЕСЛИ
  ЗАПРОС(сп)
  
  sql = SQL_ОТКРЫТЬ(ф_СпрДиапОбъемовЭЭ)
  ЦИКЛ ДЛЯ(и = 1, sql.ВСЕГО)
    sql.ПЕРЕЙТИ(и)
    ид = sql.ПОЛЕ("ID")
    диапазон!"имя_"!ид = sql.ПОЛЕ("NAME")
    диапазон!"нач_"!ид = sql.ПОЛЕ("VOL_S")
    диапазон!"кон_"!ид = sql.ПОЛЕ("VOL_E")
  КОНЕЦ_ЦИКЛА
  
  ЦИКЛ ДЛЯ(ж = 1, ВСЕГО)
    ПЕРЕЙТИ(ж)
    ид = ПОЛЕ("ROV")
    ЕСЛИ ид <> "" ТО
      ЕСЛИ СУЩ_ПЕРЕМ(диапазон!"имя_"!ид) ТО
        ЗАП_ПОЛЕ("NAME", диапазон!"имя_"!ид)
        ЗАП_ПОЛЕ("VOL_S", диапазон!"нач_"!ид)
        ЗАП_ПОЛЕ("VOL_E", диапазон!"кон_"!ид)
      КОНЕЦ_ЕСЛИ
    КОНЕЦ_ЕСЛИ
  КОНЕЦ_ЦИКЛА
  
  sql.ЗАКРЫТЬ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ ТИП_SQL ТИП_ЛОГИКА: STG_СинхронизироватьТариф(ТИП_СТРОКА: id)
  спр = "Справочник тарифов"
  ЕСЛИ id = "" ТО
    id = СТР_ЗНАЧ(SPR_TARIF_id)
  КОНЕЦ_ЕСЛИ
  РЕЗУЛЬТАТ = НЕТ
  ЕСЛИ SPR_TARIF_эл_счит[id + "|SPR_TARIF_id_vzn"] И 
       SPR_TARIF_эл_счит[id + "|SPR_TARIF_d1"] И
       SPR_TARIF_эл_счит[id + "|SPR_TARIF_d2"] И 
       SPR_TARIF_эл_счит[id + "|SPR_TARIF_token"] ТО
    ЕСЛИ СУЩ_ПЕРЕМ(Данные!ВсегоСтр!"D") ТО
      Данные!ВсегоСтр!"D"++
    КОНЕЦ_ЕСЛИ
    ЕСЛИ stg_профилиВыгрузкиСпр!спр!"_subreq_add" ТО
      SPR_TARIF_Упаковать(id)
    КОНЕЦ_ЕСЛИ
    поз = НАЙТИ_ПОЗ("id", SPR_TARIF_id_vzn,
                    "d1", SPR_TARIF_d1, 
                    "d2", SPR_TARIF_d2, 
                    "token", SPR_TARIF_token)
    ЕСЛИ поз > 0 ТО
      ЕСЛИ СУЩ_ПЕРЕМ(Данные!ВсегоСтр!"F") ТО
        Данные!ВсегоСтр!"E"++
      КОНЕЦ_ЕСЛИ
      ПЕРЕЙТИ(поз)
      ЕСЛИ SPR_TARIF_эл_счит[id + "|SPR_TARIF_is_synced"] ТО
        ЗАП_ПОЛЕ("IS_SYNCED", SPR_TARIF_is_synced)
      КОНЕЦ_ЕСЛИ
      ЕСЛИ SPR_TARIF_эл_счит[id + "|SPR_TARIF_id"] ТО
        ЗАП_ПОЛЕ("ID_RECSITE", SPR_TARIF_id)
      КОНЕЦ_ЕСЛИ
      ЕСЛИ SPR_TARIF_эл_счит[id + "|SPR_TARIF_uuid"] ТО
        ЗАП_ПОЛЕ("UUID", SPR_TARIF_uuid)
      КОНЕЦ_ЕСЛИ
      ЗАМЕНИТЬ
      РЕЗУЛЬТАТ = ДА
    ИНАЧЕ
      ЕСЛИ СУЩ_ПЕРЕМ(Данные!ВсегоСтр!"F") ТО
        Данные!ВсегоСтр!"F"++
      КОНЕЦ_ЕСЛИ
    КОНЕЦ_ЕСЛИ
  КОНЕЦ_ЕСЛИ
  STG_СинхронизироватьТариф = РЕЗУЛЬТАТ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ ТИП_SQL STG_ДобЗначТарифы(ТИП_СТРОКА: инд) //все значения
  спр = "tax"
  ДобавитьЗначениеС(спр, инд + "|SPR_TARIF_type", "spr_tarif--spr_tarif")
  ДобавитьЗначениеЧ(спр, инд + "|SPR_TARIF_token", ПОЛЕ("token"))
  ДобавитьЗначениеЧ(спр, инд + "|SPR_TARIF_id_vzn", ПОЛЕ("id"))
  ДобавитьЗначениеД(спр, инд + "|SPR_TARIF_d2", ПОЛЕ("d2"))
  ДобавитьЗначениеД(спр, инд + "|SPR_TARIF_d1", ПОЛЕ("d1"))
  ДобавитьЗначениеЧ(спр, инд + "|SPR_TARIF_fix", ПОЛЕ("fix"))
  ДобавитьЗначениеЧ(спр, инд + "|SPR_TARIF_t3sn", ПОЛЕ("t3sn"))
  ДобавитьЗначениеЧ(спр, инд + "|SPR_TARIF_t2sn", ПОЛЕ("t2sn"))
  ДобавитьЗначениеЧ(спр, инд + "|SPR_TARIF_t1sn", ПОЛЕ("t1sn"))
  ДобавитьЗначениеЧ(спр, инд + "|SPR_TARIF_t3", ПОЛЕ("t3"))
  ДобавитьЗначениеЧ(спр, инд + "|SPR_TARIF_t2", ПОЛЕ("t2"))
  ДобавитьЗначениеС(спр, инд + "|SPR_TARIF_rov_id", ПОЛЕ("rov"))
  ДобавитьЗначениеС(спр, инд + "|SPR_TARIF_rov_n", ПОЛЕ("name"))
  ДобавитьЗначениеЧ(спр, инд + "|SPR_TARIF_vol_s", ПОЛЕ("vol_s"))
  ДобавитьЗначениеЧ(спр, инд + "|SPR_TARIF_vol_e", ПОЛЕ("vol_e"))
  ЕСЛИ IB_CONTEXT_СчитатьЛок("синхронизацияСайта") = "" ТО
    ДобавитьЗначениеЛ(спр, инд + "|SPR_TARIF_is_synced", НЕТ)
  ИНАЧЕ
    ДобавитьЗначениеЛ(спр, инд + "|SPR_TARIF_is_synced", ДА)
  КОНЕЦ_ЕСЛИ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ STG_ВыгрузитьСвязи
  СБРОС(SPR_LINK_ALL_эл_доб, SPR_LINK_ALL_эл_счит, SPR_LINK_ALL_эл_знач, SPR_LINK_ALL_эл_изм)
  спр = "Справочник владельцев участков"
  rest_колЭлемПодЗапрДоб = stg_профилиВыгрузкиСпр!спр!"_qty_add"
  
  ЕСЛИ оп_проверятьБазуПоСайту ТО
    ЕСЛИ SPR_LINK_ALL_ПолучитьСписок(ДА) ТО
      STG_ПроверитьИдБазы(ф_СвязьВладУч)
    КОНЕЦ_ЕСЛИ
    СБРОС(SPR_LINK_ALL_эл_id, SPR_LINK_ALL_эл_уд, SPR_LINK_ALL_эл_счит, SPR_LINK_ALL_эл_доб,  SPR_LINK_ALL_эл_знач, SPR_LINK_ALL_эл_изм, REST_эл)
  КОНЕЦ_ЕСЛИ
  
  СОЗДАТЬ(sql_loop, ТИП_SQL)
  sql_loop.STG_ЗапросВыгрузкиСпрСвязи
  sql = SQL_ОТКРЫТЬ(ф_СвязьВладУч)
  длина = ДЛИНА(СТР_ЗНАЧ(sql_loop.ВСЕГО))
  STG_ИниСтрокуОтчета("Справочник связей владельцев и участков")
  СтатусСоздать("Обработка связей для выгрузки")
  СтатусСтартПрогресс(sql_loop.ВСЕГО)
  ЦИКЛ ДЛЯ(и = sql_loop.ВСЕГО, 1, -1)
    sql_loop.ПЕРЕЙТИ(и)
    инд = СТР0(и, длина)
    SPR_LINK_ALL_эл_доб!инд = НЕТ
    Данные!ВсегоСтр!"C"++
    
    STG_ПрокачкаСтатуса("обработка связей: " + sql_loop.ПОЛЕ("fio"))
    
    sql_loop.STG_ДобЗначСвязи(инд)
    
    ЕСЛИ НЕ stg_профилиВыгрузкиСпр!спр!"_subreq_add" ТО
      ЕСЛИ SPR_LINK_ALL_ДобавитьМнож(НЕТ) ТО
        sql.STG_СинхронизироватьСвязь("")
      ИНАЧЕ
        СТОП
      КОНЕЦ_ЕСЛИ
      
      СБРОС(SPR_LINK_ALL_эл_доб, SPR_LINK_ALL_эл_счит, SPR_LINK_ALL_эл_знач, SPR_LINK_ALL_эл_изм)
    КОНЕЦ_ЕСЛИ
  КОНЕЦ_ЦИКЛА
  СтатусЗакрыть
  
  ЕСЛИ stg_профилиВыгрузкиСпр!спр!"_subreq_add" ТО
    SPR_LINK_ALL_ДобавитьМнож(stg_профилиВыгрузкиСпр!спр!"_subreq_add")
    СтатусСоздать("Синхронизация справочника связей")
    СтатусСтартПрогресс(КОЛ_ЭЛЕМ(REST_эл_id))
    ЦИКЛ ИНДЕКС(лог = SPR_LINK_ALL_эл_доб!инд)
      ЕСЛИ лог ТО
        STG_ПрокачкаСтатуса("Синхронизация справочника связей")
        sql.STG_СинхронизироватьСвязь(инд)
      КОНЕЦ_ЕСЛИ
    КОНЕЦ_ЦИКЛА
    СтатусЗакрыть
    СБРОС(SPR_LINK_ALL_эл_доб, SPR_LINK_ALL_эл_счит, SPR_LINK_ALL_эл_знач, SPR_LINK_ALL_эл_изм)
  КОНЕЦ_ЕСЛИ
  
  sql_loop.ЗАКРЫТЬ
  sql.ЗАКРЫТЬ
  //СтатусЗакрыть
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ ТИП_SQL STG_ЗапросВыгрузкиСпрСвязи
  СОЗДАТЬ(сп, ТИП_СПИСОК)
  сп.ДОБАВИТЬ("SELECT A.*, B.SRT FROM")
  сп.ДОБАВИТЬ("'" + ф_СвязьВладУч + "' A")
  сп.ДОБАВИТЬ("INNER JOIN")
  сп.ДОБАВИТЬ("'" + ф_СпрУчастковГаражей + "' B")
  сп.ДОБАВИТЬ("ON A.ID_AREA = B.ID_AREA WHERE (A.IS_SYNCED = FALSE OR A.IS_SYNCED IS NULL) AND A.datotchsv > '" + СТР(ДАТА_ТЕК) + "'")
  ЕСЛИ г_колУчастков > 0 ТО
    сп.ДОБАВИТЬ("AND A.ID_AREA IN (")
    сп.STG_ARH_СчитатьАрхив(к_АрхивСпрУчастков, г_путьПрофиляСпрУчастков)
    сп.ДОБАВИТЬ(")")
  КОНЕЦ_ЕСЛИ
  сп.ДОБАВИТЬ("ORDER BY B.SRT")
  ЗАПРОС(сп)
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ ТИП_SQL ТИП_ЛОГИКА: STG_СинхронизироватьСвязь(ТИП_СТРОКА: id)
  спр = "Справочник владельцев участков"
  ЕСЛИ id = "" ТО
    id = СТР_ЗНАЧ(SPR_LINK_ALL_id)
  ИНАЧЕ
    id = СТР_ФРАГ(id, "|", 1)
  КОНЕЦ_ЕСЛИ
  РЕЗУЛЬТАТ = НЕТ
  ЕСЛИ СУЩ_ПЕРЕМ(SPR_LINK_ALL_эл_счит[id + "|SPR_LINK_ALL_id_area"]) ТО
    ЕСЛИ SPR_LINK_ALL_эл_счит[id + "|SPR_LINK_ALL_id_area"] И 
         SPR_LINK_ALL_эл_счит[id + "|SPR_LINK_ALL_id_owner"] ТО
      ЕСЛИ СУЩ_ПЕРЕМ(Данные!ВсегоСтр!"D") ТО
        Данные!ВсегоСтр!"D"++
      КОНЕЦ_ЕСЛИ
      ЕСЛИ stg_профилиВыгрузкиСпр!спр!"_subreq_add" ТО
        SPR_LINK_ALL_Упаковать(id)
      КОНЕЦ_ЕСЛИ
      поз = НАЙТИ_ПОЗ("id_area", SPR_LINK_ALL_id_area, 
                      "id_owner", SPR_LINK_ALL_id_owner)
      ЕСЛИ поз > 0 ТО
        ЕСЛИ СУЩ_ПЕРЕМ(Данные!ВсегоСтр!"E") ТО
          Данные!ВсегоСтр!"E"++
        КОНЕЦ_ЕСЛИ
        ПЕРЕЙТИ(поз)
        ЕСЛИ SPR_LINK_ALL_эл_счит[id + "|SPR_LINK_ALL_is_synced"] ТО
          ЗАП_ПОЛЕ("IS_SYNCED", SPR_LINK_ALL_is_synced)
        КОНЕЦ_ЕСЛИ
        ЕСЛИ SPR_LINK_ALL_эл_счит[id + "|SPR_LINK_ALL_id"] ТО
          ЗАП_ПОЛЕ("ID_RECSITE", SPR_LINK_ALL_id)
        КОНЕЦ_ЕСЛИ
        ЕСЛИ SPR_LINK_ALL_эл_счит[id + "|SPR_LINK_ALL_uuid"] ТО
          ЗАП_ПОЛЕ("UUID", SPR_LINK_ALL_uuid)
        КОНЕЦ_ЕСЛИ
        ЗАМЕНИТЬ
        РЕЗУЛЬТАТ = ДА
      ИНАЧЕ
        ЕСЛИ СУЩ_ПЕРЕМ(Данные!ВсегоСтр!"F") ТО
          Данные!ВсегоСтр!"F"++
        КОНЕЦ_ЕСЛИ
      КОНЕЦ_ЕСЛИ
    КОНЕЦ_ЕСЛИ
  КОНЕЦ_ЕСЛИ
  STG_СинхронизироватьСвязь = РЕЗУЛЬТАТ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ ТИП_SQL STG_ДобЗначСвязи(ТИП_СТРОКА: инд) //все значения
  спр = "link_all"
  ДобавитьЗначениеС(спр, инд + "|SPR_LINK_ALL_type", "spr_link_all--spr_link_all")
  ДобавитьЗначениеС(спр, инд + "|SPR_LINK_ALL_fio", ПОЛЕ("fio"))
  ДобавитьЗначениеС(спр, инд + "|SPR_LINK_ALL_part", ПОЛЕ("part"))
  ДобавитьЗначениеС(спр, инд + "|SPR_LINK_ALL_nomsv", ПОЛЕ("nomsv"))
  ДобавитьЗначениеД(спр, инд + "|SPR_LINK_ALL_datregsv", ПОЛЕ("datregsv"))
  ДобавитьЗначениеД(спр, инд + "|SPR_LINK_ALL_datotchsv", ПОЛЕ("datotchsv"))
  ДобавитьЗначениеЛ(спр, инд + "|SPR_LINK_ALL_member", ПОЛЕ("member"))
  ДобавитьЗначениеЧ(спр, инд + "|SPR_LINK_ALL_id_area", ПОЛЕ("id_area"))
  ДобавитьЗначениеЧ(спр, инд + "|SPR_LINK_ALL_id_owner", ПОЛЕ("id_owner"))
  ДобавитьЗначениеС(спр, инд + "|SPR_LINK_ALL_fls", ПОЛЕ("fls"))
  ЕСЛИ IB_CONTEXT_СчитатьЛок("синхронизацияСайта") = "" ТО
    ДобавитьЗначениеЛ(спр, инд + "|SPR_LINK_ALL_is_synced", НЕТ)
  ИНАЧЕ
    ДобавитьЗначениеЛ(спр, инд + "|SPR_LINK_ALL_is_synced", ДА)
  КОНЕЦ_ЕСЛИ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
//-------------------------------------------------------------------------------------------------------------------------//
ПЕРЕМ г_типыПоИд!
ФУНКЦИЯ STG_ВыгрузитьЖурнал
  СБРОС(SPR_REGISTER_эл_доб, SPR_REGISTER_эл_счит, SPR_REGISTER_эл_знач, SPR_REGISTER_эл_изм, REST_эл_id)
  спр = "Журнал операций"
  rest_колЭлемПодЗапрДоб = stg_профилиВыгрузкиСпр!спр!"_qty_add"
  
  //STG_КоррСуммыЖурнала //- эту штуку надо делать один раз перед выгрузкой базы на сайт
  //STG_КоррИдентВзносов //- эту штуку надо делать один раз перед выгрузкой базы на сайт
  
  СБРОС(г_типыПоИд)
  sql = SQL_ОТКРЫТЬ(ф_СпрЦелевыхВзносов)
  ЦИКЛ ДЛЯ(и = 1, sql.ВСЕГО)
    sql.ПЕРЕЙТИ(и)
    г_типыПоИд[sql.ПОЛЕ("ID")] = sql.ПОЛЕ("CODP")
  КОНЕЦ_ЦИКЛА
  г_типыПоИд[к_СтатьиЗНИд] = к_СтатьиЗНКод
  г_типыПоИд[к_СтатьиПЭЭИд] = к_СтатьиПотЭЭКодСерв
  sql.ЗАКРЫТЬ
  
  tmp_журнал = ф_Журнал
  
  ЕСЛИ оп_проверятьБазуПоСайту ТО
    ЕСЛИ SPR_REGISTER_ПолучитьСписок(ДА) ТО
      STG_ПроверитьИдБазы(ф_Журнал)
    КОНЕЦ_ЕСЛИ
  КОНЕЦ_ЕСЛИ
  СБРОС(SPR_REGISTER_эл_id, SPR_REGISTER_эл_уд, SPR_REGISTER_эл_счит, SPR_REGISTER_эл_доб,  SPR_REGISTER_эл_знач, SPR_REGISTER_эл_изм, REST_эл, REST_эл_id)
  
  СОЗДАТЬ(sql_loop, ТИП_SQL)
  sql_loop.STG_ЗапросВыгрузкиЖурнал //основной join журнала и журнала1
  
  main = SQL_ОТКРЫТЬ(ф_Журнал) //основной файл для синхронизации
  
  //ЕСЛИ г_источникДанных = к_ИсточникЖХО ТО
  //  ф_Журнал = ф_Журнал1
  //КОНЕЦ_ЕСЛИ
  
  СОЗДАТЬ(сп, ТИП_СПИСОК)
  /*сп.ДОБАВИТЬ("SELECT * FROM")
  сп.ДОБАВИТЬ("'" + ф_Журнал + "'")
  ЕСЛИ г_колУчастков > 0 ТО
    сп.ДОБАВИТЬ("WHERE ID_AREA IN (")
    сп.STG_ARH_СчитатьАрхив(к_АрхивСпрУчастков, г_путьПрофиляСпрУчастков)
    сп.ДОБАВИТЬ(")")
  КОНЕЦ_ЕСЛИ
  sql = SQL_ЗАПРОС(сп)*/
  
  длина = ДЛИНА(СТР_ЗНАЧ(sql_loop.ВСЕГО))
  СтатусСоздать("Обработка журнала для выгрузки")
  СтатусСтартПрогресс(sql_loop.ВСЕГО)
  STG_ИниСтрокуОтчета("Журнал операций")
  типы!"" = ""
  колОб = 0
  ЦИКЛ ДЛЯ(и = sql_loop.ВСЕГО, 1, -1)
    sql_loop.ПЕРЕЙТИ(и)
    инд = СТР0(и, длина)
    SPR_REGISTER_эл_доб!инд = НЕТ
    Данные!ВсегоСтр!"C"++
    
    STG_ПрокачкаСтатуса("обработка журнала")
    
    sql_loop.STG_ДобЗначЖурнал(инд)
    
    ЕСЛИ НЕ stg_профилиВыгрузкиСпр!спр!"_subreq_add" ТО
      ЕСЛИ SPR_REGISTER_ДобавитьМнож(НЕТ) ТО
        //sql.STG_СинхронизироватьЖурнал("")
        main.STG_СинхронизироватьЖурнал("")
      ИНАЧЕ
        СТОП
      КОНЕЦ_ЕСЛИ
      
      СБРОС(SPR_REGISTER_эл_доб, SPR_REGISTER_эл_счит, SPR_REGISTER_эл_знач, SPR_REGISTER_эл_изм)
    ИНАЧЕ
      колОб++
      ЕСЛИ колОб = 500 ИЛИ 
           и = 1 ТО
        SPR_REGISTER_ДобавитьМнож(stg_профилиВыгрузкиСпр!спр!"_subreq_add")
        СтатусСоздать("Синхронизация журнала операций")
        СтатусСтартПрогресс(КОЛ_ЭЛЕМ(REST_эл_id))
        ЦИКЛ ИНДЕКС(лог = SPR_REGISTER_эл_доб!инд)
          ЕСЛИ лог ТО
            STG_ПрокачкаСтатуса("Синхронизация журнала операций")
            //sql.STG_СинхронизироватьЖурнал(инд)
            main.STG_СинхронизироватьЖурнал(инд)
          КОНЕЦ_ЕСЛИ
        КОНЕЦ_ЦИКЛА
        СБРОС(SPR_REGISTER_эл_доб, SPR_REGISTER_эл_счит, SPR_REGISTER_эл_знач, SPR_REGISTER_эл_изм, REST_эл_id)
        СтатусЗакрыть
        колОб = 0
      КОНЕЦ_ЕСЛИ
    КОНЕЦ_ЕСЛИ
  КОНЕЦ_ЦИКЛА
  СтатусЗакрыть
  
  /*ЕСЛИ оп_подзапрДобавление ТО
    SPR_REGISTER_ДобавитьМнож(оп_подзапрДобавление)
    СтатусСоздать("Синхронизация журнала операций")
    СтатусСтартПрогресс(КОЛ_ЭЛЕМ(REST_эл_id))
    ЦИКЛ ИНДЕКС(лог = SPR_REGISTER_эл_доб!инд)
      ЕСЛИ лог ТО
        STG_ПрокачкаСтатуса("Синхронизация журнала операций")
        sql.STG_СинхронизироватьЖурнал(инд) //"", 
      КОНЕЦ_ЕСЛИ
    КОНЕЦ_ЦИКЛА
    СБРОС(SPR_REGISTER_эл_доб, SPR_REGISTER_эл_счит, SPR_REGISTER_эл_знач, SPR_REGISTER_эл_изм)
    СтатусЗакрыть
  КОНЕЦ_ЕСЛИ*/
  
  //ф_Журнал = tmp_журнал
  
  //надо синхронизировать ф_Журнал и ф_Журнал1, если источник ЖХО - уй говнище
  /*ЕСЛИ г_источникДанных = к_ИсточникЖХО ТО
    main = SQL_ОТКРЫТЬ(ф_Журнал)
    СтатусСоздать("Синхронизация основного файла журнала операций")
    СтатусСообщение("Синхронизация основного файла журнала операций")
    СтатусСтартПрогресс(sql.ВСЕГО)
    ЦИКЛ ДЛЯ(и = 1, sql.ВСЕГО)
      sql.ПЕРЕЙТИ(и)
      СтатусОбновитьПрогресс("")
      
      поз = main.НАЙТИ_ПОЗ("DOC", sql.ПОЛЕ("DOC"),
                           "DAT", sql.ПОЛЕ("DAT"),
                           "CONTENT", sql.ПОЛЕ("CONTENT"),
                           "ID_AREA", sql.ПОЛЕ("ID_AREA"),
                           "FLS", sql.ПОЛЕ("FLS"),
                           "REC_TYPE", sql.ПОЛЕ("REC_TYPE"),
                           "TYPE", sql.ПОЛЕ("TYPE"))
      ЕСЛИ поз > 0 ТО
        main.ПЕРЕЙТИ(поз)
        main.ЗАП_ПОЛЕ("ADD_SUM", sql.ПОЛЕ("ADD_SUM"))
        main.ЗАП_ПОЛЕ("PAY_SUM", sql.ПОЛЕ("PAY_SUM"))
        main.ЗАП_ПОЛЕ("ID_RECSITE", sql.ПОЛЕ("ID_RECSITE"))
        main.ЗАП_ПОЛЕ("UUID", sql.ПОЛЕ("UUID"))
        main.ЗАП_ПОЛЕ("IS_SYNCED", sql.ПОЛЕ("IS_SYNCED"))
        main.ЗАМЕНИТЬ
      ИНАЧЕ
        ЦИКЛ ДЛЯ(поля = 1, sql.КОЛ_ПОЛЕЙ)
          поле = sql.НАЗВ_ПОЛЯ(поля)
          main.ЗАП_ПОЛЕ(поле, sql.ПОЛЕ(поле))
        КОНЕЦ_ЦИКЛА
        main.ДОБАВИТЬ
      КОНЕЦ_ЕСЛИ
    КОНЕЦ_ЦИКЛА
    main.ЗАКРЫТЬ
    СтатусЗакрыть
  КОНЕЦ_ЕСЛИ*/

  sql_loop.ЗАКРЫТЬ
  //sql.ЗАКРЫТЬ
  main.ЗАКРЫТЬ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ ТИП_SQL STG_ЗапросВыгрузкиЖурнал
  СОЗДАТЬ(сп, ТИП_СПИСОК)
  
  ЕСЛИ г_источникДанных = к_ИсточникЖХО ТО
    ИСПОЛЬЗОВАТЬ("ST_GSK\ST_GSK_REGISTER.IBL")
    IB_CONTEXT_УстановитьЛок("гр_датаОпераций", СТР(гр_датаОпераций))
    
    tmp_журнал = ф_Журнал
    ф_Журнал = ф_Журнал1
    ЕСЛИ НЕ СУЩ_ФАЙЛ(ф_Журнал1) ТО
      STG_КонвЖХОвDBF
    КОНЕЦ_ЕСЛИ
    ф_Журнал = tmp_журнал
    
    //момент обновления идент сайта в файле журнала под большим вопросом. по идее он нафиг не нужен, так как они обновляются после выгрузки.
    /*main = SQL_ОТКРЫТЬ(ф_Журнал)
    sql = SQL_ОТКРЫТЬ(ф_Журнал1)
    СтатусСоздать("Подготовка журнала к показу")
    СтатусСообщение("Подготовка журнала к показу")
    ЦИКЛ ДЛЯ(и = 1, main.ВСЕГО)
      main.ПЕРЕЙТИ(и)
      поз = sql.НАЙТИ_ПОЗ("DOC", main.ПОЛЕ("DOC"),
                          "DAT", main.ПОЛЕ("DAT"),
                          "CONTENT", main.ПОЛЕ("CONTENT"),
                          "ID_AREA", main.ПОЛЕ("ID_AREA"),
                          "FLS", main.ПОЛЕ("FLS"),
                          "REC_TYPE", main.ПОЛЕ("REC_TYPE"),
                          "TYPE", main.ПОЛЕ("TYPE"),
                          "ADD_SUM", main.ПОЛЕ("ADD_SUM"),
                          "PAY_SUM", main.ПОЛЕ("PAY_SUM"))
      ЕСЛИ поз > 0 ТО
        sql.ПЕРЕЙТИ(поз)
        main.ЗАП_ПОЛЕ("ID_VZN", sql.ПОЛЕ("ID_VZN"))
        //main.ЗАП_ПОЛЕ("ID_CALC", sql.ПОЛЕ("ID_CALC"))
        main.ЗАП_ПОЛЕ("ID_RECSITE", sql.ПОЛЕ("ID_RECSITE"))
        main.ЗАП_ПОЛЕ("UUID", sql.ПОЛЕ("UUID"))
        main.ЗАП_ПОЛЕ("IS_SYNCED", sql.ПОЛЕ("IS_SYNCED"))
        main.ЗАМЕНИТЬ
      КОНЕЦ_ЕСЛИ
    КОНЕЦ_ЦИКЛА
    СтатусЗакрыть
    main.ЗАКРЫТЬ
    sql.ЗАКРЫТЬ*/
  КОНЕЦ_ЕСЛИ
    
  сп.ОЧИСТИТЬ
  сп.ДОБАВИТЬ("SELECT A.CODS, A.N_AREA, A.ID_AREA, A.FLS, B.ID_VZN, A.TYPE, A.ADD_SUM, A.PAY_SUM, A.REC_TYPE, A.DAT, A.DOC,")
  сп.ДОБАВИТЬ("A.CONTENT, A.ID_CALC, A.ID_RECSITE, A.UUID, A.IS_SYNCED, C.SRT FROM") //B.ID_RECSITE, B.UUID, B.IS_SYNCED
  сп.ДОБАВИТЬ("'" + ф_Журнал + "' A")
  сп.ДОБАВИТЬ("INNER JOIN")
  сп.ДОБАВИТЬ("'" + ф_Журнал1 + "' B")
  сп.ДОБАВИТЬ("ON A.DOC = B.DOC AND A.DAT = B.DAT AND A.N_AREA = B.N_AREA AND A.FLS = B.FLS AND A.CONTENT = B.CONTENT AND " + // - проблемное поле
              "A.REC_TYPE = B.REC_TYPE AND A.TYPE = B.TYPE AND (A.ADD_SUM = B.ADD_SUM OR A.ADD_SUM IS NULL) AND (A.PAY_SUM = B.PAY_SUM OR A.PAY_SUM IS NULL)") //
  сп.ДОБАВИТЬ("INNER JOIN")
  сп.ДОБАВИТЬ("'" + ф_СпрУчастковГаражей + "' C")
  сп.ДОБАВИТЬ("ON B.ID_AREA = C.ID_AREA WHERE")
  контекст = IB_CONTEXT_ИзвлечьЛок(к_атрПоказВсехЗаписей)
  ЕСЛИ контекст = "" ТО
    сп.ДОБАВИТЬ("(B.IS_SYNCED = FALSE OR B.IS_SYNCED IS NULL) AND")
  КОНЕЦ_ЕСЛИ
  сп.ДОБАВИТЬ("A.DAT BETWEEN '" + СТР(гр_датаОпераций) + "' AND '" + СТР(гр_датаОперацийПо) + "'")
  сп.ДОБАВИТЬ("AND (A.ADD_SUM <> 0 OR A.PAY_SUM <> 0)")
  ЕСЛИ г_колУчастков > 0 ТО
    сп.ДОБАВИТЬ("AND B.ID_AREA IN (")
    сп.STG_ARH_СчитатьАрхив(к_АрхивСпрУчастков, г_путьПрофиляСпрУчастков)
    сп.ДОБАВИТЬ(")")
  КОНЕЦ_ЕСЛИ
  времФайл = г_папкаВрем + "\tmp_uploadRegister1.dbf" 
  IB_FILE_ФайлУдалить(времФайл)
  sql = SQL_ЗАПРОС(сп)
  sql.ЗАПИСАТЬ(времФайл)
  //ОТЛАДКА(сп)
  //БД_РЕДАКТОР(sql)
  sql.ЗАКРЫТЬ
  
  /*сп.ОЧИСТИТЬ
  сп.ДОБАВИТЬ("SELECT A.*, B.SRT FROM")
  сп.ДОБАВИТЬ("'" + ф_Журнал + "' A")
  сп.ДОБАВИТЬ("INNER JOIN")
  сп.ДОБАВИТЬ("'" + ф_СпрУчастковГаражей + "' B")
  сп.ДОБАВИТЬ("ON A.ID_AREA = B.ID_AREA WHERE")
  контекст = IB_CONTEXT_ИзвлечьЛок(к_атрПоказВсехЗаписей)
  ЕСЛИ контекст = "" ТО
    сп.ДОБАВИТЬ("(A.IS_SYNCED = FALSE OR A.IS_SYNCED IS NULL) AND")
  КОНЕЦ_ЕСЛИ
  сп.ДОБАВИТЬ("A.DAT BETWEEN '" + СТР(гр_датаОпераций) + "' AND '" + СТР(гр_датаОперацийПо) + "'")
  сп.ДОБАВИТЬ("AND (A.ADD_SUM <> 0 OR A.PAY_SUM <> 0)")
  ЕСЛИ г_колУчастков > 0 ТО
    сп.ДОБАВИТЬ("AND A.ID_AREA IN (")
    сп.STG_ARH_СчитатьАрхив(к_АрхивСпрУчастков, г_путьПрофиляСпрУчастков)
    сп.ДОБАВИТЬ(")")
  КОНЕЦ_ЕСЛИ
  времФайл = г_папкаВрем + "\tmp_uploadRegister.dbf" 
  IB_FILE_ФайлУдалить(времФайл)
  sql = SQL_ЗАПРОС(сп)
  sql.ЗАПИСАТЬ(времФайл)
  sql.ЗАКРЫТЬ*/
  
  сп.ОЧИСТИТЬ
  сп.ДОБАВИТЬ("SELECT A.*, B.ID, B.CAP, CAST('' AS CHAR(20)) AS RT_STR FROM")
  сп.ДОБАВИТЬ("'" + времФайл + "' A")
  сп.ДОБАВИТЬ("LEFT JOIN")
  сп.ДОБАВИТЬ("'" + ф_СпрЦелевыхВзносов + "' B")
  сп.ДОБАВИТЬ("ON A.ID_VZN = B.ID")
  сп.ДОБАВИТЬ("ORDER BY A.DAT, A.SRT, A.ID_AREA, B.ID")
  ЗАПРОС(сп)
  времФайл = г_папкаВрем + "\tmp_uploadRegister.dbf" 
  IB_FILE_ФайлУдалить(времФайл)
  sql = SQL_ЗАПРОС(сп)
  sql.ЗАПИСАТЬ(времФайл)
  sql.ЗАКРЫТЬ
  
  сп.ОЧИСТИТЬ
  сп.ДОБАВИТЬ("UPDATE")
  сп.ДОБАВИТЬ("'" + времФайл + "'")
  сп.ДОБАВИТЬ("SET CAP = '" + к_СтатьиПЭЭ + "' WHERE ID_VZN = '" + СТР_ЗНАЧ(к_СтатьиПЭЭИд) + "'")
  SQL_ЗАПРОС(сп)
  
  сп.ОЧИСТИТЬ
  сп.ДОБАВИТЬ("UPDATE")
  сп.ДОБАВИТЬ("'" + времФайл + "'")
  сп.ДОБАВИТЬ("SET CAP = '" + к_СтатьиЗН + "' WHERE ID_VZN = '" + СТР_ЗНАЧ(к_СтатьиЗНИд) + "'")
  SQL_ЗАПРОС(сп)
  
  парам!к_ТипЗаписиЖурналаНач = к_ТипЗаписиЖурналаНачНазв
  парам!к_ТипЗаписиЖурналаКасса = к_ТипЗаписиЖурналаКассаНазв
  парам!к_ТипЗаписиЖурналаРасчСч = к_ТипЗаписиЖурналаРасчСчНазв
  парам!к_ТипЗаписиЖурналаПени = к_ТипЗаписиЖурналаПениНазв
  парам!к_ТипЗаписиЖурналаИО = к_ТипЗаписиЖурналаИОНазв
  парам!к_ТипЗаписиЖурналаПениКасса = "пени (касса)"
  парам!к_ТипЗаписиЖурналаПениРасчСч = "пени (расч. сч.)"
  парам!к_ТипЗаписиЖурналаВозвратКасса = к_ТипЗаписиЖурналаВозврКасса
  парам!к_ТипЗаписиЖурналаВозвратРсч = к_ТипЗаписиЖурналаВозврРсч
  ЦИКЛ ИНДЕКС(знач = парам!инд)
    сп.ОЧИСТИТЬ
    сп.ДОБАВИТЬ("UPDATE")
    сп.ДОБАВИТЬ("'" + времФайл + "'")
    сп.ДОБАВИТЬ("SET RT_STR = '" + знач + "' WHERE REC_TYPE = " + инд)
    SQL_ЗАПРОС(сп)
  КОНЕЦ_ЦИКЛА
  
  ОТКРЫТЬ(времФайл)
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ ТИП_SQL ТИП_ЛОГИКА: STG_СинхронизироватьЖурнал(ТИП_СТРОКА: id) // тип,
  спр = "Журнал операций"
  ЕСЛИ id = "" ТО
    id = СТР_ЗНАЧ(SPR_REGISTER_id)
  КОНЕЦ_ЕСЛИ
  РЕЗУЛЬТАТ = НЕТ
  ЕСЛИ СУЩ_ПЕРЕМ(SPR_REGISTER_эл_счит[id + "|SPR_REGISTER_id_area"]) ТО
    ЕСЛИ SPR_REGISTER_эл_счит[id + "|SPR_REGISTER_id_area"] И 
         SPR_REGISTER_эл_счит[id + "|SPR_REGISTER_id_vzn"] И 
         SPR_REGISTER_эл_счит[id + "|SPR_REGISTER_rec_type"] И 
         SPR_REGISTER_эл_счит[id + "|SPR_REGISTER_dat"] ТО
      ЕСЛИ НЕ СУЩ_ПЕРЕМ(г_типыПоИд!SPR_REGISTER_id_vzn) ТО
        ВЫХОД
      КОНЕЦ_ЕСЛИ
      ЕСЛИ СУЩ_ПЕРЕМ(Данные!ВсегоСтр!"D") ТО
        Данные!ВсегоСтр!"D"++
      КОНЕЦ_ЕСЛИ
      ЕСЛИ stg_профилиВыгрузкиСпр!спр!"_subreq_add" ТО
        SPR_REGISTER_Упаковать(id)
      КОНЕЦ_ЕСЛИ
      поз = НАЙТИ_ПОЗ("id_area", SPR_REGISTER_id_area, 
                      "fls", SPR_REGISTER_fls, 
                      "type", г_типыПоИд!SPR_REGISTER_id_vzn, 
                      "rec_type", SPR_REGISTER_rec_type, 
                      "dat", SPR_REGISTER_dat, 
                      "pay_sum", SPR_REGISTER_pay_sum, 
                      "add_sum", SPR_REGISTER_add_sum, 
                      "is_synced", НЕТ)
      ЕСЛИ поз > 0 ТО
        ЕСЛИ СУЩ_ПЕРЕМ(Данные!ВсегоСтр!"E") ТО
          Данные!ВсегоСтр!"E"++
        КОНЕЦ_ЕСЛИ
        ПЕРЕЙТИ(поз)
        ЕСЛИ SPR_REGISTER_эл_счит[id + "|SPR_REGISTER_is_synced"] ТО
          ЗАП_ПОЛЕ("IS_SYNCED", SPR_REGISTER_is_synced)
        КОНЕЦ_ЕСЛИ
        ЕСЛИ SPR_REGISTER_эл_счит[id + "|SPR_REGISTER_id"] ТО
          ЗАП_ПОЛЕ("ID_RECSITE", SPR_REGISTER_id)
        КОНЕЦ_ЕСЛИ
        ЕСЛИ SPR_REGISTER_эл_счит[id + "|SPR_REGISTER_uuid"] ТО
          ЗАП_ПОЛЕ("UUID", SPR_REGISTER_uuid)
        КОНЕЦ_ЕСЛИ
        ЗАМЕНИТЬ
        РЕЗУЛЬТАТ = ДА
      ИНАЧЕ
        ЕСЛИ СУЩ_ПЕРЕМ(Данные!ВсегоСтр!"F") ТО
          Данные!ВсегоСтр!"F"++
        КОНЕЦ_ЕСЛИ
      КОНЕЦ_ЕСЛИ
    КОНЕЦ_ЕСЛИ
  КОНЕЦ_ЕСЛИ
  STG_СинхронизироватьЖурнал = РЕЗУЛЬТАТ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ ТИП_SQL STG_ДобЗначЖурнал(ТИП_СТРОКА: инд) //все значения
  спр = "register"
  ДобавитьЗначениеС(спр, инд + "|SPR_REGISTER_type", "spr_register--spr_register")
  ДобавитьЗначениеЧ(спр, инд + "|SPR_REGISTER_id_vzn", ПОЛЕ("id_vzn")) //_vzn
  ДобавитьЗначениеС(спр, инд + "|SPR_REGISTER_fls", ПОЛЕ("fls"))
  ДобавитьЗначениеЧ(спр, инд + "|SPR_REGISTER_id_area", ПОЛЕ("id_area"))
  ЕСЛИ IB_DBF_ПолеСущ("cap") ТО
    ДобавитьЗначениеС(спр, инд + "|SPR_REGISTER_cap", ПОЛЕ("cap"))
  ИНАЧЕ
    ЕСЛИ СУЩ_ПЕРЕМ(г_наимВзнПоИд[ПОЛЕ("id_vzn")]) ТО
      ДобавитьЗначениеС(спр, инд + "|SPR_REGISTER_cap", г_наимВзнПоИд[ПОЛЕ("id_vzn")])
    КОНЕЦ_ЕСЛИ
  КОНЕЦ_ЕСЛИ
  ДобавитьЗначениеЧ(спр, инд + "|SPR_REGISTER_rec_type", ПОЛЕ("rec_type"))
  ДобавитьЗначениеД(спр, инд + "|SPR_REGISTER_dat", ПОЛЕ("dat"))
  ДобавитьЗначениеЧ(спр, инд + "|SPR_REGISTER_pay_sum", ПОЛЕ("pay_sum"))
  ДобавитьЗначениеЧ(спр, инд + "|SPR_REGISTER_add_sum", ПОЛЕ("add_sum"))
  ЕСЛИ IB_CONTEXT_СчитатьЛок("синхронизацияСайта") = "" ТО
    ДобавитьЗначениеЛ(спр, инд + "|SPR_REGISTER_is_synced", НЕТ)
  ИНАЧЕ
    ДобавитьЗначениеЛ(спр, инд + "|SPR_REGISTER_is_synced", ДА)
  КОНЕЦ_ЕСЛИ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ STG_ПоказатьЖурнал
  СОЗДАТЬ(сп, ТИП_СПИСОК)
  /*сп.ДОБАВИТЬ("SELECT A.*, B.ID, B.CAP, CAST('' AS CHAR(20)) AS RT_STR FROM")
  сп.ДОБАВИТЬ("'" + ф_Журнал + "' A")
  сп.ДОБАВИТЬ("LEFT JOIN")
  сп.ДОБАВИТЬ("'" + ф_СпрЦелевыхВзносов + "' B")
  сп.ДОБАВИТЬ("ON A.ID_VZN = B.ID AND A.TYPE = B.CODP WHERE (A.IS_SYNCED = FALSE OR A.IS_SYNCED IS NULL) AND")
  сп.ДОБАВИТЬ("DAT BETWEEN '" + СТР(гр_датаОпераций) + "' AND '" + СТР(гр_датаОперацийПо) + "'")
  сп.ДОБАВИТЬ("AND ADD_SUM <> 0 OR PAY_SUM <> 0")
  ЕСЛИ г_колУчастков > 0 ТО
    сп.ДОБАВИТЬ("AND A.ID_AREA IN (")
    сп.STG_ARH_СчитатьАрхив(к_АрхивСпрУчастков, г_путьПрофиляСпрУчастков)
    сп.ДОБАВИТЬ(")")
  КОНЕЦ_ЕСЛИ
  сп.ДОБАВИТЬ("ORDER BY A.N_AREA, A.DAT, B.ID")
  sql = SQL_ЗАПРОС(сп)*/
  СОЗДАТЬ(sql, ТИП_SQL)
  sql.STG_ЗапросВыгрузкиЖурнал
  
  /*ЦИКЛ ДЛЯ(и = 1, sql.ВСЕГО)
    sql.ПЕРЕЙТИ(и)
    ВЫБОР(sql.ПОЛЕ("REC_TYPE"))
     #к_ТипЗаписиЖурналаНач: имя = к_ТипЗаписиЖурналаНачНазв
     #к_ТипЗаписиЖурналаКасса: имя = к_ТипЗаписиЖурналаКассаНазв
     #к_ТипЗаписиЖурналаРасчСч: имя = к_ТипЗаписиЖурналаРасчСчНазв
     #к_ТипЗаписиЖурналаПени: имя = к_ТипЗаписиЖурналаПениНазв
     #к_ТипЗаписиЖурналаИО: имя = к_ТипЗаписиЖурналаИОНазв
     #к_ТипЗаписиЖурналаПениКасса: имя = "пени (касса)"
     #к_ТипЗаписиЖурналаПениРасчСч: имя = "пени (расч. сч.)"
     #к_ТипЗаписиЖурналаВозвратКасса: имя = к_ТипЗаписиЖурналаВозврКасса
     #к_ТипЗаписиЖурналаВозвратРсч: имя = к_ТипЗаписиЖурналаВозврРсч
    КОНЕЦ_ВЫБОРА
    
    //sql.ЗАП_ПОЛЕ("CONTENT", СТР_РАЗБИТЬ(sql.ПОЛЕ("CONTENT"), 25))
    sql.ЗАП_ПОЛЕ("RT_STR", имя)
    sql.ЗАМЕНИТЬ
  КОНЕЦ_ЦИКЛА*/
  
  т = БД_ВЫБОР(sql, "Записи журнала на выгрузку",
               ["N_AREA"     : "Участок"    : 10,
                "FLS"        : "ФЛС"        : 10,
                "CAP"        : "Взнос"      : 20,
                "DAT"        : "Дата"       : 10,
                "DOC"        : "Документ"   : 10,
                "CONTENT"    : "Содержание" : 25,
                "RT_STR"     : "Тип записи" : 15,
                "ADD_SUM"    : "Начисление" : 10,
                "PAY_SUM"    : "Оплата"     : 10,
                "ID_RECSITE" : "id"         : 5,
                "UUID"       : "uuid"       : 6,
                "IS_SYNCED"  : "Синхр."     : 6])
  sql.ЗАКРЫТЬ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ STG_ВыгрузитьРасчеты
  СБРОС(SPR_CALC_REG_эл_доб, SPR_CALC_REG_эл_счит, SPR_CALC_REG_эл_знач, SPR_CALC_REG_эл_изм)
  спр = "Журнал расчетов"
  rest_колЭлемПодЗапрДоб = stg_профилиВыгрузкиСпр!спр!"_qty_add"
  
  //STG_КоррИдентВзносов //- эту штуку надо делать один раз перед выгрузкой базы на сайт
  //STG_АктуализироватьЖурналы //- эту штуку надо делать один раз перед выгрузкой базы на сайт
  
  СБРОС(г_типыПоИд)
  sql = SQL_ОТКРЫТЬ(ф_СпрЦелевыхВзносов)
  г_типыПоИд[0] = "" //костыль
  ЦИКЛ ДЛЯ(и = 1, sql.ВСЕГО)
    sql.ПЕРЕЙТИ(и)
    г_типыПоИд[sql.ПОЛЕ("ID")] = sql.ПОЛЕ("CODP")
  КОНЕЦ_ЦИКЛА
  sql.ЗАКРЫТЬ
  
  СОЗДАТЬ(sql_loop, ТИП_SQL)
  sql_loop.STG_ЗапросВыгрузкиРасчетов
  //БД_РЕДАКТОР(sql_loop)
  
  ЕСЛИ оп_проверятьБазуПоСайту ТО
    ЕСЛИ SPR_CALC_REG_ПолучитьСписок(ДА) ТО
      STG_ПроверитьИдБазы(ф_ЖурналРасчетов)
    КОНЕЦ_ЕСЛИ
    СБРОС(SPR_CALC_REG_эл_id, SPR_CALC_REG_эл_уд, SPR_CALC_REG_эл_счит, SPR_CALC_REG_эл_доб,  SPR_CALC_REG_эл_знач, SPR_CALC_REG_эл_изм, REST_эл)
  КОНЕЦ_ЕСЛИ
  
  СОЗДАТЬ(сп, ТИП_СПИСОК)
  сп.ДОБАВИТЬ("SELECT * FROM")
  сп.ДОБАВИТЬ("'" + ф_Журнал + "'")
  сп.ДОБАВИТЬ("WHERE ID_CALC > 0 AND DAT BETWEEN '" + СТР(гр_датаОпераций) + "' AND '" + СТР(гр_датаОперацийПо) + "'")
  ЕСЛИ г_колУчастков > 0 ТО
    сп.ДОБАВИТЬ("AND ID_AREA IN (")
    сп.STG_ARH_СчитатьАрхив(к_АрхивСпрУчастков, г_путьПрофиляСпрУчастков)
    сп.ДОБАВИТЬ(")")
  КОНЕЦ_ЕСЛИ
  sql1 = SQL_ЗАПРОС(сп)
  //БД_РЕДАКТОР(sql1)
  //ВЫХОД
  длина = ДЛИНА(СТР_ЗНАЧ(sql_loop.ВСЕГО))
  кодыВзн!г_сервИнд = ""
  идРасчетов!г_сервИнд = 0 
  sql = SQL_ОТКРЫТЬ(ф_ЖурналРасчетов)
  СтатусСоздать("Обработка расчетов для выгрузки")
  СтатусСтартПрогресс(sql_loop.ВСЕГО)
  STG_ИниСтрокуОтчета("Журнал расчётов")
  колОб = 0
  всегоОб = sql_loop.ВСЕГО
  ЦИКЛ ДЛЯ(и = 1, всегоОб)
    sql_loop.ПЕРЕЙТИ(и)
    идРасч = sql_loop.ПОЛЕ("ID_CALC")
    идУч = sql_loop.ПОЛЕ("ID_AREA")
    кодВзн = sql_loop.ПОЛЕ("type")
    идИПУ = sql_loop.ПОЛЕ("id_ipu")
    //индРасч = СТР_ЗНАЧ(идУч) + "|" + кодВзн
    //
    STG_ПрокачкаСтатуса("обработка расчетов: ")
    //
    поз = sql1.НАЙТИ_ПОЗ("ID_CALC", идРасч, "ID_AREA", идУч, "TYPE", кодВзн)
    ЕСЛИ поз > 0 ТО
      Данные!ВсегоСтр!"C"++
      инд = СТР0(и, длина)
      //идРасчетов!инд = sql_loop.ПОЛЕ("ID_CALC")
      //кодыВзн!инд = sql_loop.ПОЛЕ("TYPE")
      SPR_CALC_REG_эл_доб!инд = НЕТ
      
      sql1.ПЕРЕЙТИ(поз)
      sql_loop.STG_ДобЗначРасчет1(инд)
      sql1.STG_ДобЗначРасчет2(инд)
      колОб++  
    КОНЕЦ_ЕСЛИ
    
    ЕСЛИ НЕ stg_профилиВыгрузкиСпр!спр!"_subreq_add" ТО
      ЕСЛИ SPR_CALC_REG_ДобавитьМнож(НЕТ) ТО
        sql.STG_СинхронизироватьРасчет("") //, кодВзн, идРасч)
      ИНАЧЕ
        СТОП
      КОНЕЦ_ЕСЛИ
      СБРОС(SPR_CALC_REG_эл_доб, SPR_CALC_REG_эл_счит, SPR_CALC_REG_эл_знач, SPR_CALC_REG_эл_изм)
    ИНАЧЕ
      ЕСЛИ колОб = 500 ИЛИ 
           и = всегоОб ТО
        SPR_CALC_REG_ДобавитьМнож(stg_профилиВыгрузкиСпр!спр!"_subreq_add")
        СтатусСоздать("Синхронизация журнала расчетов")
        СтатусСтартПрогресс(КОЛ_ЭЛЕМ(REST_эл_id))
        ЦИКЛ ИНДЕКС(лог = SPR_CALC_REG_эл_доб!инд)
          ЕСЛИ лог ТО
            STG_ПрокачкаСтатуса("Синхронизация журнала расчетов")
            sql.STG_СинхронизироватьРасчет(инд) //, кодыВзн!инд, идРасчетов!инд)
          КОНЕЦ_ЕСЛИ
        КОНЕЦ_ЦИКЛА
        СтатусЗакрыть
        СБРОС(SPR_CALC_REG_эл_доб, SPR_CALC_REG_эл_счит, SPR_CALC_REG_эл_знач, SPR_CALC_REG_эл_изм)
        колОб = 0
      КОНЕЦ_ЕСЛИ
    КОНЕЦ_ЕСЛИ
  КОНЕЦ_ЦИКЛА
  СтатусЗакрыть
  
  /*ЕСЛИ оп_подзапрДобавление ТО
    SPR_CALC_REG_ДобавитьМнож(оп_подзапрДобавление)
    СтатусСоздать("Синхронизация журнала расчетов")
    СтатусСтартПрогресс(КОЛ_ЭЛЕМ(REST_эл_id))
    ЦИКЛ ИНДЕКС(лог = SPR_CALC_REG_эл_доб!инд)
      ЕСЛИ лог ТО
        STG_ПрокачкаСтатуса("Синхронизация журнала расчетов")
        sql.STG_СинхронизироватьРасчет(инд) //, кодыВзн!инд, идРасчетов!инд)
      КОНЕЦ_ЕСЛИ
    КОНЕЦ_ЦИКЛА
    СтатусЗакрыть
    СБРОС(SPR_CALC_REG_эл_доб, SPR_CALC_REG_эл_счит, SPR_CALC_REG_эл_знач, SPR_CALC_REG_эл_изм)
  КОНЕЦ_ЕСЛИ*/
  
  sql_loop.ЗАКРЫТЬ
  sql.ЗАКРЫТЬ
  sql1.ЗАКРЫТЬ
  //СтатусЗакрыть
КОНЕЦ_ФУНКЦИИ

ФУНКЦИЯ STG_АктуализироватьЖурналы
  СОЗДАТЬ(сп, ТИП_СПИСОК)
  //удалим расчеты, которых нет в журнале
  сп.ДОБАВИТЬ("DELETE FROM")
  сп.ДОБАВИТЬ("'" + ф_ЖурналРасчетов + "'")
  сп.ДОБАВИТЬ("WHERE ID_CALC NOT IN (SELECT ID_CALC FROM")
  сп.ДОБАВИТЬ("'" + ф_Журнал + "'")
  сп.ДОБАВИТЬ("WHERE ID_CALC > 0)")
  SQL_ЗАПРОС(сп)
  
  сп.ОЧИСТИТЬ
  сп.ДОБАВИТЬ("DELETE FROM")
  сп.ДОБАВИТЬ("'" + ф_Журнал + "'")
  сп.ДОБАВИТЬ("WHERE ADD_SUM = 0 AND PAY_SUM = 0")
  SQL_ЗАПРОС(сп)
  
  IB_DBF_УпакТабл(ф_ЖурналРасчетов)
  
  парамВзн!"" = ""
  парамУч!"" = ""
  парамИПУ!"" = ""
  СБРОС(парамВзн, парамУч, парамИПУ)
  
  sql = SQL_ОТКРЫТЬ(ф_СпрЦелевыхВзносов)
  ЦИКЛ ДЛЯ(и = 1, sql.ВСЕГО)
    sql.ПЕРЕЙТИ(и)
    код = sql.ПОЛЕ("CODP")
    парамВзн!"тип_"!код = sql.ПОЛЕ("TYPE")
    парамВзн!"метод_"!код = sql.ПОЛЕ("METHOD")
  КОНЕЦ_ЦИКЛА
  sql.ЗАКРЫТЬ
  
  sql = SQL_ОТКРЫТЬ(ф_СпрУчастковГаражей)
  ЦИКЛ ДЛЯ(и = 1, sql.ВСЕГО)
    sql.ПЕРЕЙТИ(и)
    идУч = sql.ПОЛЕ("ID_AREA")
    парамУч!"площадь_"!идУч = sql.ПОЛЕ("SQUARE")
  КОНЕЦ_ЦИКЛА
  sql.ЗАКРЫТЬ
  
  //далее надо вытащить все записи из
  sql_журнал = SQL_ОТКРЫТЬ(ф_ЖурналРасчетов) //может быть так, что участок в журнале отличается от уч в файле расч.
  
  //не падает
  сп.ОЧИСТИТЬ
  сп.ДОБАВИТЬ("SELECT B.*, A.DAT, A.ADD_SUM, A.PAY_SUM FROM")
  сп.ДОБАВИТЬ("'" + ф_Журнал + "' A")
  сп.ДОБАВИТЬ("INNER JOIN")
  сп.ДОБАВИТЬ("'" + ф_ЖурналРасчетов + "' B")
  сп.ДОБАВИТЬ("ON A.ID_AREA = B.ID_AREA AND A.ID_CALC = B.ID_CALC AND A.ID_VZN = B.ID_TYPE")
  сп.ДОБАВИТЬ("WHERE B.SUM_T1 = 0")
  //ОТЛАДКА(сп)
  sql = SQL_ЗАПРОС(сп)
  //БД_РЕДАКТОР(sql)
  
  ЦИКЛ ДЛЯ(и = 1, sql.ВСЕГО)
    sql.ПЕРЕЙТИ(и)
    
    идВзн = sql.ПОЛЕ("ID_TYPE")
    идУч = sql.ПОЛЕ("ID_AREA")
    идРасч = sql.ПОЛЕ("ID_CALC")
    идИПУ = sql.ПОЛЕ("ID_IPU")
    
    поз = sql_журнал.НАЙТИ_ПОЗ("ID_CALC", идРасч, "ID_AREA", идУч, "ID_TYPE", идВзн, "ID_IPU", идИПУ, "SUM_T1", 0)
    ЕСЛИ поз > 0 ТО
      sql_журнал.ПЕРЕЙТИ(поз)
      sql_журнал.ЗАП_ПОЛЕ("SUM_T1", sql.ПОЛЕ("ADD_SUM"))
      ЕСЛИ sql.ПОЛЕ("TYPE") <> "ЭЭ" ТО
        ЕСЛИ СУЩ_ПЕРЕМ(парамУч!"площадь_"!идУч) ТО
          sql_журнал.ЗАП_ПОЛЕ("SQUARE", парамУч!"площадь_"!идУч)
        КОНЕЦ_ЕСЛИ
      КОНЕЦ_ЕСЛИ
      sql_журнал.ЗАМЕНИТЬ
    КОНЕЦ_ЕСЛИ
  КОНЕЦ_ЦИКЛА
  sql.ЗАКРЫТЬ
  sql_журнал.ЗАКРЫТЬ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ ТИП_SQL STG_ЗапросВыгрузкиРасчетов
  СОЗДАТЬ(сп, ТИП_СПИСОК)
  сп.ДОБАВИТЬ("SELECT A.*, B.SRT FROM") //
  сп.ДОБАВИТЬ("'" + ф_ЖурналРасчетов + "' A")
  сп.ДОБАВИТЬ("INNER JOIN")
  сп.ДОБАВИТЬ("'" + ф_СпрУчастковГаражей + "' B")
  сп.ДОБАВИТЬ("ON A.ID_AREA = B.ID_AREA")
  контекст = IB_CONTEXT_ИзвлечьЛок(к_атрПоказВсехЗаписей)
  ЕСЛИ контекст = "" ТО
    сп.ДОБАВИТЬ("WHERE (A.IS_SYNCED = FALSE OR A.IS_SYNCED IS NULL)")
  КОНЕЦ_ЕСЛИ
  ЕСЛИ г_колУчастков > 0 ТО
    сп.ДОБАВИТЬ(?(сп.ВСЕГО > 5, "AND", "WHERE") + " A.ID_AREA IN (")
    сп.STG_ARH_СчитатьАрхив(к_АрхивСпрУчастков, г_путьПрофиляСпрУчастков)
    сп.ДОБАВИТЬ(")")
  КОНЕЦ_ЕСЛИ
  сп.ДОБАВИТЬ(?(сп.ВСЕГО > 5, "AND", "WHERE")) 
  сп.ДОБАВИТЬ("(A.SUM_T1 <> 0 OR A.SUM_T2 <> 0 OR A.SUM_T3 <> 0 OR SUM_FIX <> 0 OR SQUARE <> 0) AND")
  сп.ДОБАВИТЬ(" A.ID_CALC IN (SELECT ID_CALC FROM")
  сп.ДОБАВИТЬ("'" + ф_Журнал + "'")
  сп.ДОБАВИТЬ("WHERE ID_CALC > 0 AND DAT BETWEEN '" + СТР(гр_датаОпераций) + "' AND '" + СТР(гр_датаОперацийПо) + "'")
  ЕСЛИ г_колУчастков > 0 ТО
    сп.ДОБАВИТЬ("AND ID_AREA IN (")
    сп.STG_ARH_СчитатьАрхив(к_АрхивСпрУчастков, г_путьПрофиляСпрУчастков)
    сп.ДОБАВИТЬ(")")
  КОНЕЦ_ЕСЛИ
  сп.ДОБАВИТЬ(")")
  сп.ДОБАВИТЬ("ORDER BY B.SRT, A.ID_CALC")
  ЗАПРОС(сп)
  //ОТЛАДКА(сп)
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ ТИП_SQL ТИП_ЛОГИКА: STG_СинхронизироватьРасчет(ТИП_СТРОКА: id) //, тип; ТИП_ЧИСЛО: id_calc)
  спр = "Журнал расчетов"
  ЕСЛИ id = "" ТО
    id = СТР_ЗНАЧ(SPR_CALC_REG_id)
  КОНЕЦ_ЕСЛИ
  РЕЗУЛЬТАТ = НЕТ
  ЕСЛИ СУЩ_ПЕРЕМ(SPR_CALC_REG_эл_счит[id + "|SPR_CALC_REG_id_area"]) ТО
    ЕСЛИ SPR_CALC_REG_эл_счит[id + "|SPR_CALC_REG_id_area"] И 
         SPR_CALC_REG_эл_счит[id + "|SPR_CALC_REG_id_vzn"] И 
         SPR_CALC_REG_эл_счит[id + "|SPR_CALC_REG_id_ipu"] И 
         SPR_CALC_REG_эл_счит[id + "|SPR_CALC_REG_dat"] ТО
      ЕСЛИ СУЩ_ПЕРЕМ(Данные!ВсегоСтр!"D") ТО
        Данные!ВсегоСтр!"D"++
      КОНЕЦ_ЕСЛИ
      ЕСЛИ stg_профилиВыгрузкиСпр!спр!"_subreq_add" ТО
        SPR_CALC_REG_Упаковать(id)
      КОНЕЦ_ЕСЛИ
      поз = НАЙТИ_ПОЗ("id_area", SPR_CALC_REG_id_area, 
                      "id_type", SPR_CALC_REG_id_vzn,
                      //"type", г_типыПоИд!SPR_CALC_REG_id_vzn, 
                      "id_ipu", SPR_CALC_REG_id_ipu, 
                      "ID_CALC", SPR_CALC_REG_id_calc,
                      "IS_SYNCED", НЕТ,
                      "SUM_T1", SPR_CALC_REG_sum_t1)
      ЕСЛИ поз > 0 ТО
        ЕСЛИ СУЩ_ПЕРЕМ(Данные!ВсегоСтр!"E") ТО
          Данные!ВсегоСтр!"E"++
        КОНЕЦ_ЕСЛИ
        ПЕРЕЙТИ(поз)
        ЕСЛИ SPR_CALC_REG_эл_счит[id + "|SPR_CALC_REG_is_synced"] ТО
          ЗАП_ПОЛЕ("IS_SYNCED", SPR_CALC_REG_is_synced)
        КОНЕЦ_ЕСЛИ
        ЕСЛИ SPR_CALC_REG_эл_счит[id + "|SPR_CALC_REG_id"] ТО
          ЗАП_ПОЛЕ("ID_RECSITE", SPR_CALC_REG_id)
        КОНЕЦ_ЕСЛИ
        ЕСЛИ SPR_CALC_REG_эл_счит[id + "|SPR_CALC_REG_uuid"] ТО
          ЗАП_ПОЛЕ("UUID", SPR_CALC_REG_uuid)
        КОНЕЦ_ЕСЛИ
        ЗАМЕНИТЬ
        РЕЗУЛЬТАТ = ДА
      ИНАЧЕ
        ЕСЛИ СУЩ_ПЕРЕМ(Данные!ВсегоСтр!"F") ТО
          Данные!ВсегоСтр!"F"++
        КОНЕЦ_ЕСЛИ
      КОНЕЦ_ЕСЛИ
    КОНЕЦ_ЕСЛИ
  КОНЕЦ_ЕСЛИ
  STG_СинхронизироватьРасчет = РЕЗУЛЬТАТ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ ТИП_SQL STG_ДобЗначРасчеты(ТИП_СТРОКА: инд) //все значения
  спр = "calc"
  ДобавитьЗначениеС(спр, инд + "|SPR_CALC_REG_type", "spr_calculations_reg--spr_calculations_reg")
  ДобавитьЗначениеЧ(спр, инд + "|SPR_CALC_REG_id_ipu", ПОЛЕ("id_ipu"))
  ДобавитьЗначениеЧ(спр, инд + "|SPR_CALC_REG_id_vzn", ПОЛЕ("id_type"))
  ДобавитьЗначениеС(спр, инд + "|SPR_CALC_REG_fls", ПОЛЕ("fls"))
  ДобавитьЗначениеЧ(спр, инд + "|SPR_CALC_REG_id_area", ПОЛЕ("id_area"))
  ДобавитьЗначениеЧ(спр, инд + "|SPR_CALC_REG_sum_pt3", ПОЛЕ("sum_pt3"))
  ДобавитьЗначениеЧ(спр, инд + "|SPR_CALC_REG_sum_pt2", ПОЛЕ("sum_pt2"))
  ДобавитьЗначениеЧ(спр, инд + "|SPR_CALC_REG_sum_pt1", ПОЛЕ("sum_pt1"))
  ДобавитьЗначениеЧ(спр, инд + "|SPR_CALC_REG_sum_snt3", ПОЛЕ("sum_snt3"))
  ДобавитьЗначениеЧ(спр, инд + "|SPR_CALC_REG_sum_snt2", ПОЛЕ("sum_snt2"))
  ДобавитьЗначениеЧ(спр, инд + "|SPR_CALC_REG_sum_snt1", ПОЛЕ("sum_snt1"))
  ДобавитьЗначениеЧ(спр, инд + "|SPR_CALC_REG_sum_t3", ПОЛЕ("sum_t3"))
  ДобавитьЗначениеЧ(спр, инд + "|SPR_CALC_REG_sum_t2", ПОЛЕ("sum_t2"))
  ДобавитьЗначениеЧ(спр, инд + "|SPR_CALC_REG_sum_t1", ПОЛЕ("sum_t1"))
  ДобавитьЗначениеЧ(спр, инд + "|SPR_CALC_REG_sum_fix", ПОЛЕ("sum_fix"))
  ДобавитьЗначениеЧ(спр, инд + "|SPR_CALC_REG_t3sn_vol", ПОЛЕ("t3sn_vol"))
  ДобавитьЗначениеЧ(спр, инд + "|SPR_CALC_REG_t2sn_vol", ПОЛЕ("t2sn_vol"))
  ДобавитьЗначениеЧ(спр, инд + "|SPR_CALC_REG_t1sn_vol", ПОЛЕ("t1sn_vol"))
  ДобавитьЗначениеЧ(спр, инд + "|SPR_CALC_REG_t3_vol", ПОЛЕ("t3_vol"))
  ДобавитьЗначениеЧ(спр, инд + "|SPR_CALC_REG_t2_vol", ПОЛЕ("t2_vol"))
  ДобавитьЗначениеЧ(спр, инд + "|SPR_CALC_REG_t1_vol", ПОЛЕ("t1_vol"))
  ДобавитьЗначениеЧ(спр, инд + "|SPR_CALC_REG_square", ПОЛЕ("square"))
  //ДобавитьЗначениеЧ(спр, инд + "|SPR_CALC_REG_rec_type", ПОЛЕ("rec_type"))
  ДобавитьЗначениеД(спр, инд + "|SPR_CALC_REG_dat", ПОЛЕ("dat"))
  //ДобавитьЗначениеЧ(спр, инд + "|SPR_CALC_REG_pay_sum", ПОЛЕ("pay_sum"))
  ДобавитьЗначениеЧ(спр, инд + "|SPR_CALC_REG_add_sum", ПОЛЕ("add_sum"))
  ЕСЛИ IB_CONTEXT_СчитатьЛок("синхронизацияСайта") = "" ТО
    ДобавитьЗначениеЛ(спр, инд + "|SPR_CALC_REG_is_synced", НЕТ)
  ИНАЧЕ
    ДобавитьЗначениеЛ(спр, инд + "|SPR_CALC_REG_is_synced", ДА)
  КОНЕЦ_ЕСЛИ
КОНЕЦ_ФУНКЦИИ

