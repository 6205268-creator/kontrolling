  ЕСЛИ г_колУчастков = 0 ИЛИ IB_CONTEXT_СчитатьЛок("очиститьСайт") = "ДА" ТО
    ЕСЛИ г_запросНаСайт ТО
      SPR_LINK_ALL_ПолучитьСписок(ДА)
      Данные!ВсегоСтр!"C" = КОЛ_ЭЛЕМ(REST_эл_id)
    КОНЕЦ_ЕСЛИ
  ИНАЧЕ
    STG_ЗапросУдалитьПоФлт(ф_СвязьВладУч)
  КОНЕЦ_ЕСЛИ
  ЕСЛИ г_запросНаСайт ТО
    //ЕСЛИ оп_подзапрУдаление И (г_колУчастков = 0 ИЛИ IB_CONTEXT_СчитатьЛок("очиститьСайт") = "ДА") ТО
    ЕСЛИ stg_профилиВыгрузкиСпр!спр!"_prot_del" = "JSONAPI" ТО
