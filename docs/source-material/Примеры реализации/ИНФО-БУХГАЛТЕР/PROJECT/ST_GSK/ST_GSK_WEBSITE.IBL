    ИНАЧЕ
      SPR_OBJECTS_УдалитьМнож(stg_профилиВыгрузкиСпр!спр!"_subreq_del")
    КОНЕЦ_ЕСЛИ
    ЦИКЛ ИНДЕКС(лог = SPR_OBJECTS_эл_уд!инд)
