            КОНЕЦ_ЕСЛИ
            ЕСЛИ MP_ANSWER_эл_счит[id + "|MP_ANSWER_id"] ТО
              ЗАП_ПОЛЕ("id_recsite", MP_ANSWER_id)
            КОНЕЦ_ЕСЛИ
            ЕСЛИ MP_ANSWER_эл_счит[id + "|MP_ANSWER_uuid"] ТО
              ЗАП_ПОЛЕ("uuid", MP_ANSWER_uuid)
            КОНЕЦ_ЕСЛИ
            ЕСЛИ MP_ANSWER_эл_счит[id + "|MP_ANSWER_uid"] ТО
              ЗАП_ПОЛЕ("uid", MP_ANSWER_uid)
            КОНЕЦ_ЕСЛИ
            ЕСЛИ MP_ANSWER_эл_счит[id + "|MP_ANSWER_created"] ТО
              ЗАП_ПОЛЕ("created", MP_ANSWER_created)
            КОНЕЦ_ЕСЛИ
            ЕСЛИ MP_ANSWER_эл_счит[id + "|MP_ANSWER_changed"] ТО
              ЗАП_ПОЛЕ("changed", MP_ANSWER_changed)
            КОНЕЦ_ЕСЛИ
            ЕСЛИ MP_ANSWER_эл_счит[id + "|MP_ANSWER_weight"] ТО
