  rest_колЭлемПодЗапрУд = stg_профилиВыгрузкиСпр!спр!"_qty_del"
  
  СБРОС(MP_RESULT_эл_id, MP_RESULT_эл_уд, MP_RESULT_эл_доб, MP_RESULT_эл_счит, MP_RESULT_эл_знач, MP_RESULT_эл_изм, REST_эл_id)
  STG_ИниСтрокуОтчета("Результаты")
  ЕСЛИ г_запросНаСайт ТО
