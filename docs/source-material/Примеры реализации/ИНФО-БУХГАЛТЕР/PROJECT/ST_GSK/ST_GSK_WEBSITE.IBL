//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ STG_СбросПолейСинхрБД(ТИП_СТРОКА: файл)
  СТРОКА_СТАТУСА("Сброс ID в БД")
  СОЗДАТЬ(сп, ТИП_СПИСОК)
  
  колЭл = КолЭлемУдаления(файл)
  
  ЕСЛИ колЭл > 0 И г_запросНаСайт ТО
    //формирование строк по 250 символов или менее
    СБРОС(г_строкиЗапроса)
    г_колСтрокЗапроса = 0
    г_колИтер = 0
    текСтрока = ""
    
    ЕСЛИ IB_CONTEXT_СчитатьЛок("очиститьСайт") = "" ТО
      STG_ФормСписокОбСинхр(файл, колЭл)
    ИНАЧЕ
      г_колСтрокЗапроса = 1
    КОНЕЦ_ЕСЛИ
    ЕСЛИ г_колСтрокЗапроса > 0 ТО
      начСтр = 1
      ЦИКЛ ПОКА(ДА)
        сп.ОЧИСТИТЬ
        ЕСЛИ файл = ф_ЖурналСинхрОстатков ТО
          сп.ДОБАВИТЬ("DELETE FROM")
          сп.ДОБАВИТЬ("'" + файл + "'")
        ИНАЧЕ
          сп.ДОБАВИТЬ("UPDATE")
          сп.ДОБАВИТЬ("'" + файл + "'")
          сп.ДОБАВИТЬ("SET ID_RECSITE = 0, IS_SYNCED = FALSE, UUID = ''")
        КОНЕЦ_ЕСЛИ
        ЕСЛИ IB_CONTEXT_СчитатьЛок("очиститьСайт") = "" ТО
          сп.ДОБАВИТЬ("WHERE ID_RECSITE IN (")
          сп.ЗаполнитьСписокЭлементов(2500, 300, начСтр)
          сп.ДОБАВИТЬ(")")
        КОНЕЦ_ЕСЛИ
        SQL_ЗАПРОС(сп)
        ЕСЛИ начСтр >= г_колСтрокЗапроса ТО
          СТОП
        КОНЕЦ_ЕСЛИ
      КОНЕЦ_ЦИКЛА
    КОНЕЦ_ЕСЛИ
  ИНАЧЕ
    ЕСЛИ НЕ г_запросНаСайт ТО
      резСущПоля = ДА
      ЕСЛИ файл = ф_ЖурналСинхрОстатков ТО
        сп.ДОБАВИТЬ("DELETE FROM")
        сп.ДОБАВИТЬ("'" + файл + "'")
      ИНАЧЕ
        сп.ДОБАВИТЬ("UPDATE")
        сп.ДОБАВИТЬ("'" + файл + "'")
        сп.ДОБАВИТЬ("SET ID_RECSITE = 0, IS_SYNCED = FALSE, UUID = ''")
        резСущПоля = IB_DBF_СущПоле(файл, "ID_AREA")
      КОНЕЦ_ЕСЛИ
      ЕСЛИ резСущПоля ТО
        ЕСЛИ г_колУчастков > 0 И IB_CONTEXT_СчитатьЛок("очиститьСайт") = "" ТО
          сп.ДОБАВИТЬ("WHERE ID_AREA IN (")
          сп.STG_ARH_СчитатьАрхив(к_АрхивСпрУчастков, г_путьПрофиляСпрУчастков)
          сп.ДОБАВИТЬ(")")
        КОНЕЦ_ЕСЛИ
      КОНЕЦ_ЕСЛИ
      SQL_ЗАПРОС(сп)
    КОНЕЦ_ЕСЛИ
  КОНЕЦ_ЕСЛИ
  СТРОКА_СТАТУСА("")
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ STG_ФормСписокОбСинхр(ТИП_СТРОКА: справочник; ТИП_ЧИСЛО: колЭл)
  текСтрока = ""
  ВЫБОР(справочник)
   #ф_СпрВладельцев:
    ЦИКЛ ИНДЕКС(логУд = SPR_OWNERS_эл_уд!номЭл)
      СформироватьСтрокуЗапроса(текСтрока, номЭл, колЭл)
    КОНЕЦ_ЦИКЛА
   #ф_СпрУчастковГаражей:
    ЦИКЛ ИНДЕКС(логУд = SPR_OBJECTS_эл_уд!номЭл)
      СформироватьСтрокуЗапроса(текСтрока, номЭл, колЭл)
    КОНЕЦ_ЦИКЛА
   #ф_СпрИндивСчетчики:
    ЦИКЛ ИНДЕКС(логУд = SPR_SHETCH_эл_уд!номЭл)
      СформироватьСтрокуЗапроса(текСтрока, номЭл, колЭл)
    КОНЕЦ_ЦИКЛА
   #ф_СпрФЛС:
    ЦИКЛ ИНДЕКС(логУд = SPR_FLS_эл_уд!номЭл)
      СформироватьСтрокуЗапроса(текСтрока, номЭл, колЭл)
    КОНЕЦ_ЦИКЛА
   #ф_СвязьВладУч: 
    ЦИКЛ ИНДЕКС(логУд = SPR_LINK_ALL_эл_уд!номЭл)
      СформироватьСтрокуЗапроса(текСтрока, номЭл, колЭл)
    КОНЕЦ_ЦИКЛА
   #ф_СпрЦелевыхВзносов:
    ЦИКЛ ИНДЕКС(логУд = SPR_VZNOSI_эл_уд!номЭл)
      СформироватьСтрокуЗапроса(текСтрока, номЭл, колЭл)
    КОНЕЦ_ЦИКЛА
   #ф_СпрТарифов:
    ЦИКЛ ИНДЕКС(логУд = SPR_TARIF_эл_уд!номЭл)
      СформироватьСтрокуЗапроса(текСтрока, номЭл, колЭл)
    КОНЕЦ_ЦИКЛА
   #ф_Журнал, ф_Журнал1:
    ЦИКЛ ИНДЕКС(логУд = SPR_REGISTER_эл_уд!номЭл)
      СформироватьСтрокуЗапроса(текСтрока, номЭл, колЭл)
    КОНЕЦ_ЦИКЛА
   #ф_ЖурналРасчетов: 
    ЦИКЛ ИНДЕКС(логУд = SPR_CALC_REG_эл_уд!номЭл)
      СформироватьСтрокуЗапроса(текСтрока, номЭл, колЭл)
    КОНЕЦ_ЦИКЛА
   #ф_ПоказанияИСЭЭ, ф_ПоказанияИСВГ: 
    ЦИКЛ ИНДЕКС(логУд = POK_SCH_эл_уд!номЭл)
      СформироватьСтрокуЗапроса(текСтрока, номЭл, колЭл)
    КОНЕЦ_ЦИКЛА
   #ф_ЖурналСинхрОстатков: 
    ЦИКЛ ИНДЕКС(логУд = SPR_DEBTS_эл_уд!номЭл)
      СформироватьСтрокуЗапроса(текСтрока, номЭл, колЭл)
    КОНЕЦ_ЦИКЛА
   #к_спрСайтаИмпортПок:
    ЦИКЛ ИНДЕКС(логУд = stg_идИПУ!номЭл)
      СформироватьСтрокуЗапроса(текСтрока, номЭл, колЭл)
    КОНЕЦ_ЦИКЛА
   #к_спрСайтаГолосования, mp_файлГолосований: 
    ЦИКЛ ИНДЕКС(логУд = MP_POLL_эл_уд!номЭл)
      СформироватьСтрокуЗапроса(текСтрока, номЭл, колЭл)
    КОНЕЦ_ЦИКЛА
   #к_спрСайтаВопросы, mp_файлВопросов: 
    ЦИКЛ ИНДЕКС(логУд = MP_QUESTION_эл_уд!номЭл)
      СформироватьСтрокуЗапроса(текСтрока, номЭл, колЭл)
    КОНЕЦ_ЦИКЛА
   #к_спрСайтаОтветы, mp_файлОтветов: 
    ЦИКЛ ИНДЕКС(логУд = MP_ANSWER_эл_уд!номЭл)
      СформироватьСтрокуЗапроса(текСтрока, номЭл, колЭл)
    КОНЕЦ_ЦИКЛА
   #mp_файлРезультатов: 
    ЦИКЛ ИНДЕКС(логУд = MP_RESULT_эл_уд!номЭл)
      СформироватьСтрокуЗапроса(текСтрока, номЭл, колЭл)
    КОНЕЦ_ЦИКЛА
    #ф_СпрРеквизитовОргСайт:
    ЦИКЛ ИНДЕКС(логУд = SPR_REKV_эл_уд!номЭл)
      СформироватьСтрокуЗапроса(текСтрока, номЭл, колЭл)
    КОНЕЦ_ЦИКЛА
    #ф_СпрНастроекСайт:
    ЦИКЛ ИНДЕКС(логУд = SPR_SETS_эл_уд!номЭл)
      СформироватьСтрокуЗапроса(текСтрока, номЭл, колЭл)
    КОНЕЦ_ЦИКЛА
  КОНЕЦ_ВЫБОРА
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ ТИП_ЧИСЛО: КолЭлемУдаления(ТИП_СТРОКА: справочник)
  РЕЗУЛЬТАТ = 0
  ВЫБОР(справочник)
   #ф_СпрВладельцев: РЕЗУЛЬТАТ = КОЛ_ЭЛЕМ(SPR_OWNERS_эл_уд)
   #ф_СпрУчастковГаражей: РЕЗУЛЬТАТ = КОЛ_ЭЛЕМ(SPR_OBJECTS_эл_уд)
   #ф_СпрИндивСчетчики: РЕЗУЛЬТАТ = КОЛ_ЭЛЕМ(SPR_SHETCH_эл_уд)
   #ф_СпрФЛС: РЕЗУЛЬТАТ = КОЛ_ЭЛЕМ(SPR_FLS_эл_уд)
   #ф_СвязьВладУч: РЕЗУЛЬТАТ = КОЛ_ЭЛЕМ(SPR_LINK_ALL_эл_уд)
   #ф_СпрЦелевыхВзносов: РЕЗУЛЬТАТ = КОЛ_ЭЛЕМ(SPR_VZNOSI_эл_уд)
   #ф_СпрТарифов: РЕЗУЛЬТАТ = КОЛ_ЭЛЕМ(SPR_TARIF_эл_уд)
   #ф_Журнал, ф_Журнал1: РЕЗУЛЬТАТ = КОЛ_ЭЛЕМ(SPR_REGISTER_эл_уд)
   #ф_ЖурналРасчетов: РЕЗУЛЬТАТ = КОЛ_ЭЛЕМ(SPR_CALC_REG_эл_уд)
   #ф_ПоказанияИСЭЭ, ф_ПоказанияИСВГ: РЕЗУЛЬТАТ = КОЛ_ЭЛЕМ(POK_SCH_эл_уд)
   #к_спрСайтаНастройки, ф_СпрНастроекСайт: РЕЗУЛЬТАТ = КОЛ_ЭЛЕМ(SPR_SETS_эл_уд)
   #ф_ЖурналСинхрОстатков: РЕЗУЛЬТАТ = КОЛ_ЭЛЕМ(SPR_DEBTS_эл_уд)
   #к_спрСайтаРеквизиты, ф_СпрРеквизитовОргСайт: РЕЗУЛЬТАТ = КОЛ_ЭЛЕМ(SPR_REKV_эл_уд)
   #к_спрСайтаГолосования, mp_файлГолосований: РЕЗУЛЬТАТ = КОЛ_ЭЛЕМ(MP_POLL_эл_уд)
   #к_спрСайтаВопросы, mp_файлВопросов: РЕЗУЛЬТАТ = КОЛ_ЭЛЕМ(MP_QUESTION_эл_уд)
   #к_спрСайтаОтветы, mp_файлОтветов: РЕЗУЛЬТАТ = КОЛ_ЭЛЕМ(MP_ANSWER_эл_уд)
   #mp_файлРезультатов: РЕЗУЛЬТАТ = КОЛ_ЭЛЕМ(MP_RESULT_эл_уд)
  КОНЕЦ_ВЫБОРА
  КолЭлемУдаления = РЕЗУЛЬТАТ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ STG_СинхронизацияСайта
  ИСПОЛЬЗОВАТЬ("SITEIB\POLL\MP_CONFIG")
  IB_CONTEXT_УстановитьЛок("синхронизацияСайта", "ДА")
  
  файлВыгрузки = ф_ЖурналИзмененияНаСайте
  ЕСЛИ IB_CONTEXT_Считать("файлГолосований") = "ДА" ТО
    файлВыгрузки = mp_файлВыгрузки
  КОНЕЦ_ЕСЛИ
  
  ЕСЛИ СУЩ_ФАЙЛ(файлВыгрузки) ТО
    STG_СчитатьПрофилиВыгрузкиСпр
    
    IB_DBF_СбросКэшаСущПолей
    СтатусСоздать("Синхронизация БД")
    СтатусСтартПрогресс(IB_DBF_ВсегоЗап(файлВыгрузки))
    //
    СОЗДАТЬ(сп, ТИП_СПИСОК)
    сп.ДОБАВИТЬ("SELECT DISTINCT CAT, ACT FROM") //считываем спр и действия 
    сп.ДОБАВИТЬ("'" + файлВыгрузки + "'")
    колСпрСинхр = КОЛ_ЭЛЕМ(stg_списокСпрДляСинхр)
    ЕСЛИ колСпрСинхр > 0 ТО
      сп.ДОБАВИТЬ("WHERE CAT IN (")
      ЦИКЛ ДЛЯ(и = 1, колСпрСинхр)
        сп.ДОБАВИТЬ("'" + stg_списокСпрДляСинхр!и + "'" + ?(и = колСпрСинхр, "", ","))
      КОНЕЦ_ЦИКЛА
      сп.ДОБАВИТЬ(")")
    КОНЕЦ_ЕСЛИ
    колДействСинхр = КОЛ_ЭЛЕМ(stg_списокДействДляСинхр)
    ЕСЛИ колДействСинхр > 0 ТО
      сп.ДОБАВИТЬ(?(сп.ВСЕГО > 2, "AND", "WHERE") + " ACT IN (")
      ЦИКЛ ДЛЯ(и = 1, колДействСинхр)
        сп.ДОБАВИТЬ("'" + stg_списокДействДляСинхр!и + "'" + ?(и = колДействСинхр, "", ","))
      КОНЕЦ_ЦИКЛА
      сп.ДОБАВИТЬ(")")
    КОНЕЦ_ЕСЛИ
    сп.ДОБАВИТЬ("ORDER BY CAT, ACT")
    sql = SQL_ЗАПРОС(сп)
    ЦИКЛ ДЛЯ(и = 1, sql.ВСЕГО)
      sql.ПЕРЕЙТИ(и)
      sql.STG_ВыгрузитьЗаписи
    КОНЕЦ_ЦИКЛА
    sql.ЗАКРЫТЬ
    СтатусЗакрыть
    ЕСЛИ stg_результатыВыгрузки.ВСЕГО > 0 ТО
      в = ВЫБОР(stg_результатыВыгрузки, "Результаты выгрузки", "Результаты", 100, 1, НЕТ, НЕТ, НЕТ, НЕТ)
    КОНЕЦ_ЕСЛИ
    stg_результатыВыгрузки.ОЧИСТИТЬ
  КОНЕЦ_ЕСЛИ
  //
  IB_CONTEXT_УстановитьЛок("синхронизацияСайта", "")
  ЕСЛИ КОЛ_ЭЛЕМ(stg_списокСпрДляСинхр) = 0 И 
       IB_CONTEXT_Считать("файлГолосований") = "" ТО
    STG_ВыгрузитьНастройки
    STG_ВыгрузитьРеквизиты
  КОНЕЦ_ЕСЛИ
  //
  СБРОС(stg_списокСпрДляСинхр, stg_списокДействДляСинхр)
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ПЕРЕМ г_наимВзнПоИд!
ФУНКЦИЯ ТИП_SQL STG_ВыгрузитьЗаписи
  акт = ПОЛЕ("ACT")
  справочник = ПОЛЕ("CAT")
  
  файлВыгрузки = ф_ЖурналИзмененияНаСайте
  ЕСЛИ IB_CONTEXT_Считать("файлГолосований") = "ДА" ТО
    файлВыгрузки = mp_файлВыгрузки
  КОНЕЦ_ЕСЛИ
  
  СБРОС(г_наимВзнПоИд, г_типыПоИд)
  ЕСЛИ справочник = к_спрСайтаРасчеты ИЛИ 
       справочник = к_спрСайтаЖурнал ТО
    sql = SQL_ОТКРЫТЬ(ф_СпрЦелевыхВзносов)
    ЦИКЛ ДЛЯ(и = 1, sql.ВСЕГО)
      sql.ПЕРЕЙТИ(и)
      г_наимВзнПоИд[sql.ПОЛЕ("ID")] = sql.ПОЛЕ("CAP")
      г_типыПоИд[sql.ПОЛЕ("ID")] = sql.ПОЛЕ("CODP")
    КОНЕЦ_ЦИКЛА
    г_наимВзнПоИд[к_СтатьиЗНИд] = к_СтатьиЗН
    г_наимВзнПоИд[к_СтатьиПЭЭИд] = к_СтатьиПЭЭ
    г_типыПоИд[к_СтатьиЗНИд] = к_СтатьиЗНКод
    г_типыПоИд[к_СтатьиПЭЭИд] = к_СтатьиПотЭЭКодСерв
    sql.ЗАКРЫТЬ
  КОНЕЦ_ЕСЛИ
  СОЗДАТЬ(сп, ТИП_СПИСОК)
  имяСпр = "справочник " + STG_ИмяСправочника(ПОЛЕ("CAT"))
  действие = STG_ИмяДействия(ПОЛЕ("ACT"))
  ЕСЛИ акт = "у" ТО
    сп.ДОБАВИТЬ("SELECT DISTINCT * FROM")
    сп.ДОБАВИТЬ("'" + файлВыгрузки + "'")
    сп.ДОБАВИТЬ("WHERE CAT = '" + справочник + "' AND ACT = '" + акт + "'")
    sql = SQL_ЗАПРОС(сп)
    ЦИКЛ ДЛЯ(и = 1, sql.ВСЕГО)
      sql.ПЕРЕЙТИ(и)
      рез = sql.STG_УдалитьССайта
      STG_СтрокаРезультат(имяСпр, sql.ПОЛЕ("DESCR"), действие, рез)
      СтатусОбновитьПрогресс("")
      
      сп.ОЧИСТИТЬ
      сп.ДОБАВИТЬ("DELETE FROM")
      сп.ДОБАВИТЬ("'" + файлВыгрузки + "'")
      сп.ДОБАВИТЬ("WHERE ID = " + СТР_ЗНАЧ(sql.ПОЛЕ("ID")))
      SQL_ЗАПРОС(сп)
    КОНЕЦ_ЦИКЛА
    sql.ЗАКРЫТЬ
  ИНАЧЕ
    ВЫБОР(справочник) //допилить для остальных
     #к_спрСайтаВладельцы : файл!1 = ф_СпрВладельцев
     #к_спрСайтаУчастки : файл!1 = ф_СпрУчастковГаражей
     #к_спрСайтаФЛС : файл!1 = ф_СпрФЛС
     #к_спрСайтаСвязи : файл!1 = ф_СвязьВладУч
     #к_спрСайтаВзносы : файл!1 = ф_СпрЦелевыхВзносов
     #к_спрСайтаТарифы : файл!1 = ф_СпрТарифов
     #к_спрСайтаИПУ : файл!1 = ф_СпрИндивСчетчики
     #к_спрСайтаПоказания : файл!1 = ф_ПоказанияИСЭЭ 
                            файл!2 = ф_ПоказанияИСВГ
     #к_спрСайтаЖурнал : файл!1 = ф_Журнал
     #к_спрСайтаРасчеты : файл!1 = ф_ЖурналРасчетов
     #к_спрСайтаГолосования : файл!1 = mp_файлГолосований 
     #к_спрСайтаВопросы : файл!1 = mp_файлВопросов
     #к_спрСайтаОтветы : файл!1 = mp_файлОтветов
    ИНАЧЕ //обработка ИПУ
      заглушка = ""
      ВЫХОД
    КОНЕЦ_ВЫБОРА
    
    ЦИКЛ ИНДЕКС(имяФ = файл!инд)
      ЕСЛИ имяФ = ф_ЖурналРасчетов ТО
        сп.ОЧИСТИТЬ
        сп.ДОБАВИТЬ("SELECT * FROM")
        сп.ДОБАВИТЬ("'" + ф_Журнал + "'")
        сп.ДОБАВИТЬ("WHERE ID_CALC IN (SELECT ID_CALC FROM")
        сп.ДОБАВИТЬ("'" + имяФ + "' A")
        сп.ДОБАВИТЬ("INNER JOIN")
        сп.ДОБАВИТЬ("'" + файлВыгрузки + "' B")
        сп.ДОБАВИТЬ("ON A.ID_RECSITE = B.ID")
        сп.ДОБАВИТЬ("WHERE B.CAT = '" + справочник + "' AND B.ACT = '" + акт + "')")
        sql0 = SQL_ЗАПРОС(сп)
      КОНЕЦ_ЕСЛИ
      //
      ЕСЛИ имяФ = ф_СпрТарифов ТО
        sql.STG_ЗапросВыгрузкиСпрТар(ДА, файлВыгрузки, справочник, акт)
      ИНАЧЕ
        сп.ОЧИСТИТЬ
        сп.ДОБАВИТЬ("SELECT * FROM")
        сп.ДОБАВИТЬ("'" + имяФ + "' A")
        сп.ДОБАВИТЬ("INNER JOIN")
        сп.ДОБАВИТЬ("'" + файлВыгрузки + "' B")
        сп.ДОБАВИТЬ("ON A.ID_RECSITE = B.ID")
        сп.ДОБАВИТЬ("WHERE B.CAT = '" + справочник + "' AND B.ACT = '" + акт + "'")
        sql = SQL_ЗАПРОС(сп)
      КОНЕЦ_ЕСЛИ
      //
      sql_src = SQL_ОТКРЫТЬ(имяФ) //для показаний 2 вызова
      ЦИКЛ ДЛЯ(и = 1, sql.ВСЕГО) //, 1, -1)
        sql.ПЕРЕЙТИ(и)
        СтатусОбновитьПрогресс("")
        //определяем объекты для доб/изм
        ЕСЛИ акт = "д" ТО
          //текИдЭлДоб = STG_КолЭлДоб(справочник) + 1
          STG_ДобавитьЭлДоб(справочник, sql.ПОЛЕ("ID_RECSITE"))
        ИНАЧЕ
          STG_ДобавитьЭлИд(справочник, СТР_ЗНАЧ(sql.ПОЛЕ("ID_RECSITE")))
        КОНЕЦ_ЕСЛИ
        //заполняем переменные объектов
        sql.STG_ЗаполнитьДанные(справочник, акт, индекс)
        ЕСЛИ имяФ = ф_ЖурналРасчетов ТО
          поз = sql0.НАЙТИ_ПОЗ("ID_CALC", sql.ПОЛЕ("ID_CALC"), "ID_AREA", sql.ПОЛЕ("ID_AREA"))
          ЕСЛИ поз > 0 ТО
            sql0.ПЕРЕЙТИ(поз)
            sql0.STG_ДобЗначРасчет2(СТР_ЗНАЧ(sql.ПОЛЕ("ID_RECSITE")))
          КОНЕЦ_ЕСЛИ
        КОНЕЦ_ЕСЛИ
        //выполняем доб/изм
        СТОП_ВСЕ
        ЕСЛИ акт = "д" ТО
          лог = STG_ДобавитьНаСайт(справочник)
        ИНАЧЕ
          лог = STG_ИзменитьНаСайте(справочник)
        КОНЕЦ_ЕСЛИ
        //
        ЕСЛИ лог ТО //синхронизируем
          ЕСЛИ справочник = к_спрСайтаВладельцы ТО
            г_выгруженВладелец!индекс = ДА
            г_выгруженВладелецИд[sql.ПОЛЕ("ID")] = ДА
          КОНЕЦ_ЕСЛИ
          резСинхр = sql_src.STG_ОбработатьОтвет(справочник)
          
          STG_СтрокаРезультат(имяСпр, sql.ПОЛЕ("DESCR"), действие, резСинхр И лог)
          
          ЕСЛИ резСинхр ТО
            сп.ОЧИСТИТЬ
            сп.ДОБАВИТЬ("DELETE FROM")
            сп.ДОБАВИТЬ("'" + файлВыгрузки + "'")
            сп.ДОБАВИТЬ("WHERE CAT = '" + справочник + "' AND ACT = '" + акт + "' AND ID = " + СТР_ЗНАЧ(sql.ПОЛЕ("ID")))
            SQL_ЗАПРОС(сп)
          КОНЕЦ_ЕСЛИ
        КОНЕЦ_ЕСЛИ
        //очищаем переменные
        STG_СбросИндексов(справочник)
      КОНЕЦ_ЦИКЛА
      sql.ЗАКРЫТЬ
      ЕСЛИ имяФ = ф_ЖурналРасчетов ТО
        sql0.ЗАКРЫТЬ
      КОНЕЦ_ЕСЛИ
    КОНЕЦ_ЦИКЛА
  КОНЕЦ_ЕСЛИ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ STG_ДобавитьЭлДоб(ТИП_СТРОКА: справочник; ТИП_ЧИСЛО: ид) //добавление и удаление
  ВЫБОР(справочник)
   #к_спрСайтаВладельцы : SPR_OWNERS_эл_доб!ид = НЕТ
   #к_спрСайтаУчастки : SPR_OBJECTS_эл_доб!ид = НЕТ
   #к_спрСайтаФЛС : SPR_FLS_эл_доб!ид = НЕТ
   #к_спрСайтаСвязи : SPR_LINK_ALL_эл_доб!ид = НЕТ
   #к_спрСайтаВзносы : SPR_VZNOSI_эл_доб!ид = НЕТ
   #к_спрСайтаТарифы : SPR_TARIF_эл_доб!ид = НЕТ
   #к_спрСайтаИПУ : SPR_SHETCH_эл_доб!ид = НЕТ
   #к_спрСайтаПоказания : POK_SCH_эл_доб!ид = НЕТ
   #к_спрСайтаЖурнал : SPR_REGISTER_эл_доб!ид = НЕТ
   #к_спрСайтаРасчеты : SPR_CALC_REG_эл_доб!ид = НЕТ
   #к_спрСайтаОстатки : SPR_DEBTS_эл_доб!ид = НЕТ
   #к_спрСайтаГолосования: MP_POLL_эл_доб!ид = НЕТ
   #к_спрСайтаВопросы: MP_QUESTION_эл_доб!ид = НЕТ
   #к_спрСайтаОтветы: MP_ANSWER_эл_доб!ид = НЕТ
  КОНЕЦ_ВЫБОРА
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ ТИП_ЧИСЛО: STG_КолЭлДоб(ТИП_СТРОКА: справочник) //добавление и удаление
  РЕЗУЛЬТАТ = 0
  ВЫБОР(справочник)
   #к_спрСайтаВладельцы : РЕЗУЛЬТАТ = КОЛ_ЭЛЕМ(SPR_OWNERS_эл_доб)
   #к_спрСайтаУчастки : РЕЗУЛЬТАТ = КОЛ_ЭЛЕМ(SPR_OBJECTS_эл_доб)
   #к_спрСайтаФЛС : РЕЗУЛЬТАТ = КОЛ_ЭЛЕМ(SPR_FLS_эл_доб)
   #к_спрСайтаСвязи : РЕЗУЛЬТАТ = КОЛ_ЭЛЕМ(SPR_LINK_ALL_эл_доб)
   #к_спрСайтаВзносы : РЕЗУЛЬТАТ = КОЛ_ЭЛЕМ(SPR_VZNOSI_эл_доб)
   #к_спрСайтаТарифы : РЕЗУЛЬТАТ = КОЛ_ЭЛЕМ(SPR_TARIF_эл_доб)
   #к_спрСайтаИПУ : РЕЗУЛЬТАТ = КОЛ_ЭЛЕМ(SPR_SHETCH_эл_доб)
   #к_спрСайтаПоказания : РЕЗУЛЬТАТ = КОЛ_ЭЛЕМ(POK_SCH_эл_доб)
   #к_спрСайтаЖурнал : РЕЗУЛЬТАТ = КОЛ_ЭЛЕМ(SPR_REGISTER_эл_доб)
   #к_спрСайтаРасчеты : РЕЗУЛЬТАТ = КОЛ_ЭЛЕМ(SPR_CALC_REG_эл_доб)
   #к_спрСайтаОстатки : РЕЗУЛЬТАТ = КОЛ_ЭЛЕМ(SPR_DEBTS_эл_доб)
   #к_спрСайтаГолосования: РЕЗУЛЬТАТ = КОЛ_ЭЛЕМ(MP_POLL_эл_доб)
   #к_спрСайтаВопросы: РЕЗУЛЬТАТ = КОЛ_ЭЛЕМ(MP_QUESTION_эл_доб)
   #к_спрСайтаОтветы: РЕЗУЛЬТАТ = КОЛ_ЭЛЕМ(MP_ANSWER_эл_доб)
  КОНЕЦ_ВЫБОРА
  STG_КолЭлДоб = РЕЗУЛЬТАТ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ STG_ДобавитьЭлИд(ТИП_СТРОКА: справочник, ид) //изменение
  ВЫБОР(справочник)
   #к_спрСайтаВладельцы : SPR_OWNERS_эл_id!ид = ид
   #к_спрСайтаУчастки : SPR_OBJECTS_эл_id!ид = ид
   #к_спрСайтаФЛС : SPR_FLS_эл_id!ид = ид
   #к_спрСайтаСвязи : SPR_LINK_ALL_эл_id!ид = ид
   #к_спрСайтаВзносы : SPR_VZNOSI_эл_id!ид = ид
   #к_спрСайтаТарифы : SPR_TARIF_эл_id!ид = ид
   #к_спрСайтаИПУ : SPR_SHETCH_эл_id!ид = ид
   #к_спрСайтаПоказания : POK_SCH_эл_id!ид = ид
   #к_спрСайтаЖурнал : SPR_REGISTER_эл_id!ид = ид
   #к_спрСайтаРасчеты : SPR_CALC_REG_эл_id!ид = ид
   #к_спрСайтаОстатки : SPR_DEBTS_эл_id!ид = ид
   #к_спрСайтаРеквизиты : SPR_REKV_эл_id!ид = ид
   #к_спрСайтаНастройки: SPR_SETS_эл_id!ид = ид
   #к_спрСайтаГолосования: MP_POLL_эл_id!ид = ид
   #к_спрСайтаВопросы: MP_QUESTION_эл_id!ид = ид
   #к_спрСайтаОтветы: MP_ANSWER_эл_id!ид = ид
   #к_спрСайтаРезультаты: MP_RESULT_эл_id!ид = ид
  КОНЕЦ_ВЫБОРА
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ ТИП_SQL STG_ЗаполнитьДанные(ТИП_СТРОКА: справочник, акт; ПЕРЕМ ТИП_СТРОКА: индекс)
  ВЫБОР(справочник)
   #к_спрСайтаВладельцы : 
    ЕСЛИ акт = "д" ТО
      индекс = СТР_ЗНАЧ(ПОЛЕ("ID_RECSITE"))
      STG_ДобЗначВладельцы(индекс)
    ИНАЧЕ
      STG_ИзмЗначВладельцы(СТР_ЗНАЧ(ПОЛЕ("ID_RECSITE")))
    КОНЕЦ_ЕСЛИ
   #к_спрСайтаУчастки : STG_ДобЗначУчастки(СТР_ЗНАЧ(ПОЛЕ("ID_RECSITE")))
   #к_спрСайтаФЛС : STG_ДобЗначФЛС(СТР_ЗНАЧ(ПОЛЕ("ID_RECSITE")))
   #к_спрСайтаСвязи : STG_ДобЗначСвязи(СТР_ЗНАЧ(ПОЛЕ("ID_RECSITE")))
   #к_спрСайтаВзносы : STG_ДобЗначВзносы(СТР_ЗНАЧ(ПОЛЕ("ID_RECSITE")))
   #к_спрСайтаТарифы : STG_ДобЗначТарифы(СТР_ЗНАЧ(ПОЛЕ("ID_RECSITE")))
   #к_спрСайтаИПУ : STG_ДобЗначИПУ(СТР_ЗНАЧ(ПОЛЕ("ID_RECSITE")))
   #к_спрСайтаПоказания : STG_ДобЗначПоказания(СТР_ЗНАЧ(ПОЛЕ("ID_RECSITE")))
   #к_спрСайтаЖурнал : STG_ДобЗначЖурнал(СТР_ЗНАЧ(ПОЛЕ("ID_RECSITE")))
   #к_спрСайтаРасчеты : //STG_ДобЗначРасчеты(СТР_ЗНАЧ(ПОЛЕ("ID_RECSITE")))
                        STG_ДобЗначРасчет1(СТР_ЗНАЧ(ПОЛЕ("ID_RECSITE")))
   #к_спрСайтаГолосования: STG_ДобЗначГолосования(СТР_ЗНАЧ(ПОЛЕ("ID_RECSITE")), акт)
                           ДобавитьЗначениеС(справочник, 
                                             СТР_ЗНАЧ(ПОЛЕ("ID_RECSITE")) + "|MP_POLL_uuid", 
                                             ПОЛЕ("UUID"))
   #к_спрСайтаВопросы: STG_ДобЗначВопросы(СТР_ЗНАЧ(ПОЛЕ("ID_RECSITE")), акт)
                       ДобавитьЗначениеС(справочник, 
                                         СТР_ЗНАЧ(ПОЛЕ("ID_RECSITE")) + "|MP_QUESTION_uuid", 
                                         ПОЛЕ("UUID"))
   #к_спрСайтаОтветы: STG_ДобЗначОтветы(СТР_ЗНАЧ(ПОЛЕ("ID_RECSITE")), акт)
                      ДобавитьЗначениеС(справочник, 
                                        СТР_ЗНАЧ(ПОЛЕ("ID_RECSITE")) + "|MP_ANSWER_uuid", 
                                        ПОЛЕ("UUID"))
  КОНЕЦ_ВЫБОРА
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ ТИП_SQL STG_УдалитьССайта
  РЕЗУЛЬТАТ = НЕТ
  ВЫБОР(ПОЛЕ("CAT"))
   #к_спрСайтаВладельцы : 
    SPR_OWNERS_id = ПОЛЕ("ID")
    РЕЗУЛЬТАТ = SPR_OWNERS_Удалить
   #к_спрСайтаУчастки : 
    SPR_OBJECTS_id = ПОЛЕ("ID")
    РЕЗУЛЬТАТ = SPR_OBJECTS_Удалить
   #к_спрСайтаФЛС : 
    SPR_FLS_id = ПОЛЕ("ID")
    РЕЗУЛЬТАТ = SPR_FLS_Удалить
   #к_спрСайтаСвязи : 
    SPR_LINK_ALL_id = ПОЛЕ("ID")
    РЕЗУЛЬТАТ = SPR_LINK_ALL_Удалить
   #к_спрСайтаВзносы : 
    SPR_VZNOSI_id = ПОЛЕ("ID")
    РЕЗУЛЬТАТ = SPR_VZNOSI_Удалить
   #к_спрСайтаТарифы : 
    SPR_TARIF_id = ПОЛЕ("ID")
    РЕЗУЛЬТАТ = SPR_TARIF_Удалить
   #к_спрСайтаИПУ : 
    SPR_SHETCH_id = ПОЛЕ("ID")
    РЕЗУЛЬТАТ = SPR_SHETCH_Удалить
   #к_спрСайтаПоказания : 
    POK_SCH_id = ПОЛЕ("ID")
    РЕЗУЛЬТАТ = POK_SCH_Удалить
   #к_спрСайтаЖурнал :
    SPR_REGISTER_id = ПОЛЕ("ID") 
    РЕЗУЛЬТАТ = SPR_REGISTER_Удалить
   #к_спрСайтаРасчеты : 
    SPR_CALC_REG_id = ПОЛЕ("ID")
    РЕЗУЛЬТАТ = SPR_CALC_REG_Удалить
   #к_спрСайтаГолосования: 
    MP_POLL_id = ПОЛЕ("ID")
    РЕЗУЛЬТАТ = MP_POLL_Удалить
   #к_спрСайтаВопросы:
    MP_QUESTION_id = ПОЛЕ("ID")
    РЕЗУЛЬТАТ = MP_QUESTION_Удалить
   #к_спрСайтаОтветы:
    MP_ANSWER_id = ПОЛЕ("ID")
    РЕЗУЛЬТАТ = MP_ANSWER_Удалить
  КОНЕЦ_ВЫБОРА
  STG_УдалитьССайта = РЕЗУЛЬТАТ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ ТИП_ЛОГИКА: STG_ДобавитьНаСайт(ТИП_СТРОКА: справочник)
  ВЫБОР(справочник)
   #к_спрСайтаВладельцы : РЕЗУЛЬТАТ = SPR_OWNERS_ДобавитьМнож(НЕТ)
   #к_спрСайтаУчастки : РЕЗУЛЬТАТ = SPR_OBJECTS_ДобавитьМнож(НЕТ)
   #к_спрСайтаФЛС : РЕЗУЛЬТАТ = SPR_FLS_ДобавитьМнож(НЕТ)
   #к_спрСайтаСвязи : РЕЗУЛЬТАТ = SPR_LINK_ALL_ДобавитьМнож(НЕТ)
   #к_спрСайтаВзносы : РЕЗУЛЬТАТ = SPR_VZNOSI_ДобавитьМнож(НЕТ)
   #к_спрСайтаТарифы : РЕЗУЛЬТАТ = SPR_TARIF_ДобавитьМнож(НЕТ)
   #к_спрСайтаИПУ : РЕЗУЛЬТАТ = SPR_SHETCH_ДобавитьМнож(НЕТ)
   #к_спрСайтаПоказания : РЕЗУЛЬТАТ = POK_SCH_ДобавитьМнож(НЕТ)
   #к_спрСайтаЖурнал : РЕЗУЛЬТАТ = SPR_REGISTER_ДобавитьМнож(НЕТ)
   #к_спрСайтаРасчеты : РЕЗУЛЬТАТ = SPR_CALC_REG_ДобавитьМнож(НЕТ)
   #к_спрСайтаГолосования: РЕЗУЛЬТАТ = MP_POLL_ДобавитьМнож(НЕТ)
   #к_спрСайтаВопросы: РЕЗУЛЬТАТ = MP_QUESTION_ДобавитьМнож(НЕТ)
   #к_спрСайтаОтветы: РЕЗУЛЬТАТ = MP_ANSWER_ДобавитьМнож(НЕТ)
  КОНЕЦ_ВЫБОРА
  STG_ДобавитьНаСайт = РЕЗУЛЬТАТ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ ТИП_ЛОГИКА: STG_ИзменитьНаСайте(ТИП_СТРОКА: справочник)
  ВЫБОР(справочник)
   #к_спрСайтаВладельцы : РЕЗУЛЬТАТ = SPR_OWNERS_ИзменитьМнож(НЕТ)
   #к_спрСайтаУчастки : РЕЗУЛЬТАТ = SPR_OBJECTS_ИзменитьМнож(НЕТ)
   #к_спрСайтаФЛС : РЕЗУЛЬТАТ = SPR_FLS_ИзменитьМнож(НЕТ)
   #к_спрСайтаСвязи : РЕЗУЛЬТАТ = SPR_LINK_ALL_ИзменитьМнож(НЕТ)
   #к_спрСайтаВзносы : РЕЗУЛЬТАТ = SPR_VZNOSI_ИзменитьМнож(НЕТ)
   #к_спрСайтаТарифы : РЕЗУЛЬТАТ = SPR_TARIF_ИзменитьМнож(НЕТ)
   #к_спрСайтаИПУ : РЕЗУЛЬТАТ = SPR_SHETCH_ИзменитьМнож(НЕТ)
   #к_спрСайтаПоказания : РЕЗУЛЬТАТ = POK_SCH_ИзменитьМнож(НЕТ)
   #к_спрСайтаЖурнал : РЕЗУЛЬТАТ = SPR_REGISTER_ИзменитьМнож(НЕТ)
   #к_спрСайтаРасчеты : РЕЗУЛЬТАТ = SPR_CALC_REG_ИзменитьМнож(НЕТ)
   #к_спрСайтаГолосования: РЕЗУЛЬТАТ = MP_POLL_ИзменитьМнож(ДА)
   #к_спрСайтаВопросы: РЕЗУЛЬТАТ = MP_QUESTION_ИзменитьМнож(ДА)
   #к_спрСайтаОтветы: РЕЗУЛЬТАТ = MP_ANSWER_ИзменитьМнож(ДА)
