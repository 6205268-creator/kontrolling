//-------------------------------------------------------------------------------------------------------------------------//
ПЕРЕМ stg_полеLabelПоGUID!
ФУНКЦИЯ ТИП_SQL STG_ДобЗначГолосования(ТИП_СТРОКА: инд, акт) //все значения
  спр = к_спрСайтаГолосования
  ДобавитьЗначениеС(спр, инд + "|MP_POLL_type", "multipoll_poll--multipoll_poll")
  ЕСЛИ акт = "д" ТО
    guid = НОВЫЙ_GUID
    stg_полеLabelПоGUID[guid] = ПОЛЕ("id_db")
    ДобавитьЗначениеС(спр, инд + "|MP_POLL_label", guid)
  ИНАЧЕ
    ДобавитьЗначениеС(спр, инд + "|MP_POLL_label", ПОЛЕ("label"))
  КОНЕЦ_ЕСЛИ
  ДобавитьЗначениеС(спр, инд + "|MP_POLL_description", ПОЛЕ("dscrptn"))
  
  ДобавитьЗначениеЛ(спр, инд + "|MP_POLL_multipoll_poll_type", ПОЛЕ("mppltype"))
  ДобавитьЗначениеЛ(спр, инд + "|MP_POLL_status", ПОЛЕ("status"))
  ДобавитьЗначениеС(спр, инд + "|MP_POLL_pollactiveuntil", ПОЛЕ("pllctvnt"))
  
  ЕСЛИ IB_CONTEXT_СчитатьЛок("синхронизацияСайта") = "" ТО
    ДобавитьЗначениеЛ(спр, инд + "|MP_POLL_is_synced", НЕТ)
  ИНАЧЕ
    ДобавитьЗначениеЛ(спр, инд + "|MP_POLL_is_synced", ДА)
  КОНЕЦ_ЕСЛИ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ ТИП_SQL STG_ДобЗначВопросы(ТИП_СТРОКА: инд, акт) //все значения
  спр = к_спрСайтаВопросы
  ДобавитьЗначениеС(спр, инд + "|MP_QUESTION_type", "multipoll_question--multipoll_question")
  ЕСЛИ акт = "д" ТО
    guid = НОВЫЙ_GUID
    stg_полеLabelПоGUID[guid] = ПОЛЕ("id_db")
    ДобавитьЗначениеС(спр, инд + "|MP_QUESTION_label", guid)
  ИНАЧЕ
    ДобавитьЗначениеС(спр, инд + "|MP_QUESTION_label", ПОЛЕ("label"))
  КОНЕЦ_ЕСЛИ
  
  ДобавитьЗначениеЛ(спр, инд + "|MP_QUESTION_status", ПОЛЕ("status"))
  ДобавитьЗначениеЛ(спр, инд + "|MP_QUESTION_mp_quest_type", ПОЛЕ("mpqstype"))
  ДобавитьЗначениеС(спр, инд + "|MP_QUESTION_poll_id", ПОЛЕ("poll_id"))
  
  ЕСЛИ IB_CONTEXT_СчитатьЛок("синхронизацияСайта") = "" ТО
    ДобавитьЗначениеЛ(спр, инд + "|MP_QUESTION_is_synced", НЕТ)
  ИНАЧЕ
    ДобавитьЗначениеЛ(спр, инд + "|MP_QUESTION_is_synced", ДА)
  КОНЕЦ_ЕСЛИ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ ТИП_SQL STG_ДобЗначОтветы(ТИП_СТРОКА: инд, акт) //все значения
  спр = к_спрСайтаОтветы
  ДобавитьЗначениеС(спр, инд + "|MP_ANSWER_type", "multipoll_answer--multipoll_answer")
  ЕСЛИ акт = "д" ТО
    guid = НОВЫЙ_GUID
    stg_полеLabelПоGUID[guid] = ПОЛЕ("id_db")
    ДобавитьЗначениеС(спр, инд + "|MP_ANSWER_label", guid)
  ИНАЧЕ
    ДобавитьЗначениеС(спр, инд + "|MP_ANSWER_label", ПОЛЕ("label"))
  КОНЕЦ_ЕСЛИ
  
  ДобавитьЗначениеЛ(спр, инд + "|MP_ANSWER_status", ПОЛЕ("status"))
  ДобавитьЗначениеС(спр, инд + "|MP_ANSWER_question_id", ПОЛЕ("quest_id"))
  
  ЕСЛИ IB_CONTEXT_СчитатьЛок("синхронизацияСайта") = "" ТО
    ДобавитьЗначениеЛ(спр, инд + "|MP_ANSWER_is_synced", НЕТ)
  ИНАЧЕ
    ДобавитьЗначениеЛ(спр, инд + "|MP_ANSWER_is_synced", ДА)
  КОНЕЦ_ЕСЛИ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
//синхронизация голосований после получения
ФУНКЦИЯ STG_СинхрГолосПослеПолуч
  СТРОКА_СТАТУСА("Синхронизация голосований")
  
  СБРОС(MP_POLL_эл_знач, MP_POLL_эл_изм, MP_POLL_эл_id)
  
  ЕСЛИ КОЛ_ЭЛЕМ(mp_p_uuid) > 0 ТО
    ЦИКЛ ИНДЕКС(лог = mp_p_uuid!идЭлемента)
      MP_POLL_эл_знач[идЭлемента + "|MP_POLL_uuid"] = mp_p_uuid!идЭлемента
      
      STG_ДобавитьЭлИд(к_спрСайтаГолосования, идЭлемента)
      ДобавитьЗначениеС(к_спрСайтаГолосования, идЭлемента + "|MP_POLL_type", "multipoll_poll--multipoll_poll")
      ДобавитьЗначениеЛ(к_спрСайтаГолосования, идЭлемента + "|MP_POLL_is_synced", ДА)
    КОНЕЦ_ЦИКЛА
  КОНЕЦ_ЕСЛИ
  
  MP_POLL_ИзменитьМнож(ДА)
  
  СТРОКА_СТАТУСА("")
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
//синхронизация голосований после получения
ФУНКЦИЯ STG_СинхрВопросыПослеПолуч
  СТРОКА_СТАТУСА("Синхронизация вопросов")
  
  СБРОС(MP_QUESTION_эл_знач, MP_QUESTION_эл_изм, MP_QUESTION_эл_id)
  
  ЕСЛИ КОЛ_ЭЛЕМ(mp_q_uuid) > 0 ТО
    ЦИКЛ ИНДЕКС(лог = mp_q_uuid!идЭлемента)
      MP_QUESTION_эл_знач[идЭлемента + "|MP_QUESTION_uuid"] = mp_q_uuid!идЭлемента
      
      STG_ДобавитьЭлИд(к_спрСайтаВопросы, идЭлемента)
      ДобавитьЗначениеС(к_спрСайтаВопросы, идЭлемента + "|MP_QUESTION_type", "multipoll_question--multipoll_question")
      ДобавитьЗначениеЛ(к_спрСайтаВопросы, идЭлемента + "|MP_QUESTION_is_synced", ДА)
    КОНЕЦ_ЦИКЛА
    
    MP_QUESTION_ИзменитьМнож(ДА)
  КОНЕЦ_ЕСЛИ
  
  СТРОКА_СТАТУСА("")
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
//синхронизация голосований после получения
ФУНКЦИЯ STG_СинхрОтветыПослеПолуч
  СТРОКА_СТАТУСА("Синхронизация ответов")
  
  СБРОС(MP_ANSWER_эл_знач, MP_ANSWER_эл_изм, MP_ANSWER_эл_id)
  
  ЕСЛИ КОЛ_ЭЛЕМ(mp_a_uuid) > 0 ТО
    ЦИКЛ ИНДЕКС(лог = mp_a_uuid!идЭлемента)
      MP_ANSWER_эл_знач[идЭлемента + "|MP_ANSWER_uuid"] = mp_a_uuid!идЭлемента
      
      STG_ДобавитьЭлИд(к_спрСайтаОтветы, идЭлемента)
      ДобавитьЗначениеС(к_спрСайтаОтветы, идЭлемента + "|MP_ANSWER_type", "multipoll_answer--multipoll_answer")
      ДобавитьЗначениеЛ(к_спрСайтаОтветы, идЭлемента + "|MP_ANSWER_is_synced", ДА)
    КОНЕЦ_ЦИКЛА
    
    MP_ANSWER_ИзменитьМнож(ДА)
  КОНЕЦ_ЕСЛИ
  
  СТРОКА_СТАТУСА("")
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
//синхронизация голосований после получения
ФУНКЦИЯ STG_СинхрРезультатыПослеПолуч
  СТРОКА_СТАТУСА("Синхронизация результатов")
  
  СБРОС(MP_RESULT_эл_знач, MP_RESULT_эл_изм, MP_RESULT_эл_id)
  
  ЕСЛИ КОЛ_ЭЛЕМ(mp_r_uuid) > 0 ТО
    ЦИКЛ ИНДЕКС(лог = mp_r_uuid!идЭлемента)
      MP_RESULT_эл_знач[идЭлемента + "|MP_RESULT_uuid"] = mp_r_uuid!идЭлемента
      
      STG_ДобавитьЭлИд(к_спрСайтаРезультаты, идЭлемента)
      ДобавитьЗначениеС(к_спрСайтаРезультаты, идЭлемента + "|MP_RESULT_type", "multipoll_result--multipoll_result")
      ДобавитьЗначениеЛ(к_спрСайтаРезультаты, идЭлемента + "|MP_RESULT_is_synced", ДА)
    КОНЕЦ_ЦИКЛА
    
    MP_RESULT_ИзменитьМнож(ДА)
  КОНЕЦ_ЕСЛИ
  
  СТРОКА_СТАТУСА("")
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ ТИП_ЛОГИКА: STG_РедПрофилейСпр(ПЕРЕМ ТИП_СТРОКА: стр)
  sql = SQL_ОТКРЫТЬ(ф_ПрофилиВыгрузкиСпр)
  
  т = БД_РЕДАКТОР(sql, "Профили выгрузки",
                  [ "NAME"   : "Справочник"                      : 35,
                    "USE"    : "Исп." + СИМВ(13) + "настр."      : 11,
                    //"PROT_A" : "Протокол" + СИМВ(13) + "доб."    : 10,
                    "SUBR_A" : "Исп. subreq" + СИМВ(13) + "доб." : 11,
                    "QTY_A"  : "Доб. за" + СИМВ(13) + " раз"     : 7,
                    "PROT_D" : "Протокол" + СИМВ(13) + "уд."     : 10,
                    "SUBR_D" : "Исп. subreq" + СИМВ(13) + "уд."  : 11,
                    "QTY_D"  : "Уд. за" + СИМВ(13) + " раз"      : 6
                  ], 
                  ДА, НЕТ, НЕТ, ДА,
                  [
                   М   : ("ST_GSK\ST_GSK_WEBSITE", "STG_ПрофилиСпрОбрМИзм")
                  ]; 
                  яч_курсор = ДА)
                  
  sql.ЗАКРЫТЬ
КОНЕЦ_ФУНКЦИИ

ФУНКЦИЯ ТИП_ЛОГИКА: STG_ПрофилиСпрОбрМИзм(ПЕРЕМ ТИП_СТРОКА: стр)
  текСтлб = РЕД_ПОЛЕ("#ТЕК_СТОЛБЕЦ")
  знач = РЕД_ПОЛЕ(текСтлб)
  
  ВЫБОР(текСтлб) 
   #"PROT_A", "PROT_D":
    УСТ_РЕД_ПОЛЕ(текСтлб, ?(знач = "REST", "JSONAPI", "REST"))
    
   #"SUBR_A", "SUBR_D", "USE": 
    УСТ_РЕД_ПОЛЕ(текСтлб, ?(знач = ДА, НЕТ, ДА))
    
   #"QTY_A", "QTY_D": 
    значВвода = ВВОД_ЗНАЧЕНИЯ("Введите название голосования:", знач)
    РЕЗУЛЬТАТ = (АТРИБУТ("результат_диалога") = "ДА") И знач <> значВвода
    ЕСЛИ РЕЗУЛЬТАТ ТО
      УСТ_РЕД_ПОЛЕ(текСтлб, значВвода)
    КОНЕЦ_ЕСЛИ
  КОНЕЦ_ВЫБОРА
  
  STG_ПрофилиСпрОбрМИзм = ДА
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ПЕРЕМ stg_профилиВыгрузкиСпр!
ФУНКЦИЯ STG_СчитатьПрофилиВыгрузкиСпр
  СБРОС(stg_профилиВыгрузкиСпр)
  
  sql = SQL_ОТКРЫТЬ(ф_ПрофилиВыгрузкиСпр)
  
  ЦИКЛ ДЛЯ(и = 1, sql.ВСЕГО)
    sql.ПЕРЕЙТИ(и)
    
    спр = sql.ПОЛЕ("NAME")

    ЕСЛИ sql.ПОЛЕ("USE") ТО
      stg_профилиВыгрузкиСпр!спр!"_subreq_add" = sql.ПОЛЕ("SUBR_A")
      stg_профилиВыгрузкиСпр!спр!"_qty_add" = sql.ПОЛЕ("QTY_A")
      //stg_профилиВыгрузкиСпр!спр!"_prot_add" = sql.ПОЛЕ("PROT_A")
      stg_профилиВыгрузкиСпр!спр!"_subreq_del" = sql.ПОЛЕ("SUBR_D")
      stg_профилиВыгрузкиСпр!спр!"_qty_del" = sql.ПОЛЕ("QTY_D")
      stg_профилиВыгрузкиСпр!спр!"_prot_del" = sql.ПОЛЕ("PROT_D")
    ИНАЧЕ
      stg_профилиВыгрузкиСпр!спр!"_subreq_add" = оп_подзапрДобавление
      stg_профилиВыгрузкиСпр!спр!"_qty_add" = гр_колПодЗапрДоб
      //stg_профилиВыгрузкиСпр!спр!"_prot_add" = гр_протоколДоб
      stg_профилиВыгрузкиСпр!спр!"_subreq_del" = оп_подзапрУдаление
      stg_профилиВыгрузкиСпр!спр!"_qty_del" = гр_колПодЗапрУд
      stg_профилиВыгрузкиСпр!спр!"_prot_del" = гр_протоколУд
    КОНЕЦ_ЕСЛИ
  КОНЕЦ_ЦИКЛА
  
  sql.ЗАКРЫТЬ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ ТИП_ЛОГИКА: STG_ПрофильВыгрузки(ПЕРЕМ ТИП_СТРОКА: стр)
  стр = ?(стр = "REST", "JSONAPI", "REST")
  STG_ПрофильВыгрузки = ДА
КОНЕЦ_ФУНКЦИИ

