//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ ТИП_ЛОГИКА: STG_ИниПечатьПО
  ЕСЛИ НЕ г_былаИниПечатьПо ТО
    STG_ПарамВыводаТаблиц //не стандартная!
    ВыводИт = НЕТ
    г_былаИниПечатьПо = ДА
  ИНАЧЕ
    STG_ИниПечатьПО = ДА
  КОНЕЦ_ЕСЛИ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ STG_ДобавитьСтрокуПО(ТИП_СТРОКА: дебет, кодСтрПодр, коррСч, кодАналитУчета, кодЦелНазн;
                                  ТИП_ЧИСЛО: сумма)
  STG_ИниПечатьПО
  ВсегоСтр++
  г_ВсегоСтрокПКО++
  г_строкаПО!ВсегоСтр!"A" = дебет
  г_строкаПО!ВсегоСтр!"B" = " "
  г_строкаПО!ВсегоСтр!"C" = кодСтрПодр
  г_строкаПО!ВсегоСтр!"D" = коррСч
  г_строкаПО!ВсегоСтр!"E" = кодАналитУчета
  г_строкаПО!ВсегоСтр!"F" = сумма
  г_строкаПО!ВсегоСтр!"G" = кодЦелНазн
  г_строкаПО!ВсегоСтр!"H" = " "
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ STG_СбросСтрокПО
  СБРОС(г_строкаПО, Данные) //Данные из TBLPRINT
  ВсегоСтр = 0
  г_ВсегоСтрокПКО = 0
  г_былаИниПечатьПо = НЕТ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
//-------------------------------------------------------------------------------------------------------------------------//
//выгрузка платежек в док и отправка их по почте
ФУНКЦИЯ ТИП_ЛОГИКА: STG_ВыгрузитьИОтправитьПД(ТИП_СТРОКА: получательНомерСчета, получательНаимБанка, получательКоррСчет, получательБИК, 
                                                          получательНаим, получательКПП, получательИНН,
                                                          наимПлатежа, плательщикФИО, плательщикФЛС, плательщикАдрес, едИзм, периодКвит;
                                               ТИП_ЧИСЛО: суммаПлатежа;
                                               ТИП_СТРОКА: eMail, формаПД, имяФайла, действие)
  отправлятьПочту = НЕТ
  ЕСЛИ ПараметрПечатиПД!"Отправлять письма" ТО
    ЕСЛИ STG_ОчиститьДирКвит И IB_MAIL_ВозможноОтправить ТО
      ЕСЛИ eMail <> "" ТО
        отправлятьПочту = ДА
      ИНАЧЕ
        IB_PROTOCOL_ДобавитьОшибку("Не удалось отправить письмо.", 
                                   "Не указан адрес электронной почты у " + плательщикФИО + " для ФЛС №" + плательщикФЛС + ".")
      КОНЕЦ_ЕСЛИ
    КОНЕЦ_ЕСЛИ
    ЕСЛИ действие = "почта" И НЕ отправлятьПочту ТО
      ВЫХОД
    КОНЕЦ_ЕСЛИ
  КОНЕЦ_ЕСЛИ
  
  СБРОС(списокОжидаемыхЗамен, списокОжидаемыхЗаменТ, списокОжидаемыхТаблиц, списокСтрокТаблицы, колСтрокТаблицы)
  СБРОС_ПОДСТ
  
  ДобавитьПодстановку("%заголовок%", плательщикФИО + ", " + плательщикАдрес + ", " + плательщикФЛС)
  ВЫБОР(формаПД) 
   #к_ФормаПДМнож, к_ФормаПДМножЭЭСерв, к_ФормаПДМножВГСерв:
    ДобавитьПодстановку("%реквизитыПолучателя%", г_реквизитыПолучателя)
  ИНАЧЕ
    ДобавитьПодстановку("%получательИнн%", получательИНН)
    ДобавитьПодстановку("%получательНаим%", получательНаим)
    ДобавитьПодстановку("%получательНомерСчета%", получательНомерСчета)
    ДобавитьПодстановку("%получательНаимБанка%", получательНаимБанка)
    ДобавитьПодстановку("%получательКоррСчет%", получательКоррСчет)
    ДобавитьПодстановку("%получательБИК%", получательБИК)
    ДобавитьПодстановку("%получательКПП%", получательКПП)
  КОНЕЦ_ВЫБОРА
  
  ДобавитьПодстановку("%плательщикФИО%", плательщикФИО)
  ДобавитьПодстановку("%плательщикАдрес%", плательщикАдрес)
  //
  ВЫБОР(формаПД)
   #к_ФормаПДМнож:
     форма = шаблонФормаПДСписок
     ЕСЛИ НЕ СУЩ_ФАЙЛ(форма) ТО
       ВЫХОД
     КОНЕЦ_ЕСЛИ
     //подстановка для формы для списка начислений
     ДобавитьПодстановку("%едИзм%", едИзм)
     ДобавитьПодстановку("%периодКвит%", периодКвит)
     ЦИКЛ ДЛЯ(стр = 1, ВсегоСтр)
       ДобавитьПодстановкуТ(стр, "%_т%", "%_т%", "")
       ДобавитьПодстановкуТ(стр, "%_т%", "%наименование%", Данные!стр!"A")
       ДобавитьПодстановкуТ(стр, "%_т%", "%тариф%", STG_ЧислоВСтрОтч(Данные!стр!"B"))
       ДобавитьПодстановкуТ(стр, "%_т%", "%площадь%", STG_ЧислоВСтрОтч(Данные!стр!"C"))
       ДобавитьПодстановкуТ(стр, "%_т%", "%сальдо%", STG_ЧислоВСтрОтч(Данные!стр!"D"))
       ДобавитьПодстановкуТ(стр, "%_т%", "%сумма%", STG_ЧислоВСтрОтч(Данные!стр!"E"))
       
       ДобавитьПодстановкуТ(стр, "%_т1%", "%_т1%", "")
       ДобавитьПодстановкуТ(стр, "%_т1%", "%наименование%", Данные!стр!"A")
       ДобавитьПодстановкуТ(стр, "%_т1%", "%тариф%", STG_ЧислоВСтрОтч(Данные!стр!"B"))
       ДобавитьПодстановкуТ(стр, "%_т1%", "%площадь%", STG_ЧислоВСтрОтч(Данные!стр!"C"))
       ДобавитьПодстановкуТ(стр, "%_т1%", "%сальдо%", STG_ЧислоВСтрОтч(Данные!стр!"D"))
       ДобавитьПодстановкуТ(стр, "%_т1%", "%сумма%", STG_ЧислоВСтрОтч(Данные!стр!"E"))
     КОНЕЦ_ЦИКЛА
     ДобавитьПодстановку("%итого%", STG_ЧислоВСтрОтч(суммаПлатежа))
   #к_ФормаПД4, к_ФормаПД4ЭЭСерв, к_ФормаПД4ВГСерв : //надо прокинуть сервисные
     форма = ?(формаПД = к_ФормаПД4, 
               шаблонФормаПД4Старая, 
               ?(формаПД = к_ФормаПД4ЭЭСерв, шаблонФормаПД4ЭЭ, шаблонФормаПД4ВГ))
     ЕСЛИ НЕ СУЩ_ФАЙЛ(форма) ТО
       ВЫХОД
     КОНЕЦ_ЕСЛИ
               
     ДобавитьПодстановку("%наимПлатежа%", наимПлатежа)
     //ДобавитьПодстановку("%плательщикФЛС%", плательщикФЛС)
     ДобавитьПодстановку("%руб%", СТР_ЗНАЧ(РУБ(суммаПлатежа)))
     ДобавитьПодстановку("%коп%", СТР0(КОП(суммаПлатежа),2))
     ЕСЛИ формаПД <> к_ФормаПД4 ТО
       ЦИКЛ ДЛЯ(стр = 1, ВсегоСтр)
         ДобавитьПодстановкуТ(стр, "%_т%", "%_т%", "")
         ДобавитьПодстановкуТ(стр, "%_т%", "%наименование%", Данные!стр!"A")
         ДобавитьПодстановкуТ(стр, "%_т%", "%предПок%", STG_ЧислоВСтрОтч(Данные!стр!"B"))
         ДобавитьПодстановкуТ(стр, "%_т%", "%текПок%", ?(Данные!стр!"C" = 0, "", STG_ЧислоВСтрОтч(Данные!стр!"C")))
         ДобавитьПодстановкуТ(стр, "%_т%", "%расход%", ?(Данные!стр!"D" = 0, "", STG_ЧислоВСтрОтч(Данные!стр!"D")))
         ДобавитьПодстановкуТ(стр, "%_т%", "%тариф%", ?(Данные!стр!"E" = 0, "", STG_ЧислоВСтрОтч(Данные!стр!"E")))
         ЕСЛИ формаПД = к_ФормаПД4ЭЭСерв ТО
           ДобавитьПодстановкуТ(стр, "%_т%", "%потери%", ?(Данные!стр!"G" = 0, "", STG_ЧислоВСтрОтч(Данные!стр!"G")))
           ДобавитьПодстановкуТ(стр, "%_т%", "%сумма%", ?(Данные!стр!"H" = 0, "", STG_ЧислоВСтрОтч(Данные!стр!"H")))
         ИНАЧЕ
           ДобавитьПодстановкуТ(стр, "%_т%", "%сумма%", ?(Данные!стр!"F" = 0, "", STG_ЧислоВСтрОтч(Данные!стр!"F")))
         КОНЕЦ_ЕСЛИ
       КОНЕЦ_ЦИКЛА
       ДобавитьПодстановку("%итого%", ?(суммаПлатежа = 0, "", STG_ЧислоВСтрОтч(суммаПлатежа)))
     КОНЕЦ_ЕСЛИ
   #к_ФормаПДМножЭЭСерв, к_ФормаПДМножВГСерв:
      форма = ?(формаПД = к_ФормаПДМножЭЭСерв, шаблонФормаПДСписокЭЭ, шаблонФормаПДСписокВГ)
      ЕСЛИ НЕ СУЩ_ФАЙЛ(форма) ТО
        ВЫХОД
      КОНЕЦ_ЕСЛИ
      //подстановка для формы для списка начислений
      ДобавитьПодстановку("%едИзм%", едИзм)
      ДобавитьПодстановку("%периодКвит%", периодКвит)
      ЦИКЛ ДЛЯ(стр = 1, ВсегоСтр)
        ДобавитьПодстановкуТ(стр, "%_т%", "%_т%", "")
        ДобавитьПодстановкуТ(стр, "%_т%", "%наименование%", Данные!стр!"A")
        ДобавитьПодстановкуТ(стр, "%_т%", "%предПок%", STG_ЧислоВСтрОтч(Данные!стр!"B"))
        ДобавитьПодстановкуТ(стр, "%_т%", "%текПок%", ?(Данные!стр!"C" = 0, "", STG_ЧислоВСтрОтч(Данные!стр!"C")))
        ДобавитьПодстановкуТ(стр, "%_т%", "%расход%", ?(Данные!стр!"D" = 0, "", STG_ЧислоВСтрОтч(Данные!стр!"D")))
        ДобавитьПодстановкуТ(стр, "%_т%", "%тариф%", ?(Данные!стр!"E" = 0, "", STG_ЧислоВСтрОтч(Данные!стр!"E")))
        ЕСЛИ формаПД = к_ФормаПДМножЭЭСерв ТО
          ДобавитьПодстановкуТ(стр, "%_т%", "%начислено%", ?(Данные!стр!"F" = 0, "", STG_ЧислоВСтрОтч(Данные!стр!"F")))
          ДобавитьПодстановкуТ(стр, "%_т%", "%потери%", ?(Данные!стр!"G" = 0, "", STG_ЧислоВСтрОтч(Данные!стр!"G")))
          ДобавитьПодстановкуТ(стр, "%_т%", "%сумма%", ?(Данные!стр!"H" = 0, "", STG_ЧислоВСтрОтч(Данные!стр!"H")))
        ИНАЧЕ
          ДобавитьПодстановкуТ(стр, "%_т%", "%сумма%", ?(Данные!стр!"F" = 0, "", STG_ЧислоВСтрОтч(Данные!стр!"F")))
        КОНЕЦ_ЕСЛИ
        
        ДобавитьПодстановкуТ(стр, "%_т1%", "%_т1%", "")
        ДобавитьПодстановкуТ(стр, "%_т1%", "%наименование%", Данные!стр!"A")
        ДобавитьПодстановкуТ(стр, "%_т1%", "%предПок%", STG_ЧислоВСтрОтч(Данные!стр!"B"))
        ДобавитьПодстановкуТ(стр, "%_т1%", "%текПок%", ?(Данные!стр!"C" = 0, "", STG_ЧислоВСтрОтч(Данные!стр!"C")))
        ДобавитьПодстановкуТ(стр, "%_т1%", "%расход%", ?(Данные!стр!"D" = 0, "", STG_ЧислоВСтрОтч(Данные!стр!"D")))
        ДобавитьПодстановкуТ(стр, "%_т1%", "%тариф%", ?(Данные!стр!"E" = 0, "", STG_ЧислоВСтрОтч(Данные!стр!"E")))
        ЕСЛИ формаПД = к_ФормаПДМножЭЭСерв ТО
          ДобавитьПодстановкуТ(стр, "%_т1%", "%начислено%", ?(Данные!стр!"F" = 0, "", STG_ЧислоВСтрОтч(Данные!стр!"F")))
          ДобавитьПодстановкуТ(стр, "%_т1%", "%потери%", ?(Данные!стр!"G" = 0, "", STG_ЧислоВСтрОтч(Данные!стр!"G")))
          ДобавитьПодстановкуТ(стр, "%_т1%", "%сумма%", ?(Данные!стр!"H" = 0, "", STG_ЧислоВСтрОтч(Данные!стр!"H")))
        ИНАЧЕ
          ДобавитьПодстановкуТ(стр, "%_т1%", "%сумма%", ?(Данные!стр!"F" = 0, "", STG_ЧислоВСтрОтч(Данные!стр!"F")))
        КОНЕЦ_ЕСЛИ
      КОНЕЦ_ЦИКЛА 
      ДобавитьПодстановку("%итого%", ?(суммаПлатежа = 0, "", STG_ЧислоВСтрОтч(суммаПлатежа)))
  КОНЕЦ_ВЫБОРА
  
  //QR-код
  путьQRCode = ""
  индПутиДШК = плательщикФЛС + г_раздОб + плательщикФИО + г_раздОб + плательщикАдрес + г_раздОб + СТР_ЗНАЧ(суммаПлатежа)
  ЕСЛИ СУЩ_ПЕРЕМ(stg_путиДШК!индПутиДШК) ТО
    путьQRCode = stg_путиДШК!индПутиДШК
  КОНЕЦ_ЕСЛИ
  ЕСЛИ путьQRCode <> "" И СУЩ_ФАЙЛ(путьQRCode) ТО
    ЕСЛИ АТРИБУТ("$гр_форматПДПочта") = к_форматHTML ТО
      путьQR = IB_FILE_ПутьОтн(ТЕК_ДИР + "\Temp", путьQRCode)
    ИНАЧЕ
      путьQR = путьQRCode
    КОНЕЦ_ЕСЛИ
    ДобавитьПодстановку("@#1", путьQR)
  //ИНАЧЕ
  //  ДобавитьПодстановку("@#1", "Pics\BMP\plug.bmp")
  КОНЕЦ_ЕСЛИ
  
  //логотип
  ЕСЛИ ПараметрПечатиПД!"Логотип СНТ" <> "" ТО
    ЕСЛИ СУЩ_ФАЙЛ(ПараметрПечатиПД!"Логотип СНТ") ТО
      ДобавитьПодстановку("@#2", ПараметрПечатиПД!"Логотип СНТ")
    КОНЕЦ_ЕСЛИ
  //ИНАЧЕ
  //  ДобавитьПодстановку("@#2", "Pics\BMP\plug.bmp")
  КОНЕЦ_ЕСЛИ
  
  //
  г_выгруженоКвитанций++
  резЭксп = НЕТ
  ЕСЛИ СТР_ФРАГ(действие, г_раздОб, 1) = "печать" ТО
    директория = г_дирВыгрузкиПД
    ЕСЛИ СУЩ_ДИР(ПОДСТР(директория, 1, 3)) ТО
      IB_FILE_ДирСоздать(директория)
    ИНАЧЕ
      IB_FILE_ДирСоздать(ТЕК_ДИР + "\Temp\SNT")
    КОНЕЦ_ЕСЛИ
    приложение = STG_ОпрИмяПрогВыгрКвит2(АТРИБУТ("$гр_выводПД"))
    расширение = АТРИБУТ("$гр_форматПД")
    рез = STG_ЭкспортФормы(директория, приложение, расширение, имяФайла, форма, формаПД, путьЗаглушка)
    ЕСЛИ рез ТО
      STG_ДобПДВАрхив(имяФайла, путьЗаглушка)
    КОНЕЦ_ЕСЛИ
  ИНАЧЕ
    ЕСЛИ действие = "почта" ТО
      директория = IB_MAIL_ДирТекРассылки
      приложение = STG_ОпрИмяПрогВыгрКвит2(АТРИБУТ("$гр_выводПДПочта"))
      расширение = АТРИБУТ("$гр_форматПДПочта")
      ЕСЛИ расширение = к_форматHTML ТО
        приложение = "html"
      КОНЕЦ_ЕСЛИ
      резЭксп = STG_ЭкспортФормы(директория, приложение, расширение, имяФайла, форма, формаПД, путьФайлаНаОтправку)
    ИНАЧЕ
      директория = г_дирВыгрузкиПД
      СОЗДАТЬ_ДИР(директория)
      приложение = STG_ОпрИмяПрогВыгрКвит2(АТРИБУТ("$гр_выводПД"))
      расширение = АТРИБУТ("$гр_форматПД")
      директорияП = IB_MAIL_ДирТекРассылки
      приложениеП = STG_ОпрИмяПрогВыгрКвит2(АТРИБУТ("$гр_выводПДПочта"))
      расширениеП = АТРИБУТ("$гр_форматПДПочта")
      ЕСЛИ расширениеП = к_форматHTML ТО
        приложениеП = "html"
      КОНЕЦ_ЕСЛИ
      
      STG_ПроверитьПарамЭкспорта(приложение, расширение)
      STG_ПроверитьПарамЭкспорта(приложениеП, расширениеП)
      
      ЕСЛИ расширение = расширениеП ТО //для html это не работает
        резЭксп = STG_ЭкспортФормы(директорияП, приложение, расширение, имяФайла, форма, формаПД, путьФайлаНаОтправку)
        рез = IB_FILE_ФайлКопировать(директорияП + "\" + имяФайла + расширение, 
                                     директория + "\" + имяФайла + расширение, 
                                     ДА)
        ЕСЛИ рез ТО
          STG_ДобПДВАрхив(имяФайла, директория + "\" + имяФайла + расширение)
        КОНЕЦ_ЕСЛИ
      ИНАЧЕ
        ЕСЛИ расширение = к_ФорматDOC И расширениеП = к_ФорматPDF ТО
          рез = STG_ЭкспортФормы(директория, приложение, расширение, имяФайла, форма, формаПД, путьЗаглушка)
          ЕСЛИ отправлятьПочту ТО
            СБРОС_ПОДСТ
            ДобавитьПодстановку("%периодКвит%", периодКвит)
            резЭксп = STG_ЭкспортФормы(директорияП, приложениеП, расширениеП, имяФайла, путьЗаглушка, формаПД, путьФайлаНаОтправку)
          КОНЕЦ_ЕСЛИ
        ИНАЧЕ
          ЕСЛИ отправлятьПочту ТО
            резЭксп = STG_ЭкспортФормы(директорияП, приложениеП, расширениеП, имяФайла, форма, формаПД, путьФайлаНаОтправку)
          //  СБРОС_ПОДСТ
          //  ДобавитьПодстановку("%периодКвит%", периодКвит)
          ИНАЧЕ
            рез = STG_ЭкспортФормы(директория, приложение, расширение, имяФайла, директория + "\" + имяФайла + расширение, формаПД, путьЗаглушка)
          КОНЕЦ_ЕСЛИ
        КОНЕЦ_ЕСЛИ
        ЕСЛИ рез ТО
          STG_ДобПДВАрхив(имяФайла, путьЗаглушка)
        КОНЕЦ_ЕСЛИ
      КОНЕЦ_ЕСЛИ
    КОНЕЦ_ЕСЛИ
  КОНЕЦ_ЕСЛИ
  
  ЕСЛИ отправлятьПочту ТО
    ЕСЛИ резЭксп ТО
      IB_MAIL_AddToDispatchList(плательщикАдрес, eMail, 
                                "Квитанция на оплату; "  + имяФайла, 
                                "Квитанция на оплату во вложении.", путьФайлаНаОтправку)
    ИНАЧЕ
      прогНазв = ?(приложение = "WORD", "MS Word", ?(приложение = "html", "html", "OpenOffice Writer"))
      прогЗаменыНазв = ?(приложение = "WORD", "MS Word", ?(приложение = "html", "html", "OpenOffice Writer"))
      IB_PROTOCOL_ДобавитьОшибку("Не удалось выгрузить платежный документ. Отправка письма отменена.",
                                 "Попробуйте закрыть все открытые окна " + прогНазв + ". " + 
                                 "Попробуйте перезапустить Инфо-Бухгалтер или перезагрузить компьютер.")
      IB_PROTOCOL_ДобавитьОшибку("",
                                 ?(приложение = "WORD", "Проверьте, активирован ли MS Word.", "") + 
                                 " Попробуйте сменить программу выгрузки на " + прогЗаменыНазв + ".")
    КОНЕЦ_ЕСЛИ
  КОНЕЦ_ЕСЛИ
КОНЕЦ_ФУНКЦИИ

//--------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ STG_ПроверитьПарамЭкспорта(ПЕРЕМ ТИП_СТРОКА: приложение, расширение)
  ЕСЛИ расширение = "" ТО
    расширение = ".pdf"
  КОНЕЦ_ЕСЛИ
  
  ЕСЛИ приложение = "" ТО
    приложение = "DEFAULT"
  КОНЕЦ_ЕСЛИ
КОНЕЦ_ФУНКЦИИ

//--------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ ТИП_ЛОГИКА: STG_ЭкспортФормы(ТИП_СТРОКА: директория, приложение, расширение, имяФайла, форма, формаПД;
                                     ПЕРЕМ ТИП_СТРОКА: путьФайлаНаОтправку)
  путьФайлаНаОтправку = директория + "\" + имяФайла + расширение 
  ЕСЛИ расширение <> к_форматHTML ТО
    STG_ПроверитьПарамЭкспорта(приложение, расширение)
    STG_ЭкспортФормы = ЭКСПОРТ_ФОРМЫ(приложение, форма, путьФайлаНаОтправку + ">close")
  ИНАЧЕ
    STG_ЭкспортФормы = STG_ЭкспортФормыHTML(формаПД, форма, путьФайлаНаОтправку)
  КОНЕЦ_ЕСЛИ
КОНЕЦ_ФУНКЦИИ

//--------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ ТИП_ЛОГИКА: STG_ОчиститьДирКвит
  ЕСЛИ НЕ stg_былаОчисткаДирКвит ТО
    stg_былаОчисткаДирКвит = ДА
    stg_резОчисткаДирКвит = STG_ОчиститьДир(г_времПапкаКвитанций)
  КОНЕЦ_ЕСЛИ
  STG_ОчиститьДирКвит = stg_резОчисткаДирКвит
КОНЕЦ_ФУНКЦИИ

ФУНКЦИЯ ТИП_ЛОГИКА: STG_ОчиститьДир(ТИП_СТРОКА: папка)
  рез = ДА
  ЕСЛИ СУЩ_ДИР(папка) ТО
    рез = УДАЛИТЬ_ДИР(папка)
  КОНЕЦ_ЕСЛИ
  ЕСЛИ рез ТО
    СОЗДАТЬ_ДИР(папка)
  ИНАЧЕ
    IB_PROTOCOL_ДобавитьОшибку("Не удалось очистить директорию временных файлов " + папка + ".", 
                               "Возможно, в ней имеются заблокированные файлы. Закройте их.")
  КОНЕЦ_ЕСЛИ
  STG_ОчиститьДир = рез
КОНЕЦ_ФУНКЦИИ

//--------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ ТИП_ЛОГИКА: STG_ВыгрузитьТаблицуНаМН(ТИП_СТРОКА: приложение, имяФайла, расширение; 
                                             ТИП_ЛОГИКА: ширинаСтолбцовАвто,
                                                         ориентацияАльбом,
                                                         узкиеПоля;
                                             ПЕРЕМ ТИП_СТРОКА: файл)
  прогВыгрузки = STG_ОпрИмяПрогВыгрТабл(приложение)
  дирВыгрузки = IB_FILE_ПутьСоед(г_дирВыгрузки, г_дирОтчетов)
  ЕСЛИ СУЩ_ДИР(ПОДСТР(дирВыгрузки, 1, 3)) ТО
    СОЗДАТЬ_ДИР(дирВыгрузки)
  ИНАЧЕ
    дирВыгрузки = ТЕК_ДИР + "\Temp\STG"
    СОЗДАТЬ_ДИР(дирВыгрузки)
  КОНЕЦ_ЕСЛИ
  
  файл = дирВыгрузки + "\" + имяФайла + расширение
  IB_TBLEXP_ПараметрыВыгрузки(файл, прогВыгрузки, ширинаСтолбцовАвто, ориентацияАльбом, узкиеПоля)
  
  STG_ВыгрузитьТаблицуНаМН = IB_TBLEXP_СохранитьТаблицуНаМН
КОНЕЦ_ФУНКЦИИ

//--------------------------------------------------------------------------------------------------------------------------//
//Формируется ДШК типа QRCode. FullName заполняется в том случае, если ФИО вкорячено одной строкой, иначе составные ФИО.
ФУНКЦИЯ ТИП_ЛОГИКА: STG_ПередатьПарамДШК(ТИП_СТРОКА: Name, PersonalAcc, BankName, BIC, CorrespAcc;         //обязательные
                                         ТИП_СТРОКА: KPP, PayeeINN, Category, PersAcc, FullName, LastName, //дополнительные
                                                     FirstName, MiddleName, PayerAddress, Purpose;
                                         ТИП_ЧИСЛО: Sum)
  СОЗДАТЬ(СП1, ТИП_СПИСОК)
  //определяется кодировка символов ДШК
  кодировка = к_КодировкаДШКWin1251
  ЕСЛИ СУЩ_ПЕРЕМ(ПараметрПечатиПД!"Кодировка ДШК") ТО
    кодировка = ПараметрПечатиПД!"Кодировка ДШК"
  КОНЕЦ_ЕСЛИ
  ВЫБОР(кодировка)
    #к_КодировкаДШКWin1251 :
     IB_QR_УстановитьECICode(22)
     IB_QR_УстановитьКодировкуФайла("WIN")
    #к_КодировкаДШКUTF8 :
     IB_QR_УстановитьECICode(26)
     IB_QR_УстановитьКодировкуФайла("UTF-8.NoBOM")      
  КОНЕЦ_ВЫБОРА
  //
  IB_QR_ДобавитьКодируемуюСтроку("ST0001" + СТР_ЗНАЧ(кодировка) + "|Name=" + Name + "|") //Обязательный реквизит.
  IB_QR_ДобавитьКодируемуюСтроку("PersonalAcc=" + PersonalAcc + "|") //Обязательный реквизит.
  IB_QR_ДобавитьКодируемуюСтроку("BankName=" + BankName + "|") //Обязательный реквизит.
  IB_QR_ДобавитьКодируемуюСтроку("BIC=" + BIC + "|") //Обязательный реквизит.
  IB_QR_ДобавитьКодируемуюСтроку("CorrespAcc=" + CorrespAcc + "|") //Обязательный реквизит.
  ЕСЛИ PayeeINN <> "" ТО //Дополнительный реквизит
    IB_QR_ДобавитьКодируемуюСтроку("PayeeINN=" + PayeeINN + "|") 
  КОНЕЦ_ЕСЛИ
  ЕСЛИ Purpose <> "" ТО //Дополнительный реквизит - наименование платежа(назначение)
    Purpose = Purpose
    IB_QR_ДобавитьКодируемуюСтроку("Purpose=" + ?(ДЛИНА(Purpose) > 210, ПОДСТР(Purpose, 1, 210), Purpose) + "|") 
  КОНЕЦ_ЕСЛИ
  ЕСЛИ Category <> "" ТО
    IB_QR_ДобавитьКодируемуюСтроку("Category=" + Category + "|") //Дополнительный реквизит
  КОНЕЦ_ЕСЛИ
  ЕСЛИ PersAcc <> "" ТО
    IB_QR_ДобавитьКодируемуюСтроку("PersAcc=" + PersAcc + "|") //Дополнительный реквизит
  КОНЕЦ_ЕСЛИ
  ЕСЛИ KPP <> "" ТО
    IB_QR_ДобавитьКодируемуюСтроку("KPP=" + KPP + "|")
  КОНЕЦ_ЕСЛИ
  //ФИО
  ЕСЛИ FullName <> "" ТО
    колСлов = СТР_РАЗД(FullName, " ", СП1)
    ЕСЛИ колСлов >= 1 ТО
      IB_QR_ДобавитьКодируемуюСтроку("LastName=" + СП1.СТРОКА(1) + "|")
    КОНЕЦ_ЕСЛИ
    ЕСЛИ колСлов >= 2 ТО
      IB_QR_ДобавитьКодируемуюСтроку("FirstName=" + СП1.СТРОКА(2) + "|")
    КОНЕЦ_ЕСЛИ
    ЕСЛИ колСлов = 3 ТО
      IB_QR_ДобавитьКодируемуюСтроку("MiddleName=" + СП1.СТРОКА(3) + "|")
    КОНЕЦ_ЕСЛИ
  ИНАЧЕ
    ЕСЛИ LastName <> "" ТО
      IB_QR_ДобавитьКодируемуюСтроку("LastName=" + LastName + "|")
    КОНЕЦ_ЕСЛИ
    ЕСЛИ FirstName <> "" ТО
      IB_QR_ДобавитьКодируемуюСтроку("FirstName=" + FirstName + "|")
    КОНЕЦ_ЕСЛИ
    ЕСЛИ MiddleName <> "" ТО
      IB_QR_ДобавитьКодируемуюСтроку("MiddleName=" + MiddleName + "|")
    КОНЕЦ_ЕСЛИ
  КОНЕЦ_ЕСЛИ
  //
  ЕСЛИ PayerAddress <> "" ТО
    IB_QR_ДобавитьКодируемуюСтроку("PayerAddress=" + PayerAddress + "|")
  КОНЕЦ_ЕСЛИ
  //сумма
  IB_QR_ДобавитьКодируемуюСтроку("Sum=" + ?(Sum <> 0, СТР_ЗНАЧ(РУБ(Sum)) + СТР0(КОП(Sum), 2), "0"))
КОНЕЦ_ФУНКЦИИ

//--------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ ТИП_СТРОКА: STG_ОпрИмяПрогВыгрКвит2(ТИП_СТРОКА: прогВыгрузки)  
  STG_ОпрИмяПрогВыгрКвит2 = ?(прогВыгрузки = к_ВыгрузкаПДВOOWriter, "OPENOFFICE WRITER",
                              ?(прогВыгрузки = к_ВыгрузкаПДВWord, "WORD", "DEFAULT"))
КОНЕЦ_ФУНКЦИИ

//--------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ ТИП_СТРОКА: STG_ОпрИмяПрогВыгрТабл(ТИП_СТРОКА: прогВыгрузки)
  STG_ОпрИмяПрогВыгрТабл = ?(прогВыгрузки = к_ВыгрузкаПДВOOCalc, "OPENOFFICE CALC",
                             ?(прогВыгрузки = к_ВыгрузкаПДВExcel, "EXCEL", "DEFAULT"))
КОНЕЦ_ФУНКЦИИ

//--------------------------------------------------------------------------------------------------------------------------//
//Основные переменные для печати таблиц - чтобы не пихать каждый раз везде.
ФУНКЦИЯ STG_ПарамВыводаТаблиц //STG_ПОДГОТОВКА_ПЕЧАТИ
  СБРОС_ТАБЛИЦ(ДА)
  //Общие параметры печати
  Раздвигать = ДА     // Вставлять строки при выводе
  ВыводИт = ДА        // Выводить итоги
  ВыделитьИтог = ДА   // Выделить строку итогов жирным
  учитывать_шапку = ДА
  //Данные для разбивки на страницы
  РазбСтр = ДА        // Делать разбивку на страницы
  КолСтрок = 0        // Количество строк на позицию (если 0, то автоопределение)
  //сброс ключевых
  ВсегоСтр = 0
  НачСтр = 0
  //НачСтлб = 2        // Столбец, с которого начинается вывод (по умолчанию 1)
  КолЯч = 0
  //ориентация и кол. срок на листе
  СОЗДАТЬ(СП,ТИП_СПИСОК)
  СПИСОК_АТРИБУТОВ("настройки печати", СП)
  г_альбом = ?(СТР_ФРАГ(СП.СТРОКА(6), "=", 2) = "ДА", ДА, НЕТ)
  СтрЛист = 0
  ЕСЛИ СП.ВСЕГО <= 7 ТО
    ОКНО_СООБ("Текущий принтер недоступен: " + АТРИБУТ("cur_printer") + СИМВ(13) + "Рекомендуется перезапустить программу", "Ошибка текущего принтера", "OK, CANCEL", "ERROR")
  ИНАЧЕ
    СтрЛист = ЗНАЧ(СТР_ФРАГ(СП.СТРОКА(9), "=", 2)) - 1
  КОНЕЦ_ЕСЛИ
КОНЕЦ_ФУНКЦИИ

//--------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ ТИП_СТРОКА: STG_ЧислоВСтрОтч(ТИП_ЧИСЛО: число) //_В_ДЕНЬГИ
  ЕСЛИ число = 0 ТО
    STG_ЧислоВСтрОтч = "-"
  ИНАЧЕ
    STG_ЧислоВСтрОтч = ?(число < 0, "-", "") + СТР_ЗНАЧ(РУБ(АБС(число))) + "." + СТР0(КОП(АБС(число)), 2)
  КОНЕЦ_ЕСЛИ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ ТИП_СТРОКА: STG_ЧислФорматЗпт(ТИП_ЧИСЛО: число) //_ЧислФорматЗпт
  ЕСЛИ число >= 0 ТО
    ЕСЛИ число = 0 ТО
      STG_ЧислФорматЗпт = "0,00"
    ИНАЧЕ
      STG_ЧислФорматЗпт = СТР_ЗНАЧ(РУБ(число))+","+СТР0(КОП(число),2)
    КОНЕЦ_ЕСЛИ
  ИНАЧЕ
    STG_ЧислФорматЗпт = "-"+СТР_ЗНАЧ(РУБ(АБС(число)))+","+СТР0(КОП(АБС(число)),2)
  КОНЕЦ_ЕСЛИ
КОНЕЦ_ФУНКЦИИ