ИСПОЛЬЗОВАТЬ_БИБЛ("IB_QR")
ИСПОЛЬЗОВАТЬ_БИБЛ("IB_MAIL")
ИСПОЛЬЗОВАТЬ_БИБЛ("IB_TBLEXPORT")
ИСПОЛЬЗОВАТЬ_БИБЛ("ST_GSK\ST_GSK_HTML")

//-------------------------------------------------------------------------------------------------------------------------//
ПЕРЕМ ТИП_СТРОКА: г_дирВыгрузкиПД
ПЕРЕМ ТИП_ДАТА: г_датаВыгрузкиПД
ПЕРЕМ ТИП_СТРОКА: г_времяВыгрузкиПД

ПЕРЕМ stg_путиДШК!  //пути ДШК для выгруженных квитанций

ПЕРЕМ г_реквПолучателя!

//печать ПД
ПЕРЕМ ТИП_ЧИСЛО: г_итогоКОплате    //итого к оплате по ПД - надо для формирования ДШК
ПЕРЕМ ТИП_ЧИСЛО: г_колСтрокТаблицы //количество добавленных в таблицу строк. надо 
                                   //для правильного разделения при формировании ПД 
                                   //для нескольких статей

//печать ПКО
ПЕРЕМ ТИП_ЧИСЛО: г_ВсегоСтрокПКО    //общее количество строк в таблице ПКО
ПЕРЕМ ТИП_ЛОГИКА: г_былаИниПечатьПо //была ли инициализация печати ПКО
ПЕРЕМ г_строкаПО!                   //значения ячеек ПКО

ПЕРЕМ ТИП_ЛОГИКА: оп_ФормироватьПустые

//очистка директории выгрузки квитанций
ПЕРЕМ ТИП_ЛОГИКА: stg_былаОчисткаДирКвит
ПЕРЕМ ТИП_ЛОГИКА: stg_резОчисткаДирКвит

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ ТИП_ЧИСЛО: STG_ПечатьКвитанций(ТИП_ЧИСЛО:  строка, сумма, текНом;
                                       ТИП_СТРОКА: адрес, фио, флс;
                                       ТИП_СТРОКА: едИзмПл, назначениеПлатежа, email, формаПД, периодКвит, имяФайла, действие)
  ЕСЛИ СТР_ФРАГ(действие, г_раздОб, 1) <> "1" И ПОЗ("почта", действие) = 0 И ПОЗ("печать", действие) = 0 ТО
    ВЫХОД
  КОНЕЦ_ЕСЛИ
  
  ЕСЛИ НЕ СУЩ_ПЕРЕМ(ПараметрПечатиПД!"Формировать ДШК") ТО
    ПараметрПечатиПД!"Формировать ДШК" = НЕТ
  КОНЕЦ_ЕСЛИ
  
  ЕСЛИ НЕ СУЩ_ПЕРЕМ(ПараметрПечатиПД!"Отправлять письма") ТО
    ПараметрПечатиПД!"Отправлять письма" = НЕТ
  КОНЕЦ_ЕСЛИ
  
  ЕСЛИ НЕ СУЩ_ПЕРЕМ(ПараметрПечатиПД!"Логотип СНТ") ТО
    ПараметрПечатиПД!"Логотип СНТ" = ""
  КОНЕЦ_ЕСЛИ
  
  ЕСЛИ НЕ СУЩ_ПЕРЕМ(оп_ФормироватьПустые) ТО
    оп_ФормироватьПустые = НЕТ
  КОНЕЦ_ЕСЛИ
  
  ЕСЛИ НЕ СУЩ_ПЕРЕМ(г_randParam!"назначениеПлатежаДШК") ТО
    г_randParam!"назначениеПлатежаДШК" = назначениеПлатежа
  КОНЕЦ_ЕСЛИ
  
  ЕСЛИ формаПД = к_ФормаПД4 ИЛИ формаПД = к_ФормаПДМнож ТО
    настрДШКВидПлатежа = ПараметрПечатиПД!"Вид платежа ИПУ"
  ИНАЧЕ
    настрДШКВидПлатежа = ПараметрПечатиПД!"Вид платежа остальные"
  КОНЕЦ_ЕСЛИ
  
  сумма = ОКРУГЛЕНИЕ(?(сумма < 0, 0, сумма), ?(ПараметрПечатиПД!"Округлять", 0, 2))
  ЕСЛИ НЕ оп_ФормироватьПустые И сумма = 0 ТО
    STG_ПечатьКвитанций = строка// - 1
    STG_СбросСтрокПД
    ВЫХОД
  КОНЕЦ_ЕСЛИ
  
  ЕСЛИ ПОЗ(к_ВыгрузкаПДНаЭкран, действие) > 0 ТО
    ВЫБОР(формаПД)
     #к_ФормаПД4, к_ФормаПД4ЭЭСерв, к_ФормаПД4ВГСерв: 
       горПозДШК = 4
       горПозЛого = 8
       вертПозДШК = строка + 2
       суммаДШК = сумма 
       строка = STG_СформироватьПД4(строка, сумма, вертПозЛого, назначениеПлатежа, фио, адрес, флс, текНом)
       ЕСЛИ формаПД <> к_ФормаПД4 ТО
         строка++
         КОНЕЦ_СТРАНИЦЫ(строка)
         строка++
         строка = STG_СформТаблРасшЭЭ(строка)
       КОНЕЦ_ЕСЛИ
       
       STG_ПечатьКвитанций = строка
       
     #к_ФормаПДМнож, к_ФормаПДМножЭЭСерв, к_ФормаПДМножВГСерв: 
       горПозДШК = 3
       горПозЛого = 6
       вертПозДШК = строка + 1
       суммаДШК = г_итогоКОплате
       
       STG_ПечатьКвитанций = STG_СформироватьПДМнож(строка, вертПозЛого, адрес, фио, флс, периодКвит, текНом)       
    ИНАЧЕ
      СООБЩЕНИЕ("Не указана форма квитанции")
      СТОП_ВСЕ
    КОНЕЦ_ВЫБОРА
    
    ЕСЛИ ПараметрПечатиПД!"Логотип СНТ" <> "" ТО
      ЕСЛИ СУЩ_ФАЙЛ(ПараметрПечатиПД!"Логотип СНТ") ТО
        ВСТАВИТЬ_КАРТИНКУ(горПозЛого, вертПозЛого, 11, 4, ПараметрПечатиПД!"Логотип СНТ", НЕТ, ДА, НЕТ, 0)
      КОНЕЦ_ЕСЛИ
    КОНЕЦ_ЕСЛИ
  ИНАЧЕ
    ВЫБОР(формаПД)
     #к_ФормаПД4, к_ФормаПД4ЭЭСерв, к_ФормаПД4ВГСерв: 
       суммаДШК = сумма 
     #к_ФормаПДМнож, к_ФормаПДМножЭЭСерв, к_ФормаПДМножВГСерв: 
       суммаДШК = г_итогоКОплате
    ИНАЧЕ
      СООБЩЕНИЕ("Не указана форма квитанции")
      СТОП_ВСЕ
    КОНЕЦ_ВЫБОРА
  КОНЕЦ_ЕСЛИ
  
  ЕСЛИ ПараметрПечатиПД!"Формировать ДШК" /*И суммаДШК > 0*/ ТО
    индПутиДШК = флс + г_раздОб + фио + г_раздОб + адрес + г_раздОб + СТР_ЗНАЧ(суммаДШК)
    ЕСЛИ НЕ СУЩ_ПЕРЕМ(stg_путиДШК!индПутиДШК) ТО
      STG_ПередатьПарамДШК(г_реквПолучателя!"наимОрг", 
                           г_реквПолучателя!"расчСч", 
                           г_реквПолучателя!"наимБанк", 
                           г_реквПолучателя!"бик", 
                           г_реквПолучателя!"коррСч",
                           г_реквПолучателя!"кппОрг", 
                           г_реквПолучателя!"иннОрг", 
                           настрДШКВидПлатежа,
                           флс, фио, "", "", "", 
                           г_randParam!"адресДШК", 
                           г_randParam!"назначениеПлатежаДШК",
                           ?(суммаДШК > 0, суммаДШК, 0))
          
      резДШК = IB_QR_СформироватьДШК
      ЕСЛИ резДШК ТО
        stg_путиДШК!индПутиДШК = IB_QR_ПолучитьПутьДШК
      КОНЕЦ_ЕСЛИ
    ИНАЧЕ
      резДШК = ДА
    КОНЕЦ_ЕСЛИ
    
    ЕСЛИ резДШК И (/*действие <> "почта" ИЛИ */ПОЗ(к_ВыгрузкаПДНаЭкран, действие) > 0) ТО
      ВСТАВИТЬ_КАРТИНКУ(горПозДШК, вертПозДШК, 18, 7, stg_путиДШК!индПутиДШК, НЕТ, ДА, НЕТ, 0)
    КОНЕЦ_ЕСЛИ
  КОНЕЦ_ЕСЛИ
  
  ЕСЛИ ПОЗ(СИМВ(13), назначениеПлатежа) > 0 ТО
    назначениеПлатежа = ПОДСТР(назначениеПлатежа, 1, ПОЗ(СИМВ(13), назначениеПлатежа))
  КОНЕЦ_ЕСЛИ
  
  ЕСЛИ  ПараметрПечатиПД!"Отправлять письма" ИЛИ
       (ПОЗ("печать", действие) > 0 И 
       (ПОЗ(к_ВыгрузкаПДВПрилУмолч, действие) > 0 ИЛИ 
        ПОЗ(к_ВыгрузкаПДВWord, действие) > 0 ИЛИ
        ПОЗ(к_ВыгрузкаПДВOOWriter, действие) > 0)) ТО
    STG_ВыгрузитьИОтправитьПД(г_реквПолучателя!"расчСч", г_реквПолучателя!"наимБанк", г_реквПолучателя!"коррСч", г_реквПолучателя!"бик", 
                              г_реквПолучателя!"наимОрг", г_реквПолучателя!"кппОрг", г_реквПолучателя!"иннОрг",
                              назначениеПлатежа, фио, флс, адрес,
                              едИзмПл, периодКвит, суммаДШК, email, формаПД, имяФайла, действие)
  КОНЕЦ_ЕСЛИ
  
  STG_СбросСтрокПД
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
//-------------------------------------------------------------------------------------------------------------------------//
//формируется форма ПД4
ФУНКЦИЯ ТИП_ЧИСЛО: STG_СформироватьПД4 (ТИП_ЧИСЛО: строка, сумма; 
                                           ПЕРЕМ ТИП_ЧИСЛО: строкаДШК;
                                           ТИП_СТРОКА: назначениеПлатежа, фио, адрес, флс;
                                           ТИП_ЧИСЛО: текНом)
   СОЗДАТЬ(СП, ТИП_СПИСОК)
   СОЗДАТЬ(Ш1, ТИП_ШРИФТ)
   СОЗДАТЬ(Ш2, ТИП_ШРИФТ)
   СОЗДАТЬ(Ш3, ТИП_ШРИФТ)
   Ш1.название = "Courier New"  Ш1.жирн = ДА
   Ш2.название = "Courier New"  Ш2.жирн = НЕТ  Ш2.размер = 7
   Ш3.название = "Courier New"  Ш3.жирн = ДА 
   позВыв = 5
   позДШК = строка+3
   ВЫВЕСТИ (позВыв + 77,строка,"Форма  ПД-4",10,1,Ш2)
   зг!1="ИЗВЕЩЕНИЕ" + ?(текНом = 0, "", " №" + СТР_ЗНАЧ(текНом))
   зг!2="КВИТАНЦИЯ" + ?(текНом = 0, "", " №" + СТР_ЗНАЧ(текНом))
   //
   колСтрокНП = 0
   н_п!0 = назначениеПлатежа
   ЦИКЛ ПОКА(н_п!0 <> "")
     колСтрокНП++
     н_п!колСтрокНП = СТР_ПЕРЕНОС(н_п!0, 64, н_п!0)
   КОНЕЦ_ЦИКЛА
   //
   колСтрокАдр = 0
   адр!0 = фио + ?(фио = "", "", ", ") + адрес //фио + "(лиц. счет №" + флс + "), " + адрес
   ЦИКЛ ПОКА(адр!0 <> "")
     колСтрокАдр++
     адр!колСтрокАдр = СТР_ПЕРЕНОС(адр!0, 64, адр!0)
   КОНЕЦ_ЦИКЛА
   //
   колСтрБанкРекв = 0
   рекв!0 = г_реквПолучателя!"наимБанк" + ", к/с "+ г_реквПолучателя!"коррСч"+", БИК "+г_реквПолучателя!"бик"
   ЦИКЛ ПОКА(рекв!0 <> "")
     колСтрБанкРекв++
     рекв!колСтрБанкРекв = СТР_ПЕРЕНОС(рекв!0, 64, рекв!0)
   КОНЕЦ_ЦИКЛА
   //
   нач = 1
   кон = 2
   ЕСЛИ СУЩ_ПЕРЕМ(г_randParam!"выводРазделовПД") ТО
     ЕСЛИ г_randParam!"выводРазделовПД" <> к_разделПДВсе ТО
       нач = ?(г_randParam!"выводРазделовПД" = к_разделПДИзвещение, 1, 2)
       кон = нач
     КОНЕЦ_ЕСЛИ
   КОНЕЦ_ЕСЛИ
   //     
   ВСТАВИТЬ_РАМКУ(позВыв + 1,строка,84,0)
   //
   ЦИКЛ ДЛЯ(и = нач, кон)
      начСтрока = строка
      строкаДШК = строка + 3
      ВЫВЕСТИ (позВыв + 4,строка+1,зг!и,12,1,Ш1)
      //строка++
      ВЫВЕСТИ (позВыв + 21,строка,"ИНН " + г_реквПолучателя!"иннОрг" + ", " + г_реквПолучателя!"наимОрг")
      строка++
      ВСТАВИТЬ_РАМКУ(позВыв + 20,строка,65,0)
      ВЫВЕСТИ (позВыв + 34,строка,"(ИНН и наименование получателя платежа)")
      строка++
      ВЫВЕСТИ (позВыв + 21,строка,"р/с "+г_реквПолучателя!"расчСч")
      строка++
      ВСТАВИТЬ_РАМКУ(позВыв + 20,строка,65,0)
      ВЫВЕСТИ (позВыв + 37,строка,"(номер счета получателя платежа)")
      строка++
      
      ЦИКЛ ДЛЯ(ж = 1, колСтрБанкРекв)
        ВЫВЕСТИ(позВыв + 21, строка, рекв!ж)
        строка++
      КОНЕЦ_ЦИКЛА
      ВСТАВИТЬ_РАМКУ(позВыв + 20,строка,65,0)
      ВЫВЕСТИ (позВыв + 32,строка,"(наименование банка и банковские реквизиты)")
      строка++
      ЕСЛИ колСтрокНП = 0 ТО
        строка++
      КОНЕЦ_ЕСЛИ
      ЦИКЛ ДЛЯ(ж = 1, колСтрокНП)
        ВЫВЕСТИ (позВыв + 21,строка, н_п!ж, Ш3)
        строка++
      КОНЕЦ_ЦИКЛА
      ВСТАВИТЬ_РАМКУ(позВыв + 20,строка, 65, 0)
      ВЫВЕСТИ (позВыв + 41,строка,"(наименование платежа)")
      строка++
      ВЫВЕСТИ (позВыв + 23,строка,"Дата")
      ВЫВЕСТИ (позВыв + 45,строка,"Сумма платежа")
      ВЫВЕСТИ (позВыв + 60,строка,STG_ЧислоВСтрОтч(сумма), Ш3)
      строка++
      ВСТАВИТЬ_РАМКУ(позВыв + 28,строка,12,0)
      ВСТАВИТЬ_РАМКУ(позВыв + 59,строка,26,0)
      //строка ФИО
      ЦИКЛ ДЛЯ(ж = 1, колСтрокАдр)
        ВЫВЕСТИ (позВыв + 21,строка, адр!ж, Ш3)
        строка++
      КОНЕЦ_ЦИКЛА
      /*ВЫВЕСТИ (позВыв + 21,строка, фио + "(лиц. счет №" + флс + "), " + Предприят + ", " + адрес, Ш3)
      строка++*/
      ВСТАВИТЬ_РАМКУ(позВыв + 20,строка,65,0)
      ВЫВЕСТИ (позВыв + 39,строка,"(Ф.И.О., адрес плательщика)")
      строка++
      ВЫВЕСТИ (позВыв + 6,строка,"Кассир",12,1,Ш1)
      ВЫВЕСТИ (позВыв + 20,строка,"Плательщик",15,1,Ш1)
      строка++
      ВСТАВИТЬ_РАМКУ(позВыв + 1,строка,84,0)
      //
      ВСТАВИТЬ_РАМКУ(позВыв + 18, начСтрока, 0, 10 + колСтрокНП + колСтрокАдр)
   КОНЕЦ_ЦИКЛА
   //
   STG_СформироватьПД4 = строка + 1
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
//-------------------------------------------------------------------------------------------------------------------------//
//ПД для нескольких статей
ФУНКЦИЯ ТИП_ЧИСЛО: STG_СформироватьПДМнож(ТИП_ЧИСЛО: строка; 
                                             ПЕРЕМ ТИП_ЧИСЛО: строкаДШК;
                                             ТИП_СТРОКА: адрес, фио, флс, периодКвит;
                                             ТИП_ЧИСЛО: текНом)
   позВыв = 3 //начальная позиция вывода
   СОЗДАТЬ(сп, ТИП_СПИСОК)
   колСтрокДанныеПолучателя = 1
   данныеПолучателя = СТР_РАЗБИТЬ(г_реквизитыПолучателя, 67, колСтрокДанныеПолучателя)
   ВСТАВИТЬ_РАМКУ(позВыв-5, строка, 90, 0, 2)
   //
   нач = 1
   кон = 2
   ЕСЛИ СУЩ_ПЕРЕМ(г_randParam!"выводРазделовПД") ТО
     ЕСЛИ г_randParam!"выводРазделовПД" <> к_разделПДВсе ТО
       нач = ?(г_randParam!"выводРазделовПД" = к_разделПДИзвещение, 1, 2)
       кон = нач
     КОНЕЦ_ЕСЛИ
   КОНЕЦ_ЕСЛИ
   //
   ЦИКЛ ДЛЯ(и = нач, кон)
     ВЫВЕСТИ(1, строка, IB_STR_ЦЕНТРИРОВАТЬ(?(и = 1, "ИЗВЕЩЕНИЕ", "КВИТАНЦИЯ")  + ?(текНом = 0, "", " №" + СТР_ЗНАЧ(текНом)), 22), 22)
     строкаДШК = строка + 1
     //данные получателя
     ВЫВЕСТИ(позВыв + 21, строка, данныеПолучателя, 67, колСтрокДанныеПолучателя, ДА)
     ВСТАВИТЬ_РАМКУ(позВыв + 20, строка, 68, колСтрокДанныеПолучателя, 2)
     строка = строка + колСтрокДанныеПолучателя
     //сведения о плательщике
     ВЫВЕСТИ(позВыв + 21, строка, IB_STR_ЦЕНТРИРОВАТЬ("Сведения о плательщике", 67), 67, 1)
     ВСТАВИТЬ_РАМКУ(позВыв + 20, строка, 68, 1)
     строка++
     //крыша
     //фио плательщика
     ВЫВЕСТИ(позВыв + 21, строка, "Ф.И.О.", 6, 1)
     ВСТАВИТЬ_РАМКУ(позВыв + 20, строка, 7, 1)
     ВЫВЕСТИ(позВыв + 28, строка, фио , 60, 1, ДА)
     ВСТАВИТЬ_РАМКУ(позВыв + 27, строка, 61, 1)
     строка++
     //адрес плательщика
     ВЫВЕСТИ(позВыв + 21, строка, "Адрес", 6, 1)
     ВСТАВИТЬ_РАМКУ(позВыв + 20, строка, 7, 1)
     ВЫВЕСТИ(позВыв + 28, строка, адрес, 60, 1, ДА)
     ВСТАВИТЬ_РАМКУ(позВыв + 27, строка, 61, 1)
     строка++
     //период
     ВЫВЕСТИ(позВыв + 21, строка, "Период", 6, 1)
     ВСТАВИТЬ_РАМКУ(позВыв + 20, строка, 7, 1)
     ВЫВЕСТИ(позВыв + 28, строка, периодКвит , 60, 1, ДА)
     ВСТАВИТЬ_РАМКУ(позВыв + 27, строка, 61, 1)
     строка++
     //печать таблички 
     НачСтр = строка//-1
     НачСтлб = позВыв + 20
     
     ЕСЛИ IB_CONTEXT_СчитатьЛок("неСбрасыватьИтоги") = "" ТО
       СБРОС(Итого) //иначе итоги будут идти нарастающим - херово
     КОНЕЦ_ЕСЛИ
     
     ПЕЧАТЬ_ШАПКИ
     ПЕЧАТЬ_ТАБЛИЦЫ
     
     строка = строка + 1 + (НачСтр - Низ - строка - 2) // в скобках кол. стрко таблицы. + КолСтрТабл!1
     г_колСтрокТаблицы = НачСтр - Низ - строка - 2
     строка++
     //подвал
     ВЫВЕСТИ(1, строка, IB_STR_ЦЕНТРИРОВАТЬ("Кассир", 24), 24)
     //
     ВЫВЕСТИ(позВыв + 21, строка, "Дата оплаты:")
     ВСТАВИТЬ_РАМКУ(позВыв + 20, строка, 34, 1)
     ВЫВЕСТИ(позВыв + 55, строка, "Подпись:")
     ВСТАВИТЬ_РАМКУ(позВыв + 54, строка, 34, 1)
     строка++
     //
     ВСТАВИТЬ_РАМКУ(позВыв-5, строка, 90, 0, 2)
   КОНЕЦ_ЦИКЛА
   строка++
   STG_СформироватьПДМнож = строка
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
//таблица расшифровки для ээ при печати формы ПД4. строки таблицы задаются в STG_ДобавитьСтрокуПДЭЭ
ФУНКЦИЯ ТИП_ЧИСЛО: STG_СформТаблРасшЭЭ(ТИП_ЧИСЛО: строка)
  строка++
  строка++
  НачСтр = строка
  НачСтлб = 5
     
  ПЕЧАТЬ_ШАПКИ
  ПЕЧАТЬ_ТАБЛИЦЫ
  
  STG_СформТаблРасшЭЭ = строка + 2 + (НачСтр - Низ - строка - 2)
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
//накидывает строки ПД для членских и целевых
ФУНКЦИЯ STG_ДобавитьСтрокуПД(ТИП_СТРОКА: наименование; ТИП_ЧИСЛО: тариф, площадь, сальдо, суммаИтого)
  ЕСЛИ сальдо <> 0 ИЛИ суммаИтого > 0 ИЛИ оп_ФормироватьПустые ТО
    ВсегоСтр++
    Данные!ВсегоСтр!"A" = наименование
    Данные!ВсегоСтр!"B" = тариф
    Данные!ВсегоСтр!"C" = площадь
    Данные!ВсегоСтр!"D" = сальдо
    Данные!ВсегоСтр!"E" = ОКРУГЛЕНИЕ(суммаИтого, ?(ПараметрПечатиПД!"Округлять", 0, 2))
    г_итогоКОплате = г_итогоКОплате + Данные!ВсегоСтр!"E"
  КОНЕЦ_ЕСЛИ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
//накидывает строки ПД для ИПУ
ФУНКЦИЯ STG_ДобавитьСтрокуПДЭЭ(ТИП_СТРОКА: наименование; ТИП_ЧИСЛО: предПок, текПок, объем, тариф, потери, сальдо)
  ВсегоСтр++
  Данные!ВсегоСтр!"A" = наименование
  Данные!ВсегоСтр!"B" = предПок
  Данные!ВсегоСтр!"C" = текПок
  Данные!ВсегоСтр!"D" = ?(объем < 0, 0, объем) //?(текПок = 0, 0, текПок - предПок)
  Данные!ВсегоСтр!"E" = тариф
  Данные!ВсегоСтр!"F" = ОКРУГЛЕНИЕ(Данные!ВсегоСтр!"D" * тариф, ?(ПараметрПечатиПД!"Округлять", 0, 2))
  Данные!ВсегоСтр!"G" = потери//?(текПок = 0, 0, потери)
  Данные!ВсегоСтр!"H" = ОКРУГЛЕНИЕ(сальдо + потери, ?(ПараметрПечатиПД!"Округлять", 0, 2))
  г_итогоКОплате = г_итогоКОплате + Данные!ВсегоСтр!"H"
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ STG_ДобавитьСтрокуПДВГ(ТИП_СТРОКА: наименование; ТИП_ЧИСЛО: предПок, текПок, тариф, сальдо)
  ВсегоСтр++
  Данные!ВсегоСтр!"A" = наименование
  Данные!ВсегоСтр!"B" = предПок
  Данные!ВсегоСтр!"C" = ?(текПок = 0, 0, текПок) 
  Данные!ВсегоСтр!"D" = ?(текПок = 0, 0, текПок - предПок)
  Данные!ВсегоСтр!"E" = тариф
  Данные!ВсегоСтр!"F" = ОКРУГЛЕНИЕ(сальдо, ?(ПараметрПечатиПД!"Округлять", 0, 2))
  г_итогоКОплате = г_итогоКОплате + Данные!ВсегоСтр!"F"
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
//накидывает строки ПД для ИПУ
ФУНКЦИЯ STG_ДобавитьПустуюСтроку(ТИП_СТРОКА: наименование)
  ВсегоСтр++
  Данные!ВсегоСтр!"A" = наименование
  Данные!ВсегоСтр!"B" = ""
  Данные!ВсегоСтр!"C" = ""
  Данные!ВсегоСтр!"D" = ""
  Данные!ВсегоСтр!"E" = ""
  Данные!ВсегоСтр!"F" = ""
  Данные!ВсегоСтр!"G" = ""
  Данные!ВсегоСтр!"H" = ""
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ STG_ДобавитьСтрИтоговПоСтлб
  ЕСЛИ ВсегоСтр > 1 ТО
    итог!г_сервИнд = 0
    ЦИКЛ ДЛЯ(ж = 1, ВсегоСтр)
      ЦИКЛ ИНДЕКС(лог = Итоги!литера)
        ЕСЛИ лог ТО
          ЕСЛИ НЕ СУЩ_ПЕРЕМ(итог!литера) ТО
            итог!литера = 0
          КОНЕЦ_ЕСЛИ
          итог!литера = итог!литера + Данные!ж!литера
        КОНЕЦ_ЕСЛИ
      КОНЕЦ_ЦИКЛА
    КОНЕЦ_ЦИКЛА
    //
    ВсегоСтр++
    Данные!ВсегоСтр!"A" = "Итоги"
    Данные!ВсегоСтр!"B" = 0
    Данные!ВсегоСтр!"C" = 0
    Данные!ВсегоСтр!"D" = 0
    Данные!ВсегоСтр!"E" = 0
    ЦИКЛ ДЛЯ(и = 6, КолЯч)
      лит = ЛИТЕР(и)
      ЕСЛИ НЕ СУЩ_ПЕРЕМ(итог!лит) ТО
        итог!лит = 0
      КОНЕЦ_ЕСЛИ
      Данные!ВсегоСтр!лит = итог!лит
    КОНЕЦ_ЦИКЛА
  КОНЕЦ_ЕСЛИ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
//сброс строк ПД
ФУНКЦИЯ STG_СбросСтрокПД
  СБРОС(Данные, КолСтрТабл)
  г_итогоКОплате = 0
  ВсегоСтр = 0
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ STG_ПодготовитьПарамТабл(ТИП_СТРОКА: типКвитанции)
  STG_ПарамВыводаТаблиц
  РазбСтр=НЕТ
  Верх=0    // Верхний колонтитул                              
  Низ=0     // Нижний колонтитул
  НизСтр=0  // Нижний колонтитул для каждой страницы     
  ВерхСтр=0  // Верхний колонтитул для каждой страницы
  
  СБРОС_ТАБЛИЦ(ДА)
  ЕСЛИ типКвитанции = "ЭЭ" ТО
    ШирЯч!1=7;     ПредЯч!1=0;     НаимЯч!1 = "" //11
    ШирЯч!2=0;     ПредЯч!2=0;     НаимЯч!2 = "Показания"
    ШирЯч!3=8;     ПредЯч!3=2;     НаимЯч!3 = "нач. пок." //7
    ШирЯч!4=8;     ПредЯч!4=2;     НаимЯч!4 = "тек. пок." //7
    ШирЯч!5=8;     ПредЯч!5=0;     НаимЯч!5 = "Расход" //7
    ШирЯч!6=7;     ПредЯч!6=0;     НаимЯч!6 = "Тариф," + СИМВ(13) + "руб." //7
    ШирЯч!7=11;     ПредЯч!7=0;     НаимЯч!7 = "Начис- лено," + СИМВ(13) + "руб." //7
    ШирЯч!8=8;     ПредЯч!8=0;     НаимЯч!8 = "Потери," + СИМВ(13) + "руб." //7
    ШирЯч!9=11;     ПредЯч!9=0;     НаимЯч!9 = "Итого," + СИМВ(13) + "руб." 
    КолЯч = 9
    Дроб!"E" = 2
    Дроб!"F" = 2
    Дроб!"G" = 2
    Дроб!"H" = 2
    //Итоги!"F" = ДА
    //Итоги!"G" = ДА
    Итоги!"H" = ДА
    КоммИт = IB_STR_ВЫРАВНИВАНИЕ("Итого к оплате:", 56, "П") 
  ИНАЧЕ
    ЕСЛИ типКвитанции = "В" ИЛИ типКвитанции = "Г" ТО
      ШирЯч!1=14;     ПредЯч!1=0;     НаимЯч!1 = "Услуга"
      ШирЯч!2=0;      ПредЯч!2=0;     НаимЯч!2 = "Показания"
      ШирЯч!3=11;     ПредЯч!3=2;     НаимЯч!3 = "нач. пок."
      ШирЯч!4=11;     ПредЯч!4=2;     НаимЯч!4 = "тек. пок."
      ШирЯч!5=10;     ПредЯч!5=0;     НаимЯч!5 = "Расход"
      ШирЯч!6=10;     ПредЯч!6=0;     НаимЯч!6 = "Тариф," + СИМВ(13) + "руб."
      ШирЯч!7=12;     ПредЯч!7=0;     НаимЯч!7 = "Итого," + СИМВ(13) + "руб."
      КолЯч = 7
      Дроб!"E" = 2
      Дроб!"F" = 2
      Итоги!"F" = ДА
      КоммИт = IB_STR_ВЫРАВНИВАНИЕ("Итого к оплате:", 55, "П") 
    ИНАЧЕ
      ЕСЛИ типКвитанции = "новый" ТО
        КолЯч = 1
        ШирЯч!КолЯч=23;     ПредЯч!КолЯч=0;     НаимЯч!КолЯч = "Наименование"  КолЯч++
        ШирЯч!КолЯч=9;     ПредЯч!КолЯч=0;     НаимЯч!КолЯч = "Тариф"  КолЯч++
        ШирЯч!КолЯч=9;     ПредЯч!КолЯч=0;     НаимЯч!КолЯч = "Объем"  КолЯч++
        ШирЯч!КолЯч=10;     ПредЯч!КолЯч=0;     НаимЯч!КолЯч = "Начислено"  КолЯч++
        ШирЯч!КолЯч=9;     ПредЯч!КолЯч=0;     НаимЯч!КолЯч = "Долг"  КолЯч++
        ШирЯч!КолЯч=9;     ПредЯч!КолЯч=0;     НаимЯч!КолЯч = "Пени"  КолЯч++
        ШирЯч!КолЯч=9;     ПредЯч!КолЯч=0;     НаимЯч!КолЯч = "Итого"
        //
        Дроб!"B" = 2
        Дроб!"C" = 2
        Дроб!"D" = 2
        Дроб!"E" = 2
        Дроб!"F" = 2
        Дроб!"G" = 2
        Итоги!"D" = ДА
        Итоги!"E" = ДА
        Итоги!"F" = ДА
        Итоги!"G" = ДА
        КоммИт = IB_STR_ВЫРАВНИВАНИЕ("Итого к оплате:", 42, "П")
      ИНАЧЕ
        ШирЯч!1=28;     ПредЯч!1=0;     НаимЯч!1 = "Наименование"
        ШирЯч!2=10;     ПредЯч!2=0;     НаимЯч!2 = "Тариф," + СИМВ(13) + "руб."
        ШирЯч!3=10;     ПредЯч!3=0;     НаимЯч!3 = "Площадь"
        ШирЯч!4=10;     ПредЯч!4=0;     НаимЯч!4 = "Долг," + СИМВ(13) + "руб."
        ШирЯч!5=10;     ПредЯч!5=0;     НаимЯч!5 = "Итого," + СИМВ(13) + "руб."
        КолЯч = 5
        Дроб!"B" = 2
        Дроб!"C" = 2
        Дроб!"D" = 2
        Дроб!"E" = 2
        Итоги!"E" = ДА  
        КоммИт = IB_STR_ВЫРАВНИВАНИЕ("Итого к оплате:", 57, "П")
      КОНЕЦ_ЕСЛИ
    КОНЕЦ_ЕСЛИ
  КОНЕЦ_ЕСЛИ
  ВыделитьИтог = ДА
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ STG_ОпределитьРеквПолучателя
  ИСПОЛЬЗОВАТЬ("ORGANIZ")
  СБРОС(г_реквПолучателя)
  //Выбор банка
  банкИзСпрОрг = НЕТ
  ЕСЛИ ПараметрПечатиПД!"Реквизиты банка из спр. орг." ТО
    //
    ЕСЛИ ПараметрПечатиПД!"ID_BANK" <> 0 ТО
      ИД = СТР_ЗНАЧ(ПараметрПечатиПД!"ID_BANK")
      ЕСЛИ НЕ СУЩ_ПЕРЕМ(БанкИД!ИД) ТО
        СЧИТАТЬ_БАНК(ПараметрПечатиПД!"ID_BANK", ПараметрПечатиПД!"ID_ORG")
        ЕСЛИ СУЩ_ПЕРЕМ(БанкИД!ИД) ТО
          ЕСЛИ БанкИД!ИД > 0 ТО
            банкИзСпрОрг = ДА
          КОНЕЦ_ЕСЛИ
        КОНЕЦ_ЕСЛИ
      ИНАЧЕ
        банкИзСпрОрг = ДА
      КОНЕЦ_ЕСЛИ
    КОНЕЦ_ЕСЛИ
  КОНЕЦ_ЕСЛИ
  //
  ЕСЛИ банкИзСпрОрг ТО
    идОрг = ПараметрПечатиПД!"ID_ORG"
    СЧИТАТЬ_ОРГ(идОрг)   
    г_реквПолучателя!"наимОрг" = ОргНазв!СТР_ЗНАЧ(идОрг)
    г_реквПолучателя!"наимОргПолн" = ОргНазв!СТР_ЗНАЧ(идОрг)
    г_реквПолучателя!"кппОрг" = ОргКПП!СТР_ЗНАЧ(идОрг)
    г_реквПолучателя!"иннОрг" = ОргИНН!СТР_ЗНАЧ(идОрг)
    
    г_реквПолучателя!"расчСч" = БанкРасч!ИД
    г_реквПолучателя!"наимБанк" = БанкНазв!ИД
    г_реквПолучателя!"бик" = БанкБИК!ИД
    г_реквПолучателя!"коррСч" = БанкКорр!ИД
  ИНАЧЕ
    г_реквПолучателя!"наимОрг" = Предприят
    г_реквПолучателя!"наимОргПолн" = ПредприятПолн
    г_реквПолучателя!"кппОрг" = КПП
    г_реквПолучателя!"иннОрг" = ГосНом
    
    г_реквПолучателя!"расчСч" = НашРасчСч
    г_реквПолучателя!"наимБанк" = НашБанк
    г_реквПолучателя!"бик" = НашБанкБИК
    г_реквПолучателя!"коррСч" = НашБанкКсч
  КОНЕЦ_ЕСЛИ
  
  //умолчание
  г_реквизитыПолучателя = "Получатель платежа: " + г_реквПолучателя!"наимОрг" + 
                          ", ИНН " + г_реквПолучателя!"иннОрг" + 
                          ", КПП " + г_реквПолучателя!"кппОрг" + 
                          ", р/с " + г_реквПолучателя!"расчСч" + 
                          " в " + г_реквПолучателя!"наимБанк" + 
                          ", БИК " + г_реквПолучателя!"бик" + 
                          ", к/с " + г_реквПолучателя!"коррСч"
  //по шаблону
  ЕСЛИ СУЩ_ПЕРЕМ(г_ПарамШаблонаПД!к_ШаблонРеквизитыПолучателя) ТО
    г_СоотвШаблонаРеквизиту!к_ШаблонПредприят = г_реквПолучателя!"наимОрг"
    г_СоотвШаблонаРеквизиту!к_ШаблонПредприятПолн = г_реквПолучателя!"наимОргПолн"
    г_СоотвШаблонаРеквизиту!к_ШаблонИНН = г_реквПолучателя!"иннОрг"
    г_СоотвШаблонаРеквизиту!к_ШаблонКПП = г_реквПолучателя!"кппОрг"
    г_СоотвШаблонаРеквизиту!к_ШаблонРасчСч = г_реквПолучателя!"расчСч"
    г_СоотвШаблонаРеквизиту!к_ШаблонКоррСч = г_реквПолучателя!"коррСч"
    г_СоотвШаблонаРеквизиту!к_ШаблонБанк = г_реквПолучателя!"наимБанк"
    г_СоотвШаблонаРеквизиту!к_ШаблонБИК = г_реквПолучателя!"бик"
    //
    г_реквизитыПолучателя = г_ПарамШаблонаПД!к_ШаблонРеквизитыПолучателя
    ЦИКЛ ИНДЕКС(знач = г_СоотвШаблонаРеквизиту!шаблонПоля)
      г_реквизитыПолучателя = ЗАМ(шаблонПоля, г_реквизитыПолучателя, знач)
    КОНЕЦ_ЦИКЛА
  КОНЕЦ_ЕСЛИ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ ТИП_ЧИСЛО: STG_ПЕЧАТЬ_ПО(ТИП_СТРОКА: СтрПодр,ПринятоОт,Осн,Втч,Прил;
                                 ТИП_ЧИСЛО: Стр,НомДок,Сумма;
                                 ТИП_ДАТА: ДатаСост;
                                 ТИП_ЛОГИКА: нескСтат)
  СОЗДАТЬ(ШЖ12,ТИП_ШРИФТ)
  ШЖ12.жирн = ДА
  ШЖ12.размер = 12
  Ч = ЧИСЛО(ДатаСост)
  м = МЕС(ДатаСост)
  М = IB_STR_МЕСЯЦП(м)
  Г = ГОД(ДатаСост)
  //СуммПроп = СУММАП(РУБ(Сумма))
  //СуммКоп = СТР0(КОП(Сумма),2)

  ВЫВЕСТИ (28,1+Стр,"Унифицированная форма № КО-1")
  ВЫВЕСТИ (28,2+Стр,"Утверждена постановлением Госкомстата")
  ВЫВЕСТИ (28,3+Стр,"России от 18.08.98 г. № 88 ")

  ВСТАВИТЬ_РАМКУ(56,5+Стр,10,1)  //код
  ВСТАВИТЬ_РАМКУ(56,6+Стр,10,3,2) //жирная рамка
  ВСТАВИТЬ_РАМКУ(56,7+Стр,10,1) //ОКПО
  ВСТАВИТЬ_РАМКУ(1,7+Стр,40,0) //организация
  ВСТАВИТЬ_РАМКУ(1,9+Стр,55,0) //структурное подразделение

  ВЫВЕСТИ(43,6+Стр,"Форма по ОКУД")
