ИСПОЛЬЗОВАТЬ_БИБЛ("ST_GSK\ST_GSK_CONST")
ИСПОЛЬЗОВАТЬ_БИБЛ("ST_GSK\ST_GSK_PEREM")
ИСПОЛЬЗОВАТЬ_БИБЛ("ST_GSK\ST_GSK_LIB01")
ИСПОЛЬЗОВАТЬ_БИБЛ("ST_GSK\ST_GSK_CONFIG")
ИСПОЛЬЗОВАТЬ_БИБЛ("IB_STR")
ИСПОЛЬЗОВАТЬ_БИБЛ("IB_DLG")

//-------------------------------------------------------------------------------------------------------------------------//
//сбрасываются сразу после заполнения шаблона соответствующего реквизита
ПЕРЕМ stg_tmpl_значениеПеремРП!    //реквизиты получателя
ПЕРЕМ stg_tmpl_значениеПеремНП!    //назначение платежа
ПЕРЕМ stg_tmpl_значениеПеремАП!    //адрес плательщика
ПЕРЕМ stg_tmpl_значениеПеремФИО!   //фио плательщика
ПЕРЕМ stg_tmpl_значениеПеремСодХО! //содержание хоз. оп.

//-------------------------------------------------------------------------------------------------------------------------//
//всегда передавать строго
ФУНКЦИЯ STG_ДобавитьЗначениеПарам(ТИП_ЧИСЛО: кодРеквизита;  //код графы или реквизита           
                                  ТИП_СТРОКА: кодПараметра, //код заменяемого параметра - %параметр%
                                              значение)     //значение
  ВЫБОР(кодРеквизита)
   #к_ШаблонРеквизитыПолучателя : 
    stg_tmpl_значениеПеремРП!кодПараметра = значение
   #к_ШаблонНазначениеПлатежа : 
    stg_tmpl_значениеПеремНП!кодПараметра = значение
   #к_ШаблонАдресПлательщика : 
    stg_tmpl_значениеПеремАП!кодПараметра = значение
   #к_ШаблонФИОПлательщика : 
    stg_tmpl_значениеПеремФИО!кодПараметра = значение
   #к_ШаблонСодержаниеХозОп : 
    stg_tmpl_значениеПеремСодХО!кодПараметра = значение
  КОНЕЦ_ВЫБОРА
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
//код ПД по названию
ФУНКЦИЯ ТИП_ЧИСЛО: STG_КодПДПоНазванию(ТИП_СТРОКА: стр; ПЕРЕМ ТИП_СТРОКА: признакПарам)
  ВЫБОР(стр)
    #к_ФормаПДМнож : STG_КодПДПоНазванию = к_ФормаПДМножКод
                     признакПарам = к_признакПарамШаблонаПД
    #к_ФормаПД4 : STG_КодПДПоНазванию = к_ФормаПД4Код
                  признакПарам = к_признакПарамШаблонаПД
    #к_ФормаПДСчСтд : STG_КодПДПоНазванию = к_ФормаПДСчСтдКод
                      признакПарам = к_признакПарамШаблонаПД
    #к_ФормаПД4ЭЭ : STG_КодПДПоНазванию = к_ФормаПД4ЭЭКод
                    признакПарам = к_признакПарамШаблонаПД
    #к_содХОПоНачВзносов : STG_КодПДПоНазванию = к_содХОПоНачВзносовКод
                           признакПарам = к_признакПарамШаблонаХО
    #к_содХОПоНачПоИПУ : STG_КодПДПоНазванию = к_содХОПоНачПоИПУКод
                         признакПарам = к_признакПарамШаблонаХО
    #к_содХОПоОплатам : STG_КодПДПоНазванию = к_содХОПоОплатамКод
                        признакПарам = к_признакПарамШаблонаХО
    #к_содХОПоПени : STG_КодПДПоНазванию = к_содХОПоПениКод
                     признакПарам = к_признакПарамШаблонаХО
    #к_содХОПоНачПриОплате : STG_КодПДПоНазванию = к_содХОПоНачПриОплатеКод
                             признакПарам = к_признакПарамШаблонаХО
    #к_формаПКО : STG_КодПДПоНазванию = к_формаПКОКод
                  признакПарам = к_признакПарамШаблонаПД
    #к_ОбщиеРеквизиты : STG_КодПДПоНазванию = к_ОбщиеРеквизитыКод
                        признакПарам = к_признакПарамШаблонаДШК
  ИНАЧЕ
    ЕСЛИ ПОЗ(к_ФормаПДМнож, стр) > 0 ТО
      STG_КодПДПоНазванию = к_ФормыПДВзносыКод
    ИНАЧЕ
      STG_КодПДПоНазванию = к_ФормыПДИПУКод
    КОНЕЦ_ЕСЛИ
    признакПарам = к_признакПарамШаблонаДШК
  КОНЕЦ_ВЫБОРА
КОНЕЦ_ФУНКЦИИ

//коды шаблонов граф/рекзвизитов по их названию
