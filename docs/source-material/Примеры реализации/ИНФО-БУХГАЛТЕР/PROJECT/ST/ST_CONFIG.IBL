ИСПОЛЬЗОВАТЬ_БИБЛ("IB_DBF")
ИСПОЛЬЗОВАТЬ_БИБЛ("IB_PROFILE")
ИСПОЛЬЗОВАТЬ_БИБЛ("IB_CONF")
ИСПОЛЬЗОВАТЬ_БИБЛ("IB_TABLE_SETTINGS")
ИСПОЛЬЗОВАТЬ_БИБЛ("ST\ST_CONST")

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ ТИП_ЛОГИКА: ST_КонвертерБД
  ST_СчитатьВерсии
  ST_ОбновитьПоляБД
  ST_ОбновитьБазуДанных
  ST_ОбновитьРабМесто
  ST_СоздатьНастрТаблиц
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
//Обновление базы данных
ФУНКЦИЯ ST_ОбновитьБазуДанных
  ЕСЛИ г_текВерсияБлока < к_ВерсияБД ТО
    ЕСЛИ г_текВерсияБлока < 2.1 ТО
      ST_CREATE_ID_УЧАСТКИ
      ST_КОНВ_ФПСЭЭ
      ST_UPDATE_CODP
    КОНЕЦ_ЕСЛИ
    ЕСЛИ г_текВерсияБлока < 2.2 ТО
      ST_N_DOM_TO_CHAR
    КОНЕЦ_ЕСЛИ
    ЕСЛИ г_текВерсияБлока < 2.3 ТО
      ST_UPDATE_ID_AREA
    КОНЕЦ_ЕСЛИ
    /*ЕСЛИ г_текВерсияБлока < 2.4 ТО
      ST_КОНВ_ФСПРВЛАД
    КОНЕЦ_ЕСЛИ*/
    ЕСЛИ г_текВерсияБлока < 2.47 ТО
      ST_УстМетодРаспр
      ST_ЗапПолеСорт(ф_СпрУчастковГаражей, "N_AREA", "SRT")
    КОНЕЦ_ЕСЛИ
    ЕСЛИ г_текВерсияБлока < 2.48 ТО
      ST_КОНВ_ФСПРВЛАД //повторно
      ST_УстПризнакиСвязиВлад
    КОНЕЦ_ЕСЛИ
    ЕСЛИ г_текВерсияБлока < 2.49 ТО
      ST_ОбновитьДоВерсии249
    КОНЕЦ_ЕСЛИ
    ЕСЛИ г_текВерсияБлока < 2.55 ТО
      ST_ЗапПолеСорт(ф_СпрУчастковГаражей, "N_AREA", "SRT")
    КОНЕЦ_ЕСЛИ
    ЕСЛИ г_текВерсияБлока < 2.59 ТО
      ST_ОбновитьЧленство
      ST_ЗаполнитьСпрУслуг
    КОНЕЦ_ЕСЛИ
    ЕСЛИ г_текВерсияБлока < 3.00 ТО
      ST_ОбновитьДоВерсии300
    КОНЕЦ_ЕСЛИ
    ЕСЛИ г_текВерсияБлока < 3.01 ТО
      ST_ОбновитьДоВерсии301
      STG_КонвЖХОвDBF
    КОНЕЦ_ЕСЛИ
    ЕСЛИ г_текВерсияБлока < 3.02 ТО
      ST_ОбновитьДоВерсии302
    КОНЕЦ_ЕСЛИ
    ЕСЛИ г_текВерсияБлока < 3.03 ТО
      ST_ОбновитьДоВерсии303
    КОНЕЦ_ЕСЛИ
    ЕСЛИ г_текВерсияБлока < 3.04 ТО
      ST_ОбновитьДоВерсии304
    КОНЕЦ_ЕСЛИ
    ЕСЛИ г_текВерсияБлока < 3.07 ТО
      ST_ОбновитьДоВерсии307
    КОНЕЦ_ЕСЛИ
    ЕСЛИ г_текВерсияБлока < 3.15 ТО
      ST_ОбновитьДоВерсии315
    КОНЕЦ_ЕСЛИ
    ЕСЛИ г_текВерсияБлока < 3.17 ТО
      ST_ОбновитьДоВерсии317
    КОНЕЦ_ЕСЛИ
    ЕСЛИ г_текВерсияБлока < 3.18 ТО
      ST_ОбновитьДоВерсии318
    КОНЕЦ_ЕСЛИ
    ЕСЛИ г_текВерсияБлока < 3.19 ТО
      ST_ОбновитьДоВерсии319
    КОНЕЦ_ЕСЛИ
    ЕСЛИ г_текВерсияБлока < 3.21 ТО
      ST_ПереносАрхивовСпр
    КОНЕЦ_ЕСЛИ
    ЕСЛИ г_текВерсияБлока < 3.24 ТО
      ST_ОбновитьДоВерсии317
    КОНЕЦ_ЕСЛИ
    ЕСЛИ г_текВерсияБлока < 3.25 ТО
      ST_ОбновитьДоВерсии325
    КОНЕЦ_ЕСЛИ
    ЕСЛИ г_текВерсияБлока < 3.26 ТО
      ST_ОбновитьДоВерсии326
    КОНЕЦ_ЕСЛИ
    ЕСЛИ г_текВерсияБлока < 3.29 ТО
      ST_ОбновитьДоВерсии328
      ST_ОбновитьДоВерсии329
    КОНЕЦ_ЕСЛИ
    ЕСЛИ г_текВерсияБлока < 3.33 ТО
      ST_ОбновитьДоВерсии333
    КОНЕЦ_ЕСЛИ
    ЕСЛИ г_текВерсияБлока < 3.38 ТО
      ST_ОбновитьДоВерсии338
    КОНЕЦ_ЕСЛИ
    ЕСЛИ г_текВерсияБлока < 3.40 ТО
      ST_ОбновитьДоВерсии340
    КОНЕЦ_ЕСЛИ
    ЕСЛИ г_текВерсияБлока < 3.41 ТО
      ST_ОбновитьДоВерсии341
    КОНЕЦ_ЕСЛИ
    ЕСЛИ г_текВерсияБлока < 3.42 ТО
      ST_ОбновитьДоВерсии342
    КОНЕЦ_ЕСЛИ
    ЕСЛИ г_текВерсияБлока < 3.44 ТО
      STG_ОбновитьДатуВСпрВлад
    КОНЕЦ_ЕСЛИ
    ЕСЛИ г_текВерсияБлока < 3.45 ТО
      STG_ОбновитьДатуВСпрВлад
    КОНЕЦ_ЕСЛИ
    //
    ЕСЛИ г_текВерсияБлока < 3.49 ТО
      STG_КорректКодУлДляИПУ
    КОНЕЦ_ЕСЛИ
    ЕСЛИ г_текВерсияБлока < 3.50 ТО
      ST_ОбновитьПоляФЛС
    КОНЕЦ_ЕСЛИ
    ЕСЛИ г_текВерсияБлока < 3.51 ТО
      STG_КоррСуммыЖурнала
    КОНЕЦ_ЕСЛИ
    ЕСЛИ г_текВерсияБлока < 3.52 ТО
      STG_КоррИдентВзносов
    КОНЕЦ_ЕСЛИ
    ЕСЛИ г_текВерсияБлока < 3.55 ТО
      STG_КорректировкаПоляIsSynced
    КОНЕЦ_ЕСЛИ
    ЕСЛИ г_текВерсияБлока < 3.58 ТО
      ST_ОбновитьДоВерсии358
    КОНЕЦ_ЕСЛИ
    
    ЕСЛИ г_текВерсияБлока < 3.67 ТО
      IB_DBF_ДОБАВИТЬ_ПОЛЕ(ф_СпрДиапОбъемовЭЭ, "С", "ROV", 10, 0)
      IB_DBF_ДОБАВИТЬ_ПОЛЕ(ф_НастройкиБлока, "Л", "VAL14", 0, 0)
    КОНЕЦ_ЕСЛИ
    //
    IB_CONF_ЗаписатьВерсиюБД(к_имяБлока, к_ВерсияБД)
  КОНЕЦ_ЕСЛИ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
//Обновление рабочего места
ФУНКЦИЯ ST_ОбновитьРабМесто
  ЕСЛИ г_текВерсияРабМеста < к_ВерсияРабМеста ТО
    ЕСЛИ г_текВерсияРабМеста < 0.04 ТО
      STG_ОбновитьНастрБланка("Реестр собственников")
    КОНЕЦ_ЕСЛИ
    
    ЕСЛИ г_текВерсияРабМеста < 0.05 ТО
      STG_ОбновитьНастрБланка("Настройки блока")
    КОНЕЦ_ЕСЛИ
    
    ЕСЛИ г_текВерсияРабМеста < 0.06 ТО
      STG_ОбновитьНастрБланка("Реестр собственников")
      STG_ОбновитьНастрБланка("Настройки блока")
      
      STG_ЗаполнитьШаблоны(к_ФормыПДВзносыКод)
      STG_ЗаполнитьШаблоны(к_ФормыПДИПУКод)
    КОНЕЦ_ЕСЛИ
    
    ЕСЛИ г_текВерсияРабМеста < 0.07 ТО 
      STG_ОбновитьНастрБланка("Настройки блока")
    КОНЕЦ_ЕСЛИ
    
    ЕСЛИ г_текВерсияРабМеста < 0.08 ТО
      ST_ОбновитьРабМестоДо008
    КОНЕЦ_ЕСЛИ
    
    ЕСЛИ г_текВерсияРабМеста < 0.09 ТО
      STG_ОбновитьНастрБланка("Реестр участков")
    КОНЕЦ_ЕСЛИ
    
    ЕСЛИ г_текВерсияРабМеста < 0.11 ТО
      ST_ОбновитьРабМестоДо011
    КОНЕЦ_ЕСЛИ
    
    ЕСЛИ г_текВерсияРабМеста < 0.12 ТО
      ST_ОбновитьРабМестоДо012
    КОНЕЦ_ЕСЛИ
    
    ЕСЛИ г_текВерсияРабМеста < 0.13 ТО
      STG_ОбновитьНастрБланка("Реестр участков")
    КОНЕЦ_ЕСЛИ
    
    ЕСЛИ г_текВерсияРабМеста < 0.14 ТО
      ST_ОбновитьРМДоВерсии014
    КОНЕЦ_ЕСЛИ
    
    ЕСЛИ г_текВерсияРабМеста < 0.15 ТО
      ST_ОбновитьРМДоВерсии015
    КОНЕЦ_ЕСЛИ
    
    ЕСЛИ г_текВерсияРабМеста < 0.16 ТО
      ST_ОбновитьРМДоВерсии016
    КОНЕЦ_ЕСЛИ
    
    ЕСЛИ г_текВерсияРабМеста < 0.17 ТО
      ST_ОбновитьРМДоВерсии017
    КОНЕЦ_ЕСЛИ
  
    IB_CONF_ЗаписатьВерсиюРМ(к_имяБлока, к_ВерсияРабМеста)
  КОНЕЦ_ЕСЛИ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
//версии БД и РМ
ФУНКЦИЯ ST_СчитатьВерсии
  логВерБД = IB_CONF_СчитатьВерсиюБД(к_имяБлока, г_текВерсияБлока)
  логВерРМ = IB_CONF_СчитатьВерсиюРМ(к_имяБлока, г_текВерсияРабМеста)

  ЕСЛИ НЕ логВерБД ИЛИ НЕ логВерРМ ТО
    ЕСЛИ СУЩ_ФАЙЛ(ф_ВерсияБДСТ) ТО //старая база - его не грохаем из-за сетевой версии
      sql = SQL_ОТКРЫТЬ(ф_ВерсияБДСТ)
      sql.ПЕРЕЙТИ(1)
      г_текВерсияБлока = ?(логВерБД, г_текВерсияБлока, sql.ПОЛЕ("VERBD"))
      ЕСЛИ НЕ логВерРМ ТО
        ЕСЛИ sql.IB_DBF_ПОЛЕ_СУЩ("VERWP") ТО
          г_текВерсияРабМеста = sql.ПОЛЕ("VERWP")
        ИНАЧЕ
          г_текВерсияРабМеста = 0
        КОНЕЦ_ЕСЛИ
      ИНАЧЕ
        г_текВерсияРабМеста = г_текВерсияРабМеста
      КОНЕЦ_ЕСЛИ
      sql.ЗАКРЫТЬ
    ИНАЧЕ //новая база
      г_текВерсияБлока = к_ВерсияБД
      г_текВерсияРабМеста = к_ВерсияРабМеста
      г_новаяБаза = ДА
    КОНЕЦ_ЕСЛИ
  КОНЕЦ_ЕСЛИ
  
  ЕСЛИ НЕ логВерБД ТО
    IB_CONF_ЗаписатьВерсиюБД(к_имяБлока, г_текВерсияБлока)
  КОНЕЦ_ЕСЛИ
  
  ЕСЛИ НЕ логВерРМ ТО
    IB_CONF_ЗаписатьВерсиюРМ(к_имяБлока, г_текВерсияРабМеста)
  КОНЕЦ_ЕСЛИ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
//Добавляет определение ГСКИлиСНТ, которое влияет на заголовки в справочниках, бланках и т.д. Выбор идет из слов гараж и участок
ФУНКЦИЯ ТИП_ЛОГИКА: ST_ДобОпрГСКИлиСНТ
  ЕСЛИ НЕ СУЩ_ОПРЕДЕЛЕНИЕ("ГСКИлиСНТ") ТО
    ДОБАВИТЬ_ОПРЕДЕЛЕНИЕ("ГСКИлиСНТ", "СНТ - 1(участок), ГСК - 2(гараж)", 1)
  КОНЕЦ_ЕСЛИ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
//Конвертирует показания счетчиков и создает счетчики в справочнике.
ФУНКЦИЯ ТИП_ЛОГИКА: ST_КОНВ_ФПСЭЭ
  СОЗДАТЬ(СП,ТИП_СПИСОК)
  //1. Считаем все идшники участков
  СП.ДОБАВИТЬ("SELECT DISTINCT CODS,N_AREA,ID_AREA FROM ")
  СП.ДОБАВИТЬ("'"+ф_СпрУчастковГаражей+"'")
  sql = SQL_ЗАПРОС(СП)
  ЕСЛИ sql.ВСЕГО>0 ТО //если база все таки не новая.
    ЦИКЛ ДЛЯ(и=1, sql.ВСЕГО)
      sql.ПЕРЕЙТИ(и)
      IdArea!СТР(sql.ПОЛЕ("CODS"))!СТР(sql.ПОЛЕ("N_AREA")) = sql.ПОЛЕ("ID_AREA")
    КОНЕЦ_ЦИКЛА
    //sql.ЗАКРЫТЬ
    файл!1 = файлСчетчик  COT!1 = "1"
    файл!2 = файлСчетчик2 COT!2 = "2"
    //2. Считаем файл однотарифных и запишем его в общий.
    ЦИКЛ ДЛЯ (Ф=1,2)
      //0. Проверим существование файлов
      ЕСЛИ НЕ СУЩ_ФАЙЛ(файл!Ф) ТО
        ПРОДОЛЖИТЬ
      КОНЕЦ_ЕСЛИ
      //1. Запишем счетчики в справочник
      СП.ОЧИСТИТЬ
      СП.ДОБАВИТЬ("SELECT DISTINCT CODS, N_AREA FROM")
      СП.ДОБАВИТЬ("'"+файл!Ф+"'")
      бд = SQL_ЗАПРОС(СП)
      ЦИКЛ ДЛЯ (и=1, бд.ВСЕГО)
        бд.ПЕРЕЙТИ(и)
        ЕСЛИ СУЩ_ПЕРЕМ(IdArea!СТР(бд.ПОЛЕ("CODS"))!СТР(бд.ПОЛЕ("N_AREA"))) ТО
          идуч = IdArea!СТР(бд.ПОЛЕ("CODS"))!СТР(бд.ПОЛЕ("N_AREA"))
          идсч = IB_DBF_МаксЗначПоля(ф_СпрИндивСчетчики,"ID") + 1
          IdSch!СТР(бд.ПОЛЕ("CODS"))!СТР(бд.ПОЛЕ("N_AREA")) = идсч
          номсч = "СчЭЭ-"+бд.ПОЛЕ("CODS")+"-" + бд.ПОЛЕ("N_AREA")
          СП.ОЧИСТИТЬ
          СП.ДОБАВИТЬ("INSERT INTO '"+ф_СпрИндивСчетчики+"'")
          СП.ДОБАВИТЬ("(ID_AREA,CODS,ID,COT,NOM,MODEL,NPOK1,NPOK2,NPOK3,DATUST,DATEND,TYPE,OBSCH,KOMMENT,SCH) VALUES")
          СП.ДОБАВИТЬ("("+СТР(идуч)+",'"+бд.ПОЛЕ("CODS")+"',"+СТР(идсч)+","+COT!Ф+",'"+номсч+"','',0,0,0,'01.01.2001','01.01.2051','ЭЭ',0,'','')")
          sql1 = SQL_ЗАПРОС(СП)
         sql1.ЗАКРЫТЬ
        КОНЕЦ_ЕСЛИ
      КОНЕЦ_ЦИКЛА
      бд.ЗАКРЫТЬ
      //2. Перенесем показания счетчика
      бд = SQL_ОТКРЫТЬ(файл!Ф)
      ЦИКЛ ДЛЯ (и=1, бд.ВСЕГО)
        бд.ПЕРЕЙТИ(и)
        Идент = СТР(бд.ПОЛЕ("CODS"))+СТР(бд.ПОЛЕ("N_AREA"))
        ЕСЛИ СУЩ_ПЕРЕМ(IdArea!Идент) И СУЩ_ПЕРЕМ(IdSch!Идент) ТО
          СП.ОЧИСТИТЬ
          СП.ДОБАВИТЬ("INSERT INTO '"+ф_ПоказанияИСЭЭ+"' ")
          СП.ДОБАВИТЬ("(CODS,ID_AREA,ID_SCH,DAT,NUM1,NUM2,NUM3) VALUES ('"+бд.ПОЛЕ("CODS")+"','"+СТР(IdArea!Идент)+"'")
          СП.ДОБАВИТЬ(","+СТР(IdSch!Идент)+",'"+СТР(бд.ПОЛЕ("DAT"))+"','"+СТР(бд.ПОЛЕ("NUM"))+"',")
          ЕСЛИ Ф=1 ТО
            СП.ДОБАВИТЬ("0,0)")
          ИНАЧЕ
            СП.ДОБАВИТЬ("'"+СТР(бд.ПОЛЕ("NUM2"))+"',0)")
          КОНЕЦ_ЕСЛИ
          sql1 = SQL_ЗАПРОС(СП)
          sql1.ЗАКРЫТЬ
        КОНЕЦ_ЕСЛИ
      КОНЕЦ_ЦИКЛА
      бд.ЗАКРЫТЬ
      ЕСЛИ НЕ СУЩ_ФАЙЛ(г_папкаБлока + "/poksch" + СТР(Ф) + ".bak") ТО
        успех = ФАЙЛ_КОПИРОВАТЬ (файл!Ф, г_папкаБлока + "/poksch" + СТР(Ф) + ".bak")
        IB_FILE_ФайлУдалить(файл!Ф)
      КОНЕЦ_ЕСЛИ
    КОНЕЦ_ЦИКЛА
    ST_КОНВ_ФПСЭЭ = ДА
  КОНЕЦ_ЕСЛИ
КОНЕЦ_ФУНКЦИИ
//-------------------------------------------------------------------------------------------------------------------------//
//Добавление полей в базу
ФУНКЦИЯ ТИП_ЛОГИКА: ST_ОбновитьПоляБД
  ЕСЛИ г_текВерсияБлока < 2.3 ТО //прежде чем грохнем N_DOM
    ST_UPDATE_ID_AREA
  КОНЕЦ_ЕСЛИ
  
  ЕСЛИ г_текВерсияБлока < 2.4 ТО
    IB_DBF_ДОБАВИТЬ_ПОЛЕ(ф_СпрУчастковГаражей, "Ч", "ID_AREA", 5, 0)
    IB_DBF_ДОБАВИТЬ_ПОЛЕ(ф_СпрУчастковГаражей, "С", "MOBILE", 20, 0)
    IB_DBF_ДОБАВИТЬ_ПОЛЕ(ф_СпрУчастковГаражей, "С", "SCH", 1, 0)
    IB_DBF_ДОБАВИТЬ_ПОЛЕ(ф_СпрУчастковГаражей, "Л", "PRIV", 0, 0)
    //17.12.2015
    IB_DBF_ДОБАВИТЬ_ПОЛЕ(ф_СпрСвязьЦВиУч, "Ч", "ID_AREA", 5, 0)
  КОНЕЦ_ЕСЛИ
  //07.04.2016
  ЕСЛИ г_текВерсияБлока < 2.41 ТО
    //ID текущего владельца
    IB_DBF_ДОБАВИТЬ_ПОЛЕ(ф_СпрУчастковГаражей, "Ч", "ID_OWNER", 5, 0)
  КОНЕЦ_ЕСЛИ
  ЕСЛИ г_текВерсияБлока < 2.43 ТО
    IB_DBF_ДОБАВИТЬ_ПОЛЕ(ф_СвязьВладУч, "С", "NOMSV", 30, 0)
    IB_DBF_ДОБАВИТЬ_ПОЛЕ(ф_СвязьВладУч, "Д", "DATREGSV", 0, 0)
    IB_DBF_ДОБАВИТЬ_ПОЛЕ(ф_СвязьВладУч, "Д", "DATOTCHSV", 0, 0)
  КОНЕЦ_ЕСЛИ
  //пусть все время проверяет
  ЕСЛИ г_текВерсияБлока < 2.45 ТО
    IB_DBF_ДОБАВИТЬ_ПОЛЕ(ф_СпрИндивСчетчики, "Ч", "TOKEN", 2, 0)
    IB_DBF_ДОБАВИТЬ_ПОЛЕ(ф_СпрИндивСчетчики, "Д", "TOKEN_DATE", 0, 0)
    IB_DBF_ДОБАВИТЬ_ПОЛЕ(ф_СпрТарифов, "Ч", "TOKEN", 2, 0)
  КОНЕЦ_ЕСЛИ
  //
  ЕСЛИ г_текВерсияБлока < 2.46 ТО
    IB_DBF_ДОБАВИТЬ_ПОЛЕ(ф_СпрУчастковГаражей, "С", "METHOD_RAS", 50, 0)
