//-------------------------------------------------------------------------------------------------------------------------//
//Обновление бд до версии 3.15
ФУНКЦИЯ ST_ОбновитьДоВерсии315
  sql = SQL_ОТКРЫТЬ(ф_НастройкиПечатиПД)
  лог = (sql.ТИП_ПОЛЯ("POL11") = "Л" И sql.ТИП_ПОЛЯ("POL12") = "Л")
  логВсего = (sql.ВСЕГО > 0)
  sql.ЗАКРЫТЬ
  //
  ЕСЛИ лог ТО
    IB_DBF_УДАЛИТЬ_ПОЛЕ(ф_НастройкиПечатиПД, "POL11")
    IB_DBF_УДАЛИТЬ_ПОЛЕ(ф_НастройкиПечатиПД, "POL12")
    
    IB_DBF_ДОБАВИТЬ_ПОЛЕ(ф_НастройкиПечатиПД, "С", "POL11", 30, 0) //реквизит Вид платежа для ИПУ
    IB_DBF_ДОБАВИТЬ_ПОЛЕ(ф_НастройкиПечатиПД, "С", "POL12", 30, 0) //реквизит Вид платежа для остальных
    IB_DBF_ДОБАВИТЬ_ПОЛЕ(ф_НастройкиПечатиПД, "С", "POL14", 50, 0) //форма квитанции для ИПУ
    IB_DBF_ДОБАВИТЬ_ПОЛЕ(ф_НастройкиПечатиПД, "С", "POL15", 50, 0) //форма квитанции для остальных
    //
    ЕСЛИ логВсего ТО
      СОЗДАТЬ(сп, ТИП_СПИСОК)
      сп.ДОБАВИТЬ("UPDATE")
      сп.ДОБАВИТЬ("'" + ф_НастройкиПечатиПД + "'")
      сп.ДОБАВИТЬ("SET POL14 = '" + к_ФормаПДСчСтд + "', POL15 = '" + к_ФормаПДМнож + "'")
      SQL_ЗАПРОС(сп)
    КОНЕЦ_ЕСЛИ
  КОНЕЦ_ЕСЛИ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ ST_ОбновитьДоВерсии317
  СОЗДАТЬ(сп, ТИП_СПИСОК)
  сп.ДОБАВИТЬ("UPDATE")
  сп.ДОБАВИТЬ("'" + ф_ПоказанияИСЭЭ + "'")
