//-------------------------------------------------------------------------------------------------------------------------//
//обновляет поле MEMBER в справочнике связи владельцев и участков
ФУНКЦИЯ ST_ОбновитьЧленство
  СОЗДАТЬ(сп, ТИП_СПИСОК)
  сп.ДОБАВИТЬ("UPDATE '" + ф_СвязьВладУч + "'")
  сп.ДОБАВИТЬ("SET MEMBER = TRUE")
  update = SQL_ЗАПРОС(сп)
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
//сконверчу справочник услуг
ФУНКЦИЯ ST_ЗаполнитьСпрУслуг
  STG_R_НастройкиПечатиПД
  СОЗДАТЬ(сп, ТИП_СПИСОК)
  естьСтатья!г_сервИнд = ДА

  sql = SQL_ОТКРЫТЬ(ф_СпрЦелевыхВзносов)
  ЦИКЛ ДЛЯ(и = 1, sql.ВСЕГО)
    sql.ПЕРЕЙТИ(и)
    код = sql.ПОЛЕ("CODP")
    естьСтатья!код = ДА
  КОНЕЦ_ЦИКЛА
  sql.ЗАКРЫТЬ

  ЕСЛИ НЕ СУЩ_ПЕРЕМ(естьСтатья!к_СтатьиЧлВзКод) ТО
    идент = 0
    sql = SQL_ОТКРЫТЬ(ф_СпрЦелевыхВзносов)
    ЦИКЛ ДЛЯ(и = 1, sql.ВСЕГО)
      sql.ПЕРЕЙТИ(и)
      идент++
      //проапдейтим уже готовые
      сп.ОЧИСТИТЬ
      сп.ДОБАВИТЬ("UPDATE")
      сп.ДОБАВИТЬ("'" + ф_СпрЦелевыхВзносов + "'")
      сп.ДОБАВИТЬ("SET REC_NAME = " + ?(ПараметрПечатиПД!"Членские взносы в назначении платежа", "'" + к_СтатьиЧлВз + "'", "CAP") +
                  ", TYPE = '" + к_ТипСтатьиЦлВз + "', METHOD = " + СТР(к_МетодРасчетаФиксВзносКод) + ", COT = " +
                  СТР(к_ТарифностьОднотарифная) + ", ORDER_BY = 20, ID = " + СТР(идент))
      сп.ДОБАВИТЬ("WHERE CODP = '" + sql.ПОЛЕ("CODP") + "'")
      update = SQL_ЗАПРОС(сп)
      //
      сп.ОЧИСТИТЬ
      сп.ДОБАВИТЬ("INSERT INTO")
      сп.ДОБАВИТЬ("'" + ф_СпрТарифов + "'")
      сп.ДОБАВИТЬ("(ID, TYPE, COT, T1, D1, D2) VALUES")
      сп.ДОБАВИТЬ("(" + СТР(идент) + ", '" + sql.ПОЛЕ("CODP") + "', " + СТР(к_ТарифностьОднотарифная) + ", " +
                  СТР(sql.ПОЛЕ("CENA")) + ", '" + СТР(к_МинДата) + "', '" + СТР(к_МаксДата) + "')")
      insert = SQL_ЗАПРОС(сп)
    КОНЕЦ_ЦИКЛА
    sql.ЗАКРЫТЬ

    //обязательной услугой является ЧлВз
    идент++
    сп.ОЧИСТИТЬ
    сп.ДОБАВИТЬ("INSERT INTO")
    сп.ДОБАВИТЬ("'" + ф_СпрЦелевыхВзносов + "'")
    сп.ДОБАВИТЬ("(ID, CODP, CAP, REC_NAME, TYPE, METHOD, COT, ORDER_BY) VALUES ")
    сп.ДОБАВИТЬ("(" + СТР(идент) + ", '" + к_СтатьиЧлВзКод + "', '" + к_СтатьиЧлВз + "', '" + к_СтатьиЧлВз + "', ")
    сп.ДОБАВИТЬ("'" + к_СтатьиЧлВз + "', " + СТР(к_МетодРасчетаПоПлощадиКод) + ", " +
                СТР(к_ТарифностьОднотарифная) + ", " + СТР(STG_ПорядокУслуги(к_СтатьиЧлВз)) + ")")
    insert = SQL_ЗАПРОС(сп)
    //
    сп.ОЧИСТИТЬ
    сп.ДОБАВИТЬ("UPDATE")
    сп.ДОБАВИТЬ("'" + ф_СпрТарифов + "'")
    сп.ДОБАВИТЬ("SET ID = " + СТР(идент) + "WHERE TYPE = '" + к_СтатьиЧлВзКод + "'")
    update = SQL_ЗАПРОС(сп)

    //остальные по необходимости из спр тарифов и целевых взносов
    сп.ОЧИСТИТЬ
    сп.ДОБАВИТЬ("SELECT DISTINCT TYPE, COT FROM")
    сп.ДОБАВИТЬ("'" + ф_СпрТарифов + "'")
    sql = SQL_ЗАПРОС(сп)
    ЦИКЛ ДЛЯ(и = 1, sql.ВСЕГО)
      sql.ПЕРЕЙТИ(и)
      код = sql.ПОЛЕ("TYPE")
      тар = sql.ПОЛЕ("COT")
      ВЫБОР(код)
       #к_СтатьиЭЭКод, к_СтатьиЭОКод, к_СтатьиВКод, к_СтатьиГКод, к_СтатьиОТКод:
        ВЫБОР(код)
         #к_СтатьиЭЭКод : имя = к_СтатьиЭЭ + ?(тар = 2, "(двухтарифная)", ?(тар = 3, "(трехтарифная)", ""))
                          имя2 = к_СтатьиЭЭ
         #к_СтатьиЭОКод : имя = к_СтатьиЭО + ?(тар = 2, "(двухтарифная)", ?(тар = 3, "(трехтарифная)", ""))
                          имя = к_СтатьиЭО
         #к_СтатьиВКод : имя = к_СтатьиВ; имя2 = имя
         #к_СтатьиГКод : имя = к_СтатьиГ; имя2 = имя
         #к_СтатьиОТКод : имя = к_СтатьиОТ; имя2 = имя
        КОНЕЦ_ВЫБОРА
        //
        идент++
        сп.ОЧИСТИТЬ
        сп.ДОБАВИТЬ("INSERT INTO")
        сп.ДОБАВИТЬ("'" + ф_СпрЦелевыхВзносов + "'")
        сп.ДОБАВИТЬ("(ID, CODP, CAP, REC_NAME, TYPE, METHOD, COT, ORDER_BY) VALUES ")
        сп.ДОБАВИТЬ("(" + СТР(идент) + ", '" + код + "', '" + имя + "', '" +
                    ?(ПараметрПечатиПД!"Членские взносы в назначении платежа", к_СтатьиЧлВз, имя2) + "', ")
        сп.ДОБАВИТЬ("'" + имя2 + "', " + СТР(к_МетодРасчетаПоСчетчикуКод) + ", " +
                    СТР(sql.ПОЛЕ("COT")) + ", " + СТР(STG_ПорядокУслуги(код)) + ")")
        insert = SQL_ЗАПРОС(сп)
        //
        сп.ОЧИСТИТЬ
        сп.ДОБАВИТЬ("UPDATE")
        сп.ДОБАВИТЬ("'" + ф_СпрТарифов + "'")
        сп.ДОБАВИТЬ("SET ID = " + СТР(идент) + "WHERE TYPE = '" + код + "' AND COT = " + СТР(sql.ПОЛЕ("COT")))
        update = SQL_ЗАПРОС(сп)
      КОНЕЦ_ВЫБОРА
    КОНЕЦ_ЦИКЛА
    sql.ЗАКРЫТЬ
  КОНЕЦ_ЕСЛИ
КОНЕЦ_ФУНКЦИИ


//-------------------------------------------------------------------------------------------------------------------------//
//заполняет поле сортировки SRT
ФУНКЦИЯ ТИП_ЛОГИКА: ST_ЗапПолеСорт(ТИП_СТРОКА: имяБД, ИсхПоле, КонПоле)
  sql = SQL_ОТКРЫТЬ(имяБД)
  ЦИКЛ ДЛЯ (и=1,sql.ВСЕГО)
    sql.ПЕРЕЙТИ(и)
    sql.СЧИТАТЬ
    ЕСЛИ IB_STR_ВыделитьЧисло(sql.ПОЛЕ(ИсхПоле), РЕЗУЛЬТАТ) ТО
      sql.ЗАП_ПОЛЕ(КонПоле, IB_STR_СтрСимвСлева(СТР(РЕЗУЛЬТАТ), "0", 30))
    ИНАЧЕ
      sql.ЗАП_ПОЛЕ(КонПоле, IB_STR_СтрСимвСлева(sql.ПОЛЕ(ИсхПоле), "0", 30))
    КОНЕЦ_ЕСЛИ
    sql.ЗАМЕНИТЬ
  КОНЕЦ_ЦИКЛА
  sql.ЗАКРЫТЬ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ ST_ОбновитьДоВерсии304
  st_lib03_долиПростые!г_сервИнд = ""
  СТРОКА_СТАТУСА("Конвертация долей собственности...")
  ЕСЛИ IB_DBF_ТипПоля(ф_СвязьВладУч, "PART") = "С" ТО
    ВЫХОД
  КОНЕЦ_ЕСЛИ
  
  СОЗДАТЬ(сп, ТИП_СПИСОК)
  сп.ДОБАВИТЬ("SELECT * FROM")
  сп.ДОБАВИТЬ("'" + ф_СвязьВладУч + "'")
  сп.ДОБАВИТЬ("WHERE PART > 0")
  sql = SQL_ЗАПРОС(сп)
  ЦИКЛ ДЛЯ(и=1, sql.ВСЕГО)
    sql.ПЕРЕЙТИ(и)
    доля = ""
    ВЫБОР(СТР(ОКРУГЛЕНИЕ(sql.ПОЛЕ("PART"), 3)))
     #"0.5" : доля = "1/2";
     #"0.333", "0.334", "0.332" : доля = "1/3";
     #"0.666", "0.667", "0.665" : доля = "2/3";
     #"0.75" : доля = "3/4";
     #"1" : доля = "1";
    ИНАЧЕ
      рез = ""
      строка = СТР(sql.ПОЛЕ("PART"))
      ЦИКЛ ДЛЯ(симв = ДЛИНА(строка), 1, -1)
        ЕСЛИ ЗНАЧ_ТЕСТ(ПОДСТР(строка, симв, 1)) ТО
          рез = ПОДСТР(строка, симв, 1) + рез
        ИНАЧЕ
          СТОП
        КОНЕЦ_ЕСЛИ
      КОНЕЦ_ЦИКЛА
      ЕСЛИ ЗНАЧ_ТЕСТ(рез) ТО
        ЕСЛИ ЗНАЧ(рез) > 0 ТО
          знам = 1
          ЦИКЛ ДЛЯ(ит=1, ДЛИНА(рез))
            знам = знам * 10
          КОНЕЦ_ЦИКЛА
          доля = рез + "/" + СТР(знам)
        КОНЕЦ_ЕСЛИ
      КОНЕЦ_ЕСЛИ
    КОНЕЦ_ВЫБОРА
    ЕСЛИ доля = "" ТО
      доля = СТР(sql.ПОЛЕ("PART"))
    ИНАЧЕ
      идВлад = sql.ПОЛЕ("ID_OWNER")
      идУчасток = sql.ПОЛЕ("ID_AREA")
      флс = sql.ПОЛЕ("FLS")
      st_lib03_долиПростые!идВлад!"@"!идУчасток!"@"!флс = доля
    КОНЕЦ_ЕСЛИ
  КОНЕЦ_ЦИКЛА
  sql.ЗАКРЫТЬ
  //
  IB_DBF_УДАЛИТЬ_ПОЛЕ(ф_СвязьВладУч, "PART")
  IB_DBF_ДОБАВИТЬ_ПОЛЕ(ф_СвязьВладУч, "С", "PART", 20, 0)
  //
  ЦИКЛ ИНДЕКС(знач = st_lib03_долиПростые!индекс)
    ЕСЛИ индекс <> г_сервИнд ТО
      идВл = СТР_ФРАГ(индекс, "@", 1)
      идУч = СТР_ФРАГ(индекс, "@", 2)
      кодФлс = СТР_ФРАГ(индекс, "@", 3)
      //
      сп.ОЧИСТИТЬ
      сп.ДОБАВИТЬ("UPDATE")
      сп.ДОБАВИТЬ("'" + ф_СвязьВладУч + "'")
      сп.ДОБАВИТЬ("SET PART = '" + знач + "'")
      сп.ДОБАВИТЬ("WHERE FLS = '" + кодФлс + "' AND ID_OWNER = " + идВл + " AND ID_AREA = " + идУч)
      SQL_ЗАПРОС(сп)
    КОНЕЦ_ЕСЛИ
  КОНЕЦ_ЦИКЛА
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
//Корректировка операций по оплате.
ФУНКЦИЯ ST_ОбновитьДоВерсии307
  //первым делом надо исправить оплаты, т.к. они попадали не в тот столбец.
  СОЗДАТЬ(сп, ТИП_СПИСОК)
  сп.ДОБАВИТЬ("SELECT * FROM")
  сп.ДОБАВИТЬ("'" + ф_Журнал + "'")
  сп.ДОБАВИТЬ("WHERE REC_TYPE IN (" + СТР(к_ТипЗаписиЖурналаКасса) + ", " + СТР(к_ТипЗаписиЖурналаРасчСч) + ") AND ADD_SUM > 0 AND PAY_SUM = 0")
  sql = SQL_ЗАПРОС(сп)
  ЦИКЛ ДЛЯ(и = sql.ВСЕГО, 1, -1)
    sql.ПЕРЕЙТИ(и)
    сп.ОЧИСТИТЬ
    сп.ДОБАВИТЬ("UPDATE")
    сп.ДОБАВИТЬ("'" + ф_Журнал + "'")
    сп.ДОБАВИТЬ("SET PAY_SUM = " + СТР(sql.ПОЛЕ("ADD_SUM")))
    сп.ДОБАВИТЬ("WHERE ID_AREA = " + СТР(sql.ПОЛЕ("ID_AREA")) + " AND FLS = '" + sql.ПОЛЕ("FLS") + "'" +
                " AND TYPE = '" + sql.ПОЛЕ("TYPE") + "' AND ADD_SUM = " + СТР(sql.ПОЛЕ("ADD_SUM")))
    сп.ДОБАВИТЬ("AND REC_TYPE = " + СТР(sql.ПОЛЕ("REC_TYPE")) + " AND DAT = '" + СТР(sql.ПОЛЕ("DAT")) + "'" +
                " AND DOC = '" + sql.ПОЛЕ("DOC") + "' AND CONTENT = ")
    сп.ДОБАВИТЬ("'" + sql.ПОЛЕ("CONTENT") + "'")
    SQL_ЗАПРОС(сп)
  КОНЕЦ_ЦИКЛА
  sql.ЗАКРЫТЬ
  //теперь надо проставить всем недостающий флс
  сп.ОЧИСТИТЬ
  сп.ДОБАВИТЬ("SELECT * FROM")
  сп.ДОБАВИТЬ("'" + ф_СпрФЛС + "'")
  сп.ДОБАВИТЬ("WHERE ID_AREA IN (SELECT ID_AREA FROM")
  сп.ДОБАВИТЬ("'" + ф_Журнал + "'")
  сп.ДОБАВИТЬ("WHERE FLS = '')")
  sql = SQL_ЗАПРОС(сп)
  ЦИКЛ ДЛЯ(и = sql.ВСЕГО, 1, -1)
    sql.ПЕРЕЙТИ(и)
    сп.ОЧИСТИТЬ
    сп.ДОБАВИТЬ("UPDATE")
    сп.ДОБАВИТЬ("'" + ф_Журнал + "'")
    сп.ДОБАВИТЬ("SET FLS = '" + sql.ПОЛЕ("FLS") + "' WHERE ID_AREA = " + СТР(sql.ПОЛЕ("ID_AREA")) + " AND FLS = ''")
    SQL_ЗАПРОС(сп)
  КОНЕЦ_ЦИКЛА
  sql.ЗАКРЫТЬ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
//Обновление рабочего места
ФУНКЦИЯ ST_ОбновитьРабМестоДо008
  ИСПОЛЬЗОВАТЬ("IB_F4")
  раздел   = "ST"
  документ = "Настройки блока"
  ib_f4_СЧИТАТЬ_ЗНАЧЕНИЯ(раздел,документ)
  ЕСЛИ СУЩ_ПЕРЕМ(ЗначениеПараметра!"Источник данных") ТО
    СОЗДАТЬ(сп, ТИП_СПИСОК)
    сп.ДОБАВИТЬ("UPDATE")
    сп.ДОБАВИТЬ("'" + ф_НастройкиБлока + "'")
    сп.ДОБАВИТЬ("SET VAL1 = '" + ЗначениеПараметра!"Источник данных" + 
                "', VAL2 = '" + ЗначениеПараметра!"Группировка участков при выборе" + 
                "', VAL3 = '" + ЗначениеПараметра!"Сортировка участков при выборе по" +
                "', VAL4 = '" + ЗначениеПараметра!"Выводить улицу в отчётах" + 
                "', VAL5 = '" + ЗначениеПараметра!"Способ ввода показаний" + "'")
    SQL_ЗАПРОС(сп)
    //грохнем настройки 
    IB_F4_УдалитьРаздел(раздел, документ)
  КОНЕЦ_ЕСЛИ
КОНЕЦ_ФУНКЦИИ

