  SQL_ЗАПРОС(сп)
  
  сп.ОЧИСТИТЬ
  сп.ДОБАВИТЬ("UPDATE")
  сп.ДОБАВИТЬ("'" + ф_ПоказанияИСВГ + "'")
  сп.ДОБАВИТЬ("SET CORR = FALSE WHERE CORR IS NULL")
  SQL_ЗАПРОС(сп)
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ ST_ОбновитьДоВерсии318
  СОЗДАТЬ(сп, ТИП_СПИСОК)
  ЕСЛИ СУЩ_ФАЙЛ(ф_архив001) ТО
    sql = SQL_ОТКРЫТЬ(ф_архив001)
    ЕСЛИ sql.ВСЕГО > 0 ТО
      sql.ПЕРЕЙТИ(1)
      ib_prof_текущийПрофиль = к_СНТПрофДлгАктЭЭ
      IB_PROF_ДобавитьГрафу2("код_счета1", "С", sql.ПОЛЕ("GR1"))
      IB_PROF_ДобавитьГрафу2("код_счета2", "С", sql.ПОЛЕ("GR2"))
      IB_PROF_ДобавитьГрафу2("код_счета3", "С", sql.ПОЛЕ("GR3"))
      IB_PROF_ЗаписатьПрофиль2(к_СНТПрофДлгАктЭЭ)
    КОНЕЦ_ЕСЛИ
    sql.ЗАКРЫТЬ
  КОНЕЦ_ЕСЛИ
  //
  ЕСЛИ СУЩ_ФАЙЛ(ф_архив002) ТО
    sql = SQL_ОТКРЫТЬ(ф_архив002)
    ЕСЛИ sql.ВСЕГО > 0 ТО
      sql.ПЕРЕЙТИ(1)
      ib_prof_текущийПрофиль = к_СНТПрофДлгРедНач
      IB_PROF_ДобавитьГрафу2("датаС", "Д", СТР(sql.ПОЛЕ("GR1")))
      IB_PROF_ДобавитьГрафу2("датаПо", "Д", СТР(sql.ПОЛЕ("GR2")))
      IB_PROF_ДобавитьГрафу2("оп_переформОп", "Л", СТР(sql.ПОЛЕ("GR3")))
      IB_PROF_ЗаписатьПрофиль2(к_СНТПрофДлгРедНач)
    КОНЕЦ_ЕСЛИ
    sql.ЗАКРЫТЬ
  КОНЕЦ_ЕСЛИ
  //
  ЕСЛИ СУЩ_ФАЙЛ(ф_архив003) ТО
    sql = SQL_ОТКРЫТЬ(ф_архив003)
    ЕСЛИ sql.ВСЕГО > 0 ТО
      sql.ПЕРЕЙТИ(1)
      ib_prof_текущийПрофиль = к_СНТПрофДлгРедОплат
      IB_PROF_ДобавитьГрафу2("датаС", "Д", СТР(sql.ПОЛЕ("GR1")))
      IB_PROF_ДобавитьГрафу2("датаПо", "Д", СТР(sql.ПОЛЕ("GR2")))
      IB_PROF_ДобавитьГрафу2("оп_переформОп", "Л", СТР(sql.ПОЛЕ("GR3")))
      IB_PROF_ЗаписатьПрофиль2(к_СНТПрофДлгРедОплат)
    КОНЕЦ_ЕСЛИ
    sql.ЗАКРЫТЬ
  КОНЕЦ_ЕСЛИ
  //
  ЕСЛИ СУЩ_ФАЙЛ(ф_архив004) ТО
    sql = SQL_ОТКРЫТЬ(ф_архив004)
    ЕСЛИ sql.ВСЕГО > 0 ТО
      sql.ПЕРЕЙТИ(1)
      IB_PROF_ДобавитьГрафу2("датаПров", "Д", СТР(sql.ПОЛЕ("GR1")))
      IB_PROF_ДобавитьГрафу2("режим", "С", sql.ПОЛЕ("GR2"))
      IB_PROF_ЗаписатьПрофиль2(к_СНТПрофДлгРедИО)
    КОНЕЦ_ЕСЛИ
    sql.ЗАКРЫТЬ
  КОНЕЦ_ЕСЛИ
  //
  IB_FILE_ФайлУдалить(ф_архив001)
  IB_FILE_ФайлУдалить(ф_архив002)
  IB_FILE_ФайлУдалить(ф_архив003)
  IB_FILE_ФайлУдалить(ф_архив004)
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ ST_ОбновитьДоВерсии319
  IB_FILE_ФайлУдалить(ф_ССС)
  //установим значение поля USE
  СОЗДАТЬ(сп, ТИП_СПИСОК)
  сп.ДОБАВИТЬ("UPDATE")
  сп.ДОБАВИТЬ("'" + ф_СпрУчастковГаражей + "'")
  сп.ДОБАВИТЬ("SET USE = TRUE")
  SQL_ЗАПРОС(сп)
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ ST_ОбновитьДоВерсии325
  //удаление файла настройки использования шаблонов
  IB_FILE_ФайлУдалить(ф_НастройкиШаблонов)
  //Замена ; и : в шаблонах полей и реквизитов. Иначе сбербанку становится плохо.
  sql = SQL_ОТКРЫТЬ(ф_ШаблоныПолейПД)
  ЦИКЛ ДЛЯ(и = 1, sql.ВСЕГО)
    sql.ПЕРЕЙТИ(и)
    ЕСЛИ sql.ПОЛЕ("ID_PD") = к_ФормыПДИПУКод ИЛИ
         sql.ПОЛЕ("ID_PD") = к_ФормыПДВзносыКод ТО
      шаблон = ЗАМ(";", sql.ПОЛЕ("TEMPLATE"), ",")
      шаблон = ЗАМ(":", шаблон, "-")
      sql.ЗАП_ПОЛЕ("TEMPLATE", шаблон)
      sql.ЗАМЕНИТЬ
    КОНЕЦ_ЕСЛИ
  КОНЕЦ_ЦИКЛА
  sql.ЗАКРЫТЬ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ ST_ОбновитьДоВерсии326
  IB_FILE_ФайлУдалить(ф_tmp014)
  IB_FILE_ФайлУдалить(ф_tmp015)
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
//перенос архивов справочников
ФУНКЦИЯ ST_ПереносАрхивовСпр
  ИСПОЛЬЗОВАТЬ("IB_PROFILE.IBL")
  врем_файл = ДИР_DBF + "\" + НОВЫЙ_GUID + ".dbf"
  //
  архив!1 = ф_архивСпрУлиц      профильСпр!1 = к_СНТПрофСпрУлиц      поле_отображ!1 = "STREAT"
  архив!2 = ф_архивСпрУчастков  профильСпр!2 = к_СНТПрофСпрУчастков  поле_отображ!2 = "N_AREA"
  архив!3 = ф_архивСпрВзносов   профильСпр!3 = к_СНТПрофСпрВзносов   поле_отображ!3 = "CAP"
  //
  СОЗДАТЬ(сп, ТИП_СПИСОК)
  ЦИКЛ ДЛЯ(и = 1, 3)
    ЕСЛИ СУЩ_ФАЙЛ(архив!и) ТО
      сп.ОЧИСТИТЬ
      сп.ДОБАВИТЬ("SELECT DISTINCT PROF FROM")
      сп.ДОБАВИТЬ("'" + архив!и + "'")
      sql = SQL_ЗАПРОС(сп)
      ЦИКЛ ДЛЯ(ж = 1, sql.ВСЕГО)
        sql.ПЕРЕЙТИ(ж)
        //
        сп.ОЧИСТИТЬ
        сп.ДОБАВИТЬ("SELECT DISTINCT * FROM")
        сп.ДОБАВИТЬ("'" + архив!и + "'")
        сп.ДОБАВИТЬ("WHERE PROF = " + СТР(sql.ПОЛЕ("PROF")))
        sql1 = SQL_ЗАПРОС(сп)
        sql1.ЗАПИСАТЬ(врем_файл)
        sql1.ЗАКРЫТЬ
        //
        ВЫБОР(sql.ПОЛЕ("PROF"))
         #к_ПрофДлгНачислений: профиль = к_СНТПрофДлгРедНач + профильСпр!и
         #к_ПрофДлгОплат: профиль = к_СНТПрофДлгРедОплат + профильСпр!и
         #к_ПрофДлгИсхОст: профиль = к_СНТПрофДлгРедИО + профильСпр!и
         #к_ПрофОборотнаяВедомость: профиль = к_СНТПрофОборотнаяВедомость + профильСпр!и
         #к_ПрофРеестрНачислений: профиль = к_СНТПрофРеестрНачислений + профильСпр!и
         #к_ПрофРеестрОплат: профиль = к_СНТПрофРеестрОплат + профильСпр!и
         #к_ПрофРеестрДолгов: профиль = к_СНТПрофРеестрДолгов + профильСпр!и
         #к_ПрофНачислениеЧлЦлВзн: профиль = к_СНТПрофНачислениеЧлЦлВзн + профильСпр!и
         #к_ПрофНачислениеЭЭ: профиль = к_СНТПрофНачислениеЭЭ + профильСпр!и
         #к_ПрофРазноскаЦлВз: профиль = к_СНТПрофДлгУстЦлВз + профильСпр!и
         #к_ПрофРеестрИПУ: профиль = к_СНТПрофРеестрИПУ + профильСпр!и
         #к_ПрофРеестрУчВлад: профиль = к_СНТПрофРеестрУчастков + профильСпр!и
         #к_ПрофОкноРуководителя: профиль = к_СНТПрофОкноРуководителя + профильСпр!и
        КОНЕЦ_ВЫБОРА
        //
        IB_PROF_ЗаписатьПрофМножВыб(профиль, врем_файл, поле_отображ!и)
        //
        IB_FILE_ФайлУдалить(врем_файл)
      КОНЕЦ_ЦИКЛА
      sql.ЗАКРЫТЬ
      //
      IB_FILE_ФайлУдалить(архив!и)
    КОНЕЦ_ЕСЛИ
  КОНЕЦ_ЦИКЛА
  ПАУЗА(10)
  УДАЛИТЬ_ДИР(г_папкаАрх)
  
  //теперь надо законвертить ред_при выборе
  ЕСЛИ IB_PROF_C_ФайлПрофиля(файлПрофиля) ТО
    сп.ОЧИСТИТЬ
    сп.ДОБАВИТЬ("SELECT DISTINCT PROF_ID FROM")
    сп.ДОБАВИТЬ("'" + файлПрофиля + "'")
    сп.ДОБАВИТЬ("WHERE VAR_NAME = 'ред_при_выборе' AND PROF_ID LIKE '%|СНТ.Справочник%'")
    sql = SQL_ЗАПРОС(сп)
    ЦИКЛ ДЛЯ(и = 1, sql.ВСЕГО)
      sql.ПЕРЕЙТИ(и)
      старыйПрофиль = sql.ПОЛЕ("PROF_ID")
      старыйКод = СТР_ФРАГ(старыйПрофиль, "|СНТ", 1)
      
      ЕСЛИ ПОЗ("Улиц", старыйПрофиль) > 0 ТО
        справочник = к_СНТПрофСпрУлиц
      ИНАЧЕ
        ЕСЛИ ПОЗ("Участков", старыйПрофиль) > 0 ТО
          справочник = к_СНТПрофСпрУчастков
        ИНАЧЕ
          справочник = к_СНТПрофСпрВзносов
        КОНЕЦ_ЕСЛИ
      КОНЕЦ_ЕСЛИ
      
      ЕСЛИ ЗНАЧ_ТЕСТ(старыйКод) ТО
        ВЫБОР(ЗНАЧ(старыйКод))
         #к_ПрофДлгНачислений: профиль = к_СНТПрофДлгРедНач + справочник
         #к_ПрофДлгОплат: профиль = к_СНТПрофДлгРедОплат + справочник
         #к_ПрофДлгИсхОст: профиль = к_СНТПрофДлгРедИО + справочник
         #к_ПрофОборотнаяВедомость: профиль = к_СНТПрофОборотнаяВедомость + справочник
         #к_ПрофРеестрНачислений: профиль = к_СНТПрофРеестрНачислений + справочник
         #к_ПрофРеестрОплат: профиль = к_СНТПрофРеестрОплат + справочник
         #к_ПрофРеестрДолгов: профиль = к_СНТПрофРеестрДолгов + справочник
         #к_ПрофНачислениеЧлЦлВзн: профиль = к_СНТПрофНачислениеЧлЦлВзн + справочник
         #к_ПрофНачислениеЭЭ: профиль = к_СНТПрофНачислениеЭЭ + справочник
         #к_ПрофРазноскаЦлВз: профиль = к_СНТПрофДлгУстЦлВз + справочник
         #к_ПрофРеестрИПУ: профиль = к_СНТПрофРеестрИПУ + справочник
         #к_ПрофРеестрУчВлад: профиль = к_СНТПрофРеестрУчастков + справочник
         #к_ПрофОкноРуководителя: профиль = к_СНТПрофОкноРуководителя + справочник
        КОНЕЦ_ВЫБОРА
        //
        сп.ОЧИСТИТЬ
        сп.ДОБАВИТЬ("UPDATE")
        сп.ДОБАВИТЬ("'" + файлПрофиля + "'")
        сп.ДОБАВИТЬ("SET PROF_ID = '" + профиль + "' WHERE PROF_ID = '" + старыйПрофиль + "'")
        SQL_ЗАПРОС(сп)
      КОНЕЦ_ЕСЛИ
    КОНЕЦ_ЦИКЛА
    sql.ЗАКРЫТЬ
  КОНЕЦ_ЕСЛИ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
//Обновление до версии 3.28 - добавлены поля объемов в таблицы показаний
//ПЕРЕМ г_начПоказания!
ФУНКЦИЯ ST_ОбновитьДоВерсии328
  ИСПОЛЬЗОВАТЬ("ST_GSK\TOP\ST_GSK_METERS")
  СОЗДАТЬ(сп, ТИП_СПИСОК)
  //
  файлПок!1 = ф_ПоказанияИСЭЭ
  файлПок!2 = ф_ПоказанияИСВГ
  //цикл по ИПУ
  сп.ОЧИСТИТЬ
  сп.ДОБАВИТЬ("SELECT ID, NPOK1, NPOK2, NPOK3 FROM")
  сп.ДОБАВИТЬ("'" + ф_СпрИндивСчетчики + "'")
  sql = SQL_ЗАПРОС(сп)
  ЦИКЛ ДЛЯ(и = 1, sql.ВСЕГО)
    sql.ПЕРЕЙТИ(и)
    идИПУ = sql.ПОЛЕ("ID")
    г_начПоказания!идИПУ!"//Т1" = sql.ПОЛЕ("NPOK1")
    г_начПоказания!идИПУ!"//Т2" = sql.ПОЛЕ("NPOK2")
    г_начПоказания!идИПУ!"//Т3" = sql.ПОЛЕ("NPOK3")
  КОНЕЦ_ЦИКЛА
  sql.ЗАКРЫТЬ
  //
  ЦИКЛ ИНДЕКС(файл = файлПок!индФайла)
    STG_ОбновитьОбъемыИПУ(файл)
  КОНЕЦ_ЦИКЛА 
  //
  СБРОС(г_начПоказания)
КОНЕЦ_ФУНКЦИИ

//Обновление до версии 3.29 - добавлены поля объемов в таблицы показаний ОПУ
ФУНКЦИЯ ST_ОбновитьДоВерсии329
  СОЗДАТЬ(сп, ТИП_СПИСОК)
  //цикл по ИПУ
  сп.ОЧИСТИТЬ
  сп.ДОБАВИТЬ("SELECT * FROM")
  сп.ДОБАВИТЬ("'" + ф_СпрОбщиеСчетчики + "'")
  sql = SQL_ЗАПРОС(сп)
  ЦИКЛ ДЛЯ(и = 1, sql.ВСЕГО)
    sql.ПЕРЕЙТИ(и)
    идИПУ = sql.ПОЛЕ("ID")
    г_начПоказания!идИПУ!"//Т1" = sql.ПОЛЕ("NPOK1")
    г_начПоказания!идИПУ!"//Т2" = sql.ПОЛЕ("NPOK2")
    г_начПоказания!идИПУ!"//Т3" = sql.ПОЛЕ("NPOK3")
  КОНЕЦ_ЦИКЛА
  sql.ЗАКРЫТЬ
  //
  STG_ОбновитьОбъемыИПУ(ф_ПоказанияОСЭЭ)
  //
  СБРОС(г_начПоказания)
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
//Обновление до версии 3.29 - обновлена константа сортировки
ФУНКЦИЯ ST_ОбновитьДоВерсии333
  СОЗДАТЬ(сп, ТИП_СПИСОК)
  сп.ДОБАВИТЬ("UPDATE")
  сп.ДОБАВИТЬ("'" + ф_НастройкиБлока + "'")
  сп.ДОБАВИТЬ("SET VAL3 = '" + к_СортПоНомеруУчастка + "' WHERE VAL3 = 'номеру участка'")
  SQL_ЗАПРОС(сп)
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
//проверяет версию БД на наличие отличий в структуре. - необходимо допилить с версии 3.20
ФУНКЦИЯ ТИП_ЧИСЛО: ST_ПроверитьВерсиюБД
  РЕЗУЛЬТАТ = г_текВерсияБлока
  
  ЕСЛИ НЕ IB_DBF_СущПоле(ф_НастройкиБлока, "VAL7") ТО
    РЕЗУЛЬТАТ = 3.29
  КОНЕЦ_ЕСЛИ
  
  ЕСЛИ НЕ IB_DBF_СущПоле(ф_ПоказанияОСЭЭ, "T1_VOL") ТО
    РЕЗУЛЬТАТ = 3.28
  КОНЕЦ_ЕСЛИ
  
  ЕСЛИ НЕ IB_DBF_СущПоле(ф_ПоказанияИСЭЭ, "T1_VOL") ТО
    РЕЗУЛЬТАТ = 3.20
  КОНЕЦ_ЕСЛИ
  
  ЕСЛИ НЕ IB_DBF_СущПоле(ф_НастройкиПени, "PERC_IPU") ТО
    РЕЗУЛЬТАТ = 3.19
  КОНЕЦ_ЕСЛИ
  
  ЕСЛИ НЕ IB_DBF_СущПоле(ф_СпрУчастковГаражей, "USE") ТО
    РЕЗУЛЬТАТ = 3.17
  КОНЕЦ_ЕСЛИ
  
  ЕСЛИ НЕ IB_DBF_СущПоле(ф_ПоказанияИСЭЭ, "CORR") ТО
    РЕЗУЛЬТАТ = 3.16
  КОНЕЦ_ЕСЛИ
  
  ЕСЛИ НЕ IB_DBF_СущПоле(ф_СпрЦелевыхВзносов, "SRCH") ТО
    РЕЗУЛЬТАТ = 3.14
  КОНЕЦ_ЕСЛИ
  
  ЕСЛИ НЕ IB_DBF_СущПоле(ф_СпрТарифов, "FIX") ТО
    РЕЗУЛЬТАТ = 3.12
  КОНЕЦ_ЕСЛИ
  
  ЕСЛИ НЕ IB_DBF_СущПоле(ф_НастройкиПечатиПД, "POL13") ТО
    РЕЗУЛЬТАТ = 3.10
  КОНЕЦ_ЕСЛИ
  
  ЕСЛИ НЕ IB_DBF_СущПоле(ф_НастройкиПечатиПД, "POL12") ТО
    РЕЗУЛЬТАТ = 3.09
  КОНЕЦ_ЕСЛИ
  
  ЕСЛИ НЕ IB_DBF_СущПоле(ф_НастройкиПечатиПД, "POL11") ТО
    РЕЗУЛЬТАТ = 3.06
  КОНЕЦ_ЕСЛИ
  
  ЕСЛИ НЕ IB_DBF_СущПоле(ф_СпрОбщиеСчетчики, "DATEND") ТО
    РЕЗУЛЬТАТ = 3.04
  КОНЕЦ_ЕСЛИ
  
  ЕСЛИ НЕ IB_DBF_СущПоле(ф_Настроек, "POL2") ТО
    РЕЗУЛЬТАТ = 2.62
  КОНЕЦ_ЕСЛИ
  
  ЕСЛИ НЕ IB_DBF_СущПоле(ф_НастройкиПени, "START_DATE") ТО
    РЕЗУЛЬТАТ = 2.61
  КОНЕЦ_ЕСЛИ
  
  ЕСЛИ НЕ IB_DBF_СущПоле(ф_НастройкиПечатиПД, "POL10") ТО
    РЕЗУЛЬТАТ = 2.54
  КОНЕЦ_ЕСЛИ
  
  ЕСЛИ НЕ IB_DBF_СущПоле(ф_НастройкиПечатиПД, "POL9") ТО
    РЕЗУЛЬТАТ = 2.53
  КОНЕЦ_ЕСЛИ
  
  ЕСЛИ НЕ IB_DBF_СущПоле(ф_НастройкиПечатиПД, "POL7") ТО
    РЕЗУЛЬТАТ = 2.48
  КОНЕЦ_ЕСЛИ
  
  ЕСЛИ НЕ IB_DBF_СущПоле(ф_СпрВладельцев, "EMAIL") ТО
    РЕЗУЛЬТАТ = 2.47
  КОНЕЦ_ЕСЛИ
  
  ЕСЛИ НЕ IB_DBF_СущПоле(ф_СпрУчастковГаражей, "SRT") ТО
    РЕЗУЛЬТАТ = 2.46
  КОНЕЦ_ЕСЛИ
  
  ЕСЛИ НЕ IB_DBF_СущПоле(ф_СпрУчастковГаражей, "METHOD_RAS") ТО
    РЕЗУЛЬТАТ = 2.45
  КОНЕЦ_ЕСЛИ
  
  ЕСЛИ НЕ IB_DBF_СущПоле(ф_СпрИндивСчетчики, "TOKEN") ТО
    РЕЗУЛЬТАТ = 2.43
  КОНЕЦ_ЕСЛИ
  
  ЕСЛИ НЕ IB_DBF_СущПоле(ф_СвязьВладУч, "NOMSV") ТО
    РЕЗУЛЬТАТ = 2.41
  КОНЕЦ_ЕСЛИ
  
  ЕСЛИ НЕ IB_DBF_СущПоле(ф_СпрУчастковГаражей, "ID_OWNER") ТО
    РЕЗУЛЬТАТ = 2.40
  КОНЕЦ_ЕСЛИ
  
  ЕСЛИ НЕ IB_DBF_СущПоле(ф_СпрУчастковГаражей, "ID_AREA") ТО
    РЕЗУЛЬТАТ = 2.00
  КОНЕЦ_ЕСЛИ
  //
  ST_ПроверитьВерсиюБД = РЕЗУЛЬТАТ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ ТИП_ЛОГИКА: ST_LIB01_НастрСтолбцовБланк64(ПЕРЕМ ТИП_СТРОКА: стр)
  логПоказа = ДА
  ЕСЛИ НЕ СУЩ_ПЕРЕМ(гр_ДетУчастокСобст) ТО
    гр_ДетУчастокСобст = стр
    логПоказа = НЕТ
  КОНЕЦ_ЕСЛИ
  ИСПОЛЬЗОВАТЬ("IB_F4")
  раздел    = "ST"
  документ  = ?(гр_ДетУчастокСобст = "По собственникам", "Реестр собственников", "Реестр участков")
  ЕСЛИ НЕ СУЩ_ФАЙЛ(ТЕК_ДИР+"\ST_DOC.INI") ТО
    STG_ОбновитьНастрБланка(документ)
  ИНАЧЕ
    ЕСЛИ НЕ ib_f4_СЧИТАТЬ_ЗНАЧЕНИЯ(раздел,документ) ТО
      STG_ОбновитьНастрБланка(документ)
    КОНЕЦ_ЕСЛИ
  КОНЕЦ_ЕСЛИ
  ЕСЛИ логПоказа ТО
    ST_LIB01_НастройкаСтолбцовБланк64 = IB_F4_ПОКАЗАТЬ_НАСТРОЙКУ(раздел,документ, ДА)
  КОНЕЦ_ЕСЛИ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ ST_ОбновитьРМДоВерсии014
  ИСПОЛЬЗОВАТЬ("IB_TABLE_SETTINGS")
  стр = "По собственникам"
  ST_LIB01_НастрСтолбцовБланк64(стр) 
  IB_TBLSET_УстановитьПрофиль(к_СНТПрофТблРеестрСобств)
  IB_TBLSET_ДобавитьПарамСтлб(ST_ЛогОтображенияСтолбца("№ п/п"), НЕТ, "№ п/п", 6, 1)
  IB_TBLSET_ДобавитьПарамСтлб(ST_ЛогОтображенияСтолбца("Адрес"), НЕТ, "Адрес", 25, 2)
  IB_TBLSET_ДобавитьПарамСтлб(ST_ЛогОтображенияСтолбца("Ф.И.О."), НЕТ, "Ф.И.О.", 35, 3)
  IB_TBLSET_ДобавитьПарамСтлб(ST_ЛогОтображенияСтолбца("Дата рождения"), НЕТ, "Дата рождения", 11, 4)
  IB_TBLSET_ДобавитьПарамСтлб(ST_ЛогОтображенияСтолбца("Место рождения"), НЕТ, "Место рождения", 20, 5)
  IB_TBLSET_ДобавитьПарамСтлб(ST_ЛогОтображенияСтолбца("Адрес прописки"), НЕТ, "Адрес прописки", 20, 6)
  IB_TBLSET_ДобавитьПарамСтлб(ST_ЛогОтображенияСтолбца("Паспортные данные"), НЕТ, "Паспортные данные", 20, 7)
  IB_TBLSET_ДобавитьПарамСтлб(ST_ЛогОтображенияСтолбца("Телефоны"), НЕТ, "Телефоны", 20, 8)
  IB_TBLSET_ДобавитьПарамСтлб(ST_ЛогОтображенияСтолбца("E-mail"), НЕТ, "E-mail", 20, 9)
  IB_TBLSET_ДобавитьПарамСтлб(ST_ЛогОтображенияСтолбца("Статус"), НЕТ, "Статус", 19, 10)
  IB_TBLSET_ДобавитьПарамСтлб(ST_ЛогОтображенияСтолбца("Комментарий"), НЕТ, "Комментарий", 30, 11)
  IB_F4_УдалитьРаздел("ST", "Реестр собственников")
  
  стр = "По " + текстЗагДПМнож
  ST_LIB01_НастрСтолбцовБланк64(стр)
  ST_НастройкиТблРеестрУчастков
  IB_F4_УдалитьРаздел("ST", "Реестр участков")
КОНЕЦ_ФУНКЦИИ

