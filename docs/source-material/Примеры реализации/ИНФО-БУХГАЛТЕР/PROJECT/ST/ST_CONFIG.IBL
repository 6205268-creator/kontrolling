//-------------------------------------------------------------------------------------------------------------------------//
//доли владельцев
ФУНКЦИЯ ST_ДолиВладельцев
  //1. посчитаем те, в которых нет доли.
  //2. проверим количество владельцев на участке. проверим наличие доли.
  //3. потом проверим периоды в пределах одного участка. если совпали, то делим доли. если нет, то 1.
  колВладельцев!"серв" = 0

  СОЗДАТЬ(СП, ТИП_СПИСОК)
  СП.ДОБАВИТЬ("SELECT COUNT(ID_OWNER) AS COT, ID_AREA FROM")
  СП.ДОБАВИТЬ("'" + ф_СвязьВладУч + "'")
  СП.ДОБАВИТЬ("GROUP BY ID_AREA")
  sql = SQL_ЗАПРОС(СП)
  ЦИКЛ ДЛЯ(и = 1, sql.ВСЕГО)
    sql.ПЕРЕЙТИ(и)
    ид = sql.ПОЛЕ("ID_AREA")
    ЕСЛИ НЕ СУЩ_ПЕРЕМ(колВладельцев!ид) ТО
    колВладельцев!ид++
  КОНЕЦ_ЦИКЛА

  ЦИКЛ ДЛЯ(и = 1, sql.ВСЕГО)
    sql.ПЕРЕЙТИ(и)
    ЕСЛИ sql.ПОЛЕ("COT") = 1 ТО
      СП.ОЧИСТИТЬ
      СП.ДОБАВИТЬ("UPDATE '" + ф_СвязьВладУч + "'")
      СП.ДОБАВИТЬ("SET PART = 1 WHERE ID_AREA = " + СТР(sql.ПОЛЕ("ID_AREA")))
      update = SQL_ЗАПРОС(СП)
    КОНЕЦ_ЕСЛИ
  КОНЕЦ_ЦИКЛА
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
//Задаем идшники для участков
ФУНКЦИЯ ТИП_ЛОГИКА: ST_CREATE_ID_УЧАСТКИ
  бд = SQL_ОТКРЫТЬ(ф_СпрУчастковГаражей)
  СОЗДАТЬ(СП,ТИП_СПИСОК)
  ЦИКЛ ДЛЯ (и=1, бд.ВСЕГО)
    бд.ПЕРЕЙТИ(и)
    СП.ОЧИСТИТЬ
    СП.ДОБАВИТЬ("UPDATE '"+ф_СпрУчастковГаражей+"'")
    СП.ДОБАВИТЬ("SET ID_AREA='"+СТР(и)+"' WHERE CODS='"+СТР(бд.ПОЛЕ("CODS"))+"' AND N_DOM='"+СТР(бд.ПОЛЕ("N_DOM"))+"' AND N_AREA='"+СТР(бд.ПОЛЕ("N_AREA"))+"'")
    sql_Добавить = SQL_ЗАПРОС(СП)
    sql_Добавить.ЗАКРЫТЬ
  КОНЕЦ_ЦИКЛА
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
//раньше были названия целевых. надо их заменить на коды.
ФУНКЦИЯ ТИП_ЛОГИКА: ST_UPDATE_CODP
  бд = SQL_ОТКРЫТЬ(ф_СпрЦелевыхВзносов)
  СОЗДАТЬ(СП,ТИП_СПИСОК)
  ЦИКЛ ДЛЯ (и=1,бд.ВСЕГО)
    бд.ПЕРЕЙТИ(и)
    СП.ОЧИСТИТЬ
    СП.ДОБАВИТЬ("UPDATE '"+ф_СпрСвязьЦВиУч+"' ")
    СП.ДОБАВИТЬ("SET CODP='"+бд.ПОЛЕ("CODP")+"' WHERE CODP='"+бд.ПОЛЕ("CAP")+"'")
    бд1 = SQL_ЗАПРОС(СП)
    бд1.ЗАКРЫТЬ
  КОНЕЦ_ЦИКЛА
  бд.ЗАКРЫТЬ
  //Удалим поля с хотя бы одним пустым кодом
  СП.ОЧИСТИТЬ
  СП.ДОБАВИТЬ("DELETE FROM '"+ф_СпрСвязьЦВиУч+"'")
  СП.ДОБАВИТЬ("WHERE CODP='' OR CODS=''")
  IB_DBF_УдалитьДубликаты(ф_СпрСвязьЦВиУч)
  ST_UPDATE_CODP = ДА
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
//Добавим значения ID_AREA для файла связи показателей
ФУНКЦИЯ ТИП_ЛОГИКА: ST_UPDATE_ID_AREA
  СОЗДАТЬ(СП,ТИП_СПИСОК)
  //считаем идншики по коду улицы и номеру дома
  ЕСЛИ IB_DBF_СущПоле(ф_СпрСвязьЦВиУч, "N_DOM") ТО
    бд = SQL_ОТКРЫТЬ(ф_СпрУчастковГаражей)
    ЦИКЛ ДЛЯ(и=1,бд.ВСЕГО)
      бд.ПЕРЕЙТИ(и)
      ЕСЛИ бд.ПОЛЕ("N_DOM") <> "" ТО
        СП.ОЧИСТИТЬ
        СП.ДОБАВИТЬ("UPDATE '"+ф_СпрСвязьЦВиУч+"' ")
        СП.ДОБАВИТЬ("SET ID_AREA='"+СТР(бд.ПОЛЕ("ID_AREA"))+"'")
        СП.ДОБАВИТЬ("WHERE CODS='"+бд.ПОЛЕ("CODS")+"' AND N_DOM='"+бд.ПОЛЕ("N_DOM")+"'")
        бд1 = SQL_ЗАПРОС(СП)
        бд1.ЗАКРЫТЬ
      КОНЕЦ_ЕСЛИ
    КОНЕЦ_ЦИКЛА
    бд.ЗАКРЫТЬ
    //Удалим поля с хотя бы одним пустым кодом
    СП.ОЧИСТИТЬ
    СП.ДОБАВИТЬ("DELETE FROM '"+ф_СпрСвязьЦВиУч+"'")
    СП.ДОБАВИТЬ("WHERE CODP='' OR CODS='' OR ID_AREA = 0")
    IB_DBF_УдалитьДубликаты(ф_СпрСвязьЦВиУч)
    ST_UPDATE_ID_AREA = ДА
  КОНЕЦ_ЕСЛИ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
//Изменение N_DOM c NUMERIC на CHAR (с сохранением всех данных) - колхоз хД
ФУНКЦИЯ ТИП_ЛОГИКА: ST_N_DOM_TO_CHAR
  файл = ф_СпрУчастковГаражей
  бд = SQL_ОТКРЫТЬ(файл)
  ЕСЛИ бд.ТИП_ПОЛЯ("N_DOM") = "Ч" ТО
    //считаем
    СОЗДАТЬ(СП,ТИП_СПИСОК)
    ЦИКЛ ДЛЯ(и=1, бд.ВСЕГО)
      бд.ПЕРЕЙТИ(и)
      НомерДома!СТР(бд.ПОЛЕ("CODS"))!"_"!СТР(бд.ПОЛЕ("ID_AREA"))!"_"!СТР(бд.ПОЛЕ("N_AREA")) = СТР(бд.ПОЛЕ("N_DOM"))
    КОНЕЦ_ЦИКЛА
    бд.ЗАКРЫТЬ
    //грохнем и добавим поле
    СП.ОЧИСТИТЬ
    СП.ДОБАВИТЬ("ALTER TABLE")
    СП.ДОБАВИТЬ("'"+файл+"'")
    СП.ДОБАВИТЬ("DROP N_DOM, ADD N_DOM CHAR(9)")
    add = SQL_ЗАПРОС(СП)
    add.ЗАКРЫТЬ
    //запишем
    бд = SQL_ОТКРЫТЬ(файл)
    ЦИКЛ ДЛЯ(и=1, бд.ВСЕГО)
      бд.ПЕРЕЙТИ(и)
      СП.ОЧИСТИТЬ
      СП.ДОБАВИТЬ("UPDATE '"+файл+"'")
      СП.ДОБАВИТЬ("SET N_DOM='"+НомерДома!СТР(бд.ПОЛЕ("CODS"))!"_"!СТР(бд.ПОЛЕ("ID_AREA"))!"_"!СТР(бд.ПОЛЕ("N_AREA"))+"'")
      СП.ДОБАВИТЬ("WHERE CODS='"+бд.ПОЛЕ("CODS")+"' AND ID_AREA='"+СТР(бд.ПОЛЕ("ID_AREA"))+"' AND N_AREA='"+бд.ПОЛЕ("N_AREA")+"'")
      add = SQL_ЗАПРОС(СП)
      add.ЗАКРЫТЬ
    КОНЕЦ_ЦИКЛА
  КОНЕЦ_ЕСЛИ
  бд.ЗАКРЫТЬ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
//Конвертация владельцев из спр. участвок в спр. владельцев.
ФУНКЦИЯ ТИП_ЛОГИКА: ST_КОНВ_ФСПРВЛАД
  СТРОКА_СТАТУСА("Создание справочника владельцев...")
  СОЗДАТЬ(СП,ТИП_СПИСОК)
  типПоля = IB_DBF_ТипПоля(ф_СвязьВладУч, "PART")
  sql = SQL_ОТКРЫТЬ(ф_СпрУчастковГаражей)
  ЕСЛИ IB_DBF_СущПоле(ф_СпрУчастковГаражей, "ROG") ТО
    ЕСЛИ СУЩ_ФАЙЛ(ф_СпрВладельцев) ТО
      sql2 = SQL_ОТКРЫТЬ(ф_СпрВладельцев)
      ЕСЛИ sql.ВСЕГО > 0 /*И sql2.ВСЕГО > 0*/ ТО
        фиоЕстьВБД!"" = 0
        ЦИКЛ ДЛЯ(и = 1, sql2.ВСЕГО)
          sql2.ПЕРЕЙТИ(и)
          фиоЕстьВБД[sql2.ПОЛЕ("FIO")] = sql2.ПОЛЕ("ID")
        КОНЕЦ_ЦИКЛА
        sql2.ЗАКРЫТЬ
        
        естьПривязка!"" = ДА
        sql2 = SQL_ОТКРЫТЬ(ф_СвязьВладУч)
        ЦИКЛ ДЛЯ(и = 1, sql2.ВСЕГО)
          sql2.ПЕРЕЙТИ(и)
          идУч = sql2.ПОЛЕ("ID_AREA")
          идВл = sql2.ПОЛЕ("ID_OWNER")
          естьПривязка!идУч!"_"!идВл = ДА
        КОНЕЦ_ЦИКЛА
        sql2.ЗАКРЫТЬ
        
        ид = IB_DBF_МаксЗначПоля(ф_СпрВладельцев, "ID") + 1 - 1 //почему -1
        ЦИКЛ ДЛЯ(и=1, sql.ВСЕГО)
          sql.ПЕРЕЙТИ(и)
          идУч = sql.ПОЛЕ("ID_AREA")
          ЕСЛИ НЕ СУЩ_ПЕРЕМ(фиоЕстьВБД[sql.ПОЛЕ("FIO")]) ТО
            ид++
            СП.ОЧИСТИТЬ
            СП.ДОБАВИТЬ("INSERT INTO '"+ф_СпрВладельцев+"'")
            СП.ДОБАВИТЬ("(ID, FIO, ROG, MESTO, PAS, ADDRESS, TEL, MOB1, MOB2, DATEIN, NOM_PROT, DATEOUT, COMM) VALUES") //, ID_AREA
            СП.ДОБАВИТЬ("("+СТР(ид)+",'"+sql.ПОЛЕ("FIO")+"','"+sql.ПОЛЕ("ROG")+"','"+sql.ПОЛЕ("MESTO")+"',") //,"+СТР(sql.ПОЛЕ("ID_AREA"))+"
            СП.ДОБАВИТЬ("'"+sql.ПОЛЕ("PAS")+"',")
            СП.ДОБАВИТЬ("'"+sql.ПОЛЕ("ADDRESS")+"',")
            СП.ДОБАВИТЬ("'"+sql.ПОЛЕ("TEL")+"','"+sql.ПОЛЕ("MOBILE")+"','','"+СТР(к_МинДата)+"','','"+СТР(к_МаксДата)+"','')")
            SQL_ЗАПРОС(СП)
          ИНАЧЕ
            ид = фиоЕстьВБД[sql.ПОЛЕ("FIO")]
          КОНЕЦ_ЕСЛИ
          
          ЕСЛИ НЕ СУЩ_ПЕРЕМ(естьПривязка!идУч!"_"!ид) ТО
            СП.ОЧИСТИТЬ
            СП.ДОБАВИТЬ("INSERT INTO '"+ф_СвязьВладУч+"'")
            СП.ДОБАВИТЬ("(ID_AREA, ID_OWNER, PART, CONSIDER, FIO, NOMSV, DATREGSV, DATOTCHSV) VALUES ("+СТР(sql.ПОЛЕ("ID_AREA"))+","+СТР(ид)+
                        "," + ?(типПоля = "С", "'1'", "1") + ",TRUE,")
            СП.ДОБАВИТЬ("'"+sql.ПОЛЕ("FIO")+"','"+sql.ПОЛЕ("NOMSV")+"','"+СТР(к_МинДата)+"','"+СТР(к_МаксДата)+"')")
            SQL_ЗАПРОС(СП)
          КОНЕЦ_ЕСЛИ
          
          //добавим текушего в справочник участков
          СП.ОЧИСТИТЬ
          СП.ДОБАВИТЬ("UPDATE '" + ф_СпрУчастковГаражей + "'")
          СП.ДОБАВИТЬ("SET ID_OWNER = " + СТР(ид) + ", FIO = '" + sql.ПОЛЕ("FIO") + "' WHERE ID_AREA = " + СТР(sql.ПОЛЕ("ID_AREA")))
          update = SQL_ЗАПРОС(СП)
          update.ЗАКРЫТЬ
        КОНЕЦ_ЦИКЛА
        sql.ЗАКРЫТЬ
      КОНЕЦ_ЕСЛИ
    КОНЕЦ_ЕСЛИ
  КОНЕЦ_ЕСЛИ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
//Функция задает метод распределения для общего счетчика ЭЭ
ФУНКЦИЯ ST_УстМетодРаспр
  СОЗДАТЬ(СП, ТИП_СПИСОК)
  СП.ДОБАВИТЬ("UPDATE '"+ф_СпрУчастковГаражей+"'")
  СП.ДОБАВИТЬ("SET METHOD_RAS = 'Равные суммы' WHERE METHOD_RAS = ''")
  sql = SQL_ЗАПРОС(СП)
  sql.ЗАКРЫТЬ
  СП.ОЧИСТИТЬ
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
//Конвертит признаки владельцев - рассчитывать и даты.
ФУНКЦИЯ ST_УстПризнакиСвязиВлад
  СОЗДАТЬ(СП, ТИП_СПИСОК)
  СП.ДОБАВИТЬ("UPDATE '" + ф_СвязьВладУч + "'")
  СП.ДОБАВИТЬ("SET CONSIDER = TRUE")
  sql = SQL_ЗАПРОС(СП)
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
//Создаст ФЛС и привяжет их к владельцам
ФУНКЦИЯ ST_ОбновитьДоВерсии249
  СОЗДАТЬ(СП, ТИП_СПИСОК)
  СП.ДОБАВИТЬ("SELECT * FROM")
  СП.ДОБАВИТЬ("'" + ф_СпрУчастковГаражей + "'")
  СП.ДОБАВИТЬ("WHERE FLS = ''")
  sql_test = SQL_ЗАПРОС(СП)
  ЕСЛИ sql_test.ВСЕГО > 0 ТО
    sql_test.ЗАКРЫТЬ
    //обновим количество флс там, где оно не указано
    СП.ОЧИСТИТЬ
    СП.ДОБАВИТЬ("UPDATE '" + ф_СпрУчастковГаражей + "'")
    СП.ДОБАВИТЬ("SET FLS = '1 л/с' WHERE FLS = ''")
    sql = SQL_ЗАПРОС(СП)
    //теперь надо прописать fls в справочник связи владельцев с участками для тех, кого ещё не привязали
    СП.ОЧИСТИТЬ
    СП.ДОБАВИТЬ("SELECT ID_AREA, N_AREA FROM")
    СП.ДОБАВИТЬ("'" + ф_СпрУчастковГаражей + "'")
    СП.ДОБАВИТЬ("WHERE ID_AREA NOT IN (SELECT DISTINCT ID_AREA FROM ")
    СП.ДОБАВИТЬ("'" + ф_СпрФЛС + "')")
    sql = SQL_ЗАПРОС(СП)
    ЦИКЛ ДЛЯ(и = 1, sql.ВСЕГО)
      sql.ПЕРЕЙТИ(и)
      СП.ОЧИСТИТЬ
      СП.ДОБАВИТЬ("UPDATE '" + ф_СвязьВладУч + "'")
      СП.ДОБАВИТЬ("SET FLS = '" + sql.ПОЛЕ("N_AREA") + "' WHERE ID_AREA = " + СТР(sql.ПОЛЕ("ID_AREA")) + " AND FLS = ''")
      sql1 = SQL_ЗАПРОС(СП)
      СП.ОЧИСТИТЬ
      СП.ДОБАВИТЬ("INSERT INTO")
      СП.ДОБАВИТЬ("'" + ф_СпрФЛС + "'")
      СП.ДОБАВИТЬ("(ID_AREA, FLS) VALUES (" + СТР(sql.ПОЛЕ("ID_AREA")) + ", '" + sql.ПОЛЕ("N_AREA") + "')")
      sql1 = SQL_ЗАПРОС(СП)
    КОНЕЦ_ЦИКЛА
    sql.ЗАКРЫТЬ
  ИНАЧЕ
    sql_test.ЗАКРЫТЬ
  КОНЕЦ_ЕСЛИ
  //Снесем временный файл 008
  IB_FILE_ФайлУдалить(ф_tmp008)
КОНЕЦ_ФУНКЦИИ

