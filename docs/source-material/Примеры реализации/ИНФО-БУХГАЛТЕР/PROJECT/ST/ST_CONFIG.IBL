  IB_DBF_УДАЛИТЬ_ПОЛЕ(ф_СпрУчастковГаражей, "ROG")
  IB_DBF_УДАЛИТЬ_ПОЛЕ(ф_СпрУчастковГаражей, "MESTO")
  IB_DBF_УДАЛИТЬ_ПОЛЕ(ф_СпрУчастковГаражей, "PAS")
  IB_DBF_УДАЛИТЬ_ПОЛЕ(ф_СпрУчастковГаражей, "TEL")
  IB_DBF_УДАЛИТЬ_ПОЛЕ(ф_СпрУчастковГаражей, "MOBILE")
  IB_DBF_УДАЛИТЬ_ПОЛЕ(ф_СпрУчастковГаражей, "NOMSV")
