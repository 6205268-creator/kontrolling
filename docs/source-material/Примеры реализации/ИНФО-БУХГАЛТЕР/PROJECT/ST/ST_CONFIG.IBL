//-------------------------------------------------------------------------------------------------------------------------//
//-------------------------------------------------------------------------------------------------------------------------//
ПЕРЕМ st_значенияФЛСПоИдУч!
ФУНКЦИЯ ST_ОбновитьПоляФЛС
  //создать флс для всех участков, где их нет
  sql_флс = SQL_ОТКРЫТЬ(ф_СпрФЛС)
  
  СОЗДАТЬ(сп, ТИП_СПИСОК)
  сп.ДОБАВИТЬ("SELECT * FROM")
  сп.ДОБАВИТЬ("'" + ф_СпрУчастковГаражей + "'")
  сп.ДОБАВИТЬ("WHERE ID_AREA NOT IN (SELECT ID_AREA FROM")
  сп.ДОБАВИТЬ("'" + ф_СпрФЛС + "')")
  sql = SQL_ЗАПРОС(сп)
  ЦИКЛ ДЛЯ(и = 1, sql.ВСЕГО)
    sql.ПЕРЕЙТИ(и)
    sql_флс.ЗАП_ПОЛЕ("ID_AREA", sql.ПОЛЕ("ID_AREA"))
    sql_флс.ЗАП_ПОЛЕ("FLS", sql.ПОЛЕ("N_AREA"))
    sql_флс.ДОБАВИТЬ
  КОНЕЦ_ЦИКЛА
  sql.ЗАКРЫТЬ
  
  ЦИКЛ ДЛЯ(и = 1, sql_флс.ВСЕГО)
    sql_флс.ПЕРЕЙТИ(и)
    идУч = sql_флс.ПОЛЕ("ID_AREA")
    st_значенияФЛСПоИдУч!идУч = sql_флс.ПОЛЕ("FLS")
  КОНЕЦ_ЦИКЛА
  sql_флс.ЗАКРЫТЬ
  
  ST_ОбновитьПолеФЛС(ф_СвязьВладУч)
  ST_ОбновитьПолеФЛС(ф_Журнал)
  ST_ОбновитьПолеФЛС(ф_ЖурналРасчетов)
  
  СБРОС(st_значенияФЛСПоИдУч)
КОНЕЦ_ФУНКЦИИ

//-------------------------------------------------------------------------------------------------------------------------//
ФУНКЦИЯ ST_ОбновитьПолеФЛС(ТИП_СТРОКА: файл)
  СОЗДАТЬ(сп, ТИП_СПИСОК)
  сп.ДОБАВИТЬ("SELECT DISTINCT ID_AREA FROM")
  сп.ДОБАВИТЬ("'" + файл + "'")
  сп.ДОБАВИТЬ("WHERE FLS = ''")
  sql = SQL_ЗАПРОС(сп)
  ЦИКЛ ДЛЯ(и = 1, sql.ВСЕГО)
    sql.ПЕРЕЙТИ(и)
    идУч = sql.ПОЛЕ("ID_AREA")
    ЕСЛИ СУЩ_ПЕРЕМ(st_значенияФЛСПоИдУч!идУч) ТО
      сп.ОЧИСТИТЬ
      сп.ДОБАВИТЬ("UPDATE")
      сп.ДОБАВИТЬ("'" + файл + "'")
      сп.ДОБАВИТЬ("SET FLS = '" + st_значенияФЛСПоИдУч!идУч + "' WHERE ID_AREA = '" + СТР(идУч) + "' AND FLS = ''")
      SQL_ЗАПРОС(сп)
    КОНЕЦ_ЕСЛИ
  КОНЕЦ_ЦИКЛА
  sql.ЗАКРЫТЬ
КОНЕЦ_ФУНКЦИИ

